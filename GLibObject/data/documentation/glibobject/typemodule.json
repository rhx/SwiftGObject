{"variants":[{"paths":["\/documentation\/glibobject\/typemodule"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject"]]},"relationshipsSections":[{"type":"inheritsFrom","kind":"relationships","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/Object"],"title":"Inherits From"},{"type":"conformsTo","kind":"relationships","identifiers":["doc:\/\/GLibObject\/4GLib14PointerWrapperP","doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectProtocol","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleProtocol","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol"],"title":"Conforms To"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"TypeModule","kind":"identifier"}]}]},{"content":[{"level":2,"anchor":"overview","text":"Overview","type":"heading"},{"inlineContent":[{"text":"The model of ","type":"text"},{"code":"GTypeModule","type":"codeVoice"},{"text":" is a dynamically loaded module which","type":"text"},{"type":"text","text":" "},{"type":"text","text":"implements some number of types and interface implementations."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"When the module is loaded, it registers its types and interfaces"},{"text":" ","type":"text"},{"type":"text","text":"using [method"},{"code":"GObject.TypeModule.register_type","type":"codeVoice"},{"text":"] and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GObject.TypeModule.add_interface"},{"type":"text","text":"]."},{"text":" ","type":"text"},{"text":"As long as any instances of these types and interface implementations","type":"text"},{"type":"text","text":" "},{"type":"text","text":"are in use, the module is kept loaded. When the types and interfaces"},{"type":"text","text":" "},{"text":"are gone, the module may be unloaded. If the types and interfaces","type":"text"},{"text":" ","type":"text"},{"text":"become used again, the module will be reloaded. Note that the last","type":"text"},{"type":"text","text":" "},{"type":"text","text":"reference cannot be released from within the module code, since that"},{"type":"text","text":" "},{"type":"text","text":"would lead to the caller’s code being unloaded before "},{"code":"g_object_unref()","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"returns to it."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Keeping track of whether the module should be loaded or not is done by"},{"type":"text","text":" "},{"text":"using a use count - it starts at zero, and whenever it is greater than","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"zero, the module is loaded. The use count is maintained internally by"},{"type":"text","text":" "},{"type":"text","text":"the type system, but also can be explicitly controlled by"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GObject.TypeModule.use"},{"type":"text","text":"] and [method"},{"code":"GObject.TypeModule.unuse","type":"codeVoice"},{"type":"text","text":"]."},{"text":" ","type":"text"},{"text":"Typically, when loading a module for the first type, ","type":"text"},{"type":"codeVoice","code":"g_type_module_use()"},{"type":"text","text":" "},{"text":"will be used to load it so that it can initialize its types. At some later","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"point, when the module no longer needs to be loaded except for the type"},{"text":" ","type":"text"},{"type":"text","text":"implementations it contains, "},{"type":"codeVoice","code":"g_type_module_unuse()"},{"type":"text","text":" is called."}]},{"type":"paragraph","inlineContent":[{"code":"GTypeModule","type":"codeVoice"},{"text":" does not actually provide any implementation of module","type":"text"},{"type":"text","text":" "},{"text":"loading and unloading. To create a particular module type you must","type":"text"},{"type":"text","text":" "},{"type":"text","text":"derive from "},{"type":"codeVoice","code":"GTypeModule"},{"type":"text","text":" and implement the load and unload functions"},{"type":"text","text":" "},{"type":"text","text":"in "},{"code":"GTypeModuleClass","type":"codeVoice"},{"type":"text","text":"."}]},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule","type":"reference","isActive":true},{"type":"text","text":" type acts as a reference-counted owner of an underlying "},{"type":"codeVoice","code":"GTypeModule"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"type":"text","text":"It provides the methods that can operate on this data type through "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleProtocol"},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule","type":"reference"},{"text":" as a strong reference or owner of a ","type":"text"},{"type":"codeVoice","code":"GTypeModule"},{"text":" instance.","type":"text"}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef","isActive":true},{"text":" (instead of ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule"},{"text":") for a lightweight Swift reference to an underlying ","type":"text"},{"code":"GTypeModule","type":"c