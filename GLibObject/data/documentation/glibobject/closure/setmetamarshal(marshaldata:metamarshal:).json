LibObject/Closure":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Closure","title":"Closure","type":"topic","navigatorTitle":[{"text":"Closure","kind":"identifier"}],"abstract":[{"type":"text","text":"A "},{"code":"GClosure","type":"codeVoice"},{"type":"text","text":" represents a callback supplied by the programmer."}],"kind":"symbol","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"Closure","kind":"identifier"}],"role":"symbol","url":"\/documentation\/glibobject\/closure"}}}