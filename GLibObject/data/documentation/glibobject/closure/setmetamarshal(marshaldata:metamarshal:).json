{"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/closure\/setmetamarshal(marshaldata:metamarshal:)"]}],"metadata":{"externalID":"s:10GLibObject15ClosureProtocolPAAE14setMetaMarshal11marshalData04metaG0ySvSg_ySpySo9_GClosureVGSg_SpySo7_GValueVGSgs6UInt32VSPyAMGSgA2GtXCSgtF::SYNTHESIZED::s:10GLibObject7ClosureC","title":"setMetaMarshal(marshalData:metaMarshal:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"setMetaMarshal","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"marshalData"},{"text":": ","kind":"text"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"metaMarshal"},{"kind":"text","text":": "},{"preciseIdentifier":"c:gclosure.h@T@GClosureMarshal","kind":"typeIdentifier","text":"GClosureMarshal"},{"text":"!)","kind":"text"}],"roleHeading":"Instance Method","symbolKind":"method","modules":[{"name":"GLibObject"}],"extendedModule":"GLibObject","role":"symbol"},"abstract":[{"type":"text","text":"Sets the meta marshaller of "},{"type":"codeVoice","code":"closure"},{"type":"text","text":"."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"setMetaMarshal","kind":"identifier"},{"text":"(","kind":"text"},{"text":"marshalData","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier"},{"text":"? = nil, ","kind":"text"},{"text":"metaMarshal","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"c:gclosure.h@T@GClosureMarshal","kind":"typeIdentifier","text":"GClosureMarshal"},{"kind":"text","text":"! = nil)"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"A meta marshaller wraps the "},{"type":"codeVoice","code":"closure"},{"type":"text","text":"’s marshal and modifies the way"},{"type":"text","text":" "},{"text":"it is called in some fashion. The most common use of this facility","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is for C callbacks."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The same marshallers (generated by ","type":"text"},{"identifier":"#glib-genmarshal","type":"reference","isActive":true},{"text":"),","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"are used everywhere, but the way that we get the callback function"},{"text":" ","type":"text"},{"type":"text","text":"differs. In most cases we want to use the "},{"type":"codeVoice","code":"closure"},{"text":"’s callback, but in","type":"text"},{"text":" ","type":"text"},{"text":"other cases we want to use some different technique to retrieve the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"callback function."}]},{"inlineContent":[{"type":"text","text":"For example, class closures for signals (see"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_signal_type_cclosure_new()"},{"text":") retrieve the callback function from a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"fixed offset in the class structure.  The meta marshaller retrieves"},{"type":"text","text":" "},{"text":"the right callback and passes it to the marshaller as the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"marshalData"},{"type":"text","text":" argument."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/Closure","doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/ClosureProtocol-Implementations"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLibObject\