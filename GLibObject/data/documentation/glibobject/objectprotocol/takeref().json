{"metadata":{"extendedModule":"GLibObject","roleHeading":"Instance Method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"takeRef","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"ObjectRef","preciseIdentifier":"s:10GLibObject0B3RefV","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"title":"takeRef()","symbolKind":"method","modules":[{"name":"GLibObject"}],"role":"symbol","externalID":"s:10GLibObject0B8ProtocolPAAE7takeRefAA0bE0VSgyF"},"kind":"symbol","abstract":[{"text":"If ","type":"text"},{"code":"object","type":"codeVoice"},{"type":"text","text":" is floating, sink it.  Otherwise, do nothing."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"takeRef"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef","text":"ObjectRef","preciseIdentifier":"s:10GLibObject0B3RefV"},{"kind":"text","text":"!"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In other words, this function will convert a floating reference (if"},{"text":" ","type":"text"},{"text":"present) into a full reference.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Typically you want to use "},{"code":"g_object_ref_sink()","type":"codeVoice"},{"text":" in order to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"automatically do the correct thing with respect to floating or"},{"text":" ","type":"text"},{"text":"non-floating references, but there is one specific scenario where","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this function is helpful."}]},{"inlineContent":[{"text":"The situation where this function is helpful is when creating an API","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"that allows the user to provide a callback function that returns a"},{"text":" ","type":"text"},{"type":"text","text":"GObject. We certainly want to allow the user the flexibility to"},{"text":" ","type":"text"},{"text":"return a non-floating reference from this callback (for the case","type":"text"},{"type":"text","text":" "},{"type":"text","text":"where the object that is being returned already exists)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"At the same time, the API style of some popular GObject-based"},{"text":" ","type":"text"},{"type":"text","text":"libraries (such as Gtk) make it likely that for newly-created GObject"},{"type":"text","text":" "},{"type":"text","text":"instances, the user can be saved some typing if they are allowed to"},{"type":"text","text":" "},{"type":"text","text":"return a floating reference."}]},{"inlineContent":[{"type":"text","text":"Using this function on the return value of the user’s callback allows"},{"type":"text","text":" "},{"text":"the user to do whichever is more convenient for them. The caller will","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"alway receives exactly one full reference to the value: either the"},{"type":"text","text":" "},{"type":"text","text":"one that was returned in the first place, or a floating reference"},{"type":"text","text":" "},{"type":"text","text":"that has been converted to a full reference."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This function has an odd interaction when combined with","type":"text"},{"type":"text","text":" "},{"code":"g_object_ref_sink()","type":"codeVoice"},{"type":"text","text":" running at the same time in another thread on"},{"text":" ","type":"text"},{"type":"text","text":"the same "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","isActive":true},{"type":"text","text":" instance. If "},{"type":"codeVoice","code":"g_object_ref_sink()"},{"type":"text","text":" runs first then"},{"type":"text","text":" "},{"text":"the result will be that the floating reference is converted to a hard","type":"text"},{"text":" ","type":"text"},{"text":"reference. If ","type":"text"},{"type":"codeVoice","code":"g_object_take_ref()"},{"type":"text","text":" runs first then the result will be"},{"type":"text","text":" "},{"text":"that the floating reference is converted to a hard reference and an","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"additional reference on top of that one is added. It is best to avoid"},{"type":"text","text":" "},{"text":"this situation.","type":"text"}]}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectProtocol\/takeRef()"},"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectProtocol"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/objectprotocol\/takeref()"]}],"references":{"doc://GLibObject/documentation/GLibObject/Object":{"role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Object"}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","navigatorTitle":[{"text":"Object","kind":"identifier"}],"kind":"symbol","type":"topic","title":"Object","url":"\/documentation\/glibobject\/object","abstract":[{"text":"The base object type.","type":"text"}]},"doc://GLibObject/documentation/GLibObject/ObjectProtocol/takeRef()":{"url":"\/documentation\/glibobject\/objectprotocol\/takeref()","kind":"symbol","role":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectProtocol\/takeRef()","abstract":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"object"},{"type":"text","text":" is floating, sink it.  Otherwise, do nothing."}],"title":"takeRef()","type":"topic","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"takeRef","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"ObjectRef","preciseIdentifier":"s:10GLibObject0B3RefV","kind":"typeIdentifier"},{"kind":"text","text":"!"}]},"doc://GLibObject/documentation/GLibObject/ObjectProtocol":{"type":"topic","role":"symbol","navigatorTitle":[{"text":"ObjectProtocol","kind":"identifier"}],"url":"\/documentation\/glibobject\/objectprotocol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ObjectProtocol"}],"abstract":[{"type":"text","text":"The base object type."}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectProtocol","title":"ObjectProtocol","kind":"symbol"},"doc://GLibObject/documentation/GLibObject":{"abstract":[],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","title":"GLibObject","role":"collection","kind":"symbol","type":"topic","url":"\/documentation\/glibobject"},"doc://GLibObject/documentation/GLibObject/ObjectRef":{"role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"ObjectRef","kind":"identifier"}],"title":"ObjectRef","url":"\/documentation\/glibobject\/objectref","abstract":[{"type":"text","text":"The base object type."}],"type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef","navigatorTitle":[{"text":"ObjectRef","kind":"identifier"}],"kind":"symbol"}}}