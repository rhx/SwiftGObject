{"variants":[{"paths":["\/documentation\/glibobject\/objectprotocol\/refsink()"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"Increase the reference count of "},{"type":"codeVoice","code":"object"},{"type":"text","text":", and possibly remove the"},{"type":"text","text":" "},{"identifier":"#floating-ref","type":"reference","isActive":true},{"type":"text","text":" reference, if "},{"code":"object","type":"codeVoice"},{"type":"text","text":" has a floating reference."}],"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectProtocol\/refSink()"},"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectProtocol"]]},"sections":[],"metadata":{"role":"symbol","externalID":"s:10GLibObject0B8ProtocolPAAE7refSinkAA0B3RefVSgyF","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"refSink","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"ObjectRef","preciseIdentifier":"s:10GLibObject0B3RefV","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"roleHeading":"Instance Method","modules":[{"name":"GLibObject"}],"extendedModule":"GLibObject","title":"refSink()","symbolKind":"method"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"attribute","text":"@discardableResult"},{"kind":"text","text":" "},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"refSink","kind":"identifier"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:10GLibObject0B3RefV","kind":"typeIdentifier","text":"ObjectRef","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef"},{"text":"!","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"text":"In other words