ifier":"s:10GLibObject10BindingRefV"},{"text":"! ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ObjectT","kind":"typeIdentifier"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:10GLibObject0B8ProtocolP","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectProtocol","text":"ObjectProtocol","kind":"typeIdentifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Whenever the "},{"type":"codeVoice","code":"sourceProperty"},{"type":"text","text":" is changed the "},{"type":"codeVoice","code":"targetProperty"},{"type":"text","text":" is"},{"type":"text","text":" "},{"type":"text","text":"updated using the same value. For instance:"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"type":"codeListing","code":["  g_object_bind_property (action, \"active\", widget, \"sensitive\", 0);"],"syntax":"C"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Will result in the “sensitive” property of the widget "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","isActive":true},{"text":" instance to be","type":"text"},{"type":"text","text":" "},{"text":"updated with the same value of the “active” property of the action ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object"},{"text":" ","type":"text"},{"text":"instance.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"flags","type":"codeVoice"},{"text":" contains ","type":"text"},{"type":"codeVoice","code":"bidirectional"},{"text":" then the binding will be mutual:","type":"text"},{"type":"text","text":" "},{"text":"if ","type":"text"},{"code":"targetProperty","type":"codeVoice"},{"text":" on ","ty