inalized from different threads. Keep another reference to the binding and","type":"text"},{"type":"text","text":" "},{"text":"use ","type":"text"},{"type":"codeVoice","code":"g_binding_unbind()"},{"type":"text","text":" instead to be on the safe side."}],"type":"paragraph"},{"inlineContent":[{"text":"A ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","type":"reference"},{"text":" can have multiple bindings.","type":"text"}],"type":"paragraph"}]}],"metadata":{"symbolKind":"method","modules":[{"name":"GLibObject"}],"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"bindProperty","kind":"identifier"},{"text":"<","kind":"text"},{"text":"ObjectT","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"sourceProperty","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"target"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"ObjectT"},{"text":", ","kind":"text"},{"text":"targetProperty","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">!, ","kind":"text"},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12BindingFlagsV","text":"BindingFlags"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:10GLibObject10BindingRefV","text":"BindingRef","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"title":"bindProperty(sourceProperty:target:targetProperty:flags:)","extendedModule":"GLibObject","roleHeading":"Instance Method","externalID":"s:10GLibObject0B8ProtocolPAAE12bin