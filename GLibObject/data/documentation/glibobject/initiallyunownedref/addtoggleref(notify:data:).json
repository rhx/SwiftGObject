{"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef","doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef\/ObjectProtocol-Implementations"]]},"metadata":{"externalID":"s:10GLibObject0B8ProtocolPAAE12addToggleRef6notify4datayySvSg_SpySo8_GObjectVGSgs5Int32VtXCSg_AGtF::SYNTHESIZED::s:10GLibObject19InitiallyUnownedRefV","roleHeading":"Instance Method","modules":[{"name":"GLibObject"}],"title":"addToggleRef(notify:data:)","symbolKind":"method","role":"symbol","extendedModule":"GLibObject","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"addToggleRef","kind":"identifier"},{"text":"(","kind":"text"},{"text":"notify","kind":"externalParam"},{"kind":"text","text":": "},{"text":"GToggleNotify","kind":"typeIdentifier","preciseIdentifier":"c:gobject.h@T@GToggleNotify"},{"text":"?, ","kind":"text"},{"text":"data","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"text":"?)","kind":"text"}]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef\/addToggleRef(notify:data:)"},"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/glibobject\/initiallyunownedref\/addtoggleref(notify:data:)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"addToggleRef","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"notify"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gobject.h@T@GToggleNotify","text":"GToggleNotify","kind":"typeIdentifier"},{"kind":"text","text":"?, "},{"text":"data","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer"},{"kind":"text","text":"? = nil)"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"inlineContent":[{"text":"This functionality is intended for binding ","type":"text"},{"type":"codeVoice","code":"object"},{"type":"text","text":" to a proxy"},{"text":" ","type":"text"},{"type":"text","text":"object managed by another memory manager. This is done with two"},{"type":"text","text":" "},{"text":"paired references: the strong reference added by","type":"text"},{"text":" ","type":"text"},{"code":"g_object_add_toggle_ref()","type":"codeVoice"},{"text":" and a reverse reference to the proxy","type":"text"},{"type":"text","text":" "},{"text":"object which is either a strong reference or weak reference.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The setup is that when there are no other references to ","type":"text"},{"type":"codeVoice","code":"object"},{"text":",","type":"text"},{"type":"text","text":" "},{"type":"text","text":"only a weak reference is held in the reverse direction from "},{"type":"codeVoice","code":"object"},{"text":" ","type":"text"},{"text":"to the proxy object, but when there are other references held to","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"object"},{"text":", a strong reference is held. The ","type":"text"},{"code":"notify","type":"codeVoice"},{"text":" callback is called","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"when the reference from "},{"code":"object","type":"codeVoice"},{"text":" to the proxy object should be","type":"text"},{"type":"text","text":" "},{"text":"“toggled” from strong to weak (","type":"text"},{"type":"codeVoice","code":"is_last_ref"},{"type":"text","text":" true) or weak to strong"},{"type":"text","text":" "},{"text":"(","type":"text"},{"type":"codeVoice","code":"is_last_ref"},{"type":"text","text":" false)."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Since a (normal) reference must be held to the object before"},{"text":" ","type":"text"},{"type":"text","text":"calling "},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"text":", the initial state of the reverse","type":"text"},{"type":"text","text":" "},{"text":"link is always strong.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Multiple toggle references may be added to the same gobject,"},{"text":" ","type":"text"},{"text":"however if there are multiple toggle references to an object, none","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of them will ever be notified until all but one are removed.  For"},{"text":" ","type":"text"},{"text":"this reason, you should only ever use a toggle reference if there","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is important state in the proxy object."}]},{"inlineContent":[{"text":"Note that if you unref the object on another thread, then ","type":"text"},{"type":"codeVoice","code":"notify"},{"text":" might","type":"text"},{"type":"text","text":" "},{"type":"text","text":"still be invoked after "},{"type":"codeVoice","code":"g_object_remove_toggle_ref()"},{"type":"text","text":", and the object argument"},{"text":" ","type":"text"},{"type":"text","text":"might be a dangling pointer. If the object is destroyed on other threads,"},{"type":"text","text":" "},{"text":"you must take care of that yourself.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"type":"text","text":" must be released with "},{"code":"g_object_remove_toggle_ref()","type":"codeVoice"},{"text":".","type":"text"}]}]}],"sections":[],"abstract":[{"type":"text","text":"Increases the reference count of the object by one and sets a"},{"text":" ","type":"text"},{"text":"callback to be called when all other references to the object are","type":"text"},{"type":"text","text":" "},{"type":"text","text":"dropped, or when this is already the last reference to the object"},{"text":" ","type":"text"},{"type":"text","text":"and another reference is established."}],"references":{"doc://GLibObject/documentation/GLibObject/InitiallyUnownedRef/addToggleRef(notify:data:)":{"url":"\/documentation\/glibobject\/initiallyunownedref\/addtoggleref(notify:data:)","abstract":[{"type":"text","text":"Increases the reference count of the object by one and sets a"},{"type":"text","text":" "},{"text":"callback to be called when all other references to the object are","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"dropped, or when this is already the last reference to the object"},{"type":"text","text":" "},{"type":"text","text":"and another reference is established."}],"kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef\/addToggleRef(notify:data:)","type":"topic","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"addToggleRef","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"notify"},{"text":": ","kind":"text"},{"text":"GToggleNotify","preciseIdentifier":"c:gobject.h@T@GToggleNotify","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"text":"data","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier"},{"text":"?)","kind":"text"}],"role":"symbol","title":"addToggleRef(notify:data:)"},"doc://GLibObject/documentation/GLibObject":{"abstract":[],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","title":"GLibObject","role":"collection","kind":"symbol","type":"topic","url":"\/documentation\/glibobject"},"doc://GLibObject/documentation/GLibObject/InitiallyUnownedRef/ObjectProtocol-Implementations":{"abstract":[],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef\/ObjectProtocol-Implementations","title":"ObjectProtocol Implementations","role":"collectionGroup","kind":"article","url":"\/documentation\/glibobject\/initiallyunownedref\/objectprotocol-implementations","type":"topic"},"doc://GLibObject/documentation/GLibObject/InitiallyUnownedRef":{"abstract":[{"text":"A type for objects that have an initially floating reference.","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"InitiallyUnownedRef"}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef","title":"InitiallyUnownedRef","role":"symbol","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"InitiallyUnownedRef"}],"url":"\/documentation\/glibobject\/initiallyunownedref","type":"topic"}}}