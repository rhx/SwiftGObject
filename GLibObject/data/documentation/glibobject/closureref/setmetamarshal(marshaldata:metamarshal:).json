:"text"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"text":"? = nil, ","kind":"text"},{"text":"metaMarshal","kind":"externalParam"},{"kind":"text","text":": "},{"text":"GClosureMarshal","preciseIdentifier":"c:gclosure.h@T@GClosureMarshal","kind":"typeIdentifier"},{"text":"! = nil)","kind":"text"}]}]},{"content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"A meta marshaller wraps the ","type":"text"},{"type":"codeVoice","code":"closure"},{"type":"text","text":"’s marshal and modifies the way"},{"text":" ","type":"text"},{"text":"it is called in some fashion. The most common use of this facility","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is for C callbacks."}]},{"inlineContent":[{"type":"text","text":"The same marshallers (generated by "},{"identifier":"#glib-genmarshal","isActive":true,"type":"reference"},{"text":"),","type":"text"},{"type":"text","text":" "},{"text":"are used everywhere, but the way that we get the callback function","type":"text"},{"type":"text","text":" "},{"text":"differs. In most cases we want to use the ","type":"text"},{"code":"closure","type":"codeVoice"},{"type":"text","text":"’s callback, but in"},{"type":"text","text":" "},{"text":"other cases we want to use some different technique to retrieve the","type":"text"},{"type":"text","text":" "},{"text":"callback function.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"For example, class closures for signals (see","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_signal_type_cclosure_new()"},{"text":") retrieve the callback function from a","type":"text"},{"text":" ","type":"text"},{"text":"fixed offset in the class structure.  The meta marshaller retrieves","type":"text"},{"text":" ","type":"text"},{"text":"the right callback and passes it to the marshaller as the","type":"text"},{"type":"text","text":" "},{"code":"marshalData","type":"codeVoice"},{"type":"text","text":" argument."}]}],"kind":"content"}],"references":{"doc://GLibObject/documentation/GLibObject/ClosureRef/ClosureProtocol-Implementations":{"abstract":[],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/ClosureProtocol-Implementations","title":"ClosureProtocol Implementations","role":"collectionGroup","kind":"article","type":"topic","url":"\/documentation\/glibobject\/closureref\/closureprotocol-implementations"},"doc://GLibObject/documentation/GLibObject":{"abstract":[],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","title":"GLibObject","role":"collection","kind":"symbol","type":"topic","url":"\/documentation\/glibobject"},"#glib-genmarshal":{"type":"link","title":"glib-genmarshal","url":"#glib-genmarshal","titleInlineContent":[{"text":"glib-genmarshal","type":"text"}],"identifier":"#glib-genmarshal"},"doc://GLibObject/documentation/GLibObject/ClosureRef":{"role":"symbol","abstract":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"GClosure"},{"type":"text","text":" represents a callback supplied by the programmer."}],"url":"\/documentation\/glibobject\/closureref","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ClosureRef","kind":"identifier"}],"type":"topic","title":"ClosureRef","navigatorTitle":[{"kind":"identifier","text":"ClosureRef"}],"kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef"},"doc://GLibObject/documentation/GLibObject/ClosureRef/setMetaMarshal(marshalData:metaMarshal:)":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/setMetaMarshal(marshalData:metaMarshal:)","title":"setMetaMarshal(marshalData:metaMarshal:)","type":"topic","url":"\/documentation\/glibobject\/closureref\/setmetamarshal(marshaldata:metamarshal:)","abstract":[{"type":"text","text":"Sets the meta marshaller of "},{"code":"closure","type":"codeVoice"},{"type":"text","text":"