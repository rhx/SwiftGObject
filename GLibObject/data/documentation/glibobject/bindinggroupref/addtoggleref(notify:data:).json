{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/bindinggroupref\/addtoggleref(notify:data:)"]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"type":"text","text":"Increases the reference count of the object by one and sets a"},{"type":"text","text":" "},{"text":"callback to be called when all other references to the object are","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"dropped, or when this is already the last reference to the object"},{"type":"text","text":" "},{"text":"and another reference is established.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingGroupRef\/addToggleRef(notify:data:)"},"kind":"symbol","metadata":{"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"addToggleRef"},{"text":"(","kind":"text"},{"text":"notify","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gobject.h@T@GToggleNotify","text":"GToggleNotify","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"data"},{"kind":"text","text":": "},{"preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"kind":"text","text":"?)"}],"title":"addToggleRef(notify:data:)","modules":[{"name":"GLibObject"}],"externalID":"s:10GLibObject0B8ProtocolPAAE12addToggleRef6notify4datayySvSg_SpySo8_GObjectVGSgs5Int32VtXCSg_AGtF::SYNTHESIZED::s:10GLibObject15BindingGroupRefV","role":"symbol","extendedModule":"GLibObject","roleHeading":"Instance Method","symbolKind":"method"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"addToggleRef","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"notify"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:gobject.h@T@GToggleNotify","text":"GToggleNotify"},{"text":"?, ","kind":"text"},{"text":"data","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"kind":"text","text":"? = nil)"}]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"inlineContent":[{"type":"text","text":"This functionality is intended for binding "},{"type":"codeVoice","code":"object"},{"type":"text","text":" to a proxy"},{"type":"text","text":" "},{"text":"object managed by another memory manager. This is done with two","type":"text"},{"type":"text","text":" "},{"type":"text","text":"paired references: the strong reference added by"},{"text":" ","type":"text"},{"code":"g_object_add_toggle_ref()","type":"codeVoice"},{"type":"text","text":" and a reverse reference to the proxy"},{"text":" ","type":"text"},{"type":"text","text":"object which is either a strong reference or weak reference."}],"type":"paragraph"},{"inlineContent":[{"text":"The setup is that when there are no other references to ","type":"text"},{"code":"object","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"text":"only a weak reference is held in the reverse direction from ","type":"text"},{"code":"object","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"to the proxy object, but when there are other references held to"},{"text":" ","type":"text"},{"type":"codeVoice","code":"object"},{"type":"text","text":", a strong reference is held. The "},{"type":"codeVoice","code":"notify"},{"text":" callback is called","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"when the reference from "},{"code":"object","type":"codeVoice"},{"type":"text","text":" to the proxy object should be"},{"type":"text","text":" "},{"type":"text","text":"“toggled” from strong to weak ("},{"type":"codeVoice","code":"is_last_ref"},{"text":" true) or weak to strong","type":"text"},{"type":"text","text":" "},{"type":"text","text":"("},{"type":"codeVoice","code":"is_last_ref"},{"type":"text","text":" false)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Since a (normal) reference must be held to the object before","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"calling "},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"type":"text","text":", the initial state of the reverse"},{"type":"text","text":" "},{"text":"link is always strong.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Multiple toggle references may be added to the same gobject,","type":"text"},{"type":"text","text":" "},{"text":"however if there are multiple toggle references to an object, none","type":"text"},{"type":"text","text":" "},{"text":"of them will ever be notified until all but one are removed.  For","type":"text"},{"type":"text","text":" "},{"text":"this reason, you should only ever use a toggle reference if there","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is important state in the proxy object."}]},{"inlineContent":[{"text":"Note that if you unref the object on another thread, then ","type":"text"},{"type":"codeVoice","code":"notify"},{"type":"text","text":" might"},{"text":" ","type":"text"},{"text":"still be invoked after ","type":"text"},{"type":"codeVoice","code":"g_object_remove_toggle_ref()"},{"type":"text","text":", and the object argument"},{"type":"text","text":" "},{"text":"might be a dangling pointer. If the object is destroyed on other threads,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"you must take care of that yourself."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"code":"g_object_add_toggle_ref()","type":"codeVoice"},{"type":"text","text":" must be released with "},{"type":"codeVoice","code":"g_object_remove_toggle_ref()"},{"text":".","type":"text"}]}]}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingGroupRef","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingGroupRef\/ObjectProtocol-Implementations"]]},"sections":[],"references":{"doc://GLibObject/documentation/GLibObject/BindingGroupRef/addToggleRef(notify:data:)":{"kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingGroupRef\/addToggleRef(notify:data:)","abstract":[{"type":"text","text":"Increases the reference count of the object by one and sets a"},{"type":"text","text":" "},{"type":"text","text":"callback to be called when all other references to the object are"},{"text":" ","type":"text"},{"type":"text","text":"dropped, or when this is already the last reference to the object"},{"text":" ","type":"text"},{"type":"text","text":"and another reference is established."}],"type":"topic","role":"symbol","title":"addToggleRef(notify:data:)","url":"\/documentation\/glibobject\/bindinggroupref\/addtoggleref(notify:data:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"addToggleRef"},{"kind":"text","text":"("},{"text":"notify","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"GToggleNotify","preciseIdentifier":"c:gobject.h@T@GToggleNotify","kind":"typeIdentifier"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"data"},{"kind":"text","text":": "},{"preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"kind":"text","text":"?)"}]},"doc://GLibObject/documentation/GLibObject/BindingGroupRef":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingGroupRef","title":"BindingGroupRef","abstract":[{"type":"codeVoice","code":"GBindingGroup"},{"type":"text","text":" can be used to bind multiple properties"},{"type":"text","text":" "},{"text":"from an object collectively.","type":"text"}],"kind":"symbol","role":"symbol","url":"\/documentation\/glibobject\/bindinggroupref","navigatorTitle":[{"text":"BindingGroupRef","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"BindingGroupRef","kind":"identifier"}],"type":"topic"},"doc://GLibObject/documentation/GLibObject":{"abstract":[],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","title":"GLibObject","role":"collection","kind":"symbol","type":"topic","url":"\/documentation\/glibobject"},"doc://GLibObject/documentation/GLibObject/BindingGroupRef/ObjectProtocol-Implementations":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingGroupRef\/ObjectProtocol-Implementations","abstract":[],"kind":"article","title":"ObjectProtocol Implementations","role":"collectionGroup","type":"topic","url":"\/documentation\/glibobject\/bindinggroupref\/objectprotocol-implementations"}}}