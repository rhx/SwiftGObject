{"metadata":{"modules":[{"name":"GLibObject"}],"roleHeading":"Instance Method","symbolKind":"method","extendedModule":"GLibObject","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"takeRef","kind":"identifier"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:10GLibObject0B3RefV","text":"ObjectRef","kind":"typeIdentifier"},{"kind":"text","text":"!"}],"title":"takeRef()","externalID":"s:10GLibObject0B8ProtocolPAAE7takeRefAA0bE0VSgyF::SYNTHESIZED::s:10GLibObject15BindingGroupRefV","role":"symbol"},"abstract":[{"type":"text","text":"If "},{"type":"codeVoice","code":"object"},{"type":"text","text":" is floating, sink it.  Otherwise, do nothing."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/bindinggroupref\/takeref()"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"takeRef","kind":"identifier"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:10GLibObject0B3RefV","text":"ObjectRef","kind":"typeIdentifier","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef"},{"text":"!","kind":"text"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"In other words, this function will convert a floating reference (if","type":"text"},{"type":"text","text":" "},{"type":"text","text":"present) into a full reference."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Typically you want to use "},{"type":"codeVoice","code":"g_object_ref_sink()"},{"text":" in order to","type":"text"},{"text":" ","type":"text"},{"text":"automatically do the correct thing with respect to floating or","type":"text"},{"text":" ","type":"text"},{"text":"non-floating references, but there is one specific scenario where","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this function is helpful."}]},{"inlineContent":[{"type":"text","text":"The situation where this function is helpful is when creating an API"},{"type":"text","text":" "},{"text":"that allows the user to provide a callback function that returns a","type":"text"},{"type":"text","text":" "},{"text":"GObject. We certainly want to allow the user the flexibility to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"return a non-floating reference from this callback (for the case"},{"type":"text","text":" "},{"text":"where the object that is being returned already exists).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"At the same time, the API style of some popular GObject-based"},{"type":"text","text":" "},{"text":"libraries (such as Gtk) make it likely that for newly-created GObject","type":"text"},{"type":"text","text":" "},{"type":"text","text":"instances, the user can be saved some typing if they are allowed to"},{"text":" ","type":"text"},{"type":"text","text":"return a floating reference."}]},{"type":"paragraph","inlineContent":[{"text":"Using this function on the return value of the user’s callback allows","type":"text"},{"type":"text","text":" "},{"text":"the user to do whichever is more convenient for them. The caller will","type":"text"},{"text":" ","type":"text"},{"text":"alway receives exactly one full reference to the value: either the","type":"text"},{"type":"text","text":" "},{"text":"one that was returned in the first place, or a floating reference","type":"text"},{"text":" ","type":"text"},{"text":"that has been converted to a full reference.","type":"text"}]},{"inlineContent":[{"text":"This function has an odd interaction when combined with","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_object_ref_sink()"},{"type":"text","text":" running at the same time in another thread on"},{"type":"text","text":" "},{"type":"text","text":"the same "},{"isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","type":"reference"},{"type":"text","text":" instance. If "},{"type":"codeVoice","code":"g_object_ref_sink()"},{"text":" runs first then","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the result will be that the floating reference is converted to a hard"},{"type":"text","text":" "},{"type":"text","text":"reference. If "},{"code":"g_object_take_ref()","type":"codeVoice"},{"type":"text","text":" runs first then the result will be"},{"type":"text","text":" "},{"text":"that the floating reference is converted to a hard reference and an","type":"text"},{"type":"text","text":" "},{"text":"additional reference on top of that one is added. It is best to avoid","type":"text"},{"text":" ","type":"text"},{"text":"this situation.","type":"text"}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingGroupRef","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingGroupRef\/ObjectProtocol-Implementations"]]},"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingGroupRef\/takeRef()"},"sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"references":{"doc://GLibObject/documentation/GLibObject/BindingGroupRef":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingGroupRef","title":"BindingGroupRef","abstract":[{"type":"codeVoice","code":"GBindingGroup"},{"type":"text","text":" can be used to bind multiple properties"},{"type":"text","text":" "},{"text":"from an object collectively.","type":"text"}],"kind":"symbol","role":"symbol","url":"\/documentation\/glibobject\/bindinggroupref","navigatorTitle":[{"text":"BindingGroupRef","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"BindingGroupRef","kind":"identifier"}],"type":"topic"},"doc://GLibObject/documentation/GLibObject/BindingGroupRef/ObjectProtocol-Implementations":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingGroupRef\/ObjectProtocol-Implementations","abstract":[],"kind":"article","title":"ObjectProtocol Implementations","role":"collectionGroup","type":"topic","url":"\/documentation\/glibobject\/bindinggroupref\/objectprotocol-implementations"},"doc://GLibObject/documentation/GLibObject/BindingGroupRef/takeRef()":{"abstract":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"object"},{"text":" is floating, sink it.  Otherwise, do nothing.","type":"text"}],"role":"symbol","kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingGroupRef\/takeRef()","title":"takeRef()","url":"\/documentation\/glibobject\/bindinggroupref\/takeref()","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"takeRef","kind":"identifier"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:10GLibObject0B3RefV","kind":"typeIdentifier","text":"ObjectRef"},{"text":"!","kind":"text"}],"type":"topic"},"doc://GLibObject/documentation/GLibObject/Object":{"role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Object"}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","navigatorTitle":[{"text":"Object","kind":"identifier"}],"kind":"symbol","type":"topic","title":"Object","url":"\/documentation\/glibobject\/object","abstract":[{"text":"The base object type.","type":"text"}]},"doc://GLibObject/documentation/GLibObject":{"abstract":[],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","title":"GLibObject","role":"collection","kind":"symbol","type":"topic","url":"\/documentation\/glibobject"},"doc://GLibObject/documentation/GLibObject/ObjectRef":{"role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"ObjectRef","kind":"identifier"}],"title":"ObjectRef","url":"\/documentation\/glibobject\/objectref","abstract":[{"type":"text","text":"The base object type."}],"type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef","navigatorTitle":[{"text":"ObjectRef","kind":"identifier"}],"kind":"symbol"}}}