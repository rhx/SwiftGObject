odeVoice","code":"sourceProperty"},{"text":" is changed the ","type":"text"},{"type":"codeVoice","code":"targetProperty"},{"text":" is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"updated using the same value. For instance:"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"syntax":"C","type":"codeListing","code":["  g_object_bind_property (action, \"active\", widget, \"sensitive\", 0);"]},{"type":"paragraph","inlineContent":[{"text":"Will result in the “sensitive” property of the widget ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object"},{"type":"text","text":" instance to be"},{"type":"text","text":" "},{"type":"text","text":"updated with the same value of the “active” property of the action "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"instance.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"flags"},{"type":"text","text":" contains "},{"code":"bidirectional","type":"codeVoice"},{"type":"text","text":" then the binding will be mutual:"},{"type":"text","text":" "},{"text":"if ","type":"text"},{"code":"targetProperty","type":"codeVoice"},{"type":"text","text":" on "},{"code":"target","type":"codeVoice"},{"type":"text","text":" changes then the "},{"code":"sourceProperty","type":"codeVoice"},{"text":" on ","type":"text"},{"type":"codeVoice","code":"source"},{"type":"text","text":" "},{"text":"will be updated as well.","type":"text"}]},{"inlineContent":[{"type":"text","text":"The binding will automatically be removed when either the "},{"type":"codeVoice","code":"source"},{"type":"text","text":" or the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"target"},{"type":"text","text":" instances are finalized. To remove the binding without affecting the