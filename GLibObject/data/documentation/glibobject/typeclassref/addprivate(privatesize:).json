{"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"symbolKind":"method","modules":[{"name":"GLibObject"}],"role":"symbol","title":"addPrivate(privateSize:)","platforms":[],"externalID":"s:10GLibObject17TypeClassProtocolPAAE10addPrivate11privateSizeySi_tF::SYNTHESIZED::s:10GLibObject12TypeClassRefV","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"addPrivate","kind":"identifier"},{"kind":"text","text":"("},{"text":"privateSize","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":")","kind":"text"}],"roleHeading":"Instance Method","extendedModule":"GLibObject"},"abstract":[{"type":"text","text":"Registers a private structure for an instantiatable type."}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"addPrivate","kind":"identifier"},{"kind":"text","text":"("},{"text":"privateSize","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":")"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"When an object is allocated, the private structures for","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the type and all of its parent types are allocated"},{"text":" ","type":"text"},{"text":"sequentially in the same memory block as the public","type":"text"},{"type":"text","text":" "},{"type":"text","text":"structures, and are zero-filled."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that the accumulated size of the private structures of"},{"text":" ","type":"text"},{"type":"text","text":"a type and all its parent types cannot exceed 64 KiB."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function should be called in the type’s "},{"code":"class_init()","type":"codeVoice"},{"type":"text","text":" function."},{"text":" ","type":"text"},{"type":"text","text":"The private structure can be retrieved using the"},{"type":"text","text":" "},{"type":"codeVoice","code":"G_TYPE_INSTANCE_GET_PRIVATE()"},{"text":" macro.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following example shows attaching a private structure"},{"type":"text","text":" "},{"type":"text","text":"MyObjectPrivate to an object MyObject defined in the standard"},{"type":"text","text":" "},{"text":"GObject fashion in the type’s ","type":"text"},{"code":"class_init()","type":"codeVoice"},{"text":" function.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note the use of a structure member “priv” to avoid the overhead"},{"type":"text","text":" "},{"type":"text","text":"of repeatedly calling "},{"type":"codeVoice","code":"MY_OBJECT_GET_PRIVATE()"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"code":["typedef struct _MyObject        MyObject;","typedef struct _MyObjectPrivate MyObjectPrivate;","","struct _MyObject {"," GObject parent;",""," MyObjectPrivate *priv;","};","","struct _MyObjectPrivate {","  int some_field;","};","","static void","my_object_class_init (MyObjectClass *klass)","{","  g_type_class_add_private (klass, sizeof (MyObjectPrivate));","}","","static void","my_object_init (MyObject *my_object)","{","  my_object->priv = G_TYPE_INSTANCE_GET_PRIVATE (my_object,","                                                 MY_TYPE_OBJECT,","                                                 MyObjectPrivate);","  \/\/ my_object->priv->some_field will be automatically initialised to 0","}","","static int","my_object_get_some_field (MyObject *my_object)","{","  MyObjectPrivate *priv;","","  g_return_val_if_fail (MY_IS_OBJECT (my_object), 0);","","  priv = my_object->priv;","","  return priv->some_field;","}"],"type":"codeListing","syntax":"C"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"add_private is deprecated:"}]},{"type":"text","text":" "},{"type":"text","text":"Use the G_ADD_PRIVATE() macro with the "},{"type":"codeVoice","code":"G_DEFINE_*"},{"type":"text","text":" "},{"text":"family of macros to add instance private data to a type","type":"text"}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeClassRef","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeClassRef\/TypeClassProtocol-Implementations"]]},"variants":[{"paths":["\/documentation\/glibobject\/typeclassref\/addprivate(privatesize:)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeClassRef\/addPrivate(privateSize:)","interfaceLanguage":"swift"},"references":{"doc://GLibObject/documentation/GLibObject/TypeClassRef/addPrivate(privateSize:)":{"deprecated":true,"type":"topic","abstract":[{"type":"text","text":"Registers a private structure for an instantiatable type."}],"title":"addPrivate(privateSize:)","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeClassRef\/addPrivate(privateSize:)","role":"symbol","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"addPrivate"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"privateSize"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":")","kind":"text"}],"url":"\/documentation\/glibobject\/typeclassref\/addprivate(privatesize:)"},"doc://GLibObject/documentation/GLibObject":{"abstract":[],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","title":"GLibObject","role":"collection","kind":"symbol","type":"topic","url":"\/documentation\/glibobje