{"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"topicSections":[{"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(_:)-2mf3j","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(_:)-47vjm","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(_:)-5hv9g","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(_:)-75qw1","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(_:)-9532m","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(cPointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(constPointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(gconstpointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(gpointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(mutating:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(opaquePointer:)"],"title":"Initializers"},{"title":"Instance Properties","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/ptr"]},{"generated":true,"title":"Default Implementations","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/PointerWrapper-Implementations","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/TypePluginProtocol-Implementations"]}],"metadata":{"role":"symbol","externalID":"s:10GLibObject13TypePluginRefV","title":"TypePluginRef","roleHeading":"Structure","navigatorTitle":[{"text":"TypePluginRef","kind":"identifier"}],"modules":[{"name":"GLibObject"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TypePluginRef","kind":"identifier"}],"symbolKind":"struct"},"sections":[],"relationshipsSections":[{"identifiers":["doc:\/\/GLibObject\/4GLib14PointerWrapperP","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol"],"type":"conformsTo","title":"Conforms To","kind":"relationships"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/typepluginref"]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"TypePluginRef","kind":"identifier"}]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"The GObject type system supports dynamic loading of types.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It goes as follows:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The type is initially introduced (usually upon loading the module"},{"type":"text","text":" "},{"type":"text","text":"the first time, or by your main application that knows what modules"},{"type":"text","text":" "},{"text":"introduces what types), like this:","type":"text"}]},{"syntax":"c","code":["new_type_id = g_type_register_dynamic (parent_type_id,","                                       \"TypeName\",","                                       new_type_plugin,","                                       type_flags);"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"where "},{"type":"codeVoice","code":"new_type_plugin"},{"text":" is an implementation of the","type":"text"},{"text":" ","type":"text"},{"code":"GTypePlugin","type":"codeVoice"},{"text":" interface.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"The type’s implementation is referenced, e.g. through"},{"text":" ","type":"text"},{"text":"[func","type":"text"},{"type":"codeVoice","code":"GObject.TypeClass.ref"},{"text":"] or through [func","type":"text"},{"code":"GObject.type_create_instance","type":"codeVoice"},{"type":"text","text":"]"},{"type":"text","text":" "},{"type":"text","text":"(this is being called by [ctor"},{"type":"codeVoice","code":"GObject.Object.new"},{"type":"text","text":"]) or through one of the above"},{"type":"text","text":" "},{"type":"text","text":"done on a type derived from "},{"type":"codeVoice","code":"new_type_id"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"This causes the type system to load the type’s implementation by calling","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GObject.TypePlugin.use"},{"type":"text","text":"] and [method"},{"type":"codeVoice","code":"GObject.TypePlugin.complete_type_info"},{"text":"]","type":"text"},{"text":" ","type":"text"},{"text":"on ","type":"text"},{"code":"new_type_plugin","type":"codeVoice"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"At some point the type’s implementation isn’t required anymore, e.g. after"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"code":"GObject.TypeClass.unref","type":"codeVoice"},{"text":"] or [func","type":"text"},{"type":"codeVoice","code":"GObject.type_free_instance"},{"text":"]","type":"text"},{"text":" ","type":"text"},{"text":"(called when the reference count of an instance drops to zero).","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This causes the type system to throw away the information retrieved"},{"text":" ","type":"text"},{"text":"from [method","type":"text"},{"type":"codeVoice","code":"GObject.TypePlugin.complete_type_info"},{"type":"text","text":"] and then it calls"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"code":"GObject.TypePlugin.unuse","type":"codeVoice"},{"type":"text","text":"] on "},{"type":"codeVoice","code":"new_type_plugin"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Things may repeat from the second step.","type":"text"}]}]}],"type":"orderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"So basically, you need to implement a "},{"type":"codeVoice","code":"GTypePlugin"},{"type":"text","text":" type that"},{"text":" ","type":"text"},{"type":"text","text":"carries a use_count, once use_count goes from zero to one, you need"},{"type":"text","text":" "},{"type":"text","text":"to load the implementation to successfully handle the upcoming"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"code":"GObject.TypePlugin.complete_type_info","type":"codeVoice"},{"text":"] call. Later, maybe after","type":"text"},{"type":"text","text":" "},{"text":"succeeding use\/unuse calls, once use_count drops to zero, you can","type":"text"},{"type":"text","text":" "},{"type":"text","text":"unload the implementation again. The type system makes sure to call"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GObject.TypePlugin.use"},{"text":"] and [method","type":"text"},{"code":"GObject.TypePlugin.complete_type_info","type":"codeVoice"},{"type":"text","text":"]"},{"type":"text","text":" "},{"type":"text","text":"again when the type is needed again."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"[class"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule","type":"reference","isActive":true},{"text":"] is an implementation of ","type":"text"},{"type":"codeVoice","code":"GTypePlugin"},{"type":"text","text":" that"},{"type":"text","text":" "},{"type":"text","text":"already implements most of this except for the actual module loading and"},{"type":"text","text":" "},{"text":"unloading. It even handles multiple registered types per module.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef","type":"reference","isActive":true},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"code":"GTypePlugin","type":"codeVoice"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol","isActive":true},{"type":"text","text":" conformance."},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef","isActive":true,"type":"reference"},{"text":" only as an ","type":"text"},{"type":"codeVoice","code":"unowned"},{"text":" reference to an existing ","type":"text"},{"code":"GTypePlugin","type":"codeVoice"},{"text":" instance.","type":"text"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin","isActive":true},{"type":"text","text":" (instead of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef"},{"text":") if you want to use Automatic Reference Counting for memory management of the underlying ","type":"text"},{"code":"GTypePlugin","type":"codeVoice"},{"type":"text","text":" instance."}]}],"type":"aside","name":"Note","style":"note"}]}],"abstract":[{"text":"An interface that handles the lifecycle of dynamically loaded types.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject"]]},"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef","interfaceLanguage":"swift"},"references":{"doc://GLibObject/documentation/GLibObject/TypePluginRef/init(cPointer:)":{"role":"symbol","abstract":[{"text":"Unsafe typed initialiser.","type":"text"},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"Do not use unless you know the underlying data type the pointer points to conforms to "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol","type":"reference","isActi