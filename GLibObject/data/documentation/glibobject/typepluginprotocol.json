nd":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"text":"GTypePlugin","kind":"typeIdentifier"},{"kind":"text","text":">!"}],"type":"topic"},"doc://GLibObject/documentation/GLibObject/TypePluginProtocol/typeRegisterDynamic(parentType:typeName:flags:)":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol\/typeRegisterDynamic(parentType:typeName:flags:)","title":"typeRegisterDynamic(parentType:typeName:flags:)","url":"\/documentation\/glibobject\/typepluginprotocol\/typeregisterdynamic(parenttype:typename:flags:)","type":"topic","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"typeRegisterDynamic","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"parentType"},{"text":": ","kind":"text"},{"text":"GType","kind":"typeIdentifier","preciseIdentifier":"c:@T@GType"},{"kind":"text","text":", "},{"kind":"externalParam","text":"typeName"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"preciseIdentifier":"s:10GLibObject9TypeFlagsV","kind":"typeIdentifier","text":"TypeFlags"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"c:@T@GType","text":"GType","kind":"typeIdentifier"}],"kind":"symbol","abstract":[{"type":"text","text":"Registers "},{"type":"codeVoice","code":"typeName"},{"text":" as the name of a new dynamic type derived from","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"parentType"},{"type":"text","text":".  The type system uses the information contained in the"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin"},{"type":"text","text":" structure pointed to by "},{"type":"codeVoice","code":"plugin"},{"text":" to manage the type and its","type":"text"},{"type":"text","text":" "},{"type":"text","text":"instances (if not abstract).  The value of "},{"type":"codeVoice","code":"flags"},{"text":" determines the nature","type":"text"},{"text":" ","type":"text"},{"text":"(e.g. abstract or not) of the type.","type":"text"}],"role":"symbol"},"doc://GLibObject/documentation/GLibObject/TypePluginProtocol/use()":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol\/use()","title":"use()","url":"\/documentation\/glibobject\/typepluginprotocol\/use()","type":"topic","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"use","kind":"identifier"},{"text":"()","kind":"text"}],"kind":"symbol","abstract":[{"type":"text","text":"Calls the "},{"code":"use_plugin","type":"codeVoice"},{"type":"text","text":" function from the "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginClass","type":"reference","isActive":true},{"type":"text","text":" of"},{"type":"text","text":" "},{"code":"plugin","type":"codeVoice"},{"text":".  There should be no need to use this function outside of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the GObject type system itself."}],"role":"symbol"},"doc://GLibObject/documentation/GLibObject/TypeModuleRef":{"abstract":[{"type":"codeVoice","code":"GTypeModule"},{"type":"text","text":" provides a simple implementation of the "},{"type":"codeVoice","code":"GTypePlugin"},{"text":" ","type":"text"},{"type":"text","text":"interface."}],"navigatorTitle":[{"kind":"identifier","text":"TypeModuleRef"}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef","title":"TypeModuleRef","role":"symbol","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"TypeModuleRef","kind":"identifier"}],"type":"topic","url":"\/documentation\/glibobject\/typemoduleref"}}}