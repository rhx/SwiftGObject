nalParam","text":"interfaceType"},{"text":": ","kind":"text"},{"text":"GType","kind":"typeIdentifier","preciseIdentifier":"c:@T@GType"},{"kind":"text","text":", "},{"kind":"externalParam","text":"info"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"InterfaceInfoT"},{"kind":"text","text":")"}],"kind":"symbol","abstract":[{"type":"text","text":"Calls the "},{"code":"complete_interface_info","type":"codeVoice"},{"type":"text","text":" function from the"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginClass","isActive":true},{"type":"text","text":" of "},{"type":"codeVoice","code":"plugin"},{"type":"text","text":". There should be no need to use this"},{"text":" ","type":"text"},{"text":"function outside of the GObject type system itself.","type":"text"}],"role":"symbol"},"doc://GLibObject/documentation/GLibObject":{"abstract":[],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","title":"GLibObject","role":"collection","kind":"symbol","type":"topic","url":"\/documentation\/glibobject"},"doc://GLibObject/documentation/GLibObject/TypePluginProtocol/unuse()":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol\/unuse()","title":"unuse()","url":"\/documentation\/glibobject\/typepluginprotocol\/unuse()","type":"topic","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"unuse"},{"text":"()","kind":"text"}],"kind":"symbol","abstract":[{"type":"text","text":"Calls the "},{"type":"codeVoice","code":"unuse_plugin"},{"text":" function from the ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginClass","type":"reference","isActive":true},{"type":"text","text":" of"},{"type":"text","text":" "},{"code":"plugin","type":"codeVoice"},{"type":"text","text":".  There should be no need to use this function outside of"},{"text":" ","type":"text"},{"type":"text","text":"the GObject type system itself."}],"role":"symbol"},"doc://GLibObject/documentation/GLibObject/TypePluginProtocol":{"type":"topic","navigatorTitle":[{"text":"TypePluginProtocol","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/glibobject\/typepluginprotocol","title":"TypePluginProtocol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"TypePluginProtocol","kind":"identifier"}],"abstract":[{"type":"text","text":"An interface that handles the lifecycle of dynamically loaded types."}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol","role":"symbol"},"doc://GLibObject/documentation/GLibObject/TypePluginClass":{"role":"symbol","kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginClass","navigatorTitle":[{"text":"TypePluginClass","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"TypePluginClass","kind":"identifier"}],"abstract":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin","isActive":true,"type":"reference"},{"type":"text","text":" interface is used by the type system in order to handle"},{"type":"text","text":" "},{"type":"text","text":"the lifecycle of dynamically loaded types."}],"title":"TypePluginClass","type":"topic","url":"\/documentation\/glibobject\/typepluginclass"},"doc://GLibObject/documentation/GLibObject/TypePluginProtocol/typeAddInterfaceDynamic(instanceType:interfaceType:)":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol\/typeAddInterfaceDynamic(instanceType:interfaceType:)","title":"typeAddInterfaceDynamic(instanceType:interfaceType:)","url":"\/documentation\/glibobject\/typepluginprotocol\/typeaddinterfacedynamic(instancetype:interfacetype:)","type":"topic","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"typeAddInterfaceDynamic"},{"kind":"text","text":"("},