{"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"TypePluginProtocol"},{"text":" : ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib14PointerWrapperP","text":"PointerWrapper"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"text":"Overview","anchor":"overview","level":2,"type":"heading"},{"inlineContent":[{"text":"The GObject type system supports dynamic loading of types.","type":"text"},{"text":" ","type":"text"},{"text":"It goes as follows:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"The type is initially introduced (usually upon loading the module"},{"text":" ","type":"text"},{"type":"text","text":"the first time, or by your main application that knows what modules"},{"type":"text","text":" "},{"type":"text","text":"introduces what types), like this:"}],"type":"paragraph"},{"code":["new_type_id = g_type_register_dynamic (parent_type_id,","                                       \"TypeName\",","                                       new_type_plugin,","                                       type_flags);"],"type":"codeListing","syntax":"c"},{"inlineContent":[{"type":"text","text":"where "},{"type":"codeVoice","code":"new_type_plugin"},{"type":"text","text":" is an implementation of the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"GTypePlugin"},{"type":"text","text":" interface."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"The type’s implementation is referenced, e.g. through","type":"text"},{"type":"text","text":" "},{"text":"[func","type":"text"},{"type":"codeVoice","code":"GObject.TypeClass.ref"},{"text":"] or through [func","type":"text"},{"type":"codeVoice","code":"GObject.type_create_instance"},{"text":"]","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(this is being called by [ctor"},{"code":"GObject.Object.new","type":"codeVoice"},{"text":"]) or through one of the above","type":"text"},{"text":" ","type":"text"},{"text":"done on a type derived from ","type":"text"},{"type":"codeVoice","code":"new_type_id"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This causes the type system to load the type’s implementation by calling"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"code":"GObject.TypePlugin.use","type":"codeVoice"},{"text":"] and [method","type":"text"},{"type":"codeVoice","code":"GObject.TypePlugin.complete_type_info"},{"text":"]","type":"text"},{"type":"text","text":" "},{"text":"on ","type":"text"},{"code":"new_type_plugin","type":"codeVoice"},{"type":"text","text":"."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"At some point the type’s implementation isn’t required anymore, e.g. after"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GObject.TypeClass.unref"},{"text":"] or [func","type":"text"},{"code":"GObject.type_free_instance","type":"codeVoice"},{"text":"]","type":"text"},{"text":" ","type":"text"},{"text":"(called when the reference count of an instance drops to zero).","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"This causes the type system to throw away the information retrieved","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"from [method"},{"type":"codeVoice","code":"GObject.TypePlugin.complete_type_info"},{"type":"text","text":"] and then it calls"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GObject.TypePlugin.unuse"},{"type":"text","text":"] on "},{"code":"new_type_plugin","type":"codeVoice"},{"type":"text","text":"."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Things may repeat from the second step."}],"type":"paragraph"}]}],"type":"orderedList"},{"type":"paragraph","inlineContent":[{"text":"So basically, you need to implement a ","type":"text"},{"type":"codeVoice","code":"GTypePlugin"},{"text":" type that","type":"text"},{"type":"text","text":" "},{"type":"text","text":"carries a use_count, once use_count goes from zero to one, you need"},{"type":"text","text":" "},{"text":"to load the implementation to successfully handle the upcoming","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GObject.TypePlugin.complete_type_info"},{"text":"] call. Later, maybe after","type":"text"},{"type":"text","text":" "},{"type":"text","text":"succeeding use\/unuse calls, once use_count drops to zero, you can"},{"type":"text","text":" "},{"type":"text","text":"unload the implementation again. The type system makes sure to call"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"code":"GObject.TypePlugin.use","type":"codeVoice"},{"type":"text","text":"] and [method"},{"type":"codeVoice","code":"GObject.TypePlugin.complete_type_info"},{"type":"text","text":"]"},{"type":"text","text":" "},{"type":"text","text":"again when the type is needed again."}]},{"inlineContent":[{"type":"text","text":"[class"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule"},{"type":"text","text":"] is an implementation of "},{"code":"GTypePlugin","type":"codeVoice"},{"text":" that","type":"text"},{"type":"text","text":" "},{"text":"already implements most of this except for the actual module loading and","type":"text"},{"text":" ","type":"text"},{"text":"unloading. It even handles multiple registered types per module.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol","isActive":true},{"type":"text","text":" protocol exposes the methods and properties of an underlying "},{"code":"GTypePlugin","type":"codeVoice"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"text":"The default implementation of these can be found in the protocol extension below.","type":"text"},{"text":" ","type":"text"},{"text":"For a concrete class that implements these methods and properties, see ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin","isActive":true},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Alternatively, use "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef","isActive":true},{"type":"text","text":" as a lighweight, "},{"type":"codeVoice","code":"unowned"},{"text":" reference if you already have an instance you just want to use.","type":"text"}]}],"kind":"content"}],"relationshipsSections":[{"kind":"relationships","type":"inheritsFrom","identifiers":["doc:\/\/GLibObject\/4GLib14PointerWrapperP"],"title":"Inherits From"},{"title":"Inherited By","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleProtocol"],"kind":"relationships","type":"inheritedBy"},{"title":"Conforming Types","kind":"relationships","type":"conformingTypes","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject"]]},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/typepluginprotocol"]}],"kind":"symbol","metadata":{"symbolKind":"protocol","navigatorTitle":[{"text":"TypePluginProtocol","kind":"identifier"}],"externalID":"s:10GLibObject18TypePluginProtoc