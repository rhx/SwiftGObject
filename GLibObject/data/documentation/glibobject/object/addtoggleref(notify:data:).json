{"sections":[],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/Object","doc:\/\/GLibObject\/documentation\/GLibObject\/Object\/ObjectProtocol-Implementations"]]},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"addToggleRef","kind":"identifier"},{"text":"(","kind":"text"},{"text":"notify","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gobject.h@T@GToggleNotify","kind":"typeIdentifier","text":"GToggleNotify"},{"text":"?, ","kind":"text"},{"text":"data","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"text":"? = nil)","kind":"text"}]}],"kind":"declarations"},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"This functionality is intended for binding ","type":"text"},{"type":"codeVoice","code":"object"},{"type":"text","text":" to a proxy"},{"type":"text","text":" "},{"type":"text","text":"object managed by another memory manager. This is done with two"},{"type":"text","text":" "},{"type":"text","text":"paired references: the strong reference added by"},{"text":" ","type":"text"},{"code":"g_object_add_toggle_ref()","type":"codeVoice"},{"type":"text","text":" and a reverse reference to the proxy"},{"text":" ","type":"text"},{"text":"object which is either a strong reference or weak reference.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The setup is that when there are no other references to "},{"code":"object","type":"codeVoice"},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"text","text":"only a weak reference is held in the reverse direction from "},{"type":"codeVoice","code":"object"},{"text":" ","type":"text"},{"text":"to the proxy object, but when there are other references held to","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"object"},{"type":"text","text":", a strong reference is held. The "},{"code":"notify","type":"codeVoice"},{"type":"text","text":" callback is called"},{"type":"text","text":" "},{"type":"text","text":"when the reference from "},{"code":"object","type":"codeVoice"},{"type":"text","text":" to the proxy object should be"},{"text":" ","type":"text"},{"type":"text","text":"“toggled” from strong to weak ("},{"type":"codeVoice","code":"is_last_ref"},{"type":"text","text":" true) or weak to strong"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"type":"codeVoice","code":"is_last_ref"},{"text":" false).","type":"text"}]},{"inlineContent":[{"type":"text","text":"Since a (normal) reference must be held to the object before"},{"text":" ","type":"text"},{"text":"calling ","type":"text"},{"code":"g_object_add_toggle_ref()","type":"codeVoice"},{"type":"text","text":", the initial state of the reverse"},{"text":" ","type":"text"},{"type":"text","text":"link is always strong."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Multiple toggle references may be added to the same gobject,"},{"type":"text","text":" "},{"type":"text","text":"however if there are multiple toggle references to an object, none"},{"type":"text","text":" "},{"type":"text","text":"of them will ever be notified until all but one are removed.  For"},{"type":"text","text":" "},{"text":"this reason, you should only ever use a toggle reference if there","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is important state in the proxy object."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that if you unref the object on another thread, then "},{"code":"notify","type":"codeVoice"},{"type":"text","text":" might"},{"type":"text","text":" "},{"type":"text","text":"still be invoked after "},{"code":"g_object_remove_toggle_ref()","type":"codeVoice"},{"type":"text","text":", and the object argument"},{"text":" ","type":"text"},{"type":"text","text":"might be a dangling pointer. If the object is destroyed on other threads,"},{"type":"text","text":" "},{"text":"you must take care of that yourself.","type":"text"}]},{"inlineContent":[{"text":"A ","type":"text"},{"code":"g_object_add_toggle_ref()","type":"codeVoice"},{"type":"text","text":" must be released with "},{"code":"g_object_remove_toggle_ref()","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/object\/addtoggleref(notify:data:)"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object\/addToggleRef(notify:data:)"},"metadata":{"externalID":"s:10GLibObject0B8ProtocolPAAE12addToggleRef6notify4datayySvSg_SpySo8_GObjectVGSgs5Int32VtXCSg_AGtF::SYNTHESIZED::s:10GLibObject0B0C","roleHeading":"Instance Method","title":"addToggleRef(notify:data:)","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"addToggleRef","kind":"identifier"},{"text":"(","kind":"text"},{"text":"notify","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gobject.h@T@GToggleNotify","text":"GToggleNotify","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"data"},{"text":": ","kind":"text"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"kind":"text","text":"?)"}],"role":"symbol","extendedModule":"GLibObject","modules":[{"name":"GLibObject"}]},"kind":"symbol","abstract":[{"type":"text","text":"Increases the reference count of the object by one and sets a"},{"type":"text","text":" "},{"type":"text","text":"callback to be called when all other references to the object are"},{"type":"text","text":" "},{"type":"text","text":"dropped, or when this is already the last reference to the object"},{"type":"text","text":" "},{"type":"text","text":"and another reference is established."}],"references":{"doc://GLibObject/documentation/GLibObject/Object/addToggleRef(notify:data:)":{"role":"symbol","abstract":[{"text":"Increases the reference count of the object by one and sets a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"callback to be called when all other references to the object are"},{"type":"text","text":" "},{"type":"text","text":"dropped, or when this is already the last reference to the object"},{"text":" ","type":"text"},{"text":"and another reference is established.","type":"text"}],"kind":"symbol","title":"addToggleRef(notify:data:)","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object\/addToggleRef(notify:data:)","type":"topic","url":"\/documentation\/glibobject\/object\/addtoggleref(notify:data:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"addToggleRef"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"notify"},{"kind":"text","text":": "},{"text":"GToggleNotify","kind":"typeIdentifier","preciseIdentifier":"c:gobject.h@T@GToggleNotify"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"data"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"kind":"text","text":"?)"}]},"doc://GLibObject/documentation/GLibObject/Object":{"role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Object"}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","navigatorTitle":[{"text":"Object","kind":"identifier"}],"kind":"symbol","type":"topic","title":"Object","url":"\/documentation\/glibobject\/object","abstract":[{"text":"The base object type.","type":"text"}]},"doc://GLibObject/documentation/GLibObject":{"abstract":[],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","title":"GLibObject","role":"collection","kind":"symbol","type":"topic","url":"\/documentation\/glibobject"},"doc://GLibObject/documentation/GLibObject/Object/ObjectProtocol-Implementations":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object\/ObjectProtocol-Implementations","abstract":[],"kind":"article","title":"ObjectProtocol Implementations","role":"collectionGroup","type":"topic","url":"\/documentation\/glibobject\/object\/objectprotocol-implementations"}}}