bObject10BindingRefV","text":"BindingRef","kind":"typeIdentifier"},{"text":"! ","kind":"text"},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"ObjectT"},{"kind":"text","text":" : "},{"text":"ObjectProtocol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectProtocol","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject0B8ProtocolP"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Whenever the ","type":"text"},{"code":"sourceProperty","type":"codeVoice"},{"text":" is changed the ","type":"text"},{"type":"codeVoice","code":"targetProperty"},{"type":"text","text":" is"},{"text":" ","type":"text"},{"text":"updated using the same value. For instance:","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"(C Language Example):","type":"text"}]},{"type":"codeListing","syntax":"C","code":["  g_object_bind_property (action, \"active\", widget, \"sensitive\", 0);"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Will result in the “sensitive” property of the widget "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","isActive":true},{"text":" instance to be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"updated with the same value of the “active” property of the action "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object"},{"text":" ","type":"text"},{"type":"text","text":"instance."}]},{"inlineContent":[{"type":"text","text":"If "},{"code":"flags","type":"codeVoice"},{"type":"text","text":" contains "},{"type":"codeVoice","code":"bidirectional"},{"text":" then the binding will be mutual:","type":"text"},{"text":" ","type":"text"},{"text":"if ","type":"text"},{"code":"targetProperty","type":"codeVoice"},{"text":" on ","type":"text"},{"code":"target",