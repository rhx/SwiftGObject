{"metadata":{"externalID":"s:10GLibObject0B8ProtocolPAAE7takeRefAA0bE0VSgyF::SYNTHESIZED::s:10GLibObject0B0C","role":"symbol","extendedModule":"GLibObject","modules":[{"name":"GLibObject"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"takeRef"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject0B3RefV","text":"ObjectRef"},{"text":"!","kind":"text"}],"roleHeading":"Instance Method","title":"takeRef()","symbolKind":"method"},"abstract":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"object"},{"type":"text","text":" is floating, sink it.  Otherwise, do nothing."}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/Object","doc:\/\/GLibObject\/documentation\/GLibObject\/Object\/ObjectProtocol-Implementations"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/object\/takeref()"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object\/takeRef()"},"kind":"symbol","primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"takeRef"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef","text":"ObjectRef","preciseIdentifier":"s:10GLibObject0B3RefV"},{"kind":"text","text":"!"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In other words, this function will convert a floating reference (if"},{"type":"text","text":" "},{"type":"text","text":"present) into a full reference."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Typically you want to use "},{"type":"codeVoice","code":"g_object_ref_sink()"},{"text":" in order to","type":"text"},{"text":" ","type":"text"},{"text":"automatically do the correct thing with respect to floating or","type":"text"},{"text":" ","type":"text"},{"text":"non-floating references, but there is one specific scenario where","type":"text"},{"type":"text","text":" "},{"text":"this function is helpful.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The situation where this function is helpful is when creating an API","type":"text"},{"text":" ","type":"text"},{"text":"that allows the user to provide a callback function that returns a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"GObject. We certainly want to allow the user the flexibility to"},{"text":" ","type":"text"},{"type":"text","text":"return a non-floating reference from this callback (for the case"},{"type":"text","text":" "},{"type":"text","text":"where the object that is being returned already exists)."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"At the same time, the API style of some popular GObject-based"},{"text":" ","type":"text"},{"text":"libraries (such as Gtk) make it likely that for newly-created GObject","type":"text"},{"type":"text","text":" "},{"type":"text","text":"instances, the user can be saved some typing if they are allowed to"},{"type":"text","text":" "},{"type":"text","text":"return a floating reference."}]},{"type":"paragraph","inlineContent":[{"text":"Using this function on the return value of the user’s callback allows","type":"text"},{"type":"text","text":" "},{"text":"the user to do whichever is more convenient for them. The caller will","type":"text"},{"type":"text","text":" "},{"text":"alway receives exactly one full reference to the value: either the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"one that was returned in the first place, or a floating reference"},{"type":"text","text":" "},{"text":"that has been converted to a full reference.","type":"text"}]},{"inlineContent":[{"text":"This function has an odd interaction when combined with","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_object_ref_sink()"},{"type":"text","text":" running at the same time in another thread on"},{"text":" ","type":"text"},{"text":"the same ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","isActive":true},{"text":" instance. If ","type":"text"},{"type":"codeVoice","code":"g_object_ref_sink()"},{"type":"text","text":" runs first then"},{"type":"text","text":" "},{"type":"text","text":"the result will be that the floating reference is converted to a hard"},{"text":" ","type":"text"},{"type":"text","text":"reference. If "},{"code":"g_object_take_ref()","type":"codeVoice"},{"type":"text","text":" runs first then the result will be"},{"type":"text","text":" "},{"type":"text","text":"that the floating reference is converted to a hard reference and an"},{"type":"text","text":" "},{"text":"additional reference on top of that one is added. It is best to avoid","type":"text"},{"text":" ","type":"text"},{"text":"this situation.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://GLibObject/documentation/GLibObject/Object/ObjectProtocol-Implementations":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object\/ObjectProtocol-Implementations","abstract":[],"kind":"article","title":"ObjectProtocol Implementations","role":"collectionGroup","type":"topic","url":"\/documentation\/glibobject\/object\/objectprotocol-implementations"},"doc://GLibObject/documentation/GLibObject/ObjectRef":{"role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"ObjectRef","kind":"identifier"}],"title":"ObjectRef","url":"\/documentation\/glibobject\/objectref","abstract":[{"type":"text","text":"The base object type."}],"type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef","navigatorTitle":[{"text":"ObjectRef","kind":"identifier"}],"kind":"symbol"},"doc://GLibObject/documentation/GLibObject":{"abstract":[],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","title":"GLibObject","role":"collection","kind":"symbol","type":"topic","url":"\/documentation\/glibobject"},"doc://GLibObject/documentation/GLibObject/Object/takeRef()":{"type":"topic","kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object\/takeRef()","role":"symbol","url":"\/documentation\/glibobject\/object\/takeref()","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"takeRef"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject0B3RefV","text":"ObjectRef"},{"text":"!","kind":"text"}],"title":"takeRef()","abstract":[{"type":"text","text":"If "},{"type":"codeVoice","code":"object"},{"text":" is floating, sink it.  Otherwise, do nothing.","type":"text"}]},"doc://GLibObject/documentation/GLibObject/Object":{"role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Object"}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","navigatorTitle":[{"text":"Object","kind":"identifier"}],"kind":"symbol","type":"topic","title":"Object","url":"\/documentation\/glibobject\/object","abstract":[{"text":"The base object type.","type":"text"}]}}}