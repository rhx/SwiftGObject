{"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"text":"If ","type":"text"},{"code":"object","type":"codeVoice"},{"type":"text","text":" is floating, sink it.  Otherwise, do nothing."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/bindingref\/takeref()"]}],"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/takeRef()","interfaceLanguage":"swift"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/ObjectProtocol-Implementations"]]},"metadata":{"modules":[{"name":"GLibObject"}],"title":"takeRef()","externalID":"s:10GLibObject0B8ProtocolPAAE7takeRefAA0bE0VSgyF::SYNTHESIZED::s:10GLibObject10BindingRefV","roleHeading":"Instance Method","role":"symbol","extendedModule":"GLibObject","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"takeRef","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"ObjectRef","preciseIdentifier":"s:10GLibObject0B3RefV","kind":"typeIdentifier"},{"text":"!","kind":"text"}]},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"takeRef","kind":"identifier"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef","preciseIdentifier":"s:10GLibObject0B3RefV","text":"ObjectRef"},{"text":"!","kind":"text"}],"platforms":["macOS"]}]},{"content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In other words, this function will convert a floating reference (if"},{"type":"text","text":" "},{"text":"present) into a full reference.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Typically you want to use ","type":"text"},{"code":"g_object_ref_sink()","type":"codeVoice"},{"type":"text","text":" in order to"},{"text":" ","type":"text"},{"type":"text","text":"automatically do the correct thing with respect to floating or"},{"text":" ","type":"text"},{"text":"non-floating references, but there is one specific scenario where","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this function is helpful."}]},{"inlineContent":[{"text":"The situation where this function is helpful is when creating an API","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"that allows the user to provide a callback function that returns a"},{"text":" ","type":"text"},{"type":"text","text":"GObject. We certainly want to allow the user the flexibility to"},{"text":" ","type":"text"},{"text":"return a non-floating reference from this callback (for the case","type":"text"},{"type":"text","text":" "},{"type":"text","text":"where the object that is being returned already exists)."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"At the same time, the API style of some popular GObject-based"},{"text":" ","type":"text"},{"type":"text","text":"libraries (such as Gtk) make it likely that for newly-created GObject"},{"type":"text","text":" "},{"type":"text","text":"instances, the user can be saved some typing if they are allowed to"},{"text":" ","type":"text"},{"type":"text","text":"return a floating reference."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Using this function on the return value of the user’s callback allows"},{"text":" ","type":"text"},{"text":"the user to do whichever is more convenient for them. The caller will","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"alway receives exactly one full reference to the value: either the"},{"type":"text","text":" "},{"type":"text","text":"one that was returned in the first place, or a floating reference"},{"type":"text","text":" "},{"type":"text","text":"that has been converted to a full reference."}]},{"type":"paragraph","inlineContent":[{"text":"This function has an odd interaction when combined with","type":"text"},{"type":"text","text":" "},{"code":"g_object_ref_sink()","type":"codeVoice"},{"type":"text","text":" running at the same time in another thread on"},{"type":"text","text":" "},{"type":"text","text":"the same "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","isActive":true},{"text":" instance. If ","type":"text"},{"type":"codeVoice","code":"g_object_ref_sink()"},{"type":"text","text":" runs first then"},{"text":" ","type":"text"},{"text":"the result will be that the floating reference is converted to a hard","type":"text"},{"type":"text","text":" "},{"type":"text","text":"reference. If "},{"type":"codeVoice","code":"g_object_take_ref()"},{"type":"text","text":" runs first then the result will be"},{"text":" ","type":"text"},{"text":"that the floating reference is converted to a hard reference and an","type":"text"},{"text":" ","type":"text"},{"text":"additional reference on top of that one is added. It is best to avoid","type":"text"},{"type":"text","text":" "},{"text":"this situation.","type":"text"}]}],"kind":"content"}],"references":{"doc://GLibObject/documentation/GLibObject/ObjectRef":{"role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"ObjectRef","kind":"identifier"}],"title":"ObjectRef","url":"\/documentation\/glibobject\/objectref","abstract":[{"type":"text","text":"The base object type."}],"type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef","navigatorTitle":[{"text":"ObjectRef","kind":"identifier"}],"kind":"symbol"},"doc://GLibObject/documentation/GLibObject/BindingRef/takeRef()":{"title":"takeRef()","abstract":[{"type":"text","text":"If "},{"type":"codeVoice","code":"object"},{"text":" is floating, sink it.  Otherwise, do nothing.","type":"text"}],"url":"\/documentation\/glibobject\/bindingref\/takeref()","kind":"symbol","role":"symbol","type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/takeRef()","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"takeRef"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject0B3RefV","text":"ObjectRef"},{"text":"!","kind":"text"}]},"doc://GLibObject/documentation/GLibObject/BindingRef":{"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"BindingRef","kind":"identifier"}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef","navigatorTitle":[{"kind":"identifier","text":"BindingRef"}],"kind":"symbol","type":"topic","title":"BindingRef","url":"\/documentation\/glibobject\/bindingref","abstract":[{"type":"codeVoice","code":"GObject"},{"type":"text","text":" instance (or source) and another property on another "},{"code":"GObject","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"instance (or target)."}]},"doc://GLibObject/documentation/GLibObject/BindingRef/ObjectProtocol-Implementations":{"title":"ObjectProtocol Implementations","type":"topic","url":"\/documentation\/glibobject\/bindingref\/objectprotocol-implementations","abstract":[],"role":"collectionGroup","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/ObjectProtocol-Implementations","kind":"article"},"doc://GLibObject/documentation/GLibObject/Object":{"role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Object"}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","navigatorTitle":[{"text":"Object","kind":"identifier"}],"kind":"symbol","type":"topic","title":"Object","url":"\/documentation\/glibobject\/object","abstract":[{"text":"The base object type.","type":"text"}]},"doc://GLibObject/documentation/GLibObject":{"abstract":[],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","title":"GLibObject","role":"collection","kind":"symbol","type":"topic","url":"\/documentation\/glibobject"}}}