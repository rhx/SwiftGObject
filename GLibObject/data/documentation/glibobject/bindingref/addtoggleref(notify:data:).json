{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/bindingref\/addtoggleref(notify:data:)"]}],"sections":[],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/addToggleRef(notify:data:)"},"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/ObjectProtocol-Implementations"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"addToggleRef","kind":"identifier"},{"text":"(","kind":"text"},{"text":"notify","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gobject.h@T@GToggleNotify","text":"GToggleNotify","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"data"},{"text":": ","kind":"text"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"kind":"text","text":"? = nil)"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"This functionality is intended for binding "},{"type":"codeVoice","code":"object"},{"text":" to a proxy","type":"text"},{"type":"text","text":" "},{"text":"object managed by another memory manager. This is done with two","type":"text"},{"type":"text","text":" "},{"text":"paired references: the strong reference added by","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"text":" and a reverse reference to the proxy","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"object which is either a strong reference or weak reference."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The setup is that when there are no other references to "},{"type":"codeVoice","code":"object"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"only a weak reference is held in the reverse direction from ","type":"text"},{"type":"codeVoice","code":"object"},{"type":"text","text":" "},{"type":"text","text":"to the proxy object, but when there are other references held to"},{"text":" ","type":"text"},{"code":"object","type":"codeVoice"},{"type":"text","text":", a strong reference is held. The "},{"type":"codeVoice","code":"notify"},{"type":"text","text":" callback is called"},{"type":"text","text":" "},{"type":"text","text":"when the reference from "},{"code":"object","type":"codeVoice"},{"text":" to the proxy object should be","type":"text"},{"text":" ","type":"text"},{"text":"“toggled” from strong to weak (","type":"text"},{"type":"codeVoice","code":"is_last_ref"},{"type":"text","text":" true) or weak to strong"},{"type":"text","text":" "},{"type":"text","text":"("},{"type":"codeVoice","code":"is_last_ref"},{"text":" false).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Since a (normal) reference must be held to the object before","type":"text"},{"type":"text","text":" "},{"text":"calling ","type":"text"},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"type":"text","text":", the initial state of the reverse"},{"type":"text","text":" "},{"text":"link is always strong.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Multiple toggle references may be added to the same gobject,"},{"text":" ","type":"text"},{"text":"however if there are multiple toggle references to an object, none","type":"text"},{"text":" ","type":"text"},{"text":"of them will ever be notified until all but one are removed.  For","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this reason, you should only ever use a toggle reference if there"},{"text":" ","type":"text"},{"type":"text","text":"is important state in the proxy object."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that if you unref the object on another thread, then "},{"type":"codeVoice","code":"notify"},{"type":"text","text":" might"},{"type":"text","text":" "},{"type":"text","text":"still be invoked after "},{"code":"g_object_remove_toggle_ref()","type":"codeVoice"},{"text":", and the object argument","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"might be a dangling pointer. If the object is destroyed on other threads,"},{"text":" ","type":"text"},{"type":"text","text":"you must take care of that yourself."}]},{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"code":"g_object_add_toggle_ref()","type":"codeVoice"},{"type":"text","text":" must be released with "},{"type":"codeVoice","code":"g_object_remove_toggle_ref()"},{"text":".","type":"text"}]}],"kind":"content"}],"abstract":[{"type":"text","text":"Increases the reference count of the object by one and sets a"},{"text":" ","type":"text"},{"text":"callback to be called when all other references to the object are","type":"text"},{"text":" ","type":"text"},{"text":"dropped, or when this is already the last reference to the object","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and another reference is established."}],"metadata":{"externalID":"s:10GLibObject0B8ProtocolPAAE12addToggleRef6notify4datayySvSg_SpySo8_GObjectVGSgs5Int32VtXCSg_AGtF::SYNTHESIZED::s:10GLibObject10BindingRefV","role":"symbol","modules":[{"name":"GLibObject"}],"symbolKind":"method","title":"addToggleRef(notify:data:)","roleHeading":"Instance Method","extendedModule":"GLibObject","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"addToggleRef"},{"text":"(","kind":"text"},{"text":"notify","kind":"externalParam"},{"kind":"text","text":": "},{"text":"GToggleNotify","kind":"typeIdentifier","preciseIdentifier":"c:gobject.h@T@GToggleNotify"},{"text":"?, ","kind":"text"},{"text":"data","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"kind":"text","text":"?)"}]},"references":{"doc://GLibObject/documentation/GLibObject/BindingRef/ObjectProtocol-Implementations":{"title":"ObjectProtocol Implementations","type":"topic","url":"\/documentation\/glibobject\/bindingref\/objectprotocol-implementations","abstract":[],"role":"collectionGroup","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/ObjectProtocol-Implementations","kind":"article"},"doc://GLibObject/documentation/GLibObject":{"abstract":[],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","title":"GLibObject","role":"collection","kind":"symbol","type":"topic","url":"\/documentation\/glibobject"},"doc://GLibObject/documentation/GLibObject/BindingRef":{"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"BindingRef","kind":"identifier"}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef","navigatorTitle":[{"kind":"identifier","text":"BindingRef"}],"kind":"symbol","type":"topic","title":"BindingRef","url":"\/documentation\/glibobject\/bindingref","abstract":[{"type":"codeVoice","code":"GObject"},{"type":"text","text":" instance (or source) and another property on another "},{"code":"GObject","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"instance (or target)."}]},"doc://GLibObject/documentation/GLibObject/BindingRef/addToggleRef(notify:data:)":{"url":"\/documentation\/glibobject\/bindingref\/addtoggleref(notify:data:)","kind":"symbol","role":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/addToggleRef(notify:data:)","abstract":[{"text":"Increases the reference count of the object by one and sets a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"callback to be called when all other references to the object are"},{"text":" ","type":"text"},{"type":"text","text":"dropped, or when this is already the last reference to the object"},{"text":" ","type":"text"},{"text":"and another reference is established.","type":"text"}],"title":"addToggleRef(notify:data:)","type":"topic","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"addToggleRef","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"notify"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:gobject.h@T@GToggleNotify","text":"GToggleNotify"},{"kind":"text","text":"?, "},{"text":"data","kind":"externalParam"},{"kind":"text","text":": "},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"kind":"text","text":"?)"}]}}}