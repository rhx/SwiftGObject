":"text"},{"text":" ","type":"text"},{"type":"text","text":"be used to store a "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ParamSpec","isActive":true},{"text":".","type":"text"}]},{"inlineContent":[{"text":"This function should be used if you plan to use a static array of","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"GParamSpecs"},{"type":"text","text":" and "},{"type":"codeVoice","code":"g_object_notify_by_pspec()"},{"text":". For instance, this","type":"text"},{"type":"text","text":" "},{"type":"text","text":"class initialization:"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"syntax":"C","type":"codeListing","code":["typedef enum {","  PROP_FOO = 1,","  PROP_BAR,","  N_PROPERTIES","} MyObjectProperty;","","static GParamSpec *obj_properties[N_PROPERTIES] = { NULL, };","","static void","my_object_class_init (MyObjectClass *klass)","{","  GObjectClass *gobject_class = G_OBJECT_CLASS (klass);","","  obj_properties[PROP_FOO] =","    g_param_spec_int (\"foo\", NULL, NULL,","                      -1, G_MAXINT,","                      0,","                      G_PARAM_READWRITE | G_PARAM_STATIC_STRINGS);","","  obj_properties[PROP_BAR] =","    g_param_spec_string (\"bar\", NULL, NULL,","                         NULL,","                         G_PARAM_READWRITE | G_PARAM_STATIC_STRINGS);","","  gobject_class->set_property = my_object_set_property;","  gobject_class->get_property = my_object_get_property;","  g_object_class_install_properties (gobject_class,","                                     G_N_ELEMENTS (obj_properties),","                                     obj_properties);","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"allows calling "},{"type":"codeVoice","code":"g_object_notify_by_pspec()"},{"text":" to notify of property changes:","type":"text"}]},{"inlineContent":[{"text":"(C Language Example):","type":"text"}],