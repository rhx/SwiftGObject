{"sections":[],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/SignalGroupRef","doc:\/\/GLibObject\/documentation\/GLibObject\/SignalGroupRef\/ObjectProtocol-Implementations"]]},"metadata":{"symbolKind":"method","title":"takeRef()","modules":[{"name":"GLibObject"}],"externalID":"s:10GLibObject0B8ProtocolPAAE7takeRefAA0bE0VSgyF::SYNTHESIZED::s:10GLibObject14SignalGroupRefV","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"takeRef","kind":"identifier"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject0B3RefV","text":"ObjectRef"},{"text":"!","kind":"text"}],"roleHeading":"Instance Method","extendedModule":"GLibObject"},"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLibObject\/documentation\/GLibObject\/SignalGroupRef\/takeRef()"},"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"takeRef","kind":"identifier"},{"kind":"text","text":"() -> "},{"text":"ObjectRef","kind":"typeIdentifier","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef","preciseIdentifier":"s:10GLibObject0B3RefV"},{"text":"!","kind":"text"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"In other words, this function will convert a floating reference (if"},{"type":"text","text":" "},{"text":"present) into a full reference.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Typically you want to use "},{"type":"codeVoice","code":"g_object_ref_sink()"},{"type":"text","text":" in order to"},{"text":" ","type":"text"},{"text":"automatically do the correct thing with respect to floating or","type":"text"},{"type":"text","text":" "},{"type":"text","text":"non-floating references, but there is one specific scenario where"},{"type":"text","text":" "},{"text":"this function is helpful.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The situation where this function is helpful is when creating an API","type":"text"},{"type":"text","text":" "},{"text":"that allows the user to provide a callback function that returns a","type":"text"},{"type":"text","text":" "},{"text":"GObject. We certainly want to allow the user the flexibility to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"return a non-floating reference from this callback (for the case"},{"text":" ","type":"text"},{"type":"text","text":"where the object that is being returned already exists)."}]},{"inlineContent":[{"text":"At the same time, the API style of some popular GObject-based","type":"text"},{"type":"text","text":" "},{"text":"libraries (such as Gtk) make it likely that for newly-created GObject","type":"text"},{"type":"text","text":" "},{"text":"instances, the user can be saved some typing if they are allowed to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"return a floating reference."}],"type":"paragraph"},{"inlineContent":[{"text":"Using this function on the return value of the user’s callback allows","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the user to do whichever is more convenient for them. The caller will"},{"text":" ","type":"text"},{"text":"alway receives exactly one full reference to the value: either the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"one that was returned in the first place, or a floating reference"},{"type":"text","text":" "},{"type":"text","text":"that has been converted to a full reference."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This function has an odd interaction when combined with","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_object_ref_sink()"},{"type":"text","text":" running at the same time in another thread on"},{"type":"text","text":" "},{"text":"the same ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","isActive":true,"type":"reference"},{"type":"text","text":" instance. If "},{"type":"codeVoice","code":"g_object_ref_sink()"},{"type":"text","text":" runs first then"},{"type":"text","text":" "},{"text":"the result will be that the floating reference is converted to a hard","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"reference. If "},{"code":"g_object_take_ref()","type":"codeVoice"},{"text":" runs first then the result will be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"that the floating reference is converted to a hard reference and an"},{"text":" ","type":"text"},{"type":"text","text":"additional reference on top of that one is added. It is best to avoid"},{"type":"text","text":" "},{"type":"text","text":"this situation."}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/signalgroupref\/takeref()"]}],"abstract":[{"type":"text","text":"If "},{"code":"object","type":"codeVoice"},{"type":"text","text":" is floating, sink it.  Otherwise, do nothing."}],"references":{"doc://GLibObject/documentation/GLibObject/Object":{"role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Object"}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","navigatorTitle":[{"text":"Object","kind":"identifier"}],"kind":"symbol","type":"topic","title":"Object","url":"\/documentation\/glibobject\/object","abstract":[{"text":"The base object type.","type":"text"}]},"doc://GLibObject/documentation/GLibObject/ObjectRef":{"role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"ObjectRef","kind":"identifier"}],"title":"ObjectRef","url":"\/documentation\/glibobject\/objectref","abstract":[{"type":"text","text":"The base object type."}],"type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef","navigatorTitle":[{"text":"ObjectRef","kind":"identifier"}],"kind":"symbol"},"doc://GLibObject/documentation/GLibObject/SignalGroupRef/takeRef()":{"role":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/SignalGroupRef\/takeRef()","kind":"symbol","type":"topic","abstract":[{"type":"text","text":"If "},{"code":"object","type":"codeVoice"},{"type":"text","text":" is floating, sink it.  Otherwise, do nothing."}],"url":"\/documentation\/glibobject\/signalgroupref\/takeref()","title":"takeRef()","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"takeRef"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","text":"ObjectRef","preciseIdentifier":"s:10GLibObject0B3RefV"},{"kind":"text","text":"!"}]},"doc://GLibObject/documentation/GLibObject/SignalGroupRef":{"role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"SignalGroupRef"}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/SignalGroupRef","navigatorTitle":[{"text":"SignalGroupRef","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/glibobject\/signalgroupref","title":"SignalGroupRef","abstract":[{"type":"codeVoice","code":"GSignalGroup"},{"type":"text","text":" manages a collection of signals on a "},{"type":"codeVoice","code":"GObject"},{"text":".","type":"text"}],"type":"topic"},"doc://GLibObject/documentation/GLibObject":{"abstract":[],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","title":"GLibObject","role":"collection","kind":"symbol","type":"topic","url":"\/documentation\/glibobject"},"doc://GLibObject/documentation/GLibObject/SignalGroupRef/ObjectProtocol-Implementations":{"role":"collectionGroup","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/SignalGroupRef\/ObjectProtocol-Implementations","kind":"article","url":"\/documentation\/glibobject\/signalgroupref\/objectprotocol-implementations","title":"ObjectProtocol Implementations","abstract":[],"type":"topic"}}}