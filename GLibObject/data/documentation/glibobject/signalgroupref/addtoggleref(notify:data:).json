{"metadata":{"role":"symbol","modules":[{"name":"GLibObject"}],"externalID":"s:10GLibObject0B8ProtocolPAAE12addToggleRef6notify4datayySvSg_SpySo8_GObjectVGSgs5Int32VtXCSg_AGtF::SYNTHESIZED::s:10GLibObject14SignalGroupRefV","title":"addToggleRef(notify:data:)","extendedModule":"GLibObject","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"addToggleRef","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"notify"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"GToggleNotify","preciseIdentifier":"c:gobject.h@T@GToggleNotify"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"data"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier","text":"gpointer"},{"kind":"text","text":"?)"}],"roleHeading":"Instance Method"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"addToggleRef"},{"text":"(","kind":"text"},{"text":"notify","kind":"externalParam"},{"kind":"text","text":": "},{"text":"GToggleNotify","kind":"typeIdentifier","preciseIdentifier":"c:gobject.h@T@GToggleNotify"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"data"},{"text":": ","kind":"text"},{"text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier"},{"text":"? = nil)","kind":"text"}],"languages":["swift"]}]},{"content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"This functionality is intended for binding ","type":"text"},{"type":"codeVoice","code":"object"},{"type":"text","text":" to a proxy"},{"type":"text","text":" "},{"text":"object managed by another memory manager. This is done with two","type":"text"},{"text":" ","type":"text"},{"text":"paired references: the strong reference added by","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"text":" and a reverse reference to the proxy","type":"text"},{"type":"text","text":" "},{"type":"text","text":"object which is either a strong reference or weak reference."}]},{"type":"paragraph","inlineContent":[{"text":"The setup is that when there are no other references to ","type":"text"},{"code":"object","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"text":"only a weak reference is held in the reverse direction from ","type":"text"},{"code":"object","type":"codeVoice"},{"type":"text","text":" "},{"text":"to the proxy object, but when there are other references held to","type":"text"},{"type":"text","text":" "},{"code":"object","type":"codeVoice"},{"type":"text","text":", a strong reference is held. The "},{"code":"notify","type":"codeVoice"},{"type":"text","text":" callback is called"},{"type":"text","text":" "},{"type":"text","text":"when the reference from "},{"type":"codeVoice","code":"object"},{"text":" to the proxy object should be","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"“toggled” from strong to weak ("},{"code":"is_last_ref","type":"codeVoice"},{"text":" true) or weak to strong","type":"text"},{"type":"text","text":" "},{"type":"text","text":"("},{"type":"codeVoice","code":"is_last_ref"},{"type":"text","text":" false)."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Since a (normal) reference must be held to the object before"},{"text":" ","type":"text"},{"type":"text","text":"calling "},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"text":", the initial state of the reverse","type":"text"},{"type":"text","text":" "},{"text":"link is always strong.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Multiple toggle references may be added to the same gobject,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"however if there are multiple toggle references to an object, none"},{"text":" ","type":"text"},{"text":"of them will ever be notified until all but one are removed.  For","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this reason, you should only ever use a toggle reference if there"},{"type":"text","text":" "},{"type":"text","text":"is important state in the proxy object."}]},{"type":"paragraph","inlineContent":[{"text":"Note that if you unref the object on another thread, then ","type":"text"},{"type":"codeVoice","code":"notify"},{"type":"text","text":" might"},{"type":"text","text":" "},{"text":"still be invoked after ","type":"text"},{"code":"g_object_remove_toggle_ref()","type":"codeVoice"},{"text":", and the object argument","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"might be a dangling pointer. If the object is destroyed on other threads,"},{"text":" ","type":"text"},{"type":"text","text":"you must take care of that yourself."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"text":" must be released with ","type":"text"},{"type":"codeVoice","code":"g_object_remove_toggle_ref()"},{"type":"text","text":"."}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/SignalGroupRef","doc:\/\/GLibObject\/documentation\/GLibObject\/SignalGroupRef\/ObjectProtocol-Implementations"]]},"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/SignalGroupRef\/addToggleRef(notify:data:)","interfaceLanguage":"swift"},"abstract":[{"text":"Increases the reference count of the object by one and sets a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"callback to be called when all other references to the object are"},{"type":"text","text":" "},{"text":"dropped, or when this is already the last reference to the object","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and another reference is established."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/signalgroupref\/addtoggleref(notify:data:)"]}],"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"references":{"doc://GLibObject/documentation/GLibObject/SignalGroupRef":{"role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"SignalGroupRef"}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/SignalGroupRef","navigatorTitle":[{"text":"SignalGroupRef","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/glibobject\/signalgroupref","title":"SignalGroupRef","abstract":[{"type":"codeVoice","code":"GSignalGroup"},{"type":"text","text":" manages a collection of signals on a "},{"type":"codeVoice","code":"GObject"},{"text":".","type":"text"}],"type":"topic"},"doc://GLibObject/documentation/GLibObject":{"abstract":[],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","title":"GLibObject","role":"collection","kind":"symbol","type":"topic","url":"\/documentation\/glibobject"},"doc://GLibObject/documentation/GLibObject/SignalGroupRef/addToggleRef(notify:data:)":{"type":"topic","abstract":[{"text":"Increases the reference count of the object by one and sets a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"callback to be called when all other references to the object are"},{"type":"text","text":" "},{"type":"text","text":"dropped, or when this is already the last reference to the object"},{"text":" ","type":"text"},{"type":"text","text":"and another reference is established."}],"title":"addToggleRef(notify:data:)","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/SignalGroupRef\/addToggleRef(notify:data:)","role":"symbol","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"addToggleRef","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"notify"},{"text":": ","kind":"text"},{"text":"GToggleNotify","kind":"typeIdentifier","preciseIdentifier":"c:gobject.h@T@GToggleNotify"},{"text":"?, ","kind":"text"},{"text":"data","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier"},{"text":"?)","kind":"text"}],"url":"\/documentation\/glibobject\/signalgroupref\/addtoggleref(notify:data:)"},"doc://GLibObject/documentation/GLibObject/SignalGroupRef/ObjectProtocol-Implementations":{"role":"collectionGroup","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/SignalGroupRef\/ObjectProtocol-Implementations","kind":"article","url":"\/documentation\/glibobject\/signalgroupref\/objectprotocol-implementations","title":"ObjectProtocol Implementations","abstract":[],"type":"topic"}}}