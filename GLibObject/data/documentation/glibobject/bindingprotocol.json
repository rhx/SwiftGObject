{"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol","interfaceLanguage":"swift"},"topicSections":[{"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol\/binding_ptr-9m3c1","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol\/flags","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol\/source","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol\/sourceProperty","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol\/target","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol\/targetProperty"],"title":"Instance Properties"},{"title":"Instance Methods","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol\/bind(property:to:_:flags:transformFrom:transformTo:)","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol\/dupSource()","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol\/dupTarget()","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol\/get(property:)","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol\/getFlags()","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol\/getSource()","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol\/getSourceProperty()","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol\/getTarget()","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol\/getTargetProperty()","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol\/set(property:value:)","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol\/unbind()"]}],"relationshipsSections":[{"kind":"relationships","title":"Inherits From","type":"inheritsFrom","identifiers":["doc:\/\/GLibObject\/4GLib14PointerWrapperP","doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectProtocol"]},{"kind":"relationships","type":"conformingTypes","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/Binding","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef"],"title":"Conforming Types"}],"kind":"symbol","abstract":[{"type":"codeVoice","code":"GObject"},{"text":" instance (or source) and another property on another ","type":"text"},{"type":"codeVoice","code":"GObject"},{"text":" ","type":"text"},{"type":"text","text":"instance (or target)."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"BindingProtocol","kind":"identifier"},{"kind":"text","text":" : "},{"text":"ObjectProtocol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectProtocol","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject0B8ProtocolP"}]}]},{"kind":"content","content":[{"text":"Overview","type":"heading","level":2,"anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"Whenever the source property changes, the same value is applied to the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"target property; for instance, the following binding:"}]},{"code":["  g_object_bind_property (object1, \"property-a\",","                          object2, \"property-b\",","                          G_BINDING_DEFAULT);"],"syntax":"c","type":"codeListing"},{"inlineContent":[{"type":"text","text":"will cause the property named “property-b” of "},{"type":"codeVoice","code":"object2"},{"type":"text","text":" to be updated"},{"type":"text","text":" "},{"type":"text","text":"every time [method"},{"code":"GObject.set","type":"codeVoice"},{"text":"] or the specific accessor changes the value of","type":"text"},{"text":" ","type":"text"},{"text":"the property “property-a” of ","type":"text"},{"code":"object1","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"It is possible to create a bidirectional binding between two properties","type":"text"},{"type":"text","text":" "},{"text":"of two ","type":"text"},{"type":"codeVoice","code":"GObject"},{"text":" instances, so that if either property changes, the","type":"text"},{"type":"text","text":" "},{"text":"other is updated as well, for instance:","type":"text"}],"type":"paragraph"},{"syntax":"c","code":["  g_object_bind_property (object1, \"property-a\",","                          object2, \"property-b\",","                          G_BINDING_BIDIRECTIONAL);"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"will keep the two properties in sync."}]},{"inlineContent":[{"type":"text","text":"It is also possible to set a custom transformation function (in both"},{"type":"text","text":" "},{"text":"directions, in case of a bidirectional binding) to apply a custom","type":"text"},{"type":"text","text":" "},{"type":"text","text":"transformation from the source value to the target value before"},{"type":"text","text":" "},{"type":"text","text":"applying it; for instance, the following binding:"}],"type":"paragraph"},{"syntax":"c","code":["  g_object_bind_property_full (adjustment1, \"value\",","                               adjustment2, \"value\",","                               G_BINDING_BIDIRECTIONAL,","                               celsius_to_fahrenheit,","                               fahrenheit_to_celsius,","                               NULL, NULL);"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"will keep the “value” property of the two adjustments in sync; the","type":"text"},{"text":" ","type":"text"},{"code":"celsius_to_fahrenheit","type":"codeVoice"},{"type":"text","text":" function will be called whenever the “value”"},{"text":" ","type":"text"},{"type":"text","text":"property of "},{"code":"adjustment1","type":"codeVoice"},{"text":" changes and will transform the current value","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of the property before applying it to the “value” property of "},{"code":"adjustment2","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"Vice versa, the ","type":"text"},{"type":"codeVoice","code":"fahrenheit_to_celsius"},{"type":"text","text":" function will be called whenever"},{"type":"text","text":" "},{"text":"the “value” property of ","type":"text"},{"type":"codeVoice","code":"adjustment2"},{"type":"text","text":" changes, and will transform the"},{"text":" ","type":"text"},{"type":"text","text":"current value of the property before applying it to the “value” property"},{"text":" ","type":"text"},{"text":"of ","type":"text"},{"type":"codeVoice","code":"adjustment1"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Binding","isActive":true},{"type":"text","text":" does not resolve cycles by itself; a cycle like"}]},{"code":["  object1:propertyA -> object2:propertyB","  object2:propertyB -> object3:propertyC","  object3:propertyC -> object1:propertyA"],"syntax":null,"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"might lead to an infinite loop. The loop, in this particular case,"},{"text":" ","type":"text"},{"text":"can be avoided if the objects emit the ","type":"text"},{"type":"codeVoice","code":"GObject"},{"text":"notify","type":"text"},{"type":"codeVoice","code":" signal only if the value has effectively been changed. A binding is implemented using the `GObject`notify"},{"text":" signal, so it is susceptible to all the","type":"text"},{"type":"text","text":" "},{"text":"various ways of blocking a signal emission, like [func","type":"text"},{"code":"GObject.signal_stop_emission","type":"codeVoice"},{"text":"]","type":"text"},{"type":"text","text":" "},{"type":"text","text":"or [func"},{"code":"GObject.signal_handler_block","type":"codeVoice"},{"text":"].","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A binding will be severed, and the resources it allocates freed, whenever"},{"text":" ","type":"text"},{"type":"text","text":"either one of the "},{"code":"GObject","type":"codeVoice"},{"type":"text","text":" instances it refers to are finalized, or when"},{"type":"text","text":" "},{"type":"text","text":"the "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Binding","isActive":true,"type":"reference"},{"type":"text","text":" instance loses its last reference."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Bindings for languages with garbage collection can use"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GObject.Binding.unbind"},{"text":"] to explicitly release a binding between the source","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and target properties, instead of relying on the last reference on the"},{"text":" ","type":"text"},{"type":"text","text":"binding, source, and target instances to drop."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol","isActive":true,"type":"reference"},{"type":"text","text":" protocol exposes the methods and properties of an underlying "},{"type":"codeVoice","code":"GBinding"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"text":"The default implementation of these can be found in the protocol extension below.","type":"text"},{"text":" ","type":"text"},{"text":"For a concrete class that implements these methods and properties, see ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Binding","isActive":true},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Alternatively, use "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef","isActive":true,"type":"reference"},{"type":"text","text":" as a lighweight, "},{"type":"codeVoice","code":"unowned"},{"type":"text","text":" reference if you already have an instance you just want to use."}]}]}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject"]]},"metadata":{"navigatorTitle":[{"text":"BindingProtocol","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"BindingProtocol"}],"role":"symbol","symbolKind":"protocol","modules":[{"name":"GLibObject"}],"roleHeading":"Protocol","title":"BindingProtocol","externalID":"s:10GLibObject15BindingProtocolP"},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/bindingprotocol"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://GLibObject/documentation/GLibObject/BindingProtocol/bind(property:to:_:flags:transformFrom:transformTo:)":{"kind":"symbol","abstract":[{"type":"text","text":"Bind a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingPropertyName"},{"type":"text","text":" source property to a given target object."}],"url":"\/documentation\/glibobject\/bindingprotocol\/bind(property:to:_:flags:transformfrom:transformto:)","role":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol\/bind(property:to:_:flags:transformFrom:transformTo:)","title":"bind(property:to:_:flags:transformFrom:transformTo:)","type":"topic","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"bind"},{"kind":"text","text":"<"},{"text":"Q","kind":"genericParameter"},{"text":", ","kind":"text"},{"text":"T","kind":"genericParameter"},{"kind":"text","text":">("},{"kind":"externalParam","text":"property"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"BindingPropertyName","preciseIdentifier":"s:10GLibObject19BindingPropertyNameO"},{"kind":"text","text":", "},{"kind":"externalParam","text":"to"},{"kind":"text","text":": "},{"text":"T","kind":"typeIdentifier"},{"kind":"text","text"