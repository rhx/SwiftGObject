{"sections":[],"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeValueCollectFunc","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"typealias","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"TypeValueCollectFunc"},{"kind":"text","text":" = "},{"preciseIdentifier":"c:@T@GTypeValueCollectFunc","text":"GTypeValueCollectFunc","kind":"typeIdentifier"}],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"This function should setup "},{"type":"codeVoice","code":"value"},{"type":"text","text":" similar to "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeValueInitFunc","isActive":true},{"text":"; e.g.","type":"text"},{"text":" ","type":"text"},{"text":"for a string value that does not allow ","type":"text"},{"code":"NULL","type":"codeVoice"},{"type":"text","text":" pointers, it needs to either"},{"type":"text","text":" "},{"text":"emit an error, or do an implicit conversion by storing an empty string.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"value"},{"type":"text","text":" passed in to this function has a zero-filled data array, so"},{"text":" ","type":"text"},{"text":"just like for ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeValueInitFunc"},{"type":"text","text":" it is guaranteed to not contain any old"},{"type":"text","text":" "},{"text":"contents that might need freeing.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"nCollectValues"},{"text":" argument is the string length of the ","type":"text"},{"code":"collect_format","type":"codeVoice"},{"text":" ","type":"text"},{"text":"field of ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeValueTable"},{"type":"text","text":", and "},{"type":"codeVoice","code":"collect_values"},{"text":" is an array of ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeCValue","isActive":true},{"text":" ","type":"text"},{"text":"with length of ","type":"text"},{"code":"nCollectValues","type":"codeVoice"},{"type":"text","text":", containing the collected values according"},{"type":"text","text":" "},{"type":"text","text":"to "},{"type":"codeVoice","code":"collect_format"},{"text":".","type":"text"}]},{"inlineContent":[{"type":"text","text":"The "},{"code":"collectFlags","type":"codeVoice"},{"text":" argument provided as a hint by the caller. It may","type":"text"},{"type":"text","text":" "},{"type":"text","text":"contain the flag "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/valueNocopyContents"},{"type":"text","text":" indicating that the collected"},{"type":"text","text":" "},{"type":"text","text":"value contents may be considered ‘static’ for the duration of the "},{"code":"value","type":"codeVoice"},{"type":"text","text":" "},{"text":"lifetime. Thus an extra copy of the contents stored in ","type":"text"},{"type":"codeVoice","code":"collectValues"},{"type":"text","text":" is"},{"text":" ","type":"text"},{"type":"text","text":"not required for assignment to "},{"code":"value","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"For our above string example, we continue with:","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"syntax":"C","type":"codeListing","code":["if (!collect_values[0].v_pointer)","  value->data[0].v_pointer = g_strdup (\"\");","else if (collect_flags & G_VALUE_NOCOPY_CONTENTS)","  {","    value->data[0].v_pointer = collect_values[0].v_pointer;","    \/\/ keep a flag for the value_free() implementation to not free this string","    value->data[1].v_uint = G_VALUE_NOCOPY_CONTENTS;","  }","else","  value->data[0].v_pointer = g_strdup (collect_values[0].v_pointer);","return NULL;"]},{"inlineContent":[{"text":"It should be noted, that it is generally a bad idea to follow the","type":"text"},{"type":"text","text":" "},{"isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/valueNocopyContents","type":"reference"},{"type":"text","text":" hint for reference counted types. Due to"},{"text":" ","type":"text"},{"type":"text","text":"reentrancy requirements and reference count assertions performed"},{"text":" ","type":"text"},{"text":"by the signal emission code, reference counts should always be","type":"text"},{"type":"text","text":" "},{"text":"incremented for reference counted contents stored in the ","type":"text"},{"type":"codeVoice","code":"value->data"},{"type":"text","text":" "},{"text":"array. To deviate from our string example for a moment, and taking","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"a look at an exemplary implementation for "},{"code":"GTypeValueTable.collect_value()","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"of "},{"type":"codeVoice","code":"GObject"},{"text":":","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"syntax":"C","code":["GObject *object = G_OBJECT (collect_values[0].v_pointer);","g_return_val_if_fail (object != NULL,","   g_strdup_printf (\"Object %p passed as invalid NULL pointer\", object));","\/\/ never honour G_VALUE_NOCOPY_CONTENTS for ref-counted types","value->data[0].v_pointer = g_object_ref (object);","return NULL;"],"type":"codeListing"},{"inlineContent":[{"text":"The reference count for valid objects is always incremented, regardless","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of "},{"code":"collect_flags","type":"codeVoice"},{"type":"text","text":". For invalid objects, the example returns a newly"},{"text":" ","type":"text"},{"text":"allocated string without altering ","type":"text"},{"code":"value","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Upon success, ","type":"text"},{"type":"codeVoice","code":"collect_value()"},{"text":" needs to return ","type":"text"},{"type":"codeVoice","code":"NULL"},{"text":". If, however,","type":"text"},{"type":"text","text":" "},{"text":"an error condition occurred, ","type":"text"},{"type":"codeVoice","code":"collect_value()"},{"type":"text","text":" should return a newly"},{"text":" ","type":"text"},{"type":"text","text":"allocated string containing an error diagnostic."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The calling code makes no assumptions about the "},{"type":"codeVoice","code":"value"},{"type":"text","text":" contents being"},{"text":" ","type":"text"},{"type":"text","text":"valid upon error returns, "},{"type":"codeVoice","code":"value"},{"type":"text","text":" is simply thrown away without further"},{"text":" ","type":"text"},{"text":"freeing. As such, it is a good idea to not allocate ","type":"text"},{"code":"GValue","type":"codeVoice"},{"text":" contents","type":"text"},{"type":"text","text":" "},{"text":"prior to returning an error; however, ","type":"text"},{"type":"codeVoice","code":"collect_values()"},{"type":"text","text":" is not obliged"},{"type":"text","text":" "},{"text":"to return a correctly setup ","type":"text"},{"type":"codeVoice","code":"value"},{"type":"text","text":" for error returns, simply because"},{"type":"text","text":" "},{"type":"text","text":"any non-"},{"type":"codeVoice","code":"NULL"},{"type":"text","text":" return is considered a fatal programming error, and"},{"text":" ","type":"text"},{"type":"text","text":"further program behaviour is undefined."}]}]}],"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/typevaluecollectfunc"]}],"abstract":[{"type":"text","text":"This function is responsible for converting the values collected from"},{"text":" ","type":"text"},{"type":"text","text":"a variadic argument list into contents suitable for storage in a "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Value","isActive":true},{"text":".","type":"text"}],"metadata":{"role":"symbol","externalID":"s:10GLibObject20TypeValueCollectFunca","roleHeading":"Type Alias","fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"TypeValueCollectFunc"}],"symbolKind":"typealias","navigatorTitle":[{"text":"TypeValueCollectFunc","kind":"identifier"}],"title":"TypeValueCollectFunc","modules":[{"name":"GLibObject"}]},"references":{"doc://GLibObject/documentation/GLibObject/valueNocopyContents":{"kind":"symbol","type":"topic","role":"symbol","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"valueNocopyContents"},{"text":": ","kind":"text"},{"text":"Int32","kind":"typeIdentifier","preciseIdentifier":"s:s5Int32V"}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/valueNocopyContents","abstract":[{"type":"text","text":"If passed to "},{"type":"codeVoice","code":"G_VALUE_COLLECT()"},{"type":"text","text":", allocated data won’t be copied"},{"type":"text","text":" "},{"text":"but used verbatim. This does not affect ref-counted types like","type":"text"},{"type":"text","text":" "},{"text":"objects. This does not affect usage of ","type":"text"},{"type":"codeVoice","code":"g_value_copy()"},{"type":"text","text":", the data will"},{"type":"text","text":" "},{"text":"be copied if it is not ref-counted.","type":"text"