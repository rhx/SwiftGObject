{"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"ClosureRef","kind":"identifier"}]}]},{"content":[{"text":"Overview","type":"heading","anchor":"overview","level":2},{"inlineContent":[{"text":"It will generally comprise a function of some kind and a marshaller","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"used to call it. It is the responsibility of the marshaller to"},{"text":" ","type":"text"},{"text":"convert the arguments for the invocation from ","type":"text"},{"code":"GValues","type":"codeVoice"},{"text":" into","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a suitable form, perform the callback on the converted arguments,"},{"type":"text","text":" "},{"text":"and transform the return value back into a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Value","type":"reference"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the case of C programs, a closure usually just holds a pointer"},{"type":"text","text":" "},{"text":"to a function and maybe a data argument, and the marshaller","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"converts between "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Value","isActive":true},{"text":" and native C types. The GObject","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"library provides the "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/CClosure","isActive":true,"type":"reference"},{"text":" type for this purpose. Bindings for","type":"text"},{"type":"text","text":" "},{"type":"text","text":"other languages need marshallers which convert between "},{"code":"GValues","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"and suitable representations in the runtime of the language in"},{"text":" ","type":"text"},{"text":"order to use functions written in that language as callbacks. Use","type":"text"},{"type":"text","text":" "},{"code":"g_closure_set_marshal()","type":"codeVoice"},{"text":" to set the marshaller on such a custom","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"closure implementation."}]},{"type":"paragraph","inlineContent":[{"text":"Within GObject, closures play an important role in the","type":"text"},{"type":"text","text":" "},{"text":"implementation of signals. When a signal is registered, the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"c_marshaller"},{"type":"text","text":" argument to "},{"type":"codeVoice","code":"g_signal_new()"},{"text":" specifies the default C","type":"text"},{"text":" ","type":"text"},{"text":"marshaller for any closure which is connected to this","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"signal. GObject provides a number of C marshallers for this"},{"text":" ","type":"text"},{"type":"text","text":"purpose, see the g_cclosure_marshal_"},{"inlineContent":[{"type":"text","text":"() functions. Additional C"},{"type":"text","text":" "},{"type":"text","text":"marshallers can be generated with the "},{"isActive":true,"identifier":"#glib-genmarshal","type":"reference"},{"text":" ","type":"text"},{"type":"text","text":"utility.  Closures can be explicitly connected to signals with"},{"text":" ","type":"text"},{"code":"g_signal_connect_closure()","type":"codeVoice"},{"text":", but it usually more convenient to let","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"GObject create a closure automatically by using one of the"},{"type":"text","text":" "},{"text":"g_signal_connect_","type":"text"}],"type":"emphasis"},{"type":"text","text":"() functions which take a callback function\/user"},{"type":"text","text":" "},{"type":"text","text":"data pair."}]},{"inlineContent":[{"text":"Using closures has a number of important advantages over a simple","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"callback function\/data pointer combination:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Closures allow the callee to get the types of the callback parameters,"},{"text":" ","type":"text"},{"type":"text","text":"which means that language bindings don’t have to write individual glue"},{"text":" ","type":"text"},{"type":"text","text":"for each callback type."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The reference counting of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Closure"},{"text":" makes it easy to handle reentrancy","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"right; if a callback is removed while it is being invoked, the closure"},{"type":"text","text":" "},{"text":"and its parameters won’t be freed until the invocation finishes.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"g_closure_invalidate()"},{"type":"text","text":" and invalidation notifiers allow callbacks to be"},{"type":"text","text":" "},{"text":"automatically removed when the objects they point to go away.","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef","isActive":true,"type":"reference"},{"text":" type acts as a lightweight Swift reference to an underlying ","type":"text"},{"type":"codeVoice","code":"GClosure"},{"text":" instance.","type":"text"},{"type":"text","text":" "},{"text":"It exposes methods that can operate on this data type through ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureProtocol","type":"reference"},{"type":"text","text":" conformance."},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef","isActive":true,"type":"reference"},{"type":"text","text":" only as an "},{"code":"unowned","type":"codeVoice"},{"text":" reference to an existing ","type":"text"},{"type":"codeVoice","code":"GClosure"},{"type":"text","text":" instance."}]},{"style":"note","content":[{"inlineContent":[{"text":"Use ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Closure","isActive":true},{"type":"text","text":" (instead of "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef","isActive":true},{"text":") if you want to use Automatic Reference Counting for memory management of the underlying ","type":"text"},{"code":"GClosure","type":"codeVoice"},{"text":" instance.","type":"text"}],"type":"paragraph"}],"name":"Note","type":"aside"}],"kind":"content"}],"relationshipsSections":[{"kind":"relationships","type":"conformsTo","title":"Conforms To","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureProtocol","doc:\/\/GLibObject\/4GLib14PointerWrapperP"]}],"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject"]]},"sections":[],"abstract":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"GClosure"},{"text":" represents a callback supplied by the programmer.","type":"text"}],"metadata":{"externalID":"s:10GLibObject10ClosureRefV","role":"symbol","modules":[{"name":"GLibObject"}],"symbolKind":"struct","title":"ClosureRef","roleHeading":"Structure","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ClosureRef"}],"navigatorTitle":[{"kind":"identifier","text":"ClosureRef"}]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],