{"metadata":{"title":"ClassInitFunc","modules":[{"name":"GLibObject"}],"symbolKind":"typealias","role":"symbol","fragments":[{"text":"typealias","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"ClassInitFunc"}],"roleHeading":"Type Alias","externalID":"s:10GLibObject13ClassInitFunca","navigatorTitle":[{"text":"ClassInitFunc","kind":"identifier"}]},"kind":"symbol","identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClassInitFunc","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"text":"A callback function used by the type system to initialize the class","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of a specific type."}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject"]]},"variants":[{"paths":["\/documentation\/glibobject\/classinitfunc"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"typealias"},{"text":" ","kind":"text"},{"text":"ClassInitFunc","kind":"identifier"},{"kind":"text","text":" = "},{"text":"GClassInitFunc","kind":"typeIdentifier","preciseIdentifier":"c:gtype.h@T@GClassInitFunc"}],"languages":["swift"]}]},{"content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"inlineContent":[{"type":"text","text":"This function should initialize all static class members."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The initialization process of a class involves:"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Copying common members from the parent class over to the"},{"type":"text","text":" "},{"text":"derived class structure.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Zero initialization of the remaining members not copied","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"over from the parent class."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Invocation of the "},{"code":"GBaseInitFunc()","type":"codeVoice"},{"text":" initializers of all parent","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"types and the class’ type."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Invocation of the class’ ","type":"text"},{"code":"GClassInitFunc()","type":"codeVoice"},{"text":" initializer.","type":"text"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"Since derived classes are partially initialized through a memory copy","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of the parent class, the general rule is that "},{"code":"GBaseInitFunc()","type":"codeVoice"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"GBaseFinalizeFunc()"},{"type":"text","text":" should take care of necessary reinitialization"},{"text":" ","type":"text"},{"text":"and release of those class members that were introduced by the type","type":"text"},{"text":" ","type":"text"},{"text":"that specified these ","type":"text"},{"type":"codeVoice","code":"GBaseInitFunc()``\/GBaseFinalizeFunc()"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"GClassInitFunc()"},{"type":"text","text":" should only care about initializing static"},{"type":"text","text":" "},{"text":"class members, while dynamic class members (such as allocated strings","type":"text"},{"text":" ","type":"text"},{"text":"or reference counted resources) are better handled by a ","type":"text"},{"code":"GBaseInitFunc()","type":"codeVoice"},{"type":"text","text":" "},{"text":"for this type, so proper initialization of the dynamic class members","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is performed for class initialization of derived types as well."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"An example may help to correspond the intend of the different class"},{"type":"text","text":" "},{"type":"text","text":"initializers:"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"type":"codeListing","code":["typedef struct {","  GObjectClass parent_class;","  gint         static_integer;","  gchar       *dynamic_string;","} TypeAClass;","static void","type_a_base_class_init (TypeAClass *class)","{","  class->dynamic_string = g_strdup (\"some string\");","}","static void","type_a_base_class_finalize (TypeAClass *class)","{","  g_free (class->dynamic_string);","}","static void","type_a_class_init (TypeAClass *class)","{","  class->static_integer = 42;","}","","typedef struct {","  TypeAClass   parent_class;","  gfloat       static_float;","  GString     *dynamic_gstring;","} TypeBClass;","static void","type_b_base_class_init (TypeBClass *class)","{","  class->dynamic_gstring = g_string_new (\"some other string\");","}","static void","type_b_base_class_finalize (TypeBClass *class)","{","  g_string_free (class->dynamic_gstring);","}","static void","type_b_class_init (TypeBClass *class)","{","  class->static_float = 3.14159265358979323846;","}"],"syntax":"C"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Initialization of TypeBClass will first cause initialization of"},{"type":"text","text":" "},{"text":"TypeAClass (derived classes reference their parent classes, see","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_type_class_ref()"},{"text":" on this).","type":"text"}]},{"inlineContent":[{"type":"text","text":"Initialization of TypeAClass roughly involves zero-initializing its fields,"},{"text":" ","type":"text"},{"type":"text","text":"then calling its "},{"code":"GBaseInitFunc()","type":"codeVoice"},{"type":"text","text":" "},{"type":"codeVoice","code":"type_a_base_class_init()"},{"type":"text","text":" to allocate"},{"type":"text","text":" "},{"text":"its dynamic members (dynamic_string), and finally calling its ","type":"text"},{"code":"GClassInitFunc()","type":"codeVoice"},{"text":" ","type":"text"},{"code":"type_a_class_init()","type":"codeVoice"},{"type":"text","text":" to initialize its static members (static_integer)."},{"type":"text","text":" "},{"type":"text","text":"The first step in the initialization process of TypeBClass is then"},{"text":" ","type":"text"},{"text":"a plain memory copy of the contents of TypeAClass into TypeBClass and","type":"text"},{"type":"text","text":" "},{"text":"zero-initialization of the remaining fields in TypeBClass.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The dynamic members of TypeAClass within TypeBClass now need"},{"text":" ","type":"text"},{"text":"reinitialization which is performed by calling ","type":"text"},{"type":"codeVoice","code":"type_a_base_class_init()"},{"type":"text","text":" "},{"type":"text","text":"with an argument of TypeBClass."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"After that, the "},{"type":"codeVoice","code":"GBaseInitFunc()"},{"text":" of TypeBClass, ","type":"text"},{"type":"codeVoice","code":"type_b_base_class_init()"},{"type":"text","text":" "},{"text":"is called to allocate the dynamic members of TypeBClass (dynamic_gstring),","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and finally the "},{"code":"GClassInitFunc()","type":"codeVoice"},{"text":" of TypeBClass, ","type":"text"},{"type":"codeVoice","code":"type_b_class_init()"},{"type":"text","text":","},{"type":"text","text":" "},{"text":"is called to complete the initialization process with the static members","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(static_float)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Corresponding finalization counter parts to the "},{"code":"GBaseInitFunc()","type":"codeVoice"},{"type":"text","text":" functions"},{"type":"text","text":" "},{"text":"have to be provided to release allocated resources at class finalization","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"time."}]}],"kind":"content"}],"sections":[],"references":{"doc://GLibObject/documentation/GLibObject":{"abstract":[],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","title":"GLibObject","role":"collection","kind":"symbol","type":"topic","url":"\/documentation\/glibobject"},"doc://GLibObject/documentation/GLibObject/ClassInitFunc":{"kind":"symbol","title":"ClassInitFunc","fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ClassInitFunc"}],"type":"topic","url":"\/documentation\/glibobject\/classinitfunc","navigatorTitle":[{"text":"ClassInitFunc","kind":"identifier"}],"abstract":[{"type":"text","text":"A callback function used by the type system to initialize the class"},{"type":"text","text":" "},{"text":"of a specific type.","type":"text"}],"role":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClassInitFunc"}}}