{"sections":[],"metadata":{"role":"symbol","externalID":"s:10GLibObject7WeakRefC","title":"WeakRef","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"WeakRef"}],"symbolKind":"class","modules":[{"name":"GLibObject"}],"roleHeading":"Class","navigatorTitle":[{"kind":"identifier","text":"WeakRef"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"WeakRef"}]}]},{"content":[{"type":"heading","text":"Overview","anchor":"overview","level":2},{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"code":"GWeakRef","type":"codeVoice"},{"text":" can either be empty (i.e. point to ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":"), or point to an"},{"text":" ","type":"text"},{"type":"text","text":"object for as long as at least one “strong” reference to that object"},{"type":"text","text":" "},{"type":"text","text":"exists. Before the object’s "},{"code":"GObjectClass.dispose","type":"codeVoice"},{"text":" method is called,","type":"text"},{"text":" ","type":"text"},{"text":"every ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRef","isActive":true,"type":"reference"},{"type":"text","text":" associated with becomes empty (i.e. points to "},{"type":"codeVoice","code":"nil"},{"text":").","type":"text"}]},{"inlineContent":[{"text":"Like ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Value","type":"reference","isActive":true},{"type":"text","text":", "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRef"},{"text":" can be statically allocated, stack- or","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"heap-allocated, or embedded in larger structures."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Unlike ","type":"text"},{"type":"codeVoice","code":"g_object_weak_ref()"},{"type":"text","text":" and "},{"type":"codeVoice","code":"g_object_add_weak_pointer()"},{"text":", this weak","type":"text"},{"type":"text","text":" "},{"text":"reference is thread-safe: converting a weak pointer to a reference is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"atomic with respect to invalidation of weak pointers to destroyed"},{"text":" ","type":"text"},{"text":"objects.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the object’s "},{"type":"codeVoice","code":"GObjectClass.dispose"},{"type":"text","text":" method results in additional"},{"text":" ","type":"text"},{"text":"references to the object being held (‘re-referencing’), any ","type":"text"},{"code":"GWeakRefs","type":"codeVoice"},{"type":"text","text":" taken"},{"type":"text","text":" "},{"type":"text","text":"before it was disposed will continue to point to "},{"code":"nil","type":"codeVoice"},{"type":"text","text":".  Any "},{"type":"codeVoice","code":"GWeakRefs"},{"text":" taken","type":"text"},{"type":"text","text":" "},{"type":"text","text":"during disposal and after re-referencing, or after disposal has returned due"},{"text":" ","type":"text"},{"text":"to the re-referencing, will continue to point to the object until its refcount","type":"text"},{"type":"text","text":" "},{"text":"goes back to zero, at which point they too will be invalidated.","type":"text"}]},{"inlineContent":[{"type":"text","text":"It is invalid to take a "},{"isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRef","type":"reference"},{"text":" on an object during ","type":"text"},{"type":"codeVoice","code":"GObjectClass.dispose"},{"type":"text","text":" "},{"type":"text","text":"without first having or creating a strong reference to the object."}],"type":"paragraph"},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/GLibO