e count of a ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule","isActive":true,"type":"reference"},{"type":"text","text":" by one. If the"},{"type":"text","text":" "},{"type":"text","text":"result is zero, the module will be unloaded. (However, the"},{"type":"text","text":" "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule","isActive":true,"type":"reference"},{"text":" will not be freed, and types associated with the","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule","type":"reference","isActive":true},{"type":"text","text":" are not unregistered. Once a "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule","isActive":true,"type":"reference"},{"text":" is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"initialized, it must exist forever.)"}],"kind":"symbol","title":"unuse()"},"doc://GLibObject/documentation/GLibObject/TypeModuleProtocol/parentInstance":{"role":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleProtocol\/parentInstance","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"parentInstance","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"GObject"}],"title":"parentInstance","url":"\/documentation\/glibobject\/typemoduleprotocol\/parentinstance","type":"topic","abstract":[],"kind":"symbol"},"doc://GLibObject/documentation/GLibObject/TypeModuleProtocol/registerEnum(name:constStaticValues:)":{"url":"\/documentation\/glibobject\/typemoduleprotocol\/registerenum(name:conststaticvalues:)","kind":"symbol","abstract":[{"type":"text","text":"Looks up or registers an enumeration that is implemented with a particular"},{"type":"text","text":" "},{"text":"type plugin. If a type with name ","type":"text"},{"type":"codeVoice","code":"type_name"},{"text":" was previously registered,","type":"text"},{"type":"t