{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TypeModuleProtocol","kind":"identifier"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","text":"ObjectProtocol","preciseIdentifier":"s:10GLibObject0B8ProtocolP","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectProtocol"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:10GLibObject18TypePluginProtocolP","kind":"typeIdentifier","text":"TypePluginProtocol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"text":"Overview","anchor":"overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"The model of ","type":"text"},{"type":"codeVoice","code":"GTypeModule"},{"text":" is a dynamically loaded module which","type":"text"},{"type":"text","text":" "},{"text":"implements some number of types and interface implementations.","type":"text"}]},{"inlineContent":[{"text":"When the module is loaded, it registers its types and interfaces","type":"text"},{"text":" ","type":"text"},{"text":"using [method","type":"text"},{"code":"GObject.TypeModule.register_type","type":"codeVoice"},{"type":"text","text":"] and"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GObject.TypeModule.add_interface"},{"text":"].","type":"text"},{"type":"text","text":" "},{"text":"As long as any instances of these types and interface implementations","type":"text"},{"type":"text","text":" "},{"type":"text","text":"are in use, the module is kept loaded. When the types and interfaces"},{"type":"text","text":" "},{"text":"are gone, the module may be unloaded. If the types and interfaces","type":"text"},{"type":"text","text":" "},{"text":"become used again, the module will be reloaded. Note that the last","type":"text"},{"type":"text","text":" "},{"text":"reference cannot be released from within the module code, since that","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"would lead to the caller’s code being unloaded before "},{"type":"codeVoice","code":"g_object_unref()"},{"text":" ","type":"text"},{"type":"text","text":"returns to it."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Keeping track of whether the module should be loaded or not is done by"},{"type":"text","text":" "},{"type":"text","text":"using a use count - it starts at zero, and whenever it is greater than"},{"type":"text","text":" "},{"type":"text","text":"zero, the module is loaded. The use count is maintained internally by"},{"text":" ","type":"text"},{"text":"the type system, but also can be explicitly controlled by","type":"text"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GObject.TypeModule.use"},{"text":"] and [method","type":"text"},{"type":"codeVoice","code":"GObject.TypeModule.unuse"},{"type":"text","text":"]."},{"type":"text","text":" "},{"text":"Typically, when loading a module for the first type, ","type":"text"},{"type":"codeVoice","code":"g_type_module_use()"},{"type":"text","text":" "},{"type":"text","text":"will be used to load it so that it can initialize its types. At some later"},{"type":"text","text":" "},{"type":"text","text":"point, when the module no longer needs to be loaded except for the type"},{"text":" ","type":"text"},{"text":"implementations it contains, ","type":"text"},{"code":"g_type_module_unuse()","type":"codeVoice"},{"type":"text","text":" is called."}],"type":"paragraph"},{"inlineContent":[{"code":"GTypeModule","type":"codeVoice"},{"text":" does not actually provide any implementation of module","type":"text"},{"type":"text","text":" "},{"type":"text","text":"loading and unloading. To create a particular module type you must"},{"text":" ","type":"text"},{"type":"text","text":"derive from "},{"type":"codeVoice","code":"GTypeModule"},{"text":" and implement the load and unload functions","type":"text"},{"type":"text","text":" "},{"type":"text","text":"in "},{"code":"GTypeModuleClass","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleProtocol","type":"reference"},{"type":"text","text":" protocol exposes the methods and properties of an underlying "},{"code":"GTypeModule","type":"codeVoice"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"text":"The default implementation of these can be found in the protocol extension below.","type":"text"},{"type":"text","text":" "},{"text":"For a concrete class that implements these methods and properties, see ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule","isActive":true,"type":"reference"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Alternatively, use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef"},{"text":" as a lighweight, ","type":"text"},{"code":"unowned","type":"codeVoice"},{"type":"text","text":" reference if you already have an instance you just want to use."}]}],"kind":"content"}],"metadata":{"navigatorTitle":[{"kind":"identifier","text":"TypeModuleProtocol"}],"externalID":"s:10GLibObject18TypeModuleProtocolP","modules":[{"name":"GLibObject"}],"fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"TypeModuleProtocol"}],"roleHeading":"Protocol","role":"symbol","symbolKind":"protocol","title":"TypeModuleProtocol"},"sections":[],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject"]]},"abstract":[{"type":"codeVoice","code":"GTypeModule"},{"type":"text","text":" provides a simple implementation of the "},{"code":"GTypePlugin","type":"codeVoice"},{"text":" ","type":"text"},{"text":"inte