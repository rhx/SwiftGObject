{"abstract":[{"type":"text","text":"Takes over the initial ownership of a closure."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/closureprotocol\/sink()"]}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureProtocol"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"sink","kind":"identifier"},{"kind":"text","text":"()"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Each closure is initially created in a “floating” state, which means","type":"text"},{"type":"text","text":" "},{"text":"that the initial reference count is not owned by any caller.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This function checks to see if the object is still floating, and if so,","type":"text"},{"type":"text","text":" "},{"text":"unsets the floating state and decreases the reference count. If the","type":"text"},{"type":"text","text":" "},{"text":"closure is not floating, ","type":"text"},{"code":"g_closure_sink()","type":"codeVoice"},{"type":"text","text":" does nothing."}]},{"inlineContent":[{"type":"text","text":"The reason for the existence of the floating state is to prevent"},{"text":" ","type":"text"},{"type":"text","text":"cumbersome code sequences like:"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"type":"codeListing","syntax":"C","code":["closure = g_cclosure_new (cb_func, cb_data);","g_source_set_closure (source, closure);","g_closure_unref (closure); \/\/ GObject doesn't really need this"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Because "},{"code":"g_source_set_closure()","type":"codeVoice"},{"type":"text","text":" (and similar functions) take ownership of the"},{"type":"text","text":" "},{"type":"text","text":"initial reference count, if it is unowned, we instead can write:"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"type":"codeListing","syntax":"C","code":["g_source_set_closure (source, g_cclosure_new (cb_func, cb_data));"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Generally, this function is used together with "},{"type":"codeVoice","code":"g_closure_ref()"},{"text":". An example","type":"text"},{"text":" ","type":"text"},{"text":"of storing a closure for later notification looks like:","type":"text"}]},{"inlineContent":[{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"code":["static GClosure *notify_closure = NULL;","void","foo_notify_set_closure (GClosure *closure)","{","  if (notify_closure)","    g_closure_unref (notify_closure);","  notify_closure = closure;","  if (notify_closure)","    {","      g_closure_ref (notify_closure);","      g_closure_sink (notify_closure);","    }","}"],"type":"codeListing","syntax":"C"},{"inlineContent":[{"type":"text","text":"Because "},{"code":"g_closure_sink()","type":"codeVoice"},{"text":" may decrement the reference count of a closure","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(if it hasn’t been called on "},{"type":"codeVoice","code":"closure"},{"text":" yet) just like ","type":"text"},{"code":"g_closure_unref()","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"codeVoice","code":"g_closure_ref()"},{"type":"text","text":" should be called prior to this function."}],"type":"paragraph"}],"kind":"content"}],"metadata":{"externalID":"s:10GLibObject15ClosureProtocolPAAE4sinkyyF","symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"sink","kind":"identifier"},{"text":"()","kind":"text"}],"roleHeading":"Instance Method","extendedModule":"GLibObject","modules":[{"name":"GLibObject"}],"title":"sink()","role":"symbol"},"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureProtocol\/sink()"},"references":{"doc://GLibObject/documentation/GLibObject/ClosureProtocol/sink()":{"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"sink","kind":"identifier"},{"kind":"text","text":"()"}],"abstract":[{"text":"Takes over the initial ownership of a closure.","type":"text"}],"url":"\/documentation\/glibobject\/closureprotocol\/sink()","role":"symbol","kind":"symbol","title":"sink()","type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureProtocol\/sink()"},"doc://GLibObject/documentation/GLibObject/ClosureProtocol":{"role":"symbol","abstract":[{"text":"A ","type":"text"},{"code":"GClosure","type":"codeVoice"},{"type":"text","text":" represents a callback supplied by the programmer."}],"url":"\/documentation\/glibobject\/closureprotocol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ClosureProtocol"}],"type":"topic","title":"ClosureProtocol","navigatorTitle":[{"kind":"identifier","text":"ClosureProtocol"}],"kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureProtocol"},"doc://GLibObject/documentation/GLibObject":{"abstract":[],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","title":"GLibObject","role":"collection","kind":"symbol","type":"topic","url":"\/documentation\/glibobject"}}}