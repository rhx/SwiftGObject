{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/objectsignalname\/notify"]}],"abstract":[{"type":"text","text":"The notify signal is emitted on an object when one of its properties has"},{"text":" ","type":"text"},{"type":"text","text":"its value set through "},{"type":"codeVoice","code":"g_object_set_property()"},{"type":"text","text":", "},{"type":"codeVoice","code":"g_object_set()"},{"text":", et al.","type":"text"}],"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectSignalName\/notify","interfaceLanguage":"swift"},"metadata":{"symbolKind":"case","modules":[{"name":"GLibObject"}],"role":"symbol","externalID":"s:10GLibObject0B10SignalNameO6notifyyA2CmF","roleHeading":"Case","title":"ObjectSignalName.notify","fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"text":"notify","kind":"identifier"}]},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectSignalName"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"notify"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Note that getting this signal doesn’t itself guarantee that the value of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the property has actually changed. When it is emitted is determined by the"},{"text":" ","type":"text"},{"type":"text","text":"derived GObject class. If the implementor did not create the property with"},{"type":"text","text":" "},{"type":"codeVoice","code":"explicitNotify"},{"type":"text","text":", then any call to "},{"code":"g_object_set_property()","type":"codeVoice"},{"text":" results","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"in "},{"code":"notify","type":"codeVoice"},{"text":" being emitted, even if the new value is the same as the old.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"If they did pass "},{"code":"explicitNotify","type":"codeVoice"},{"type":"text","text":", then this signal is emitted only"},{"type":"text","text":" "},{"text":"when they explicitly call ","type":"text"},{"code":"g_object_notify()","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"g_object_notify_by_pspec()","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and common practice is to do that only when the value has actually changed."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This signal is typically used to obtain change notification for a"},{"text":" ","type":"text"},{"text":"single property, by specifying the property name as a detail in the","type":"text"},{"type":"text","text":" "},{"code":"g_signal_connect()","type":"codeVoice"},{"type":"text","text":" call, like this:"}]},{"inlineContent":[{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"syntax":"C","type":"codeListing","code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is important to note that you must use"},{"type":"text","text":" "},{"isActive":true,"identifier":"#canonical-parameter-names","type":"reference"},{"type":"text","text":" as"},{"type":"text","text":" "},{"text":"detail strings for the notify signal.","type":"text"}]}],"kind":"content"}],"references":{"doc://GLibObject/documentation/GLibObject/ObjectSignalName/notify":{"role":"symbol","type":"topic","abstract":[{"type":"text","text":"The notify signal is emitted on an object when one of its properties has"},{"text":" ","type":"text"},{"text":"its value set through ","type":"text"},{"type":"codeVoice","code":"g_object_set_property()"},{"type":"text","text":", "},{"code":"g_object_set()","type":"codeVoice"},{"type":"text","text":", et al."}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectSignalName\/notify","title":"ObjectSignalName.notify","url":"\/documentation\/glibobject\/objectsignalname\/notify","kind":"symbol","fragments":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"text":"notify","kind":"identifier"}]},"#canonical-parameter-names":{"identifier":"#canonical-parameter-names","titleInlineContent":[{"text":"canonical parameter names","type":"text"}],"url":"#canonical-parameter-names","type":"link","title":"canonical parameter names"},"doc://GLibObject/documentation/GLibObject/ObjectSignalName":{"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ObjectSignalName"}],"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"ObjectSignalName","kind":"identifier"}],"url":"\/documentation\/glibobject\/objectsignalname","type":"topic","title":"ObjectSignalName","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectSignalName","abstract":[]},"doc://GLibObject/documentation/GLibObject":{"abstract":[],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","title":"GLibObject","role":"collection","kind":"symbol","type":"topic","url":"\/documentation\/glibobject"}}}