{"abstract":[{"type":"text","text":"The notify signal is emitted on an object when one of its properties has"},{"type":"text","text":" "},{"type":"text","text":"its value set through "},{"type":"codeVoice","code":"g_object_set_property()"},{"text":", ","type":"text"},{"code":"g_object_set()","type":"codeVoice"},{"type":"text","text":", et al."}],"metadata":{"roleHeading":"Case","symbolKind":"case","role":"symbol","externalID":"s:10GLibObject20TypeModuleSignalNameO6notifyyA2CmF","modules":[{"name":"GLibObject"}],"title":"TypeModuleSignalName.notify","fragments":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"kind":"identifier","text":"notify"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"text":"notify","kind":"identifier"}],"languages":["swift"]}]},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"Note that getting this signal doesn’t itself guarantee that the value of"},{"text":" ","type":"text"},{"text":"the property has actually changed. When it is emitted is determined by the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"derived GObject class. If the implementor did not create the property with"},{"type":"text","text":" "},{"code":"explicitNotify","type":"codeVoice"},{"type":"text","text":", then any call to "},{"type":"codeVoice","code":"g_object_set_property()"},{"text":" results","type":"text"},{"text":" ","type":"text"},{"text":"in ","type":"text"},{"type":"codeVoice","code":"notify"},{"type":"text","text":" being emitted, even if the new value is the same as the old."},{"text":" ","type":"text"},{"text":"If they did pass ","type":"text"},{"code":"explicitNotify","type":"codeVoice"},{"text":", then this signal is emitted only","type":"text"},{"type":"text","text":" "},{"text":"when they explicitly call ","type":"text"},{"type":"codeVoice","code":"g_object_notify()"},{"type":"text","text":" or "},{"code":"g_object_notify_by_pspec()","type":"codeVoice"},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"text","text":"and common practice is to do that only when the value has actually changed."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This signal is typically used to obtain change notification for a"},{"type":"text","text":" "},{"type":"text","text":"single property, by specifying the property name as a detail in the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_signal_connect()"},{"type":"text","text":" call, like this:"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"(C Language Example):","type":"text"}]},{"syntax":"C","code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"It is important to note that you must use"},{"text":" ","type":"text"},{"type":"reference","identifier":"#canonical-parameter-names","isActive":true},{"type":"text","text":" as"},{"text":" ","type":"text"},{"text":"detail strings for the notify signal.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/glibobject\/typemodulesignalname\/notify"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleSignalName"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleSignalName\/notify","interfaceLanguage":"swift"},"kind":"symbol","sections":[],"references":{"doc://GLibObject/documentation/GLibObject/TypeModuleSignalName":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleSignalName","abstract":[],"kind":"symbol","navigatorTitle":[{"text":"TypeModuleSignalName","kind":"identifier"}],"fragments":[{"text":"enum","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"TypeModuleSignalName"}],"title":"TypeModuleSignalName","role":"symbol","type":"topic","url":"\/documentation\/glibobject\/typemodulesignalname"},"doc://GLibObject/documentation/GLibObject":{"abstract":[],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","title":"GLibObject","role":"collection","kind":"symbol","type":"topic","url":"\/documentation\/glibobject"},"doc://GLibObject/documentation/GLibObject/TypeModuleSignalName/notify":{"url":"\/documentation\/glibobject\/typemodulesignalname\/notify","title":"TypeModuleSignalName.notify","abstract":[{"text":"The notify signal is emitted on an object when one of its properties has","type":"text"},{"type":"text","text":" "},{"text":"its value set through ","type":"text"},{"code":"g_object_set_property()","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"g_object_set()"},{"type":"text","text":", et al."}],"role":"symbol","fragments":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"kind":"identifier","text":"notify"}],"type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleSignalName\/notify","kind":"symbol"},"#canonical-parameter-names":{"identifier":"#canonical-parameter-names","type":"link","title":"canonical parameter names","titleInlineContent":[{"type":"text","text":"canonical parameter names"}],"url":"#canonical-parameter-names"}}}