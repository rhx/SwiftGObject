":"text","text":" "},{"text":"signal are difficult to compute. A class implementor may opt to not","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"emit the signal if no one is attached anyway, thus saving the cost"},{"type":"text","text":" "},{"text":"of building the arguments.","type":"text"}]}],"kind":"content"}],"references":{"doc://GLibObject/documentation/GLibObject/ObjectRef/signalHasHandlerPending(signalID:detail:mayBeBlocked:)":{"kind":"symbol","title":"signalHasHandlerPending(signalID:detail:mayBeBlocked:)","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef\/signalHasHandlerPending(signalID:detail:mayBeBlocked:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"signalHasHandlerPending","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"signalID"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"kind":"text","text":", "},{"kind":"externalParam","text":"detail"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GQuark","text":"GQuark"},{"kind":"text","text":", "},{"kind":"externalParam","text":"mayBeBlocked"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"abstract":[{"text":"Returns whether there are any handlers connected to ","type":"text"},{"type":"codeVoice","code":"instance"},{"text":" for the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"given signal id and detail."}],"role":"symbol","url":"\/documentation\/glibobject\/objectref\/signalhashandlerpending(signalid:detail:maybeblocked:)","type":"topic"},"doc://GLibObject/documentation/GLibObject/ObjectRef":{"role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"ObjectRef","kind":"identifier"}],"title":"ObjectRef","url":"\/doc