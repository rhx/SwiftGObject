{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/objectref\/addtoggleref(notify:data:)"]}],"abstract":[{"type":"text","text":"Increases the reference count of the object by one and sets a"},{"text":" ","type":"text"},{"text":"callback to be called when all other references to the object are","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"dropped, or when this is already the last reference to the object"},{"type":"text","text":" "},{"text":"and another reference is established.","type":"text"}],"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef\/addToggleRef(notify:data:)"},"metadata":{"symbolKind":"method","modules":[{"name":"GLibObject"}],"extendedModule":"GLibObject","role":"symbol","externalID":"s:10GLibObject0B8ProtocolPAAE12addToggleRef6notify4datayySvSg_SpySo8_GObjectVGSgs5Int32VtXCSg_AGtF::SYNTHESIZED::s:10GLibObject0B3RefV","roleHeading":"Instance Method","title":"addToggleRef(notify:data:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"addToggleRef","kind":"identifier"},{"kind":"text","text":"("},{"text":"notify","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"GToggleNotify","preciseIdentifier":"c:gobject.h@T@GToggleNotify"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"data"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"text":"?)","kind":"text"}]},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef","doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef\/ObjectProtocol-Implementations"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"addToggleRef","kind":"identifier"},{"text":"(","kind":"text"},{"text":"notify","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:gobject.h@T@GToggleNotify","text":"GToggleNotify"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"data"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer"},{"text":"? = nil)","kind":"text"}]}]},{"content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"This functionality is intended for binding "},{"type":"codeVoice","code":"object"},{"type":"text","text":" to a proxy"},{"text":" ","type":"text"},{"text":"object managed by another memory manager. This is done with two","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"paired references: the strong reference added by"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"text":" and a reverse reference to the proxy","type":"text"},{"type":"text","text":" "},{"type":"text","text":"object which is either a strong reference or weak reference."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The setup is that when there are no other references to "},{"type":"codeVoice","code":"object"},{"text":",","type":"text"},{"type":"text","text":" "},{"type":"text","text":"only a weak reference is held in the reverse direction from "},{"type":"codeVoice","code":"object"},{"type":"text","text":" "},{"type":"text","text":"to the proxy object, but when there are other references held to"},{"text":" ","type":"text"},{"code":"object","type":"codeVoice"},{"type":"text","text":", a strong reference is held. The "},{"type":"codeVoice","code":"notify"},{"type":"text","text":" callback is called"},{"text":" ","type":"text"},{"text":"when the reference from ","type":"text"},{"code":"object","type":"codeVoice"},{"text":" to the proxy object should be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"“toggled” from strong to weak ("},{"type":"codeVoice","code":"is_last_ref"},{"type":"text","text":" true) or weak to strong"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"type":"codeVoice","code":"is_last_ref"},{"type":"text","text":" false)."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Since a (normal) reference must be held to the object before"},{"type":"text","text":" "},{"type":"text","text":"calling "},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"type":"text","text":", the initial state of the reverse"},{"text":" ","type":"text"},{"text":"link is always strong.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Multiple toggle references may be added to the same gobject,"},{"text":" ","type":"text"},{"type":"text","text":"however if there are multiple toggle references to an object, none"},{"type":"text","text":" "},{"type":"text","text":"of them will ever be notified until all but one are removed.  For"},{"type":"text","text":" "},{"type":"text","text":"this reason, you should only ever use a toggle reference if there"},{"text":" ","type":"text"},{"text":"is important state in the proxy object.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that if you unref the object on another thread, then "},{"code":"notify","type":"codeVoice"},{"type":"text","text":" might"},{"text":" ","type":"text"},{"type":"text","text":"still be invoked after "},{"type":"codeVoice","code":"g_object_remove_toggle_ref()"},{"text":", and the object argument","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"might be a dangling pointer. If the object is destroyed on other threads,"},{"text":" ","type":"text"},{"type":"text","text":"you must take care of that yourself."}]},{"inlineContent":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"type":"text","text":" must be released with "},{"type":"codeVoice","code":"g_object_remove_toggle_ref()"},{"text":".","type":"text"}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://GLibObject/documentation/GLibObject/ObjectRef/ObjectProtocol-Implementations":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef\/ObjectProtocol-Implementations","abstract":[],"kind":"article","title":"ObjectProtocol Implementations","role":"collectionGroup","type":"topic","url":"\/documentation\/glibobject\/objectref\/objectprotocol-implementations"},"doc://GLibObject/documentation/GLibObject/ObjectRef/addToggleRef(notify:data:)":{"role":"symbol","type":"topic","abstract":[{"type":"text","text":"Increases the reference count of the object by one and sets a"},{"text":" ","type":"text"},{"text":"callback to be called when all other references to the object are","type":"text"},{"type":"text","text":" "},{"type":"text","text":"dropped, or when this is already the last reference to the object"},{"type":"text","text":" "},{"text":"and another reference is established.","type":"text"}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef\/addToggleRef(notify:data:)","url":"\/documentation\/glibobject\/objectref\/addtoggleref(notify:data:)","title":"addToggleRef(notify:data:)","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"addToggleRef"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"notify"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:gobject.h@T@GToggleNotify","text":"GToggleNotify"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"data"},{"kind":"text","text":": "},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"kind":"text","text":"?)"}]},"doc://GLibObject/documentation/GLibObject/ObjectRef":{"role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"ObjectRef","kind":"identifier"}],"title":"ObjectRef","url":"\/documentation\/glibobject\/objectref","abstract":[{"type":"text","text":"The base object type."}],"type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef","navigatorTitle":[{"text":"ObjectRef","kind":"identifier"}],"kind":"symbol"},"doc://GLibObject/documentation/GLibObject":{"abstract":[],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","title":"GLibObject","role":"collection","kind":"symbol","type":"topic","url":"\/documentation\/glibobject"}}}