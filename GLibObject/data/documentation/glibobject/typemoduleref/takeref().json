{"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/takeRef()","interfaceLanguage":"swift"},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/typemoduleref\/takeref()"]}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"takeRef","kind":"identifier"},{"text":"() -> ","kind":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef","kind":"typeIdentifier","text":"ObjectRef","preciseIdentifier":"s:10GLibObject0B3RefV"},{"kind":"text","text":"!"}]}],"kind":"declarations"},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"text":"In other words, this function will convert a floating reference (if","type":"text"},{"type":"text","text":" "},{"type":"text","text":"present) into a full reference."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Typically you want to use ","type":"text"},{"type":"codeVoice","code":"g_object_ref_sink()"},{"text":" in order to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"automatically do the correct thing with respect to floating or"},{"text":" ","type":"text"},{"text":"non-floating references, but there is one specific scenario where","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this function is helpful."}]},{"inlineContent":[{"text":"The situation where this function is helpful is when creating an API","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"that allows the user to provide a callback function that returns a"},{"type":"text","text":" "},{"type":"text","text":"GObject. We certainly want to allow the user the flexibility to"},{"type":"text","text":" "},{"text":"return a non-floating reference from this callback (for the case","type":"text"},{"type":"text","text":" "},{"type":"text","text":"where the object that is being returned already exists)."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"At the same time, the API style of some popular GObject-based"},{"text":" ","type":"text"},{"text":"libraries (such as Gtk) make it likely that for newly-created GObject","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"instances, the user can be saved some typing if they are allowed to"},{"text":" ","type":"text"},{"type":"text","text":"return a floating reference."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Using this function on the return value of the user’s callback allows"},{"type":"text","text":" "},{"text":"the user to do whichever is more convenient for them. The caller will","type":"text"},{"type":"text","text":" "},{"text":"alway receives exactly one full reference to the value: either the","type":"text"},{"type":"text","text":" "},{"text":"one that was returned in the first place, or a floating reference","type":"text"},{"type":"text","text":" "},{"text":"that has been converted to a full reference.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This function has an odd interaction when combined with","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_object_ref_sink()"},{"text":" running at the same time in another thread on","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the same "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","type":"reference","isActive":true},{"type":"text","text":" instance. If "},{"code":"g_object_ref_sink()","type":"codeVoice"},{"type":"text","text":" runs first then"},{"type":"text","text":" "},{"text":"the result will be that the floating reference is converted to a hard","type":"text"},{"text":" ","type":"text"},{"text":"reference. If ","type":"text"},{"type":"codeVoice","code":"g_object_take_ref()"},{"text":" runs first then the result will be","type":"text"},{"text":" ","type":"text"},{"text":"that the floating reference is converted to a hard reference and an","type":"text"},{"type":"text","text":" "},{"type":"text","text":"additional reference on top of that one is added. It is best to avoid"},{"type":"text","text":" "},{"type":"text","text":"this situation."}]}],"kind":"content"}],"abstract":[{"type":"text","text":"If "},{"type":"codeVoice","code":"object"},{"type":"text","text":" is floating, sink it.  Otherwise, do nothing."}],"metadata":{"symbolKind":"method","modules":[{"name":"GLibObject"}],"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"takeRef","kind":"identifier"},{"kind":"text","text":"() -> "},{"text":"ObjectRef","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject0B3RefV"},{"kind":"text","text":"!"}],"externalID":"s:10GLibObject0B8ProtocolPAAE7takeRefAA0bE0VSgyF::SYNTHESIZED::s:10GLibObject13TypeModuleRefV","roleHeading":"Instance Method","extendedModule":"GLibObject","title":"takeRef()","role":"symbol"},"sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/ObjectProtocol-Implementations"]]},"references":{"doc://GLibObject/documentation/GLibObject/TypeModuleRef/ObjectProtocol-Implementations":{"abstract":[],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/ObjectProtocol-Implementations","title":"ObjectProtocol Implementations","role":"collectionGroup","kind":"article","url":"\/documentation\/glibobject\/typemoduleref\/objectprotocol-implementations","type":"topic"},"doc://GLibObject/documentation/GLibObject/TypeModuleRef":{"abstract":[{"type":"codeVoice","code":"GTypeModule"},{"type":"text","text":" provides a simple implementation of the "},{"type":"codeVoice","code":"GTypePlugin"},{"text":" ","type":"text"},{"type":"text","text":"interface."}],"navigatorTitle":[{"kind":"identifier","text":"TypeModuleRef"}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef","title":"TypeModuleRef","role":"symbol","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"TypeModuleRef","kind":"identifier"}],"type":"topic","url":"\/documentation\/glibobject\/typemoduleref"},"doc://GLibObject/documentation/GLibObject/TypeModuleRef/takeRef()":{"type":"topic","title":"takeRef()","role":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/takeRef()","abstract":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"object"},{"text":" is floating, sink it.  Otherwise, do nothing.","type":"text"}],"kind":"symbol","url":"\/documentation\/glibobject\/typemoduleref\/takeref()","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"takeRef"},{"text":"() -> ","kind":"text"},{"text":"ObjectRef","preciseIdentifier":"s:10GLibObject0B3RefV","kind":"typeIdentifier"},{"text":"!","kind":"text"}]},"doc://GLibObject/documentation/GLibObject/ObjectRef":{"role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"ObjectRef","kind":"identifier"}],"title":"ObjectRef","url":"\/documentation\/glibobject\/objectref","abstract":[{"type":"text","text":"The base object type."}],"type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef","navigatorTitle":[{"text":"ObjectRef","kind":"identifier"}],"kind":"symbol"},"doc://GLibObject/documentation/GLibObject/Object":{"role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Object"}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","navigatorTitle":[{"text":"Object","kind":"identifier"}],"kind":"symbol","type":"topic","title":"Object","url":"\/documentation\/glibobject\/object","abstract":[{"text":"The base object type.","type":"text"}]},"doc://GLibObject/documentation/GLibObject":{"abstract":[],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","title":"GLibObject","role":"collection","kind":"symbol","type":"topic","url":"\/documentation\/glibobject"}}}