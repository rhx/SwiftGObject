{"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"type":"text","text":"Increases the reference count of the object by one and sets a"},{"type":"text","text":" "},{"text":"callback to be called when all other references to the object are","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"dropped, or when this is already the last reference to the object"},{"type":"text","text":" "},{"text":"and another reference is established.","type":"text"}],"kind":"symbol","metadata":{"extendedModule":"GLibObject","externalID":"s:10GLibObject0B8ProtocolPAAE12addToggleRef6notify4datayySvSg_SpySo8_GObjectVGSgs5Int32VtXCSg_AGtF::SYNTHESIZED::s:10GLibObject13TypeModuleRefV","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"addToggleRef","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"notify"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gobject.h@T@GToggleNotify","text":"GToggleNotify","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"text":"data","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"kind":"text","text":"?)"}],"modules":[{"name":"GLibObject"}],"symbolKind":"method","role":"symbol","roleHeading":"Instance Method","title":"addToggleRef(notify:data:)"},"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/addToggleRef(notify:data:)","interfaceLanguage":"swift"},"sections":[],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/ObjectProtocol-Implementations"]]},"variants":[{"paths":["\/documentation\/glibobject\/typemoduleref\/addtoggleref(notify:data:)"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"addToggleRef","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"notify"},{"text":": ","kind":"text"},{"text":"GToggleNotify","kind":"typeIdentifier","preciseIdentifier":"c:gobject.h@T@GToggleNotify"},{"kind":"text","text":"?, "},{"text":"data","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier"},{"kind":"text","text":"? = nil)"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This functionality is intended for binding "},{"code":"object","type":"codeVoice"},{"text":" to a proxy","type":"text"},{"type":"text","text":" "},{"type":"text","text":"object managed by another memory manager. This is done with two"},{"type":"text","text":" "},{"text":"paired references: the strong reference added by","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"type":"text","text":" and a reverse reference to the proxy"},{"type":"text","text":" "},{"text":"object which is either a strong reference or weak reference.","type":"text"}]},{"inlineContent":[{"text":"The setup is that when there are no other references to ","type":"text"},{"code":"object","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"text":"only a weak reference is held in the reverse direction from ","type":"text"},{"code":"object","type":"codeVoice"},{"type":"text","text":" "},{"text":"to the proxy object, but when there are other references held to","type":"text"},{"type":"text","text":" "},{"code":"object","type":"codeVoice"},{"type":"text","text":", a strong reference is held. The "},{"type":"codeVoice","code":"notify"},{"type":"text","text":" callback is called"},{"text":" ","type":"text"},{"type":"text","text":"when the reference from "},{"code":"object","type":"codeVoice"},{"text":" to the proxy object should be","type":"text"},{"text":" ","type":"text"},{"text":"“toggled” from strong to weak (","type":"text"},{"code":"is_last_ref","type":"codeVoice"},{"type":"text","text":" true) or weak to strong"},{"type":"text","text":" "},{"text":"(","type":"text"},{"code":"is_last_ref","type":"codeVoice"},{"text":" false).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Since a (normal) reference must be held to the object before"},{"type":"text","text":" "},{"type":"text","text":"calling "},{"code":"g_object_add_toggle_ref()","type":"codeVoice"},{"text":", the initial state of the reverse","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"link is always strong."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Multiple toggle references may be added to the same gobject,"},{"type":"text","text":" "},{"type":"text","text":"however if there are multiple toggle references to an object, none"},{"type":"text","text":" "},{"text":"of them will ever be notified until all but one are removed.  For","type":"text"},{"type":"text","text":" "},{"type":"text","text":"this reason, you should only ever use a toggle reference if there"},{"type":"text","text":" "},{"text":"is important state in the proxy object.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that if you unref the object on another thread, then "},{"type":"codeVoice","code":"notify"},{"type":"text","text":" might"},{"type":"text","text":" "},{"text":"still be invoked after ","type":"text"},{"type":"codeVoice","code":"g_object_remove_toggle_ref()"},{"type":"text","text":", and the object argument"},{"text":" ","type":"text"},{"text":"might be a dangling pointer. If the object is destroyed on other threads,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"you must take care of that yourself."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"type":"text","text":" must be released with "},{"code":"g_object_remove_toggle_ref()","type":"codeVoice"},{"type":"text","text":"."}]}],"kind":"content"}],"references":{"doc://GLibObject/documentation/GLibObject/TypeModuleRef/addToggleRef(notify:data:)":{"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"addToggleRef","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"notify"},{"text":": ","kind":"text"},{"text":"GToggleNotify","preciseIdentifier":"c:gobject.h@T@GToggleNotify","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"text":"data","kind":"externalParam"},{"kind":"text","text":": "},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"text":"?)","kind":"text"}],"url":"\/documentation\/glibobject\/typemoduleref\/addtoggleref(notify:data:)","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/addToggleRef(notify:data:)","abstract":[{"type":"text","text":"Increases the reference count of the object by one and sets a"},{"type":"text","text":" "},{"type":"text","text":"callback to be called when all other references to the object are"},{"text":" ","type":"text"},{"text":"dropped, or when this is already the last reference to the object","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and another reference is established."}],"type":"topic","kind":"symbol","role":"symbol","title":"addToggleRef(notify:data:)"},"doc://GLibObject/documentation/GLibObject/TypeModuleRef":{"abstract":[{"type":"codeVoice","code":"GTypeModule"},{"type":"text","text":" provides a simple implementation of the "},{"type":"codeVoice","code":"GTypePlugin"},{"text":" ","type":"text"},{"type":"text","text":"interface."}],"navigatorTitle":[{"kind":"identifier","text":"TypeModuleRef"}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef","title":"TypeModuleRef","role":"symbol","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"TypeModuleRef","kind":"identifier"}],"type":"topic","url":"\/documentation\/glibobject\/typemoduleref"},"doc://GLibObject/documentation/GLibObject":{"abstract":[],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","title":"GLibObject","role":"collection","kind":"symbol","type":"topic","url":"\/documentation\/glibobject"},"doc://GLibObject/documentation/GLibObject/TypeModuleRef/ObjectProtocol-Implementations":{"abstract":[],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/ObjectProtocol-Implementations","title":"ObjectProtocol Implementations","role":"collectionGroup","kind":"article","url":"\/documentation\/glibobject\/typemoduleref\/objectprotocol-implementations","type":"topic"}}}