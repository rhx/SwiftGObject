{"metadata":{"externalID":"s:10GLibObject0B8ProtocolPAAE23signalHasHandlerPending0D2ID6detail12mayBeBlockedSbSi_s6UInt32VSbtF::SYNTHESIZED::s:10GLibObject13TypeModuleRefV","title":"signalHasHandlerPending(signalID:detail:mayBeBlocked:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"signalHasHandlerPending","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"signalID"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"text":"detail","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@GQuark","text":"GQuark","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"mayBeBlocked"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"roleHeading":"Instance Method","symbolKind":"method","modules":[{"name":"GLibObject"}],"extendedModule":"GLibObject","role":"symbol"},"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"paths":["\/documentation\/glibobject\/typemoduleref\/signalhashandlerpending(signalid:detail:maybeblocked:)"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/ObjectProtocol-Implementations"]]},"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/signalHasHandlerPending(signalID:detail:mayBeBlocked:)"},"abstract":[{"type":"text","text":"Returns whether there are any handlers connected to "},{"code":"instance","type":"codeVoice"},{"text":" for the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"given signal id and detail."}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"signalHasHandlerPending"},{"kind":"text","text":"("},{"kind":"externalParam","text":"signalID"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"kind":"text","text":", "},{"kind":"externalParam","text":"detail"},{"kind":"text","text":": "},{"text":"GQuark","kind":"typeIdentifier","preciseIdentifier":"c:@T@GQuark"},{"text":", ","kind":"text"},{"text":"mayBeBlocked","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"detail"},{"text":" is 0 then it will only match handlers that were connected","type":"text"},{"type":"text","text":" "},{"text":"without detail.  If ","type":"text"},{"type":"codeVoice","code":"detail"},{"type":"text","text":" is non-zero then it will match handlers"},{"type":"text","text":" "},{"text":"connected both without detail and with the given detail.  This is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"consistent with how a signal emitted with "},{"code":"detail","type":"codeVoice"},{"type":"text","text":" would be delivered"},{"type":"text","text":" "},{"type":"text","text":"to those handlers."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Since 2.46 this also checks for a non-default class closure being"},{"text":" ","type":"text"},{"type":"text","text":"installed, as this is basically always what you want."}]},{"type":"paragraph","inlineContent":[{"text":"One example of when you might use this is when the arguments to the","type":"text"},{"type":"text","text":" "},{"text":"signal are difficult to compute. A class implementor may opt to not","type":"text"},{"text":" ","type":"text"},{"text":"emit the signal if no one is attached anyway, thus saving the cost","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of building the arguments."}]}]}],"references":{"doc://GLibObject/documentation/GLibObject/TypeModuleRef":{"abstract":[{"type":"codeVoice","code":"GTypeModule"},{"type":"text","text":" provides a simple implementation of the "},{"type":"codeVoice","code":"GTypePlugin"},{"text":" ","type":"text"},{"type":"text","text":"interface."}],"navigatorTitle":[{"kind":"identifier","text":"TypeModuleRef"}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef","title":"TypeModuleRef","role":"symbol","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"TypeModuleRef","kind":"identifier"}],"type":"topic","url":"\/documentation\/glibobject\/typemoduleref"},"doc://GLibObject/documentation/GLibObject":{"abstract":[],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","title":"GLibObject","role":"collection","kind":"symbol","type":"topic","url":"\/documentation\/glibobject"},"doc://GLibObject/documentation/GLibObject/TypeModuleRef/signalHasHandlerPending(signalID:detail:mayBeBlocked:)":{"type":"topic","title":"signalHasHandlerPending(signalID:detail:mayBeBlocked:)","role":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/signalHasHandlerPending(signalID:detail:mayBeBlocked:)","abstract":[{"type":"text","text":"Returns whether there are any handlers connected to "},{"code":"instance","type":"codeVoice"},{"text":" for the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"given signal id and detail."}],"kind":"symbol","url":"\/documentation\/glibobject\/typemoduleref\/signalhashandlerpending(signalid:detail:maybeblocked:)","fragments":[{"kind