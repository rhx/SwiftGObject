{"metadata":{"externalID":"s:4GLib11DirProtocolPAAE5unrefyyF::SYNTHESIZED::s:4GLib3DirC","title":"unref()","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"unref","kind":"identifier"},{"kind":"text","text":"()"}],"symbolKind":"method","extendedModule":"GLib","role":"symbol","roleHeading":"Instance Method","modules":[{"name":"GLib"}]},"abstract":[{"text":"Decrements the reference count of ","type":"text"},{"code":"dir","type":"codeVoice"},{"type":"text","text":"."}],"kind":"symbol","sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/dir\/unref()"]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/Dir\/unref()"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/Dir","doc:\/\/GLib\/documentation\/GLib\/Dir\/DirProtocol-Implementations"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"unref","kind":"identifier"},{"kind":"text","text":"()"}]}]},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"text":"Once the reference count reaches zero, the directory will be closed and all","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"resources associated with it will be freed. If [method"},{"type":"codeVoice","code":"GLib.Dir.close"},{"text":"] is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"called when the reference count is greater than zero, the directory is closed"},{"type":"text","text":" "},{"type":"text","text":"but the "},{"code":"GDir","type":"codeVoice"},{"text":" structure will not be freed until its reference count reaches","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"zero."}],"type":"paragraph"},{"inlineContent":