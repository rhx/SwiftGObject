{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/test_option_isolate_dirs"]}],"kind":"symbol","abstract":[{"type":"text","text":"A value that can be passed as an option to [func"},{"type":"codeVoice","code":"GLib.test_init"},{"text":"].","type":"text"}],"sections":[],"metadata":{"role":"symbol","externalID":"s:4GLib24TEST_OPTION_ISOLATE_DIRSSSvp","title":"TEST_OPTION_ISOLATE_DIRS","platforms":[],"fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"TEST_OPTION_ISOLATE_DIRS"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"}],"modules":[{"name":"GLib"}],"roleHeading":"Global Variable","symbolKind":"var"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/TEST_OPTION_ISOLATE_DIRS"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"let"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TEST_OPTION_ISOLATE_DIRS"},{"text":": ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"Creates a unique temporary directory for each unit test and uses sets"},{"text":" ","type":"text"},{"type":"text","text":"XDG directories to point into subdirectories of it for the duration of"},{"text":" ","type":"text"},{"type":"text","text":"the unit test. The directory tree is cleaned up after the test finishes"},{"text":" ","type":"text"},{"text":"successfully.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that this doesn’t take effect until [func"},{"code":"GLib.test_run","type":"codeVoice"},{"text":"] is called,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"so calls to (for example) [func"},{"type":"codeVoice","code":"GLib.get_home_dir"},{"type":"text","text":"] will return the"},{"type":"text","text":" "},{"type":"text","text":"system-wide value when made in a test program’s "},{"code":"main()","type":"codeVoice"},{"type":"text","text":" function."}]},{"type":"paragraph","inlineContent":[{"text":"The following functions will return subdirectories of the temporary directory","type":"text"},{"type":"text","text":" "},{"type":"text","text":"when this option is used. The specific subdirectory paths in use are not"},{"text":" ","type":"text"},{"text":"guaranteed to be stable API — always use a getter function to retrieve them.","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.get_home_dir"},{"text":"]","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"[func","type":"text"},{"code":"GLib.get_user_cache_dir","type":"codeVoice"},{"type":"text","text":"]"}]}]},{"content":[{"inlineContent":[{"text":"[func","type":"text"},{"code":"GLib.get_system_config_dirs","type":"codeVoice"},{"text":"]","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"[func"},{"code":"GLib.get_user_config_dir","type":"codeVoice"},{"text":"]","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"[func","type":"text"},{"type":"codeVoice","code":"GLib.get_system_data_dirs"},{"type":"text","text":"]"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"[func","type":"text"},{"type":"codeVoice","code":"GLib.get_user_data_dir"},{"type":"text","text":"]"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"[func","type":"text"},{"code":"GLib.get_user_state_dir","type":"codeVoice"},{"text":"]","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.get_user_runtime_dir"},{"type":"text","text":"]"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"The subdirectories may not be created by the test harness; as with normal","type":"text"},{"type":"text","text":" "},{"type":"text","text":"calls to functions like [func"},{"code":"GLib.get_user_cache_dir","type":"codeVoice"},{"type":"text","text":"], the caller must"},{"text":" ","type":"text"},{"text":"be prepared to create the directory if it doesn’t exist.","type":"text"},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"TEST_OPTION_ISOLATE_DIRS is deprecated:"}]},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/testOptionIsolateDirs"},{"type":"text","text":" instead."}]}]}],"references":{"doc://GLib/documentation/GLib/testOptionIsolateDirs":{"abstract":[{"type":"text","text":"A value that can be passed as an option to [func"},{"type":"codeVoice","code":"GLib.test_init"},{"type":"text","text":"]."}],"fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"testOptionIsolateDirs","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"}],"role":"symbol","title":"testOptionIsolateDirs","url":"\/documentation\/glib\/testoptionisolatedirs","type":"topic","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/testOptionIsolateDirs"},"doc://GLib/documentation/GLib/TEST_OPTION_ISOLATE_DIRS":{"kind":"symbol","url":"\/documentation\/glib\/test_option_isolate_dirs","role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/TEST_OPTION_ISOLATE_DIRS","title":"TEST_OPTION_ISOLATE_DIRS","deprecated":true,"fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TEST_OPTION_ISOLATE_DIRS","kind":"identifier"},{"kind":"text","text":": "},{"kind":"ty