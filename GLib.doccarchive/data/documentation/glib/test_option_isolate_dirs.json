{"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/TEST_OPTION_ISOLATE_DIRS"},"abstract":[{"type":"text","text":"A value that can be passed as an option to [func"},{"code":"GLib.test_init","type":"codeVoice"},{"text":"].","type":"text"}],"variants":[{"paths":["\/documentation\/glib\/test_option_isolate_dirs"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"metadata":{"roleHeading":"Global Variable","fragments":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"text":"TEST_OPTION_ISOLATE_DIRS","kind":"identifier"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"}],"platforms":[],"symbolKind":"var","role":"symbol","title":"TEST_OPTION_ISOLATE_DIRS","modules":[{"name":"GLib"}],"externalID":"s:4GLib24TEST_OPTION_ISOLATE_DIRSSSvp"},"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"let"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TEST_OPTION_ISOLATE_DIRS"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"}],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"Creates a unique temporary directory for each unit test and uses sets"},{"text":" ","type":"text"},{"type":"text","text":"XDG directories to point into subdirectories of it for the duration of"},{"type":"text","text":" "},{"text":"the unit test. The directory tree is cleaned up after the test finishes","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"successfully."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Note that this doesn’t take effect until [func","type":"text"},{"code":"GLib.test_run","type":"codeVoice"},{"text":"] is called,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"so calls to (for example) [func"},{"code":"GLib.get_home_dir","type":"codeVoice"},{"type":"text","text":"] will return the"},{"text":" ","type":"text"},{"text":"system-wide value when made in a test program’s ","type":"text"},{"type":"codeVoice","code":"main()"},{"type":"text","text":" function."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following functions will return subdirectories of the temporary directory"},{"type":"text","text":" "},{"text":"when this option is used. The specific subdirectory paths in use are not","type":"text"},{"type":"text","text":" "},{"text":"guaranteed to be stable API — always use a getter function to retrieve them.","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.get_home_dir"},{"type":"text","text":"]"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"[func"},{"code":"GLib.get_user_cache_dir","type":"codeVoice"},{"type":"text","text":"]"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"[func"},{"code":"GLib.get_system_config_dirs","type":"codeVoice"},{"type":"text","text":"]"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"[func"},{"code":"GLib.get_user_config_dir","type":"codeVoice"},{"type":"text","text":"]"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.get_system_data_dirs"},{"type":"text","text":"]"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"[func","type":"text"},{"code":"GLib.get_user_data_dir","type":"codeVoice"},{"text":"]","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.get_user_state_dir"},{"text":"]","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.get_user_runtime_dir"},{"text":"]","type":"text"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"The subdirectories may not be created by the test harness; as with normal","type":"text"},{"text":" ","type":"text"},{"text":"calls to functions like [func","type":"text"},{"type":"codeVoice","code":"GLib.get_user_cache_dir"},{"type":"text","text":"], the caller must"},{"type":"text","text":" "},{"text":"be prepared to create the directory if it doesn’t exist.","type":"text"},{"text":" ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"TEST_OPTION_ISOLATE_DIRS is deprecated:"}]},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/testOptionIsolateDirs","isActive":true},{"text":" instead.","type":"text"}]}]}],"references":{"doc://GLib/documentation/GLib/TEST_OPTION_ISOLATE_DIRS":{"abstract":[{"type":"text","text":"A value that can be passed as an option to [func"},{"type":"codeVoice","code":"GLib.test_init"},{"text":"].","type":"text"}],"deprecated":true,"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/TEST_OPTION_ISOLATE_DIRS","kind":"symbol","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"text":"TEST_OPTION_ISOLATE_DIRS","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"}],"role":"symbol","title":"TEST_OPTION_ISOLATE_DIRS","url":"\/documentation\/glib\/test_option_isolate_dirs"},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/testOptionIsolateDirs":{"fragments":[{"kind":"keyword","text":"let"},{"text":" ","kind":"text"},{"kind":"identifier","text":"testOptionIsolateDirs"},{"text":": ","kind":"text"},{"kind"