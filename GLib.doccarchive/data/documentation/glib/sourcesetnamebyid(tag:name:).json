{"kind":"symbol","sections":[],"abstract":[{"type":"text","text":"Sets the name of a source using its ID."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"sourceSetNameByID","kind":"identifier"},{"text":"(","kind":"text"},{"text":"tag","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"kind":"externalParam","text":"name"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"text":"CChar","preciseIdentifier":"s:s5CChara","kind":"typeIdentifier"},{"kind":"text","text":">!)"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"This is a convenience utility to set source names from the return","type":"text"},{"type":"text","text":" "},{"text":"value of [func","type":"text"},{"type":"codeVoice","code":"GLib.idle_add"},{"text":"], [func","type":"text"},{"type":"codeVoice","code":"GLib.timeout_add"},{"type":"text","text":"], etc."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is a programmer error to attempt to set the name of a non-existent"},{"type":"text","text":" "},{"type":"text","text":"source."}]},{"inlineContent":[{"text":"More specifically: source IDs can be reissued after a source has been","type":"text"},{"type":"text","text":" "},{"type":"text","text":"destroyed and therefore it is never valid to use this function with a"},{"type":"text","text":" "},{"type":"text","text":"source ID which may have already been removed.  An example is when"},{"text":" ","type":"text"},{"text":"scheduling an idle to run in another thread with [func","type":"text"},{"type":"codeVoice","code":"GLib.idle_add"},{"type":"text","text":"]: the"},{"text":" ","type":"text"},{"text":"idle may already have run and been removed by the time this function","type":"text"},{"type":"text","text":" "},{"text":"is called on its (now invalid) source ID.  This source ID may have","type":"text"},{"text":" ","type":"text"},{"text":"been reissued, leading to the operation being performed against the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"wrong source."}],"type":"paragraph"}],"kind":"content"}],"metadata":{"roleHeading":"Function","role":"symbol","symbolKind":"func","externalID":"s:4GLib17sourceSetNameByID3tag4nameySi_SPys4Int8VGSgtF","title":"sourceSetNameByID(tag:name:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"sourceSetNameByID"},{"text":"(","kind":"text"},{"text":"tag","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"name"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"CChar","preciseIdentifier":"s:s5CChara"},{"text":">!)","kind":"text"}],"modules":[{"name":"GLib"}]},"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/glib\/sourcesetnamebyid(tag:name:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/sourceSetNameByID(tag:name:)","interfaceLanguage":"swift"},"references":{"doc://GLib/documentation/GLib/sourceSetNameByID(tag:name:)":{"role":"symbol","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"sourceSetNameByID","kind":"identifier"},{"text":"(","kind":"text"},{"text":"tag","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":", "},{"kind