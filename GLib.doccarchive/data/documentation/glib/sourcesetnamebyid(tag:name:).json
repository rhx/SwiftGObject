{"variants":[{"paths":["\/documentation\/glib\/sourcesetnamebyid(tag:name:)"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"symbolKind":"func","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"sourceSetNameByID"},{"kind":"text","text":"("},{"text":"tag","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"text":"name","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:s5CChara","text":"CChar"},{"text":">!)","kind":"text"}],"externalID":"s:4GLib17sourceSetNameByID3tag4nameySi_SPys4Int8VGSgtF","title":"sourceSetNameByID(tag:name:)","modules":[{"name":"GLib"}],"roleHeading":"Function"},"abstract":[{"type":"text","text":"Sets the name of a source using its ID."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"sourceSetNameByID"},{"kind":"text","text":"("},{"kind":"externalParam","text":"tag"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"text":"name","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"s:s5CChara","text":"CChar"},{"text":">!)","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is a convenience utility to set source names from the return"},{"text":" ","type":"text"},{"type":"text","text":"value of [func"},{"code":"GLib.idle_add","type":"codeVoice"},{"text":"], [func","type":"text"},{"code":"GLib.timeout_add","type":"codeVoice"},{"type":"text","text":"], etc."}]},{"inlineContent":[{"text":"It is a programmer error to attempt to set the name of a non-existent","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"source."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"More specifically: source IDs can be reissued after a source has been"},{"type":"text","text":" "},{"text":"destroyed and therefore it is never valid to use this function with a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"source ID which may have already been removed.  An example is when"},{"text":" ","type":"text"},{"type":"text","text":"scheduling an idle to run in another thread with [func"},{"code":"GLib.idle_add","type":"codeVoice"},{"text":"]: the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"idle may already have run and been removed by the time this function"},{"type":"text","text":" "},{"type":"text","text":"is called on its (now invalid) source ID.  This source ID may have"},{"text":" ","type":"text"},{"text":"been reissued, leading to the operation being performed against the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"wrong source."}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/sourceSetNameByID(tag:name:)"},"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","references":{"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/sourceSetNameByID(tag:name:)":{"kind":"symbol","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sourceSetNameByID","kind":"identifier"},