ileFlags\/multiline","isActive":true},{"type":"text","text":" is set, the “start of line” and “end of line”"},{"type":"text","text":" "},{"type":"text","text":"constructs match immediately following or immediately before any"},{"text":" ","type":"text"},{"text":"newline in the string, respectively, as well as at the very start","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and end. This can be changed within a pattern by a “(?m)” option"},{"text":" ","type":"text"},{"type":"text","text":"setting."}],"url":"\/documentation\/glib\/regexcompileflags\/multiline"},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"}}}