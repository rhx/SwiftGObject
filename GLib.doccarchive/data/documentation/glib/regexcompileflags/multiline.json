{"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"static"},{"text":" ","kind":"text"},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"multiline","kind":"identifier"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags","preciseIdentifier":"s:4GLib17RegexCompileFlagsV","kind":"typeIdentifier","text":"RegexCompileFlags"}]}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags"]]},"metadata":{"roleHeading":"Type Property","externalID":"s:4GLib17RegexCompileFlagsV9multilineACvpZ","title":"multiline","symbolKind":"property","modules":[{"name":"GLib"}],"fragments":[{"text":"static","kind":"keyword"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"text":" ","kind":"text"},{"text":"multiline","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"RegexCompileFlags","preciseIdentifier":"s:4GLib17RegexCompileFlagsV"}],"role":"symbol"},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags\/multiline","interfaceLanguage":"swift"},"kind":"symbol","abstract":[{"type":"text","text":"By default, GRegex treats the strings as consisting"},{"type":"text","text":" "},{"type":"text","text":"of a single line of characters (even if it actually contains"},{"text":" ","type":"text"},{"text":"newlines). The “start of line” metacharacter (”^”) matches only","type":"text"},{"type":"text","text":" "},{"text":"at the start of the string, while the “end of line” metacharacter","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(”$”) matches only at the end of the string, or before a terminating"},{"type":"text","text":" "},{"type":"text","text":"newline (unless "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags\/dollarEndonly"},{"text":" is set). When","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags\/multiline"},{"text":" is set, the “start of line” and “end of line”","type":"text"},{"type":"text","text":" "},{"text":"constructs match immediately following or immediately before any","type":"text"},{"text":" ","type":"text"},{"text":"newline in the string, respectively, as well as at the very start","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and end. This can be changed within a pattern by a “(?m)” option"},{"type":"text","text":" "},{"text":"setting.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/regexcompileflags\/multiline"]}],"references":{"doc://GLib/documentation/GLib/RegexCompileFlags/dollarEndonly":{"abstract":[{"type":"text","text":"A dollar metacharacter (”$”) in the pattern"},{"text":" ","type":"text"},{"type":"text","text":"matches only at the end of the string. Without this option, a"},{"type":"text","text":" "},{"text":"dollar also matches immediately before the final character if","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"it is a newline (but not before any other newlines). This option"},{"type":"text","text":" "},{"type":"text","text":"is ignored if "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags\/multiline","isActive":true},{"type":"text","text":" is set."}],"title":"dollarEndonly","role":"symbol","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags\/dollarEndonly","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"dollarEndonly"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib17RegexCompileFlagsV","text":"RegexCompileFlags"}],