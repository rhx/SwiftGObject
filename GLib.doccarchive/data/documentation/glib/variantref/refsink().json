{"sections":[],"metadata":{"title":"refSink()","modules":[{"name":"GLib"}],"symbolKind":"method","extendedModule":"GLib","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"refSink","kind":"identifier"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef"},{"text":"!","kind":"text"}],"externalID":"s:4GLib15VariantProtocolPAAE7refSinkAA0B3RefVSgyF::SYNTHESIZED::s:4GLib10VariantRefV","role":"symbol"},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/VariantRef\/refSink()","interfaceLanguage":"swift"},"kind":"symbol","primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"refSink"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef","text":"VariantRef"},{"kind":"text","text":"!"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Calling "},{"type":"codeVoice","code":"g_variant_ref_sink()"},{"type":"text","text":" on a "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true,"type":"reference"},{"text":" with a floating reference","type":"text"},{"type":"text","text":" "},{"text":"will convert the floating reference into a full reference.  Calling","type":"text"},{"type":"text","text":" "},{"code":"g_variant_ref_sink()","type":"codeVoice"},{"type":"text","text":" on a non-floating "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference","isActive":true},{"text":" results in an","type":"text"},{"type":"text","text":" "},{"text":"additional normal reference being added.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"In other words, if the ","type":"text"},{"code":"value","type":"codeVoice"},{"type":"text","text":" is floating, then this call “assumes"},{"text":" ","type":"text"},{"type":"text","text":"ownership” of the floating reference, converting it to a normal"},{"type":"text","text":" "},{"type":"text","text":"reference.  If the "},{"code":"value","type":"codeVoice"},{"text":" is not floating, then this call adds a","type":"text"},{"text":" ","type":"text"},{"text":"new normal reference increasing the reference count by one.","type":"text"}]},{"inlineContent":[{"type":"text","text":"All calls that result in a "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"type":"text","text":" instance being inserted into a"},{"type":"text","text":" "},{"text":"container will call ","type":"text"},{"code":"g_variant_ref_sink()","type":"codeVoice"},{"type":"text","text":" on the instance.  This means"},{"type":"text","text":" "},{"text":"that if the value was just created (and has only its floating","type":"text"},{"type":"text","text":" "},{"type":"text","text":"reference) then the container will assume sole ownership of the value"},{"type":"text","text":" "},{"text":"at that point and the caller will not need to unreference it.  This","type":"text"},{"type":"text","text":" "},{"text":"makes certain common styles of programming much easier while still","type":"text"},{"type":"text","text":" "},{"text":"maintaining normal refcounting semantics in situations where values","type":"text"},{"text":" ","type":"text"},{"text":"are not floating.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"schemaVersion":{"patch":0,"minor":3,"major":0},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/VariantRef","doc:\/\/GLib\/documentation\/GLib\/VariantRef\/VariantProtocol-Implementations"]]},"variants":[{"paths":["\/documentation\/glib\/variantref\/refsink()"],"traits":[{"interfaceLanguage":"swift"}]}],"abstrac