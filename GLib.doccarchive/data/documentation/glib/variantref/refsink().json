":"text","text":" is a variant datatype; it can contain one or more values"},{"type":"text","text":" "},{"text":"along with information about the type of the values.","type":"text"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"Variant","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","navigatorTitle":[{"text":"Variant","kind":"identifier"}],"title":"Variant","role":"symbol","type":"topic","kind":"symbol","url":"\/documentation\/glib\/variant"},"doc://GLib/documentation/GLib/VariantRef":{"abstract":[{"code":"GVariant","type":"codeVoice"},{"text":" is a variant datatype; it can contain one or more values","type":"text"},{"type":"text","text":" "},{"type":"text","text":"along with information about the type of the values."}],"type":"topic","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"VariantRef","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef","title":"VariantRef","url":"\/documentation\/glib\/variantref","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"VariantRef"}]}}}