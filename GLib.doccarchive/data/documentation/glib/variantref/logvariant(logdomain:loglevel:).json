vert the value into a string."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For more details on its usage and about the parameters, see [func"},{"type":"codeVoice","code":"GLib.log_structured"},{"text":"].","type":"text"}]}],"kind":"content"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://GLib/documentation/GLib/VariantRef/VariantProtocol-Implementations":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef\/VariantProtocol-Implementations","url":"\/documentation\/glib\/variantref\/variantprotocol-implementations","title":"VariantProtocol Implementations","abstract":[],"kind":"article","role":"collectionGroup","type":"topic"},"doc://GLib/documentation/GLib/Variant":{"abstract":[{"code":"GVariant","type":"codeVoice"},{"type":"text","text":" is a variant datatype; it can contain one or more values"},{"type":"text","text":" "},{"text":"along with information about the type of the values.","type":"text"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"Variant","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","navigatorTitle":[{"text":"Variant","kind":"identifier"}],"title":"Variant","role":"symbol","type":"topic","kind":"symbol","url":"\/documentation\/glib\/variant"},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/LogLevelFlags":{"abstract":[{"text":"Flags specifying the level of log messages.","type":"text"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"LogLevelFlags","kind":"identifier"}],"url":"\/documentation\/glib\/loglevelflags","role":"symbol","navigatorTitle":[{"text":"LogLevelFlags","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/LogLevelFlags","title":"LogLevelFlags"},"doc://GLib/d