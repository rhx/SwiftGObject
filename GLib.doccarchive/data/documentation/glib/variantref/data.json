e size","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of the result."}]},{"inlineContent":[{"type":"text","text":"To deserialize the data returned by this function, in addition to the"},{"type":"text","text":" "},{"type":"text","text":"serialized data, you must know the type of the "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true,"type":"reference"},{"text":", and (if the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"machine might be different) the endianness of the machine that stored"},{"type":"text","text":" "},{"text":"it. As a result, file formats or network messages that incorporate","type":"text"},{"type":"text","text":" "},{"type":"text","text":"serialized "},{"type":"codeVoice","code":"GVariants"},{"type":"text","text":" must include this information either"},{"type":"text","text":" "},{"type":"text","text":"implicitly (for instance “the file always contains a"},{"type":"text","text":" "},{"code":"G_VARIANT_TYPE_VARIANT","type":"codeVoice"},{"type":"text","text":" and it is always in little-endian order”) or"},{"type":"text","text":" "},{"type":"text","text":"explicitly (by storing the type and\/or endianness in addition to the"},{"type":"text","text":" "},{"text":"serialized data).","type":"text"}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/variantref\/data"]}],"metadata":{"externalID":"s:4GLib15VariantProtocolPAAE4dataSVSgvp::SYNTHESIZED::s:4GLib10VariantRefV","symbolKind":"property","role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"data"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gconstpointer","text":"gconstpointer"},{"text":"?","kind":"text"}],"roleHeading":"Instance Property","modules":[{"name":"GLib"}],"extendedModule":"GLib","title":"data"},"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc