"}]}]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"value","type":"codeVoice"},{"text":" is a fixed-sized value that was deserialized from a","type":"text"},{"type":"text","text":" "},{"text":"corrupted serialized container then ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" may be returned.  In this"},{"text":" ","type":"text"},{"text":"case, the proper thing to do is typically to use the appropriate","type":"text"},{"text":" ","type":"text"},{"text":"number of nul bytes in place of ","type":"text"},{"code":"value","type":"codeVoice"},{"type":"text","text":".  If "},{"code":"value","type":"codeVoice"},{"text":" is not fixed-sized","type":"text"},{"type":"text","text":" "},{"type":"text","text":"then "},{"code":"nil","type":"codeVoice"},{"text":" is never returned.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"In the case that ","type":"text"},{"type":"codeVoice","code":"value"},{"text":" is already in serialized form, this function","type":"text"},{"type":"text","text":" "},{"text":"is ","type":"text"},{"type":"codeVoice","code":"O(1)"},{"text":".  If the value is not already in serialized form,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"serialization occurs implicitly and is approximately "},{"type":"codeVoice","code":"O(n)"},{"text":" in the size","type":"text"},{"text":" ","type":"text"},{"text":"of the result.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"To deserialize the data returned by this function, in addition to the","type":"text"},{"text":" ","type":"text"},{"text":"serialized data, you must know the type of the ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"type":"text","text":", and (if the"},{"type":"text","text":" "},{"text":"machine might be different) the endianness of the machine that stored","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"it. As a result, file formats or network messages that incorporate"},{"type":"text","text":" "},{"type":"text","text":"serialized "},{"type":"codeVoice","code":"GVariants"},{"type":"text","text":" must include this information either"},{"type":"text","text":" "},{"type":"text","text":"implicitly (for instance “the file always contains a"},{"text":" ","type":"text"},{"code":"G_VARIANT_TYPE_VARIANT","type":"codeVoice"},{"type":"text","text":" and it is always in little-endian order”) or"},{"text":" ","type":"text"},{"text":"explicitly (by storing the type and\/or endianness in addition to the","type":"text"},{"text":" ","type":"text"},{"text":"serialized data).","type":"text"}]}]}],"references":{"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/VariantRef":{"role":"symbol","type":"topic","url":"\/documentation\/glib\/variantref","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef","abstract":[{"code":"GVariant","type":"codeVoice"},{"text":" is a variant datatype; it can contain one or more values","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"along with information about the type of the values."}],"kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"VariantRef","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"VariantRef"}],"title":"VariantRef"},"doc://GLib/documentation/GLib/VariantRef/VariantProtocol-Implementations":{"title":"VariantProtocol Implementations","type":"topic","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef\/VariantProtocol-Implementations","kind":"article","role":"collectionGroup","url":"\/documentation\/glib\/variantref\/variantprotocol-implementations"},"doc://GLib/docume