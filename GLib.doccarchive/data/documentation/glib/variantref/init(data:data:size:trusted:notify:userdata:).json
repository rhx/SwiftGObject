type":"text"},{"text":" ","type":"text"},{"type":"text","text":"file in the user’s home directory, etc."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"data"},{"type":"text","text":" was not stored in this machine’s native endianness, any multi-byte"},{"text":" ","type":"text"},{"text":"numeric values in the returned variant will also be in non-native","type":"text"},{"type":"text","text":" "},{"text":"endianness. ","type":"text"},{"code":"g_variant_byteswap()","type":"codeVoice"},{"type":"text","text":" can be used to recover the original values."}]},{"inlineContent":[{"type":"codeVoice","code":"notify"},{"text":" will be called with ","type":"text"},{"code":"userData","type":"codeVoice"},{"type":"text","text":" when "},{"code":"data","type":"codeVoice"},{"type":"text","text":" is no longer"},{"type":"text","text":" "},{"text":"needed.  The exact time of this call is unspecified and might even be","type":"text"},{"text":" ","type":"text"},{"text":"before this function returns.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Note: ","type":"text"},{"code":"data","type":"codeVoice"},{"type":"text","text":" must be backed by memory that is aligned appropriately for the"},{"type":"text","text":" "},{"code":"type","type":"codeVoice"},{"type":"text","text":" being loaded. Otherwise this function will internally create a copy of"},{"type":"text","text":" "},{"text":"the memory (since GLib 2.60) or (in older versions) fail and exit the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"process."}],"type":"paragraph"}],"kind":"content"}],"sections":[],"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"symbolKind":"init","fragments":[{"kind":"identifier","text":"init"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"VariantTypeT"},{"kind":"text","text":">("},{"text":"data","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"VariantTypeT","kind":"t