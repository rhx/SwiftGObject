"},{"type":"text","text":" "},{"code":"g_variant_print()","type":"codeVoice"},{"type":"text","text":"’s annotated types like "},{"code":"int64 -1000","type":"codeVoice"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"There may be implementation specific restrictions on deeply nested values,"},{"text":" ","type":"text"},{"type":"text","text":"which would result in a "},{"code":"recursion","type":"codeVoice"},{"type":"text","text":" error. "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true,"type":"reference"},{"type":"text","text":" is"},{"type":"text","text":" "},{"type":"text","text":"guaranteed to handle nesting up to at least 64 levels."}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/VariantRef"]]},"sections":[],"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/VariantRef\/parse(type:text:limit:endptr:)","interfaceLanguage":"swift"},"references":{"doc://GLib/documentation/GLib/Variant":{"abstract":[{"code":"GVariant","type":"codeVoice"},{"type":"text","text":" is a variant datatype; it can contain one or more values"},{"type":"text","text":" "},{"text":"along with information about the type of the values.","type":"text"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"Variant","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","navigatorTitle":[{"text":"Variant","kind":"identifier"}],"title":"Variant","role":"symbol","type":"topic","kind":"symbol","url":"\/documentation\/glib\/variant"},"doc://GLib/documentation/GLib/VariantRef/parse(type:text:limit:endptr:)":{"abstract":[{"text":"Parses a ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"type":"text","text":" from a text representation."}],"title":"parse(type:text:limit:endptr:)","role":"symbol","