{"metadata":{"roleHeading":"Instance Property","externalID":"s:4GLib15VariantProtocolPAAE10normalFormAA0B3RefVSgvp::SYNTHESIZED::s:4GLib10VariantRefV","extendedModule":"GLib","role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"normalForm","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"modules":[{"name":"GLib"}],"symbolKind":"property","title":"normalForm"},"abstract":[{"text":"Gets a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference"},{"type":"text","text":" instance that has the same value as "},{"code":"value","type":"codeVoice"},{"text":" and is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"trusted to be in normal form."}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"normalForm"},{"kind":"text","text":": "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef","kind":"typeIdentifier","text":"VariantRef","preciseIdentifier":"s:4GLib10VariantRefV"},{"text":"! { ","kind":"text"},{"kind":"keyword","text":"get"},{"text":" }","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"inlineContent":[{"text":"If ","type":"text"},{"code":"value","type":"codeVoice"},{"type":"text","text":" is already trusted to be in normal form then a new"},{"text":" ","type":"text"},{"type":"text","text":"reference to "},{"type":"codeVoice","code":"value"},{"type":"text","text":" is returned."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"value"},{"type":"text","text":" is not already trusted, then it is scanned to check if it"},{"text":" ","type":"text"},{"text":"i