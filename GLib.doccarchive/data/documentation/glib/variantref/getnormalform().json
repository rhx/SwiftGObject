{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/VariantRef","doc:\/\/GLib\/documentation\/GLib\/VariantRef\/VariantProtocol-Implementations"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/VariantRef\/getNormalForm()"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"getNormalForm"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef","kind":"typeIdentifier","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef"},{"text":"!","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"value"},{"text":" is already trusted to be in normal form then a new","type":"text"},{"type":"text","text":" "},{"type":"text","text":"reference to "},{"code":"value","type":"codeVoice"},{"text":" is returned.","type":"text"}]},{"inlineContent":[{"type":"text","text":"If "},{"code":"value","type":"codeVoice"},{"type":"text","text":" is not already trusted, then it is scanned to check if it"},{"type":"text","text":" "},{"type":"text","text":"is in normal form.  If it is found to be in normal form then it is"},{"type":"text","text":" "},{"type":"text","text":"marked as trusted and a new reference to it is returned."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"value"},{"text":" is found not to be in normal form then a new trusted","type":"text"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"type":"text","text":" is created with the same value as "},{"type":"codeVoice","code":"value"},{"type":"text","text":". The non-normal parts of"},{"type":"text","text":" "},{"code":"value","type":"codeVoice"},{"type":"text","text":" will be replaced with default values which are guaranteed to be in"},{"type":"text","text":" "},{"type":"text","text":"normal form."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It makes sense to call this function if you’ve received "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference","isActive":true},{"type":"text","text":" "},{"text":"data from untrusted sources and you want to ensure your serialized","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"output is definitely in normal form."}]},{"inlineContent":[{"text":"If ","type":"text"},{"code":"value","type":"codeVoice"},{"text":" is already in normal form, a new reference will be returned","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(which will be floating if "},{"type":"codeVoice","code":"value"},{"type":"text","text":" is floating). If it is not in normal form,"},{"type":"text","text":" "},{"type":"text","text":"the newly created "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"type":"text","text":" will be returned with a single non-floating"},{"text":" ","type":"text"},{"type":"text","text":"reference. Typically, "},{"code":"g_variant_take_ref()","type":"codeVoice"},{"text":" should be called on the return","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"value from this function to guarantee ownership of a single non-floating"},{"text":" ","type":"text"},{"type":"text","text":"reference to it."}],"type":"paragraph"}],"kind":"content"}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/variantref\/getnormalform()"]}],"metadata":{"extendedModule":"GLib","externalID":"s:4GLib15VariantProtocolPAAE13getNormalFormAA0B3RefVSgyF::SYNTHESIZED::s:4GLib10VariantRefV","symbolKind":"method","modules":[{"name":"GLib"}],"