{"abstract":[{"text":"Performs a byteswapping operation on the contents of ","type":"text"},{"type":"codeVoice","code":"value"},{"type":"text","text":".  The"},{"text":" ","type":"text"},{"text":"result is that all multi-byte numeric data contained in ","type":"text"},{"type":"codeVoice","code":"value"},{"type":"text","text":" is"},{"text":" ","type":"text"},{"text":"byteswapped.  That includes 16, 32, and 64bit signed and unsigned","type":"text"},{"type":"text","text":" "},{"type":"text","text":"integers as well as file handles and double precision floating point"},{"text":" ","type":"text"},{"text":"values.","type":"text"}],"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/VariantRef","doc:\/\/GLib\/documentation\/GLib\/VariantRef\/VariantProtocol-Implementations"]]},"variants":[{"paths":["\/documentation\/glib\/variantref\/byteswap()"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"extendedModule":"GLib","symbolKind":"method","externalID":"s:4GLib15VariantProtocolPAAE8byteswapAA0B3RefVSgyF::SYNTHESIZED::s:4GLib10VariantRefV","title":"byteswap()","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"byteswap","kind":"identifier"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef","kind":"typeIdentifier"},{"kind":"text","text":"!"}],"role":"symbol","modules":[{"name":"GLib"}]},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/VariantRef\/byteswap()","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"byteswap","kind":"identifier"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef","text":"VariantRef","preciseIdentifier":"s:4GLib10VariantRefV"},{"kind":"text","text":"!"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"This function is an identity mapping on any value that does not","type":"text"},{"text":" ","type":"text"},{"text":"contain multi-byte numeric data.  That include strings, booleans,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"bytes and containers containing only these things (recursively)."}]},{"inlineContent":[{"text":"While this function can safely handle untrusted, non-normal data, it is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"recommended to check whether the input is in normal form beforehand, using"},{"text":" ","type":"text"},{"code":"g_variant_is_normal_form()","type":"codeVoice"},{"type":"text","text":", and to reject non-normal inputs if your"},{"type":"text","text":" "},{"type":"text","text":"application can be strict about what inputs it rejects."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The returned value is always in normal form and is marked as trusted."},{"type":"text","text":" "},{"type":"text","text":"A full, not floating, reference is returned."}]}]}],"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://GLib/documentation/GLib/VariantRef":{"abstract":[{"code":"GVariant","type":"codeVoice"},{"text":" is a variant datatype; it can contain one or more values","type":"text"},{"type":"text","text":" "},{"type":"text","text":"along with information about the type of the values."}],"type":"topic","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"VariantRef","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef","title":"VariantRef","url":"\/documentation\/glib\/variantref","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"VariantRef"}]},"doc://GLib/documentation/GLib":{"url":"\/documentatio