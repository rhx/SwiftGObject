{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"takeRef","kind":"identifier"},{"text":"() -> ","kind":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef","kind":"typeIdentifier","text":"VariantRef","preciseIdentifier":"s:4GLib10VariantRefV"},{"kind":"text","text":"!"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"Typically you want to use ","type":"text"},{"type":"codeVoice","code":"g_variant_ref_sink()"},{"text":" in order to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"automatically do the correct thing with respect to floating or"},{"text":" ","type":"text"},{"type":"text","text":"non-floating references, but there is one specific scenario where"},{"text":" ","type":"text"},{"text":"this function is helpful.","type":"text"}]},{"inlineContent":[{"type":"text","text":"The situation where this function is helpful is when creating an API"},{"type":"text","text":" "},{"type":"text","text":"that allows the user to provide a callback function that returns a"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"type":"text","text":".  We certainly want to allow the user the flexibility to"},{"text":" ","type":"text"},{"type":"text","text":"return a non-floating reference from this callback (for the case"},{"text":" ","type":"text"},{"type":"text","text":"where the value that is being returned already exists)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"At the same time, the style of the ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference","isActive":true},{"type":"text","text":" API makes it likely that"},{"text":" ","type":"text"},{"text":"for newly-created ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"type":"text","text":" instances, the user can be saved some"},{"type":"text","text":" "},{"text":"typing if they are allowed to return a ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":" with a floating","type":"text"},{"text":" ","type":"text"},{"text":"reference.","type":"text"}]},{"inlineContent":[{"text":"Using this function on the return value of the user’s callback allows","type":"text"},{"text":" ","type":"text"},{"text":"the user to do whichever is more convenient for them.  The caller","type":"text"},{"type":"text","text":" "},{"text":"will always receives exactly one full reference to the value: either","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the one that was returned in the first place, or a floating reference"},{"type":"text","text":" "},{"type":"text","text":"that has been converted to a full reference."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This function has an odd interaction when combined with","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_variant_ref_sink()"},{"text":" running at the same time in another thread on","type":"text"},{"type":"text","text":" "},{"text":"the same ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":" instance.  If ","type":"text"},{"code":"g_variant_ref_sink()","type":"codeVoice"},{"type":"text","text":" runs first then"},{"text":" ","type":"text"},{"type":"text","text":"the result will be that the floating reference is converted to a hard"},{"text":" ","type":"text"},{"text":"reference.  If ","type":"text"},{"type":"codeVoice","code":"g_variant_take_ref()"},{"type":"text","text":" runs first then the result will"},{"text":" ","type":"text"},{"type":"text","text":"be that the floating reference is converted to a hard reference and"},{"type":"text","text":" "},{"type":"text","text":"an additional reference on top of that one is added.  It is best to"},{"type":"text","text":" "},{"type":"text","text":"avoid this situation."}]}],"kind":"content"}],"metadata":{"roleHeading":"Instance Method","externalID":"s:4GLib15VariantProtocolPAAE7takeRefAA0bE0VSgyF::SYNTHESIZED::s:4GLib10VariantRefV","extendedModule":"GLib","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"takeRef","kind":"identifier"},{"kind":"text","text":"() -> "},{"text":"VariantRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV"},{"text":"!","kind":"text"}],"modules":[{"name":"GLib"}],"symbolKind":"method","title":"takeRef()"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/VariantRef","doc:\/\/GLib\/documentation\/GLib\/VariantRef\/VariantProtocol-Implementations"]]},"sections":[],"abstract":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"value"},{"text":" is floating, sink it.  Otherwise, do nothing.","type":"text"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/variantref\/takeref()"]}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/VariantRef\/takeRef()"},"references":{"doc://GLib/documentation/GLib/Variant":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Variant"}],"kind":"symbol","title":"Variant","role":"symbol","abstract":[{"type":"codeVoice","code":"GVariant"},{"type":"text","text":" is a variant datatype; it can contain one or more values"},{"text":" ","type":"text"},{"type":"text","text":"along with information about the type of the values."}],"url":"\/documentation\/glib\/variant","navigatorTitle":[{"text":"Variant","kind":"identifier"}]},"doc://GLib/documentation/GLib/VariantRef/takeRef()":{"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"takeRef","kind":"identifier"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","text":"VariantRef","preciseIdentifier":"s:4GLib10VariantRefV"},{"kind":"text","text":"!"}],"role":"symbol","abstract":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"value"},{"text":" is floating, sink it.  Otherwise, do nothing.","type":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef\/takeRef()","type":"topic","kind":"symbol","title":"takeRef()","url":"\/documentation\/glib\/variantref\/takeref()"},"doc://GLib/documentation/GLib/VariantRef":{"role":"symbol","type":"topic","url":"\/documentation\/glib\/variantref","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef","abstract":[{"code":"GVariant","type":"codeVoice"},{"text":" is a variant datatype; it can contain one or more values","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"along with information about the type of the values."}],"kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"VariantRef","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"VariantRef"}],"title":"VariantRef"},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/VariantRef/VariantProtocol-Implementations":{"title":"VariantProtocol Implementations","type":"topic","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef\/VariantProtocol-Implementations","kind":"article","role":"collectionGroup","url":"\/documentation\/glib\/variantref\/variantprotocol-implementations"}}}