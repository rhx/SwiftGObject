{"kind":"symbol","sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/VariantRef","doc:\/\/GLib\/documentation\/GLib\/VariantRef\/VariantProtocol-Implementations"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/variantref\/takeref()"]}],"abstract":[{"text":"If ","type":"text"},{"code":"value","type":"codeVoice"},{"text":" is floating, sink it.  Otherwise, do nothing.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"takeRef","kind":"identifier"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:4GLib10VariantRefV","kind":"typeIdentifier","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef","text":"VariantRef"},{"text":"!","kind":"text"}],"platforms":["macOS"]}]},{"content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"text":"Typically you want to use ","type":"text"},{"type":"codeVoice","code":"g_variant_ref_sink()"},{"type":"text","text":" in order to"},{"type":"text","text":" "},{"text":"automatically do the correct thing with respect to floating or","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"non-floating references, but there is one specific scenario where"},{"type":"text","text":" "},{"type":"text","text":"this function is helpful."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The situation where this function is helpful is when creating an API","type":"text"},{"type":"text","text":" "},{"type":"text","text":"that allows the user to provide a callback function that returns a"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"type":"text","text":".  We certainly want to allow the user the flexibility to"},{"type":"text","text":" "},{"text":"return a non-floating reference from this callback (for the case","type":"text"},{"text":" ","type":"text"},{"text":"where the value that is being returned already exists).","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"At the same time, the style of the "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"text":" API makes it likely that","type":"text"},{"type":"text","text":" "},{"text":"for newly-created ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference"},{"text":" instances, the user can be saved some","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"typing if they are allowed to return a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":" with a floating","type":"text"},{"text":" ","type":"text"},{"text":"reference.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Using this function on the return value of the user’s callback allows"},{"type":"text","text":" "},{"text":"the user to do whichever is more convenient for them.  The caller","type":"text"},{"type":"text","text":" "},{"text":"will always receives exactly one full reference to the value: either","type":"text"},{"text":" ","type":"text"},{"text":"the one that was returned in the first place, or a floating reference","type":"text"},{"type":"text","text":" "},{"text":"that has been converted to a full reference.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This function has an odd interaction when combined with"},{"type":"text","text":" "},{"code":"g_variant_ref_sink()","type":"codeVoice"},{"type":"text","text":" running at the same time in another thread on"},{"type":"text","text":" "},{"text":"the same ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true,"type":"reference"},{"text":" instance.  If ","type":"text"},{"code":"g_variant_ref_sink()","type":"codeVoice"},{"type":"text","text":" runs first then"},{"text":" ","type":"text"},{"type":"text","text":"the result will be that the floating reference is converted to a hard"},{"type":"text","text":" "},{"text":"reference.  If ","type":"text"},{"type":"codeVoice","code":"g_variant_take_ref()"},{"type":"text","text":" runs first then the result will"},{"text":" ","type":"text"},{"text":"be that the floating reference is converted to a hard reference and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"an additional reference on top of that one is added.  It is best to"},{"text":" ","type":"text"},{"text":"avoid this situation.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/VariantRef\/takeRef()"},"metadata":{"role":"symbol","title":"takeRef()","externalID":"s:4GLib15VariantProtocolPAAE7takeRefAA0bE0VSgyF::SYNTHESIZED::s:4GLib10VariantRefV","symbolKind":"method","roleHeading":"Instance Method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"takeRef","kind":"identifier"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef"},{"text":"!","kind":"text"}],"extendedModule":"GLib","modules":[{"name":"GLib"}]},"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://GLib/documentation/GLib/VariantRef/takeRef()":{"title":"takeRef()","role":"symbol","abstract":[{"text":"If ","type":"text"},{"code":"value","type":"codeVoice"},{"text":" is floating, sink it.  Otherwise, do nothing.","type":"text"}],"type":"topic","kind":"symbol","url":"\/documentation\/glib\/variantref\/takeref()","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef\/takeRef()","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"takeRef","kind":"identifier"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef"},{"text":"!","kind":"text"}]},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/VariantRef/VariantProtocol-Implementations":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef\/VariantProtocol-Implementations","url":"\/documentation\/glib\/variantref\/variantprotocol-implementations","title":"VariantProtocol Implementations","abstract":[],"kind":"article","role":"collectionGroup","type":"topic"},"doc://GLib/documentation/GLib/VariantRef":{"abstract":[{"code":"GVariant","type":"codeVoice"},{"text":" is a variant datatype; it can contain one or more values","type":"text"},{"type":"text","text":" "},{"type":"text","text":"along with information about the type of the values."}],"type":"topic","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"VariantRef","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef","title":"VariantRef","url":"\/documentation\/glib\/variantref","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"VariantRef"}]},"doc://GLib/documentation/GLib/Variant":{"abstract":[{"code":"GVariant","type":"codeVoice"},{"type":"text","text":" is a variant datatype; it can contain one or more values"},{"type":"text","text":" "},{"text":"along with information about the type of the values.","type":"text"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"Variant","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","navigatorTitle":[{"text":"Variant","kind":"identifier"}],"title":"Variant","role":"symbol","type":"topic","kind":"symbol","url":"\/documentation\/glib\/variant"}}}