text":"they are tried. If all the alternatives match the empty string, the","type":"text"},{"type":"text","text":" "},{"text":"entire match fails. For example, if the pattern “a?b?” is applied to","type":"text"},{"text":" ","type":"text"},{"text":"a string not beginning with “a” or “b”, it matches the empty string","type":"text"},{"type":"text","text":" "},{"text":"at the start of the string. With this flag set, this match is not","type":"text"},{"text":" ","type":"text"},{"text":"valid, so GRegex searches further into the string for occurrences","type":"text"},{"type":"text","text":" "},{"text":"of “a” or “b”.","type":"text"}],"fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"notempty","kind":"identifier"},{"text":": ","kind":"text"},{"text":"RegexMatchFlags","kind":"typeIdentifier","preciseIdentifier":"s:4GLib15RegexMatchFlagsV"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexMatchFlags\/notempty","kind":"symbol","type":"topic","role":"symbol","title":"notempty","url":"\/documentation\/glib\/regexmatchflags\/notempty"},"doc://GLib/s10SetAlgebraP":{"identifier":"doc:\/\/GLib\/s10SetAlgebraP","title":"Swift.SetAlgebra","type":"unresolvable"},"doc://GLib/SQ":{"identifier":"doc:\/\/GLib\/SQ","title":"Swift.Equatable","type":"unresolvable"},"doc://GLib/documentation/GLib/RegexMatchFlags/notemptyAtstart":{"fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"notemptyAtstart"},{"kind":"text","text":": "},{"text":"RegexMatchFlags","kind":"typeIdentifier","preciseIdentifier":"s:4GLib15RegexMatchFlagsV"}],"title":"notemptyAtstart","url":"\/documentation\/glib\/regexmatchflags\/notemptyatstart","abstract":[{"text":"Like ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexMatchFlags\/notempty"},{"type":"text","text"