{"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"roleHeading":"Structure","externalID":"s:4GLib14VariantDictRefV","symbolKind":"struct","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"VariantDictRef","kind":"identifier"}],"modules":[{"name":"GLib"}],"navigatorTitle":[{"kind":"identifier","text":"VariantDictRef"}],"title":"VariantDictRef"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"VariantDictRef"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","anchor":"overview","level":2,"text":"Overview"},{"inlineContent":[{"text":"It can be used for doing a sequence of dictionary lookups in an","type":"text"},{"text":" ","type":"text"},{"text":"efficient way on an existing ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference"},{"text":" dictionary or it can be used","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to construct new dictionaries with a hashtable-like interface.  It"},{"text":" ","type":"text"},{"text":"can also be used for taking existing dictionaries and modifying them","type":"text"},{"text":" ","type":"text"},{"text":"in order to create new ones.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","isActive":true,"type":"reference"},{"text":" can only be used with ","type":"text"},{"code":"G_VARIANT_TYPE_VARDICT","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"dictionaries."}]},{"type":"paragraph","inlineContent":[{"text":"It is possible to use ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict"},{"type":"text","text":" allocated on the stack or on the"},{"type":"text","text":" "},{"text":"heap.  When using a stack-allocated ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict"},{"text":", you begin with a","type":"text"},{"type":"text","text":" "},{"text":"call to ","type":"text"},{"type":"codeVoice","code":"g_variant_dict_init()"},{"type":"text","text":" and free the resources with a call to"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_variant_dict_clear()"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Heap-allocated "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict"},{"type":"text","text":" follows normal refcounting rules: you"},{"text":" ","type":"text"},{"type":"text","text":"allocate it with "},{"type":"codeVoice","code":"g_variant_dict_new()"},{"text":" and use ","type":"text"},{"type":"codeVoice","code":"g_variant_dict_ref()"},{"type":"text","text":" "},{"text":"and ","type":"text"},{"type":"codeVoice","code":"g_variant_dict_unref()"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"code":"g_variant_dict_end()","type":"codeVoice"},{"type":"text","text":" is used to convert the "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","isActive":true},{"text":" back into a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"dictionary-type "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"type":"text","text":".  When used with stack-allocated instances,"},{"text":" ","type":"text"},{"type":"text","text":"this also implicitly frees all associated memory, but for"},{"type":"text","text":" "},{"type":"text","text":"heap-allocated instances, you must still call "},{"type":"codeVoice","code":"g_variant_dict_unref()"},{"type":"text","text":" "},{"type":"text","text":"afterwards."}]},{"type":"paragraph","inlineContent":[{"text":"You will typically want to use a heap-allocated ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","type":"reference","isActive":true},{"type":"text","text":" when"},{"text":" ","type":"text"},{"type":"text","text":"you expose it as part of an API.  For most other uses, the"},{"text":" ","type":"text"},{"type":"text","text":"stack-allocated form will be more convenient."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Consider the following two examples that do the same thing in each"},{"type":"text","text":" "},{"type":"text","text":"style: take an existing dictionary and look up the “count” uint32"},{"type":"text","text":" "},{"text":"key, adding 1 to it if it is found, or returning an error if the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"key is not found.  Each returns the new dictionary as a floating"},{"text":" ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true,"type":"reference"},{"type":"text","text":"."}]},{"text":"Using a stack-allocated GVariantDict","anchor":"Using-a-stack-allocated-GVariantDict","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"(C Language Example):","type":"text"}]},{"type":"codeListing","code":["  GVariant *","  add_to_count (GVariant  *orig,","                GError   **error)","  {","    GVariantDict dict;","    guint32 count;","","    g_variant_dict_init (&dict, orig);","    if (!g_variant_dict_lookup (&dict, \"count\", \"u\", &count))","      {","        g_set_error (...);","        g_variant_dict_clear (&dict);","        return NULL;","      }","","    g_variant_dict_insert (&dict, \"count\", \"u\", count + 1);","","    return g_variant_dict_end (&dict);","  }"],"syntax":"C"},{"type":"heading","text":"Using heap-allocated GVariantDict","level":2,"anchor":"Using-heap-allocated-GVariantDict"},{"inlineContent":[{"text":"(C Language Example):","type":"text"}],"type":"paragraph"},{"code":["  GVariant *","  add_to_count (GVariant  *orig,","                GError   **error)","  {","    GVariantDict *dict;","    GVariant *result;","    guint32 count;","","    dict = g_variant_dict_new (orig);","","    if (g_variant_dict_lookup (dict, \"count\", \"u\", &count))","      {","        g_variant_dict_insert (dict, \"count\", \"u\", count + 1);","        result = g_variant_dict_end (dict);","      }","    else","      {","        g_set_error (...);","        result = NULL;","      }","","    g_variant_dict_unref (dict);","","    return result;","  }"],"type":"codeListing","syntax":"C"},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDictRef","isActive":true,"type":"reference"},{"text":" type acts as a lightweight Swift reference to an underlying ","type":"text"},{"type":"codeVoice","code":"GVariantDict"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"text":"It exposes methods that can operate on this data type through ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDictProtocol","isActive":true},{"text":" conformance.","type":"text"},{"type":"text","text":" "},{"text":"Use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDictRef"},{"text":" only as an ","type":"text"},{"code":"unowned","type":"codeVoice"},{"type":"text","text":" reference to an existing "},{"code":"GVariantDict","type":"codeVoice"},{"type":"text","text":" instance."}],"type":"paragraph"},{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict"},{"type":"text","text":" (instead of "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDictRef","isActive":true,"type":"reference"},{"text":") if you want to use Automatic Reference Counting for memory management of the underlying ","type":"text"},{"type":"codeVoice","code":"GVariantDict"},{"type":"text","text":" instance."}]}]}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"sections":[],"kind":"symbol","topicSections":[{"generated":true,"title":"Initializers","anchor":"Initializers","identifiers":["doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/init(_:)-1m81v","doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/init(_:)-2ionc","doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/init(_:)-32bsf","doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/init(_:)-3gqla","doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/init(_:)-9l5r7","doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/init(asv:)","doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/init(constPointer:)","doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/init(mutating:)","doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/init(opaquePointer:)"]},{"generated":true,"anchor":"Instance-Properties","title":"Instance Properties","identifiers":["doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/ptr"]},{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/PointerWrapper-Implementations","doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/VariantDictProtocol-Implementations"],"generated":true,"title":"Default Implementations","anchor":"Default-Implementations"}],"relationshipsSections":[{"kind":"relationships","identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","doc:\/\/GLib\/documentation\/GLib\/VariantDictProtocol"],"type":"conformsTo","title":"Conforms To"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/VariantDictRef"},"abstract":[{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","isActive":true},{"text":" is a mutable interface to ","type":"text"