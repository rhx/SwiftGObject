{"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/KeyFile","interfaceLanguage":"swift"},"abstract":[{"type":"codeVoice","code":"GKeyFile"},{"type":"text","text":" parses .ini-like config files."}],"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"relationshipsSections":[{"kind":"relationships","title":"Conforms To","identifiers":["doc:\/\/GLib\/documentation\/GLib\/KeyFileProtocol","doc:\/\/GLib\/documentation\/GLib\/PointerWrapper"],"type":"conformsTo"}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/keyfile"]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"KeyFile","kind":"identifier"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"text":"Overview","type":"heading","anchor":"overview"},{"inlineContent":[{"type":"codeVoice","code":"GKeyFile"},{"type":"text","text":" lets you parse, edit or create files containing groups of"},{"type":"text","text":" "},{"text":"key-value pairs, which we call ‘key files’ for lack of a better name.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Several freedesktop.org specifications use key files. For example, the"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"https:\/\/specifications.freedesktop.org\/desktop-entry-spec\/latest\/"},{"text":" ","type":"text"},{"type":"text","text":"and the "},{"isActive":true,"type":"reference","identifier":"https:\/\/specifications.freedesktop.org\/icon-theme-spec\/latest\/"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The syntax of key files is described in detail in the","type":"text"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/specifications.freedesktop.org\/desktop-entry-spec\/latest\/","isActive":true,"overridingTitle":"Desktop Entry Specification","overridingTitleInlineContent":[{"type":"text","text":"Desktop Entry Specification"}]},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"here is a quick summary: Key files consists of groups of key-value pairs, interspersed","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"with comments."}],"type":"paragraph"},{"code":["# this is just an example","# there can be comments before the first group","","[First Group]","","Name=Key File Example\\tthis value shows\\nescaping","","# localized strings are stored in multiple key-value pairs","Welcome=Hello","Welcome[de]=Hallo","Welcome[fr_FR]=Bonjour","Welcome[it]=Ciao","","[Another Group]","","Numbers=2;20;-200;0","","Booleans=true;false;true;true"],"type":"codeListing","syntax":"txt"},{"inlineContent":[{"text":"Lines beginning with a ","type":"text"},{"type":"codeVoice","code":"#"},{"text":" and blank lines are considered comments.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Groups are started by a header line containing the group name enclosed","type":"text"},{"text":" ","type":"text"},{"text":"in ","type":"text"},{"code":"[","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"]"},{"text":", and ended implicitly by the start of the next group or","type":"text"},{"type":"text","text":" "},{"text":"the end of the file. Each key-value pair must be contained in a group.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Key-value pairs generally have the form "},{"code":"key=value","type":"codeVoice"},{"text":", with the exception","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of localized strings, which have the form "},{"code":"key[locale]=value","type":"codeVoice"},{"text":", with a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"locale identifier of the form "},{"type":"codeVoice","code":"lang_COUNTRY"},{"type":"text","text":"MODIFIER`` where "},{"type":"codeVoice","code":"COUNTRY"},{"type":"text","text":" "},{"type":"text","text":"and `MODIFIER` are optional. As a special case, the locale `C` is associated"},{"text":" ","type":"text"},{"type":"text","text":"with the untranslated pair `key=value` (since GLib 2.84). Space before and"},{"text":" ","type":"text"},{"type":"text","text":"after the `=` character is ignored. Newline, tab, carriage return and"},{"text":" ","type":"text"},{"text":"backslash characters in value are escaped as `\\n`, `\\t`, `\\r`, and `\\\\`,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"respectively. To preserve leading spaces in values, these can also be escaped"},{"text":" ","type":"text"},{"text":"as `\\s`.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Key files can store strings (possibly with localized variants), integers,"},{"type":"text","text":" "},{"type":"text","text":"booleans and lists of these. Lists are separated by a separator character,"},{"text":" ","type":"text"},{"type":"text","text":"typically "},{"code":";","type":"codeVoice"},{"text":" or ","type":"text"},{"type":"codeVoice","code":","},{"type":"text","text":". To use the list separator character in a value in"},{"text":" ","type":"text"},{"type":"text","text":"a list, it has to be escaped by prefixing it with a backslash."}]},{"inlineContent":[{"text":"This syntax is obviously inspired by the .ini files commonly met","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"on Windows, but there are some important differences:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":".ini files use the ","type":"text"},{"code":";","type":"codeVoice"},{"type":"text","text":" character to begin comments,"},{"text":" ","type":"text"},{"text":"key files use the ","type":"text"},{"code":"#","type":"codeVoice"},{"type":"text","text":" character."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Key files do not allow for ungrouped keys meaning only"},{"type":"text","text":" "},{"type":"text","text":"comments can precede the first group."}]}]},{"content":[{"inlineContent":[{"text":"Key files are always encoded in UTF-8.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Key and Group names are case-sensitive. For example, a group called","type":"text"},{"text":" ","type":"text"},{"code":"[GROUP]","type":"codeVoice"},{"text":" is a different from ","type":"text"},{"code":"[group]","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":".ini files don’t have a strongly typed boolean entry type,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"they only have "},{"type":"codeVoice","code":"GetProfileInt()"},{"type":"text","text":". In key files, only"},{"text":" ","type":"text"},{"type":"codeVoice","code":"true"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"false"},{"type":"text","text":" (in lower case) are allowed."}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that in contrast to the"},{"text":" ","type":"text"},{"overridingTitleInlineContent":[{"text":"Desktop Entry Specification","type":"text"}],"overridingTitle":"Desktop Entry Specification","isActive":true,"identifier":"https:\/\/specifications.freedesktop.org\/desktop-entry-spec\/latest\/","type":"reference"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"groups in key files may contain the same key multiple times; the last entry wins.","type":"text"},{"type":"text","text":" "},{"text":"Key files may also contain multiple groups with the same name; they are merged","type":"text"},{"type":"text","text":" "},{"type":"text","text":"together. Another difference is that keys and group names in key files are not"},{"text":" ","type":"text"},{"text":"restricted to ASCII characters.","type":"text"}]},{"inlineContent":[{"text":"Here is an example of loading a key file and reading a value:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"c","code":["`g_autoptr(GError)` error = NULL;","`g_autoptr(GKeyFile)` key_file = g_key_file_new ();","","if (!g_key_file_load_from_file (key_file, \"key-file.ini\", flags, &error))","  {","    if (!g_error_matches (error, G_FILE_ERROR, G_FILE_ERROR_NOENT))","      g_warning (\"Error loading key file: `s`\", error->message);","    return;","  }","","g_autofree gchar *val = g_key_file_get_string (key_file, \"Group Name\", \"SomeKey\", &error);","if (val == NULL &&","    !g_error_matches (error, G_KEY_FILE_ERROR, G_KEY_FILE_ERROR_KEY_NOT_FOUND))","  {","    g_warning (\"Error finding key in key file: `s`\", error->message);","    return;","  }","else if (val == NULL)","  {","    \/\/ Fall back to a default value.","    val = g_strdup (\"default-value\");","  }"]},{"inlineContent":[{"type":"text","text":"Here is an example of creating and saving a key file:"}],"type":"paragraph"},{"syntax":"c","type":"codeListing","code":["`g_autoptr(GKeyFile)` key_file = g_key_file_new ();","const gchar *val = …;","`g_autoptr(GError)` error = NULL;","","g_key_file_set_string (key_file, \"Group Name\", \"SomeKey\", val);","","\/\/ Save as a file.","if (!g_key_file_save_to_file (key_file, \"key-file.ini\", &error))","  {","    g_warning (\"Error saving key file: `s`\", error->message);","    return;","  }","","\/\/ Or store to a GBytes for use elsewhere.","gsize data_len;","g_autofree guint8 *data = (guint8 *) g_key_file_to_data (key_file, &data_len, &error);","if (data == NULL)","  {","    g_warning (\"Error saving key file: `s`\", error->message);","    return;","  }","`g_autoptr(GBytes)` bytes = g_bytes_new_take (g_steal_pointer (&data), data_len);"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/KeyFile"},{"text":" type acts as a reference-counted owner of an underlying ","type":"text"},{"code":"GKeyFile","type":"codeVoice"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"It provides the methods that can operate on this data type through "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/KeyFileProtocol"},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/KeyFile"},{"type":"text","text":" as a strong reference or owner of a "},{"code":"GKeyFile","type":"codeVoice"},{"text":" instance.","type":"text"}]},{"name":"Note","content":[{"inlineContent":[{"type":"text","text":"Use "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/KeyFileRef","isActive":true,"type":"reference"},{"text":" (instead of ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/KeyFile"},{"text":") for a lightweight Swift reference to an underlying ","type":"text"},{"type":"codeVoice","code":"GKeyFile"},{"type":"text","text":" instance."}],"type":"paragraph"}],"type":"aside","style":"note"}]}],"metadata":{"title":"KeyFile","externalID":"s:4GLib7KeyFileC","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"KeyFile","kind":"identifier"}],"role":"symbol","symbolKind":"class","modules":[{"name":"GLib"}],"navigatorTitle":[{"kind":"identifier","text":"KeyFile"}],"roleHeading":"Class"},"schemaVersion":{"minor":3,"major":0,"patch":0},"topicSections":[{"generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/KeyFile\/init()","doc:\/\/GLib\/documentation\/GLib\/KeyFile\/init(_:)-1hpxa","doc:\/\/GLib\/documentation\/GLib\/KeyFile\/init(_:)-2cylo","doc:\/\/GLib\/documentation\/GLib\/KeyFile\/init(_:)-55cb","doc:\/\/GLib\/documentation\/GLib\/KeyFile\/init(_:)-6cxh2","doc:\/\/GLib\/documentation\/GLib\/KeyFile\/init(_:)-7e0t2","doc:\/\/GLib\/documentation\/GLib\/KeyFile\/init(cPointer:)","doc:\/\