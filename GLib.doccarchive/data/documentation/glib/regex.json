{"topicSections":[{"generated":true,"anchor":"Initializers","identifiers":["doc:\/\/GLib\/documentation\/GLib\/Regex\/init(_:)-14i11","doc:\/\/GLib\/documentation\/GLib\/Regex\/init(_:)-38s23","doc:\/\/GLib\/documentation\/GLib\/Regex\/init(_:)-5mtur","doc:\/\/GLib\/documentation\/GLib\/Regex\/init(_:)-7dwt1","doc:\/\/GLib\/documentation\/GLib\/Regex\/init(_:)-8o1r7","doc:\/\/GLib\/documentation\/GLib\/Regex\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/Regex\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/Regex\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/Regex\/init(opaquePointer:)","doc:\/\/GLib\/documentation\/GLib\/Regex\/init(pattern:compileOptions:matchOptions:)","doc:\/\/GLib\/documentation\/GLib\/Regex\/init(raw:)-1y1qf","doc:\/\/GLib\/documentation\/GLib\/Regex\/init(raw:)-4klw6","doc:\/\/GLib\/documentation\/GLib\/Regex\/init(retaining:)","doc:\/\/GLib\/documentation\/GLib\/Regex\/init(retainingCPointer:)","doc:\/\/GLib\/documentation\/GLib\/Regex\/init(retainingOpaquePointer:)","doc:\/\/GLib\/documentation\/GLib\/Regex\/init(retainingRaw:)-1u2ye","doc:\/\/GLib\/documentation\/GLib\/Regex\/init(retainingRaw:)-7yto8"],"title":"Initializers"},{"title":"Instance Properties","anchor":"Instance-Properties","generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/Regex\/ptr"]},{"generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/Regex\/RegexProtocol-Implementations"],"title":"Default Implementations","anchor":"Default-Implementations"}],"kind":"symbol","metadata":{"navigatorTitle":[{"text":"Regex","kind":"identifier"}],"modules":[{"name":"GLib"}],"externalID":"s:4GLib5RegexC","symbolKind":"class","role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"Regex","kind":"identifier"}],"roleHeading":"Class","title":"Regex"},"sections":[],"relationshipsSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","doc:\/\/GLib\/documentation\/GLib\/RegexProtocol"],"kind":"relationships","type":"conformsTo","title":"Conforms To"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/regex"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"Regex","kind":"identifier"}]}]},{"kind":"content","content":[{"text":"Overview","level":2,"type":"heading","anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"After instantiating a ","type":"text"},{"code":"GRegex","type":"codeVoice"},{"type":"text","text":", you can use its methods to find matches"},{"type":"text","text":" "},{"type":"text","text":"in a string, replace matches within a string, or split the string at matches."}]},{"inlineContent":[{"code":"GRegex","type":"codeVoice"},{"type":"text","text":" implements regular expression pattern matching using syntax and"},{"text":" ","type":"text"},{"type":"text","text":"semantics (such as character classes, quantifiers, and capture groups)"},{"text":" ","type":"text"},{"text":"similar to Perl regular expression. See the","type":"text"},{"text":" ","type":"text"},{"identifier":"man:pcre2pattern(3)","type":"reference","isActive":true},{"text":" for details.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"A typical scenario for regex pattern matching is to check if a string","type":"text"},{"type":"text","text":" "},{"type":"text","text":"matches a pattern. The following statements implement this scenario."}],"type":"paragraph"},{"syntax":"{ .c }","code":["const char *regex_pattern = \".*GLib.*\";","const char *string_to_search = \"You will love the GLib implementation of regex\";","`g_autoptr(GMatchInfo)` match_info = NULL;","`g_autoptr(GRegex)` regex = NULL;","","regex = g_regex_new (regex_pattern, G_REGEX_DEFAULT, G_REGEX_MATCH_DEFAULT, NULL);","g_assert (regex != NULL);","","if (g_regex_match (regex, string_to_search, G_REGEX_MATCH_DEFAULT, &match_info))","  {","    int start_pos, end_pos;","    g_match_info_fetch_pos (match_info, 0, &start_pos, &end_pos);","    g_print (\"Match successful! Overall pattern matches bytes `d` to `d`\\n\", start_pos, end_pos);","  }","else","  {","    g_print (\"No match!\\n\");","  }"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The constructor for "},{"code":"GRegex","type":"codeVoice"},{"text":" includes two sets of bitmapped flags:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"[flags"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags"},{"type":"text","text":"]—These flags"},{"type":"text","text":" "},{"text":"control how GLib compiles the regex. There are options for case","type":"text"},{"text":" ","type":"text"},{"text":"sensitivity, multiline, ignoring whitespace, etc.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"[flags","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexMatchFlags","isActive":true,"type":"reference"},{"type":"text","text":"]—These flags control"},{"text":" ","type":"text"},{"type":"codeVoice","code":"GRegex"},{"type":"text","text":"’s matching behavior, such as anchoring and customizing definitions"},{"type":"text","text":" "},{"text":"for newline characters.","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some regex patterns include backslash assertions, such as "},{"type":"codeVoice","code":"\\d"},{"type":"text","text":" (digit) or"},{"type":"text","text":" "},{"code":"\\D","type":"codeVoice"},{"type":"text","text":" (non-digit). The regex pattern must escape those backslashes. For"},{"text":" ","type":"text"},{"text":"example, the pattern ","type":"text"},{"type":"codeVoice","code":"\"\\\\d\\\\D\""},{"text":" matches a digit followed by a non-digit.","type":"text"}]},{"inlineContent":[{"type":"text","text":"GLib’s implementation of pattern matching includes a "},{"type":"codeVoice","code":"start_position"},{"type":"text","text":" "},{"type":"text","text":"argument for some of the match, replace, and split methods. Specifying"},{"type":"text","text":" "},{"text":"a start position provides flexibility when you want to ignore the first","type":"text"},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"type":"text","text":"n"}]},{"text":" characters of a string, but want to incorporate backslash assertions","type":"text"},{"type":"text","text":" "},{"type":"text","text":"at character "},{"inlineContent":[{"type":"text","text":"n"}],"type":"emphasis"},{"type":"text","text":" - 1. For example, a database field contains inconsistent"},{"type":"text","text":" "},{"text":"spelling for a job title: ","type":"text"},{"type":"codeVoice","code":"healthcare provider"},{"type":"text","text":" and "},{"type":"codeVoice","code":"health-care provider"},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"The database manager wants to make the spelling consistent by adding a","type":"text"},{"type":"text","text":" "},{"text":"hyphen when it is missing. The following regex pattern tests for the string","type":"text"},{"type":"text","text":" "},{"code":"care","type":"codeVoice"},{"text":" preceded by a non-word boundary character (instead of a hyphen)","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and followed by a space."}],"type":"paragraph"},{"syntax":"{ .c }","type":"codeListing","code":["const char *regex_pattern = \"\\\\Bcare\\\\s\";"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"An efficient way to match with this pattern is to start examining at"},{"type":"text","text":" "},{"type":"codeVoice","code":"start_position"},{"type":"text","text":" 6 in the string "},{"type":"codeVoice","code":"healthcare"},{"text":" or ","type":"text"},{"code":"health-care","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"codeListing","syntax":"{ .c }","code":["const char *regex_pattern = \"\\\\Bcare\\\\s\";","const char *string_to_search = \"healthcare provider\";","`g_autoptr(GMatchInfo)` match_info = NULL;","`g_autoptr(GRegex)` regex = NULL;","","regex = g_regex_new (","  regex_pattern,","  G_REGEX_DEFAULT,","  G_REGEX_MATCH_DEFAULT,","  NULL);","g_assert (regex != NULL);","","g_regex_match_full (","  regex,","  string_to_search,","  -1,","  6, \/\/ position of 'c' in the test string.","  G_REGEX_MATCH_DEFAULT,","  &match_info,","  NULL);"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The method [method"},{"type":"codeVoice","code":"GLib.Regex.match_full"},{"text":"] (and other methods implementing","type":"text"},{"type":"text","text":" "},{"code":"start_pos","type":"codeVoice"},{"type":"text","text":") allow for lookback before the start position to determine if"},{"type":"text","text":" "},{"type":"text","text":"the previous character satisfies an assertion."}]},{"inlineContent":[{"type":"text","text":"Unless you set the [flags"},{"type":"codeVoice","code":"GLib.RegexCompileFlags.RAW"},{"text":"] as one of","type":"text"},{"type":"text","text":" "},{"text":"the ","type":"text"},{"type":"codeVoice","code":"GRegexCompileFlags"},{"type":"text","text":", all the strings passed to "},{"type":"codeVoice","code":"GRegex"},{"type":"text","text":" methods must"},{"text":" ","type":"text"},{"type":"text","text":"be encoded in UTF-8. The lengths and the positions inside the strings are"},{"text":" ","type":"text"},{"type":"text","text":"in bytes and not in characters, so, for instance, "},{"code":"\\xc3\\xa0","type":"codeVoice"},{"text":" (i.e., ","type":"text"},{"type":"codeVoice","code":"à"},{"text":")","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is two bytes long but it is treated as a single character. If you set"},{"type":"text","text":" "},{"type":"codeVoice","code":"G_REGEX_RAW"},{"text":", the strings can be non-valid UTF-8 strings and a byte is","type":"text"},{"type":"text","text":" "},{"text":"treated as a character, so ","type":"text"},{"type":"codeVoice","code":"\\xc3\\xa0"},{"text":" is two bytes and two characters long.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Regarding line endings, ","type":"text"},{"type":"codeVoice","code":"\\n"},{"type":"text","text":" matches a "},{"type":"codeVoice","code":"\\n"},{"type":"text","text":" character, and "},{"type":"codeVoice","code":"\\r"},{"type":"text","text":" matches"},{"type":"text","text":" "},{"type":"text","text":"a "},{"type":"codeVoice","code":"\\r"},{"type":"text","text":" character. More generally, "},{"code":"\\R","type":"codeVoice"},{"type":"text","text":" matches all typical line endings:"},{"type":"text","text":" "},{"text":"CR + LF (","type":"text"},{"code":"\\r\\n","type":"codeVoice"},{"text":"), LF (linefeed, U+000A, ","type":"text"},{"type":"codeVoice","code":"\\n"},{"text":"), VT (vertical tab, U+000B,","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"\\v"},{"text":"), FF (formfeed, U+000C, ","type":"text"},{"code":"\\f","type":"codeVoice"},{"text":"), CR (carriage return, U+000D, ","type":"text"},{"type":"codeVoice","code":"\\r"},{"type":"text","text":"),"},{"type":"text","text":" "},{"text":"NEL (next line, U+0085), LS (line separator, U+2028), and PS (paragraph","type":"text"},{"type":"text","text":" "},{"type":"text","text":"separator, U+2029)."}]},{"inlineContent":[{"type":"text","text":"The behaviour of the dot, circumflex, and dollar metacharacters are"},{"text":" ","type":"text"},{"text":"affected by newline characters. By default, ","type":"text"},{"type":"codeVoice","code":"GRegex"},{"text":" matches any newline","type":"text"},{"type":"text","text":" "},{"type":"text","text":"character matched by "},{"type":"codeVoice","code":"\\R"},{"type":"text","text":". You can limit the matched newline characters by"},{"text":" ","type":"text"},{"text":"specifying the [flags","type":"text"},{"type":"codeVoice","code":"GLib.RegexMatchFlags.NEWLINE_CR"},{"text":"],","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[flags"},{"code":"GLib.RegexMatchFlags.NEWLINE_LF","type":"codeVoice"},{"text":"], and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[flags"},{"type":"codeVoice","code":"GLib.RegexMatchFlags.NEWLINE_CRLF"},{"text":"] compile options, and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"with [flags"},{"type":"codeVoice","code":"GLib.RegexMatchFlags.NEWLINE_ANY"},{"type":"text","text":"],"},{"text":" ","type":"text"},{"type":"text","text":"[flags"},{"code":"GLib.RegexMatchFlags.NEWLINE_CR","type":"codeVoice"},{"text":"],","type":"text"},{"type":"text","text":" "},{"text":"[flags","type":"text"},{"type":"codeVoice","code":"GLib.RegexMatchFlags.NEWLINE_LF"},{"text":"] and","type":"text"},{"text":" ","type":"text"},{"text":"[flags","type":"text"},{"type":"codeVoice","code":"GLib.RegexMatchFlags.NEWLINE_CRLF"},{"text":"] match options.","type":"text"},{"text":" ","type":"text"},{"text":"These settings are also relevant when compiling a pattern if","type":"text"},{"type":"text","text":" "},{"text":"[flags","type":"text"},{"code":"GLib.RegexCompileFlags.EXTENDED","type":"codeVoice"},{"text":"] is set and an unescaped","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"#"},{"type":"text","text":" outside a character class is encountered. This indicates a comment"},{"text":" ","type":"text"},{"type":"text","text":"that lasts until after the next newline."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Because ","type":"text"},{"type":"codeVoice","code":"GRegex"},{"type":"text","text":" does not modify its internal state between creation and"},{"type":"text","text":" "},{"text":"destruction, you can create and modify the same ","type":"text"},{"code":"GRegex","type":"codeVoice"},{"type":"text","text":" instance from"},{"text":" ","type":"text"},{"text":"different threads. In contrast, [struct","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo"},{"text":"] is not thread safe.","type":"text"}]},{"inlineContent":[{"text":"The regular expression low-level functionalities are obtained through","type":"text"},{"text":" ","type":"text"},{"text":"the excellent ","type":"text"},{"identifier":"http:\/\/www.pcre.org\/","type":"reference","isActive":true},{"text":" library written by Philip Hazel.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Regex","isActive":true,"type":"reference"},{"type":"text","text":" type acts as a reference-counted owner of an underlying "},{"type":"codeVoice","code":"GRegex"},{"text":" instance.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"It provides the methods that can operate on this data type through "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexProtocol","type":"reference"},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Regex"},{"type":"text","text":" as a strong reference or owner of a "},{"code":"GRegex","type":"codeVoice"},{"text":" instance.","type":"text"}]},{"style":"note","type":"aside","name":"Note","content":[{"inlineContent":[{"type":"text","text":"Use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexRef"},{"text":" (instead of ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Regex"},{"type":"text","text":") for a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GRegex"},{"type":"text","text":" instance."}],"type":"paragraph"}]}]}],"schemaVe