ing:compileoptions:matchoptions:)"]}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/regexSplitSimple(pattern:string:compileOptions:matchOptions:)"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"regexSplitSimple"},{"kind":"text","text":"("},{"text":"pattern","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"string"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"text":">!, ","kind":"text"},{"text":"compileOptions","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"RegexCompileFlags","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags","preciseIdentifier":"s:4GLib17RegexCompileFlagsV","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"matchOptions","kind":"externalParam"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexMatchFlags","text":"RegexMatchFlags","preciseIdentifier":"s:4GLib15RegexMatchFlagsV","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"text":">?>!","kind":"text"}],"platforms":["macOS"]}]},{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"This function is equivalent to ","type":"text"},{"type":"codeVoice","code":"g_regex_split()"},{"text":" but it does","type":"text"},{"text":" ","type":"text"},{"text":"not require to compile the pattern with ","type":"text"},{"code":"g_regex_new()","type":"codeVoice"},{"text":", avoiding","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"some lines of code when you need just to do a split without"},{"type":"text","text":" "},{"text":"extracting substrings, capture counts, and so on.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If this function is to be called on the same "},{"type":"codeVoice","code":"pattern"},{"type":"text","text":" more than"},{"text":" ","type":"text"},{"text":"once, it’s more efficient to compile the pattern once with","type":"text"},{"text":" ","type":"text"},{"code":"g_regex_new()","type":"codeVoice"},{"type":"text","text":" and then use "},{"code":"g_regex_split()","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"As a special case, the result of splitting the empty string “”","type":"text"},{"type":"text","text":" "},{"text":"is an empty vector, not a vector containing a single string.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The reason for this special case is that being able to represent"},{"type":"text","text":" "},{"type":"text","text":"an empty vector is typically more useful than consistent handling"},{"type":"text","text":" "},{"type":"text","text":"of empty elements. If you do need to represent empty elements,"},{"type":"text","text":" "},{"type":"text","text":"you’ll need to check for the empty string before calling this"},{"type":"text","text":" "},{"text":"function.","type":"text"}]},{"inlineContent":[{"text":"A pattern that can match empty strings splits ","type":"text"},{"type":"codeVoice","code":"string"},{"type":"text","text":" into"},{"text":" ","type":"text"},{"type":"text","text":"separate characters wherever it matches the empty string between"},{"text":" ","type":"text"},{"type":"text","text":"characters. For example splitting “ab c” using as a separator"},{"text":" ","type":"text"},{"type":"text","text":"“\\s*”, you will get “a”, “b” and “c”."}],"type":"paragraph"}],"kind":"content"}],"abstract":[{"type":"text","text":"Breaks the string on the pattern, and returns an array of"},{"text":" ","type":"text"},{"text":"the tokens. If the pattern contains capturing parentheses,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"then the text for each of the substrings will also be returned."},{"text":" ","type":"text"},{"type":"text","text":"If the pattern does not match anywhere in the string, then the"},{"type":"text","text":" "},{"text":"whole string is returned as the first token.","type":"text"}],"references":{"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/RegexMatchFlags":{"abstract":[{"text":"Flags specifying match-time options.","type":"text"}],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexMatchFlags","role":"symbol","title":"RegexMatchFlags","kind":"symbol","url":"\/documentation\/glib\/regexmatchflags","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"RegexMatchFlags","kind":"identifier"}],"navigatorTitle":[{"text":"RegexMatchFlags","kind":"identifier"}]},"doc://GLib/documentation/GLib/RegexCompileFlags":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags","kind":"symbol","role":"symbol","abstract":[{"text":"Flags specifying compile-time options.","type":"text"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RegexCompileFlags","kind":"identifier"}],"title":"RegexCompileFlags","navigatorTitle":[{"text":"RegexCompileFlags","kind":"identifier"}],"url":"\/documentation\/glib\/regexcompileflags"},"doc://GLib/documentation/GLib/regexSplitSimple(pattern:string:compileOptions:matchOptions:)":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/regexSplitSimple(pattern:string:compileOptions:matchOptions:)","abstract":[{"type":"text","text":"Breaks the string on the pattern, and returns an array of"},{"text":" ","type":"text"},{"type":"text","text":"the tokens. If the pattern contains capturing parentheses,"},{"text":" ","type":"text"},{"type":"text","text":"then the text for each of the substrings will also be returned."},{"text":" ","type":"text"},{"type":"text","text":"If the pattern does not match anywhere in the string, then the"},{"text":" ","type":"text"},{"type":"text","text":"whole string is returned as the first token."}],"title":"regexSplitSimple(pattern:string:compileOptions:matchOptions:)","url":"\/documentation\/glib\/regexsplitsimple(pattern:string:compileoptions:matchoptions:)","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"regexSplitSimple","kind":"identifier"},{"text":"(","kind":"text"},{"text":"pattern","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"string"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier","text":"gchar"},{"text":">!, ","kind":"text"},{"text":"compileOptions","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib17RegexCompileFlagsV","text":"RegexCompileFlags"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"matchOptions"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIde