ext","text":"an empty vector is typically more useful than consistent handling"},{"text":" ","type":"text"},{"type":"text","text":"of empty elements. If you do need to represent empty elements,"},{"text":" ","type":"text"},{"text":"you’ll need to check for the empty string before calling this","type":"text"},{"text":" ","type":"text"},{"text":"function.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"A pattern that can match empty strings splits ","type":"text"},{"type":"codeVoice","code":"string"},{"type":"text","text":" into"},{"type":"text","text":" "},{"type":"text","text":"separate characters wherever it matches the empty string between"},{"type":"text","text":" "},{"type":"text","text":"characters. For example splitting “ab c” using as a separator"},{"type":"text","text":" "},{"text":"“\\s*”, you will get “a”, “b” and “c”.","type":"text"}]}],"kind":"content"}],"sections":[],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/regexSplitSimple(pattern:string:compileOptions:matchOptions:)","interfaceLanguage":"swift"},"metadata":{"role":"symbol","title":"regexSplitSimple(pattern:string:compileOptions:matchOptions:)","roleHeading":"Function","symbolKind":"func","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"regexSplitSimple"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"pattern"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">!, "},{"text":"string","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"compileOptions"},{"kind":"text","text":": "},{