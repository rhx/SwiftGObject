{"topicSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/VariantDict\/init(_:)-2ksq6","doc:\/\/GLib\/documentation\/GLib\/VariantDict\/init(_:)-44k6f","doc:\/\/GLib\/documentation\/GLib\/VariantDict\/init(_:)-6durr","doc:\/\/GLib\/documentation\/GLib\/VariantDict\/init(_:)-6mm5q","doc:\/\/GLib\/documentation\/GLib\/VariantDict\/init(_:)-6y8h5","doc:\/\/GLib\/documentation\/GLib\/VariantDict\/init(asv:)","doc:\/\/GLib\/documentation\/GLib\/VariantDict\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/VariantDict\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/VariantDict\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/VariantDict\/init(opaquePointer:)","doc:\/\/GLib\/documentation\/GLib\/VariantDict\/init(raw:)-1rndj","doc:\/\/GLib\/documentation\/GLib\/VariantDict\/init(raw:)-5mi2y","doc:\/\/GLib\/documentation\/GLib\/VariantDict\/init(retaining:)","doc:\/\/GLib\/documentation\/GLib\/VariantDict\/init(retainingCPointer:)","doc:\/\/GLib\/documentation\/GLib\/VariantDict\/init(retainingOpaquePointer:)","doc:\/\/GLib\/documentation\/GLib\/VariantDict\/init(retainingRaw:)-2823f","doc:\/\/GLib\/documentation\/GLib\/VariantDict\/init(retainingRaw:)-9l3bf"],"title":"Initializers","generated":true,"anchor":"Initializers"},{"anchor":"Instance-Properties","title":"Instance Properties","identifiers":["doc:\/\/GLib\/documentation\/GLib\/VariantDict\/ptr"],"generated":true},{"title":"Default Implementations","anchor":"Default-Implementations","generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/VariantDict\/VariantDictProtocol-Implementations"]}],"metadata":{"navigatorTitle":[{"text":"VariantDict","kind":"identifier"}],"symbolKind":"class","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"VariantDict","kind":"identifier"}],"role":"symbol","roleHeading":"Class","title":"VariantDict","externalID":"s:4GLib11VariantDictC","modules":[{"name":"GLib"}]},"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict"},{"text":" is a mutable interface to ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":" dictionaries.","type":"text"}],"relationshipsSections":[{"type":"conformsTo","kind":"relationships","title":"Conforms To","identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","doc:\/\/GLib\/documentation\/GLib\/VariantDictProtocol"]}],"kind":"symbol","primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"VariantDict","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"overview","type":"heading"},{"inlineContent":[{"type":"text","text":"It can be used for doing a sequence of dictionary lookups in an"},{"type":"text","text":" "},{"type":"text","text":"efficient way on an existing "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference","isActive":true},{"type":"text","text":" dictionary or it can be used"},{"text":" ","type":"text"},{"text":"to construct new dictionaries with a hashtable-like interface.  It","type":"text"},{"type":"text","text":" "},{"text":"can also be used for taking existing dictionaries and modifying them","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"in order to create new ones."}],"type":"paragraph"},{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","type":"reference"},{"type":"text","text":" can only be used with "},{"type":"codeVoice","code":"G_VARIANT_TYPE_VARDICT"},{"text":" ","type":"text"},{"type":"text","text":"dictionaries."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is possible to use "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","type":"reference","isActive":true},{"type":"text","text":" allocated on the stack or on the"},{"type":"text","text":" "},{"text":"heap.  When using a stack-allocated ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","isActive":true},{"text":", you begin with a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"call to "},{"code":"g_variant_dict_init()","type":"codeVoice"},{"type":"text","text":" and free the resources with a call to"},{"text":" ","type":"text"},{"code":"g_variant_dict_clear()","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Heap-allocated "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict"},{"type":"text","text":" follows normal refcounting rules: you"},{"type":"text","text":" "},{"type":"text","text":"allocate it with "},{"type":"codeVoice","code":"g_variant_dict_new()"},{"type":"text","text":" and use "},{"type":"codeVoice","code":"g_variant_dict_ref()"},{"text":" ","type":"text"},{"type":"text","text":"and "},{"code":"g_variant_dict_unref()","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"code":"g_variant_dict_end()","type":"codeVoice"},{"text":" is used to convert the ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict"},{"type":"text","text":" back into a"},{"text":" ","type":"text"},{"type":"text","text":"dictionary-type "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference"},{"type":"text","text":".  When used with stack-allocated instances,"},{"text":" ","type":"text"},{"type":"text","text":"this also implicitly frees all associated memory, but for"},{"text":" ","type":"text"},{"text":"heap-allocated instances, you must still call ","type":"text"},{"code":"g_variant_dict_unref()","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"afterwards."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You will typically want to use a heap-allocated "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","isActive":true},{"type":"text","text":" when"},{"text":" ","type":"text"},{"type":"text","text":"you expose it as part of an API.  For most other uses, the"},{"text":" ","type":"text"},{"type":"text","text":"stack-allocated form will be more convenient."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Consider the following two examples that do the same thing in each"},{"type":"text","text":" "},{"type":"text","text":"style: take an existing dictionary and look up the “count” uint32"},{"text":" ","type":"text"},{"type":"text","text":"key, adding 1 to it if it is found, or returning an error if the"},{"type":"text","text":" "},{"text":"key is not found.  Each returns the new dictionary as a floating","type":"text"},{"type":"text","text":" "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference","isActive":true},{"text":".","type":"text"}]},{"type":"heading","anchor":"Using-a-stack-allocated-GVariantDict","level":2,"text":"Using a stack-allocated GVariantDict"},{"inlineContent":[{"text":"(C Language Example):","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"C","code":["  GVariant *","  add_to_count (GVariant  *orig,","                GError   **error)","  {","    GVariantDict dict;","    guint32 count;","","    g_variant_dict_init (&dict, orig);","    if (!g_variant_dict_lookup (&dict, \"count\", \"u\", &count))","      {","        g_set_error (...);","        g_variant_dict_clear (&dict);","        return NULL;","      }","","    g_variant_dict_insert (&dict, \"count\", \"u\", count + 1);","","    return g_variant_dict_end (&dict);","  }"]},{"text":"Using heap-allocated GVariantDict","type":"heading","level":2,"anchor":"Using-heap-allocated-GVariantDict"},{"inlineContent":[{"text":"(C Language Example):","type":"text"}],"type":"paragraph"},{"syntax":"C","code":["  GVariant *","  add_to_count (GVariant  *orig,","                GError   **error)","  {","    GVariantDict *dict;","    GVariant *result;","    guint32 count;","","    dict = g_variant_dict_new (orig);","","    if (g_variant_dict_lookup (dict, \"count\", \"u\", &count))","      {","        g_variant_dict_insert (dict, \"count\", \"u\", count + 1);","        result = g_variant_dict_end (dict);","      }","    else","      {","        g_set_error (...);","        result = NULL;","      }","","    g_variant_dict_unref (dict);","","    return result;","  }"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","isActive":true},{"text":" type acts as a reference-counted owner of an underlying ","type":"text"},{"code":"GVariantDict","type":"codeVoice"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"It provides the methods that can operate on this data type through "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDictProtocol","type":"reference","isActive":true},{"text":" conformance.","type":"text"},{"type":"text","text":" "},{"text":"Use ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","isActive":true},{"text":" as a strong reference or owner of a ","type":"text"},{"code":"GVariantDict","type":"codeVoice"},{"text":" instance.","type":"text"}],"type":"paragraph"},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDictRef"},{"text":" (instead of ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","type":"reference","isActive":true},{"text":") for a lightweight Swift reference to an underlying ","type":"text"},{"code":"GVariantDict","type":"codeVo