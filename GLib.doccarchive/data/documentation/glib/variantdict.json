stack-allocated ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","isActive":true,"type":"reference"},{"text":", you begin with a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"call to "},{"code":"g_variant_dict_init()","type":"codeVoice"},{"text":" and free the resources with a call to","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_variant_dict_clear()"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Heap-allocated "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict"},{"type":"text","text":" follows normal refcounting rules: you"},{"type":"text","text":" "},{"type":"text","text":"allocate it with "},{"type":"codeVoice","code":"g_variant_dict_new()"},{"type":"text","text":" and use "},{"type":"codeVoice","code":"g_variant_dict_ref()"},{"type":"text","text":" "},{"type":"text","text":"and "},{"type":"codeVoice","code":"g_variant_dict_unref()"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"code":"g_variant_dict_end()","type":"codeVoice"},{"type":"text","text":" is used to convert the "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","type":"reference"},{"text":" back into a","type":"text"},{"type":"text","text":" "},{"text":"dictionary-type ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":".  When used with stack-allocated instances,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this also implicitly frees all associated memory, but for"},{"type":"text","text":" "},{"type":"text","text":"heap-allocated instances, you must still call "},{"type":"codeVoice","code":"g_variant_dict_unref()"},{"text":" ","type":"text"},{"type":"text","text":"afterwards."}]},{"type":"paragraph","inlineContent":[{"text":"You will typically want to use a heap-allocated ","type":"text"},{"i