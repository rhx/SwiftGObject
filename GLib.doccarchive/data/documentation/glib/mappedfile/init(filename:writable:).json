":"class"},{"kind":"text","text":" "},{"text":"MappedFile","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/MappedFile","title":"MappedFile","role":"symbol","kind":"symbol","navigatorTitle":[{"text":"MappedFile","kind":"identifier"}]},"doc://GLib/documentation/GLib/FileError":{"navigatorTitle":[{"kind":"identifier","text":"FileError"}],"kind":"symbol","abstract":[{"text":"Values corresponding to ","type":"text"},{"code":"errno","type":"codeVoice"},{"text":" codes returned from file operations","type":"text"},{"type":"text","text":" "},{"type":"text","text":"on UNIX. Unlike "},{"code":"errno","type":"codeVoice"},{"text":" codes, GFileError values are available on","type":"text"},{"type":"text","text":" "},{"type":"text","text":"all systems, even Windows. The exact meaning of each code depends"},{"type":"text","text":" "},{"type":"text","text":"on what sort of file operation you were performing; the UNIX"},{"text":" ","type":"text"},{"type":"text","text":"documentation gives more details. The following error code descriptions"},{"type":"text","text":" "},{"type":"text","text":"come from the GNU C Library manual, and are under the copyright"},{"type":"text","text":" "},{"text":"of that manual.","type":"text"}],"title":"FileError","role":"symbol","type":"topic","fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"FileError"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/FileError","url":"\/documentation\/glib\/fileerror"}}}