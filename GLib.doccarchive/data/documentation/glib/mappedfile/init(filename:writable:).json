{"abstract":[{"text":"Maps a file into memory. On UNIX, this is using the ","type":"text"},{"code":"mmap()","type":"codeVoice"},{"text":" function.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"init","kind":"keyword"},{"kind":"text","text":"("},{"kind":"externalParam","text":"filename"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"kind":"text","text":">!, "},{"text":"writable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"writable"},{"type":"text","text":" is "},{"code":"true","type":"codeVoice"},{"text":", the mapped buffer may be modified, otherwise","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"it is an error to modify the mapped buffer. Modifications to the buffer"},{"type":"text","text":" "},{"text":"are not visible to other processes mapping the same file, and are not","type":"text"},{"type":"text","text":" "},{"type":"text","text":"written back to the file."}],"type":"paragraph"},{"inlineContent":[{"text":"Note that modifications of the underlying file might affect the contents","type":"text"},{"type":"text","text":" "},{"text":"of the ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MappedFile","isActive":true,"type":"reference"},{"text":". Therefore, mapping should only be used if the file","type":"text"},{"type":"text","text":" "},{"type":"text","text":"will not be modified, or if all modifications of the file are done"},{"type":"text","text":" "},{"type":"text","text":"atomically (e.g. using "},{"code":"g_file_set_contents()","type":"codeVoice"},{"type":"text","text":")."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"filename"},{"type":"text","text":" is the name of an empty, regular file, the function"},{"text":" ","type":"text"},{"type":"text","text":"will successfully return an empty "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/MappedFile","type":"reference"},{"text":". In other cases of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"size 0 (e.g. device files such as \/dev\/null), "},{"type":"codeVoice","code":"error"},{"type":"text","text":" will be set"},{"text":" ","type":"text"},{"type":"text","text":"to the "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/FileError","type":"reference"},{"text":" value ","type":"text"},{"type":"codeVoice","code":"inval"},{"text":".","type":"text"}]}],"kind":"content"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/MappedFile"]]},"metadata":{"symbolKind":"init","modules":[{"name":"GLib"}],"externalID":"s:4GLib10MappedFileC8filename8writableACSPys4Int8VGSg_SbtKcfc","title":"init(filename:writable:)","roleHeading":"Initializer","fragments":[{"kind":"identifier","text":"init"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"filename"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"writable"},{"text":": ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"},{"kind":"text","text":") "},{"text":"throws","kind":"keyword"}],"role":"symbol"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":[