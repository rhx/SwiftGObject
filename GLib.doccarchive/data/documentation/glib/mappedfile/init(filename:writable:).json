deVoice","code":"g_file_set_contents()"},{"type":"text","text":")."}],"type":"paragraph"},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"filename"},{"text":" is the name of an empty, regular file, the function","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"will successfully return an empty "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/MappedFile"},{"type":"text","text":". In other cases of"},{"type":"text","text":" "},{"type":"text","text":"size 0 (e.g. device files such as \/dev\/null), "},{"code":"error","type":"codeVoice"},{"type":"text","text":" will be set"},{"type":"text","text":" "},{"type":"text","text":"to the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/FileError"},{"type":"text","text":" value "},{"type":"codeVoice","code":"inval"},{"text":".","type":"text"}],"type":"paragraph"}]}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/MappedFile\/init(filename:writable:)"},"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/glib\/mappedfile\/init(filename:writable:)"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"modules":[{"name":"GLib"}],"title":"init(filename:writable:)","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"text":"filename","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"writable"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":") "},{"text":"throws","kind":"keyword"}],"roleHeading":"Initializer","externalID":"s:4GLib10MappedFileC8filename8writableACSPys4Int8VGSg_SbtKcfc"