{"sections":[],"kind":"symbol","metadata":{"symbolKind":"method","modules":[{"name":"GLib"}],"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"steal"},{"kind":"text","text":"("},{"text":"len","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sp","kind":"typeIdentifier","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gsize","kind":"typeIdentifier","text":"gsize"},{"kind":"text","text":">!) -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"text":"?>!","kind":"text"}],"extendedModule":"GLib","roleHeading":"Instance Method","title":"steal(len:)","role":"symbol","externalID":"s:4GLib16PtrArrayProtocolPAAE5steal3lenSpySvSgGSgSpySuGSg_tF::SYNTHESIZED::s:4GLib17ReferenceArrayRefV"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/ReferenceArrayRef","doc:\/\/GLib\/documentation\/GLib\/ReferenceArrayRef\/PtrArrayProtocol-Implementations"]]},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/ReferenceArrayRef\/steal(len:)","interfaceLanguage":"swift"},"abstract":[{"text":"Frees the data in the array and resets the size to zero, while","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the underlying array is preserved for use elsewhere and returned"},{"type":"text","text":" "},{"text":"to the caller.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/referencearrayref\/steal(len:)"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"steal","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"len"},{"kind":"text","text":": "},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gsize","text":"gsize"},{"kind":"text","text":">! = nil) -> "},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gpointer","text":"gpointer"},{"text":"?>!","kind":"text"}]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Note that if the array is ","type":"text"},{"type":"codeVoice","code":"NULL"},{"text":" terminated this may still return","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"NULL"},{"text":" if the length of the array was zero and pdata was not yet","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"allocated."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Even if set, the [callback"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/DestroyNotify","isActive":true},{"type":"text","text":"] function will never be called"},{"type":"text","text":" "},{"text":"on the current contents of the array and the caller is","type":"text"},{"type":"text","text":" "},{"text":"responsible for freeing the array elements.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"An example of use:","type":"text"}]},{"syntax":"c","code":["`g_autoptr(GPtrArray)` chunk_buffer = g_ptr_array_new_with_free_func (g_bytes_unref);","","\/\/ Some part of your application appends a number of chunks to the pointer array.","g_ptr_array_add (chunk_buffer, g_bytes_new_static (\"hello\", 5));","g_ptr_array_add (chunk_buffer, g_bytes_new_static (\"world\", 5));","","…","","\/\/ Periodically, the chunks need to be sent as an array-and-length to some","\/\/ other part of the program.","GBytes **chunks;","gsize n_chunks;","","chunks = g_ptr_array_steal (chunk_buffer, &n_chunks);","for (gsize i = 0; i < n_chunks; i++)","  {","    \/\/ Do something with each chunk here, and then free them, since","    \/\/ `g_ptr_array_steal()` transfers ownership of all the elements and the","    \/\/ array to the caller.","    …","","    g_bytes_unref (chunks[i]);","  }","","g_free (chunks);","","\/\/ After calling `g_ptr_array_steal()`, the pointer array can be reused for the","\/\/ next set of chunks.","g_assert (chunk_buffer->len == 0);"],"type":"codeListing"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://GLib/documentation/GLib/ReferenceArrayRef":{"kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/ReferenceArrayRef","role":"symbol","abstract":[{"text":"The ","type":"text"},{"code":"ReferenceArrayRef","type":"codeVoice"},{"type":"text","text":" struct acts as a lightweight, typed wrapper around "},{"type":"codeVoice","code":"GList"},{"type":"text","text":","},{"text":" ","type":"text"},{"text":"with the associated ","type":"text"},{"code":"Element","type":"codeVoice"},{"type":"text","text":" representing the type of"},{"text":" ","type":"text"},{"text":"the elements stored in the list.","type":"text"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"ReferenceArrayRef"}],"title":"ReferenceArrayRef","navigatorTitle":[{"text":"ReferenceArrayRef","kind":"identifier"}],"url":"\/documentation\/glib\/referencearrayref"},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/DestroyNotify":{"url":"\/documentation\/glib\/destroynotify","title":"DestroyNotify","role":"symbol","fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"DestroyNotify"}],"type":"topic","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLi