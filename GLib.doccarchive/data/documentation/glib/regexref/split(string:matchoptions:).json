atch empty strings splits ","type":"text"},{"type":"codeVoice","code":"string"},{"type":"text","text":" into separate"},{"type":"text","text":" "},{"text":"characters wherever it matches the empty string between characters.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"For example splitting “ab c” using as a separator “\\s*”, you will get"},{"type":"text","text":" "},{"text":"“a”, “b” and “c”.","type":"text"}]}]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/RegexRef","doc:\/\/GLib\/documentation\/GLib\/RegexRef\/RegexProtocol-Implementations"]]},"variants":[{"paths":["\/documentation\/glib\/regexref\/split(string:matchoptions:)"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/RegexRef\/split(string:matchOptions:)","interfaceLanguage":"swift"},"abstract":[{"text":"Breaks the string on the pattern, and returns an array of the tokens.","type":"text"},{"text":" ","type":"text"},{"text":"If the pattern contains capturing parentheses, then the text for each","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of the substrings will also be returned. If the pattern does not match"},{"text":" ","type":"text"},{"text":"anywhere in the string, then the whole string is returned as the first","type":"text"},{"type":"text","text":" "},{"text":"token.","type":"text"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"modules":[{"name":"GLib"}],"roleHeading":"Instance Method","title":"split(string:matchOptions:)","extendedModule":"GLib","role":"symbol","externalID":"s:4GLib13RegexProtocolPAAE5split6string12matchOptionsSpySpys4Int8VGSgGSgSPyAHGSg_AA0B10MatchFlagsVtF::SYNTHESIZED::s:4GLib8RegexRefV","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"split"},{"text":"(","kind":"text"},{"text":"string","kind":"externalParam"},{"kind":"text