e case of a pattern","type":"text"},{"type":"text","text":" "},{"type":"text","text":"that begins with any kind of lookbehind assertion, such as “\\b”."}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/regexref\/splitfull(string:stringlen:startposition:matchoptions:maxtokens:)"]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/RegexRef","doc:\/\/GLib\/documentation\/GLib\/RegexRef\/RegexProtocol-Implementations"]]},"references":{"doc://GLib/documentation/GLib/RegexRef":{"url":"\/documentation\/glib\/regexref","title":"RegexRef","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexRef","navigatorTitle":[{"text":"RegexRef","kind":"identifier"}],"kind":"symbol","type":"topic","role":"symbol","abstract":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"GRegex"},{"type":"text","text":" is a compiled form of a regular expression."}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RegexRef","kind":"identifier"}]},"doc://GLib/documentation/GLib/RegexMatchFlags":{"url":"\/documentation\/glib\/regexmatchflags","type":"topic","navigatorTitle":[{"text":"RegexMatchFlags","kind":"identifier"}],"kind":"symbol","abstract":[{"type":"text","text":"Flags specifying match-time options."}],"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexMatchFlags","title":"RegexMatchFlags","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"RegexMatchFlags"}]},"doc://GLib/documentation/GLib/RegexRef/splitFull(string:stringLen:startPosition:matchOptions:maxTokens:)":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexRef\/splitFull(string:stringLen:startPosition:matchOptions:maxTokens:)","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"splitFull"},{"text":"(","kind":"text"},{"text":"string","kind":"externalPar