{"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"matchAllFull","kind":"identifier"},{"kind":"text","text":"("},{"text":"string","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"stringLen"},{"text":": ","kind":"text"},{"text":"gssize","preciseIdentifier":"c:@T@gssize","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"startPosition"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"matchOptions","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"RegexMatchFlags","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexMatchFlags","preciseIdentifier":"s:4GLib15RegexMatchFlagsV","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"matchInfo","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"GMatchInfo"},{"kind":"text","text":">?>! = nil) "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}]}]},{"content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"text":"This function uses a different algorithm (called DFA, i.e. deterministic","type":"text"},{"type":"text","text":" "},{"text":"finite automaton), so it can retrieve all the possible matches, all","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"starting at the same point in the string. For instance matching"},{"text":" ","type":"text"},{"code":"\"<a> <b> <c>\"","type":"codeVoice"},{"text":" against the pattern ","type":"text"},{"code":"\"<.*>\"","type":"codeVoice"},{"type":"text","text":" "},{"text":"you would obtain three matches: ","type":"text"},{"code":"\"<a> <b> <c>\"","type":"codeVoice"},{"type":"text","text":","},{"text":" ","type":"text"},{"code":"\"<a> <b>\"","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"\"<a>\"","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The number of matched strings is retrieved using","type":"text"},{"type":"text","text":" "},{"code":"g_match_info_get_match_count()","type":"codeVoice"},{"type":"text","text":". To obtain the matched strings and"},{"text":" ","type":"text"},{"text":"their position you can use, respectively, ","type":"text"},{"type":"codeVoice","code":"g_match_info_fetch()"},{"type":"text","text":" and"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_match_info_fetch_pos()"},{"type":"text","text":". Note that the strings are returned in"},{"text":" ","type":"text"},{"type":"text","text":"reverse order of length; that is, the longest matching string is"},{"text":" ","type":"text"},{"type":"text","text":"given first."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that the DFA algorithm is slower than the standard one and it"},{"type":"text","text":" "},{"text":"is not able to capture substrings, so backreferences do not work.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Setting "},{"type":"codeVoice","code":"startPosition"},{"text":" differs from just passing over a shortened","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"string and setting "},{"code":"notbol","type":"codeVoice"},{"type":"text","text":" in the case of a pattern"},{"text":" ","type":"text"},{"text":"that begins with any kind of lookbehind assertion, such as “\\b”.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Unless "},{"type":"codeVoice","code":"raw"},{"text":" is specified in the options, ","type":"text"},{"code":"string","type":"codeVoice"},{"type":"text","text":" must be valid UTF-8."}]},{"inlineContent":[{"type":"text","text":"A "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo","isActive":true,"type":"reference"},{"type":"text","text":" structure, used to get information on the match, is"},{"text":" ","type":"text"},{"type":"text","text":"stored in "},{"type":"codeVoice","code":"matchInfo"},{"text":" if not ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":". Note that if "},{"type":"codeVoice","code":"matchInfo"},{"type":"text","text":" is"},{"text":" ","type":"text"},{"type":"text","text":"not "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" then it is created even if the function returns "},{"type":"codeVoice","code":"false"},{"text":",","type":"text"},{"type":"text","text":" "},{"text":"i.e. you must free it regardless if regular expression actually","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"matched."}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"string"},{"text":" is not copied and is used in ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo","type":"reference"},{"type":"text","text":" internally. If"},{"type":"text","text":" "},{"text":"you use any ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo"},{"text":" method (except ","type":"text"},{"code":"g_match_info_free()","type":"codeVoice"},{"type":"text","text":") after"},{"text":" ","type":"text"},{"text":"freeing or modifying ","type":"text"},{"type":"codeVoice","code":"string"},{"type":"text","text":" then the behaviour is undefined."}],"type":"paragraph"}],"kind":"content"}],"varia