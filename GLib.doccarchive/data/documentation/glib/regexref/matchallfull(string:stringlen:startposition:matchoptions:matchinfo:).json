","text":" "},{"type":"codeVoice","code":"g_match_info_fetch_pos()"},{"type":"text","text":". Note that the strings are returned in"},{"text":" ","type":"text"},{"type":"text","text":"reverse order of length; that is, the longest matching string is"},{"text":" ","type":"text"},{"type":"text","text":"given first."}],"type":"paragraph"},{"inlineContent":[{"text":"Note that the DFA algorithm is slower than the standard one and it","type":"text"},{"text":" ","type":"text"},{"text":"is not able to capture substrings, so backreferences do not work.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Setting "},{"type":"codeVoice","code":"startPosition"},{"text":" differs from just passing over a shortened","type":"text"},{"type":"text","text":" "},{"type":"text","text":"string and setting "},{"type":"codeVoice","code":"notbol"},{"type":"text","text":" in the case of a pattern"},{"type":"text","text":" "},{"text":"that begins with any kind of lookbehind assertion, such as “\\b”.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Unless ","type":"text"},{"type":"codeVoice","code":"raw"},{"type":"text","text":" is specified in the options, "},{"code":"string","type":"codeVoice"},{"text":" must be valid UTF-8.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo","type":"reference"},{"text":" structure, used to get information on the match, is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"stored in "},{"code":"matchInfo","type":"codeVoice"},{"text":" if not ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":". Note that if ","type":"text"},{"type":"codeVoice","code":"matchInfo"},{"type":"text","text":" is"},{"text":" ","type":"text"},{"text":"not ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":" then it is created even if the function returns "},{"code":"false","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"text":"i.e. you must free it regardless if regular expression actually","type":"text"},{"type":"text","text":" "},{"text":"matched.","type":"text"}]},{"type":"paragraph","inlineContent":[{"code":"string","type":"codeVoice"},{"type":"text","text":" is not copied and is used in "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo","isActive":true,"type":"reference"},{"type":"text","text":" internally. If"},{"text":" ","type":"text"},{"type":"text","text":"you use any "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo"},{"type":"text","text":" method (except "},{"code":"g_match_info_free()","type":"codeVoice"},{"text":") after","type":"text"},{"type":"text","text":" "},{"type":"text","text":"freeing or modifying "},{"code":"string","type":"codeVoice"},{"type":"text","text":" then the behaviour is undefined."}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/RegexRef","doc:\/\/GLib\/documentation\/GLib\/RegexRef\/RegexProtocol-Implementations"]]},"references":{"doc://GLib/documentation/GLib/RegexMatchFlags":{"url":"\/documentation\/glib\/regexmatchflags","type":"topic","navigatorTitle":[{"text":"RegexMatchFlags","kind":"identifier"}],"kind":"symbol","abstract":[{"type":"text","text":"Flags specifying match-time options."}],"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexMatchFlags","title":"RegexMatchFlags","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"RegexMatchFlags"}]},"doc://GLib/documentation/GLib/MatchInfo":{"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"MatchInfo"}],"kind":"symbol","title":"MatchInfo","url":"\/documentation\/glib\/matchinfo","abstract":[{"text":"A GMatchInfo is an opaque struct used to return information about","type