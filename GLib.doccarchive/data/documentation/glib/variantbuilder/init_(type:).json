{"kind":"symbol","abstract":[{"text":"Initialises a ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder","isActive":true},{"type":"text","text":" structure."}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"init_"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"VariantTypeT"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"type"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"VariantTypeT"},{"kind":"text","text":") "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"text":"VariantTypeT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantTypeProtocol","preciseIdentifier":"s:4GLib19VariantTypeProtocolP","text":"VariantTypeProtocol","kind":"typeIdentifier"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"type"},{"text":" must be non-","type":"text"},{"code":"nil","type":"codeVoice"},{"text":".  It specifies the type of container to","type":"text"},{"type":"text","text":" "},{"text":"construct.  It can be an indefinite type such as","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"G_VARIANT_TYPE_ARRAY"},{"type":"text","text":" or a definite type such as “as” or “(ii)”."},{"type":"text","text":" "},{"text":"Maybe, array, tuple, dictionary entry and variant-typed values may be","type":"text"},{"type":"text","text":" "},{"text":"constructed.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If using a static type such as one of the ","type":"text"},{"type":"codeVoice","code":"G_VARIANT_TYPE_*"},{"type":"text","text":" constants"},{"type":"text","text":" "},{"type":"text","text":"or a "},{"type":"codeVoice","code":"G_VARIANT_TYPE (\"(ii)\")"},{"text":" macro, it is more performant to use","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_variant_builder_init_static()"},{"text":" rather than ","type":"text"},{"type":"codeVoice","code":"g_variant_builder_init()"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"After the builder is initialised, values are added using"},{"type":"text","text":" "},{"code":"g_variant_builder_add_value()","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"g_variant_builder_add()","type":"codeVoice"},{"text":".","type":"text"}]},{"inlineContent":[{"type":"text","text":"After all the child values are added, "},{"code":"g_variant_builder_end()","type":"codeVoice"},{"type":"text","text":" frees"},{"type":"text","text":" "},{"type":"text","text":"the memory associated with the builder and returns the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":" that","type":"text"},{"type":"text","text":" "},{"type":"text","text":"was created."}],"type":"paragraph"},{"inlineContent":[{"text":"This function completely ignores the previous contents of ","type":"text"},{"code":"builder","type":"codeVoice"},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"On one hand this means that it is valid to pass in completely","type":"text"},{"text":" ","type":"text"},{"text":"uninitialised memory.  On the other hand, this means that if you are","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"initialising over top of an existing "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder","isActive":true,"type":"reference"},{"type":"text","text":" you need to"},{"text":" ","type":"text"},{"text":"first call ","type":"text"},{"type":"codeVoice","code":"g_variant_builder_clear()"},{"type":"text","text":" in order to avoid leaking"},{"type":"text","text":" "},{"text":"memory.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"You must not call ","type":"text"},{"code":"g_variant_builder_ref()","type":"codeVoice"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_variant_builder_unref()"},{"text":" on a ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder"},{"type":"text","text":" that was initialised"},{"text":" ","type":"text"},{"type":"text","text":"with this function.  If you ever pass a reference to a"},{"type":"text","text":" "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder","type":"reference","isActive":true},{"type":"text","text":" outside of the control of your own code then you"},{"text":" ","type":"text"},{"type":"text","text":"should assume that the person receiving that reference may try to use"},{"text":" ","type":"text"},{"text":"reference counting; you should use ","type":"text"},{"code":"g_variant_builder_new()","type":"codeVoice"},{"type":"text","text":" instead of"},{"type":"text","text":" "},{"type":"text","text":"this function."}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/VariantBuilder","doc:\/\/GLib\/documentation\/GLib\/VariantBuilder\/VariantBuilderProtocol-Implementations"]]},"sections":[],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder\/init_(type:)","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/glib\/variantbuilder\/init_(type:)"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"modules":[{"name":"GLib"}],"role":"symbol","extendedModule":"GLib","externalID":"s:4GLib22VariantBuilderProtocolPAAE5init_4typeyqd___tAA0b4TypeD0Rd__lF::SYNTHESIZED::s:4GLib14VariantBuilderC","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"init_"},{"text":"<","kind":"text"},{"text":"Var