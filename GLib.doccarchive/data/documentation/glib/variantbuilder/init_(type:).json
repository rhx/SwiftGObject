{"metadata":{"symbolKind":"method","role":"symbol","extendedModule":"GLib","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"init_","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"VariantTypeT"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"type"},{"text":": ","kind":"text"},{"text":"VariantTypeT","kind":"typeIdentifier"},{"text":")","kind":"text"}],"title":"init_(type:)","modules":[{"name":"GLib"}],"roleHeading":"Instance Method","externalID":"s:4GLib22VariantBuilderProtocolPAAE5init_4typeyqd___tAA0b4TypeD0Rd__lF::SYNTHESIZED::s:4GLib14VariantBuilderC"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/variantbuilder\/init_(type:)"]}],"abstract":[{"type":"text","text":"Initialises a "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder","isActive":true,"type":"reference"},{"type":"text","text":" structure."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder\/init_(type:)"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"init_"},{"kind":"text","text":"<"},{"text":"VariantTypeT","kind":"genericParameter"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"type"},{"text":": ","kind":"text"},{"text":"VariantTypeT","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"kind":"keyword","text":"where"},{"text":" ","kind":"text"},{"text":"VariantTypeT","kind":"typeIdentifier"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:4GLib19VariantTypeProtocolP","kind":"typeIdentifier","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantTypeProtocol","text":"VariantTypeProtocol"}]}],"kind":"declarations"},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"type"},{"type":"text","text":" must be non-"},{"type":"codeVoice","code":"nil"},{"type":"text","text":".  It specifies the type of container to"},{"text":" ","type":"text"},{"type":"text","text":"construct.  It can be an indefinite type such as"},{"text":" ","type":"text"},{"type":"codeVoice","code":"G_VARIANT_TYPE_ARRAY"},{"type":"text","text":" or a definite type such as “as” or “(ii)”."},{"text":" ","type":"text"},{"text":"Maybe, array, tuple, dictionary entry and variant-typed values may be","type":"text"},{"type":"text","text":" "},{"text":"constructed.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If using a static type such as one of the "},{"code":"G_VARIANT_TYPE_*","type":"codeVoice"},{"text":" constants","type":"text"},{"type":"text","text":" "},{"text":"or a ","type":"text"},{"code":"G_VARIANT_TYPE (\"(ii)\")","type":"codeVoice"},{"text":" macro, it is more performant to use","type":"text"},{"type":"text","text":" "},{"code":"g_variant_builder_init_static()","type":"codeVoice"},{"type":"text","text":" rather than "},{"type":"codeVoice","code":"g_variant_builder_init()"},{"text":".","type":"text"}]},{"inlineContent":[{"type":"text","text":"After the builder is initialised, values are added using"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_variant_builder_add_value()"},{"type":"text","text":" or "},{"code":"g_variant_builder_add()","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"After all the child values are added, "},{"code":"g_variant_builder_end()","type":"codeVoice"},{"type":"text","text":" frees"},{"type":"text","text":" "},{"type":"text","text":"the memory associated with the builder and returns the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"type":"text","text":" that"},{"type":"text","text":" "},{"type":"text","text":"was created."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This function completely ignores the previous contents of "},{"type":"codeVoice","code":"builder"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"On one hand this means that it is valid to pass in completely"},{"text":" ","type":"text"},{"text":"uninitialised memory.  On the other hand, this means that if you are","type":"text"},{"text":" ","type":"text"},{"text":"initialising over top of an existing ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder","isActive":true},{"type":"text","text":" you need to"},{"text":" ","type":"text"},{"type":"text","text":"first call "},{"code":"g_variant_builder_clear()","type":"codeVoice"},{"type":"text","text":" in order to avoid leaking"},{"type":"text","text":" "},{"text":"memory.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"You must not call ","type":"text"},{"type":"codeVoice","code":"g_variant_builder_ref()"},{"type":"text","text":" or"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_variant_builder_unref()"},{"text":" on a ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder","isActive":true,"type":"reference"},{"type":"text","text":" that was initialised"},{"type":"text","text":" "},{"text":"with this function.  If you ever pass a reference to a","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder"},{"type":"text","text":" outside of the control of your own code then you"},{"text":" ","type":"text"},{"text":"should assume that the person receiving that reference may try to use","type":"text"},{"type":"text","text":" "},{"type":"text","text":"reference counting; you should use "},{"code":"g_variant_builder_new()","type":"codeVoice"},{"type":"text","text":" instead of"},{"text":" ","type":"text"},{"text":"this function.","type":"text"}]}],"kind":"content"}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/VariantBuilder","doc:\/\/GLib\/documentation\/GLib\/VariantBuilder\/VariantBuilderProtocol-Implementations"]]},"references":{"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/VariantTypeProtocol":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantTypeProtocol","role":"symbol","type":"topic","navigatorTitle":[{"text":"VariantTypeProtocol","kind":"identifier"}],"abstract":[{"text":"A type in the [type","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":"] type system.","type":"text"}],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"VariantTypeProtocol","kind":"identifier"}],"title":"VariantTypeProtocol","url":"\/documentation\/glib\/varianttypeprotocol","kind":"symbol"},"doc://GLib/documentation/GLib/VariantBuilder":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"VariantBuilder","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder","url":"\/documentation\/glib\/variantbuilder","role":"symbol","navigatorTitle":[{"text":"VariantBuilder","kind":"identifier"}],"kind":"symbol","title":"VariantBuilder","abstract":[{"text":"A utility type for constructing container-type ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"type":"text","text":" instances."}]},"doc://GLib/documentation/GLib/Variant":{"abstract":[{"code":"GVariant","type":"codeVoice"},{"type":"text","text":" is a variant datatype; it can contain one or more values"},{"type":"text","text":" "},{"text":"along with information about the type