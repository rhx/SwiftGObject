{"sections":[],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/DateTimeRef\/weekNumberingYear","interfaceLanguage":"swift"},"metadata":{"roleHeading":"Instance Property","title":"weekNumberingYear","externalID":"s:4GLib16DateTimeProtocolPAAE17weekNumberingYearSivp::SYNTHESIZED::s:4GLib11DateTimeRefV","symbolKind":"property","modules":[{"name":"GLib"}],"role":"symbol","extendedModule":"GLib","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"weekNumberingYear","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}]},"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"weekNumberingYear","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"text":" { ","kind":"text"},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"inlineContent":[{"text":"This function, taken together with ","type":"text"},{"code":"g_date_time_get_week_of_year()","type":"codeVoice"},{"type":"text","text":" and"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_date_time_get_day_of_week()"},{"type":"text","text":" can be used to determine the full ISO"},{"type":"text","text":" "},{"text":"week date on which ","type":"text"},{"code":"datetime","type":"codeVoice"},{"text":" falls.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is usually equal to the normal Gregorian year (as returned by"},{"type":"text","text":" "},{"code":"g_date_time_get_year()","type":"codeVoice"},{"type":"text","text":"), except as detailed below:"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For Thursday, the week-numbering year is always equal to the usual"},{"type":"text","text":" "},{"type":"text","text":"calendar year.  For other days, the number is such that every day"},{"type":"text","text":" "},{"text":"within a complete week (Monday to Sunday) is contained within the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"same week-numbering year."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For Monday, Tuesday and Wednesday occurring near the end of the year,"},{"type":"text","text":" "},{"text":"this may mean that the week-numbering year is one greater than the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"calendar year (so that these days have the same week-numbering year"},{"type":"text","text":" "},{"type":"text","text":"as the Thursday occurring early in the next year)."}]},{"inlineContent":[{"text":"For Friday, Saturday and Sunday occurring near the start of the year,","type":"text"},{"text":" ","type":"text"},{"text":"this may mean that the week-numbering year is one less than the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"calendar year (so that these days have the same week-numbering year"},{"text":" ","type":"text"},{"type":"text","text":"as the Thursday occurring late in the previous year)."}],"type":"paragraph"},{"inlineContent":[{"text":"An equivalent description is that the week-numbering year is equal to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the calendar year containing the majority of the days in the current"},{"type":"text","text":" "},{"text":"week (Monday to Sunday).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that January 1 0001 in the proleptic Gregorian calendar is a"},{"text":" ","type":"text"},{"text":"Monday, so this function never returns 0.","type":"text"}]}]}],"abstract":[{"text":"Returns the ISO 8601 week-numbering year in which the week containing","type":"text"},{"ty