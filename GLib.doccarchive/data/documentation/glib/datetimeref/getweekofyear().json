{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"getWeekOfYear"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The first week of the year is week 1.  This is the week that contains"},{"type":"text","text":" "},{"text":"the first Thursday of the year.  Equivalently, this is the first week","type":"text"},{"type":"text","text":" "},{"text":"that has more than 4 of its days falling within the calendar year.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The value 0 is never returned by this function.  Days contained","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"within a year but occurring before the first ISO 8601 week of that"},{"type":"text","text":" "},{"type":"text","text":"year are considered as being contained in the last week of the"},{"type":"text","text":" "},{"text":"previous year.  Similarly, the final days of a calendar year may be","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"considered as being part of the first ISO 8601 week of the next year"},{"type":"text","text":" "},{"text":"if 4 or more days of that week are contained within the new year.","type":"text"}]}],"kind":"content"}],"kind":"symbol","abstract":[{"type":"text","text":"Returns the ISO 8601 week number for the week containing "},{"type":"codeVoice","code":"datetime"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The ISO 8601 week number is the same for every day of the week (from"},{"type":"text","text":" "},{"type":"text","text":"Moday through Sunday).  That can produce some unusual results"},{"type":"text","text":" "},{"text":"(described below).","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/DateTimeRef","doc:\/\/GLib\/documentation\/GLib\/DateTimeRef\/DateTimeProtocol-Implementations"]]},"metadata":{"role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"getWeekOfYear","kind":"identifier"},{"kind":"text","text":"() -> "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"roleHeading":"Instance Method","title":"getWeekOfYear()","modules":[{"name":"GLib"}],"symbolKind":"method","extendedModule":"GLib","externalID":"s:4GLib16DateTimeProtocolPAAE13getWeekOfYearSiyF::SYNTHESIZED::s:4GLib11DateTimeRefV"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/datetimeref\/getweekofyear()"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/DateTimeRef\/getWeekOfYear()"},"schemaVersion":{"patch":0,"minor":3,"major":0},"sections":[],"references":{"doc://GLib/documentation/GLib/DateTimeRef/getWeekOfYear()":{"role":"symbol","abstract":[{"type":"text","text":"Returns the ISO 8601 week number for the week containing "},{"code":"datetime","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The ISO 8601 week number is the same for every day of the week (from","type":"text"},{"text":" ","type":"text"},{"text":"Moday through Sunday).  That can produce some unusual results","type":"text"},{"text":" ","type":"text"},{"text":"(described below).","type":"text"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"getWeekOfYear"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"url":"\/documentation\/glib\/datetimeref\/getweekofyear()","title":"getWeekOfYear()","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeRef\/getWeekOfYear()"},"doc://GLib/documentation/GLib/DateTimeRef/DateTimeProtocol-Implementations":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeRef\/DateTimeProtocol-Implementations","kind":"article","url":"\/documentation\/glib\/datetimeref\/datetimeprotocol-implementations","role":"collectionGroup","title":"DateTimeProtocol Implementations","type":"topic","abstract":[]},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/DateTimeRef":{"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeRef","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DateTimeRef","kind":"identifier"}],"navigatorTitle":[{"text":"DateTimeRef","kind":"identifier"}],"abstract":[{"type":"codeVoice","code":"GDateTime"},{"text":" is a structure that combines a Gregorian date and time","type":"text"},{"text":" ","type":"text"},{"text":"into a single structure.","type":"text"}],"title":"DateTimeRef","role":"symbol","url":"\/documentation\/glib\/datetimeref","kind":"symbol"}}}