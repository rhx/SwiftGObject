{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/DateTimeRef\/getWeekOfYear()"},"abstract":[{"type":"text","text":"Returns the ISO 8601 week number for the week containing "},{"code":"datetime","type":"codeVoice"},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"The ISO 8601 week number is the same for every day of the week (from","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Moday through Sunday).  That can produce some unusual results"},{"text":" ","type":"text"},{"type":"text","text":"(described below)."}],"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/datetimeref\/getweekofyear()"]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/DateTimeRef","doc:\/\/GLib\/documentation\/GLib\/DateTimeRef\/DateTimeProtocol-Implementations"]]},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"getWeekOfYear"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The first week of the year is week 1.  This is the week that contains"},{"type":"text","text":" "},{"type":"text","text":"the first Thursday of the year.  Equivalently, this is the first week"},{"text":" ","type":"text"},{"type":"text","text":"that has more than 4 of its days falling within the calendar year."}]},{"type":"paragraph","inlineContent":[{"text":"The value 0 is never returned by this function.  Days contained","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"within a year but occurring before the first ISO 8601 week of 