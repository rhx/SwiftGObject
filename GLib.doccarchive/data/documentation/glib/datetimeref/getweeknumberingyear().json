{"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/datetimeref\/getweeknumberingyear()"]}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/DateTimeRef\/getWeekNumberingYear()","interfaceLanguage":"swift"},"kind":"symbol","schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"roleHeading":"Instance Method","extendedModule":"GLib","title":"getWeekNumberingYear()","symbolKind":"method","modules":[{"name":"GLib"}],"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"getWeekNumberingYear","kind":"identifier"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}],"externalID":"s:4GLib16DateTimeProtocolPAAE20getWeekNumberingYearSiyF::SYNTHESIZED::s:4GLib11DateTimeRefV","role":"symbol"},"abstract":[{"type":"text","text":"Returns the ISO 8601 week-numbering year in which the week containing"},{"type":"text","text":" "},{"code":"datetime","type":"codeVoice"},{"text":" falls.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/DateTimeRef","doc:\/\/GLib\/documentation\/GLib\/DateTimeRef\/DateTimeProtocol-Implementations"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"getWeekNumberingYear","kind":"identifier"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function, taken together with "},{"type":"codeVoice","code":"g_date_time_get_week_of_year()"},{"text":" and","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_date_time_get_day_of_week()"},{"text":" can be used to determine the full ISO","type":"text"},{"text":" ","type":"text"},{"text":"week date on which ","type":"text"},{"type":"codeVoice","code":"datetime"},{"type":"text","text":" falls."}]},{"inlineContent":[{"text":"This is usually equal to the normal Gregorian year (as returned by","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_date_time_get_year()"},{"text":"), except as detailed below:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For Thursday, the week-numbering year is always equal to the usual"},{"type":"text","text":" "},{"type":"text","text":"calendar year.  For other days, the number is such that every day"},{"type":"text","text":" "},{"type":"text","text":"within a complete week (Monday to Sunday) is contained within the"},{"type":"text","text":" "},{"text":"same week-numbering year.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"For Monday, Tuesday and Wednesday occurring near the end of the year,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"this may mean that the week-numbering year is one greater than the"},{"type":"text","text":" "},{"type":"text","text":"calendar year (so that these days have the same week-numbering year"},{"text":" ","type":"text"},{"text":"as the Thursday occurring early in the next year).","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For Friday, Saturday and Sunday occurring near the start of the year,"},{"type":"text","text":" "},{"text":"this may mean that the week-numbering year is one less than the","type":"text"},{"text":" ","type":"text"},{"text":"calendar year (so that these days have the same week-numbering year","type":"text"},{"type":"text","text":" "},{"type":"text","text":"as the Thursday occurring late in the previous year)."}]},{"inlineContent":[{"text":"An equivalent description is that the week-numbering year is equal to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the calendar year containing the majority of the days in the current"},{"text":" ","type":"text"},{"type":"text","text":"week (Monday to Sunday)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Note that January 1 0001 in the proleptic Gregorian calendar is a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Monday, so this function never returns 0."}]}]}],"references":{"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/DateTimeRef":{"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeRef","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DateTimeRef","kind":"identifier"}],"navigatorTitle":[{"text":"DateTimeRef","kind":"identifier"}],"abstract":[{"type":"codeVoice","code":"GDateTime"},{"text":" is a structure that combines a Gregorian date and time","type":"text"},{"text":" ","type":"text"},{"text":"into a single structure.","type":"text"}],"title":"DateTimeRef","role":"symbol","url":"\/documentation\/glib\/datetimeref","kind":"symbol"},"doc://GLib/documentation/GLib/DateTimeRef/DateTimeProtocol-Implementations":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeRef\/DateTimeProtocol-Implementations","kind":"article","url":"\/documentation\/glib\/datetimeref\/datetimeprotocol-implementations","role":"collectionGroup","title":"DateTimeProtocol Implementations","type":"topic","abstract":[]},"doc://GLib/documentation/GLib/DateTimeRef/getWeekNumberingYear()":{"role":"symbol","abstract":[{"type":"text","text":"Returns the ISO 8601 week-numbering year in which the week containing"},{"text":" ","type":"text"},{"type":"codeVoice","code":"datetime"},{"text":" falls.","type":"text"}],"kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"getWeekNumberingYear"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"url":"\/documentation\/glib\/datetimeref\/getweeknumberingyear()","title":"getWeekNumberingYear()","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeRef\/getWeekNumberingYear()"}}}