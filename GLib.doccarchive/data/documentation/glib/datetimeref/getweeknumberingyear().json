{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/DateTimeRef\/getWeekNumberingYear()"},"sections":[],"abstract":[{"type":"text","text":"Returns the ISO 8601 week-numbering year in which the week containing"},{"type":"text","text":" "},{"code":"datetime","type":"codeVoice"},{"text":" falls.","type":"text"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"getWeekNumberingYear","kind":"identifier"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"This function, taken together with "},{"code":"g_date_time_get_week_of_year()","type":"codeVoice"},{"text":" and","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_date_time_get_day_of_week()"},{"type":"text","text":" can be used to determine the full ISO"},{"text":" ","type":"text"},{"text":"week date on which ","type":"text"},{"type":"codeVoice","code":"datetime"},{"type":"text","text":" falls."}],"type":"paragraph"},{"inlineContent":[{"text":"This is usually equal to the normal Gregorian year (as returned by","type":"text"},{"text":" ","type":"text"},{"code":"g_date_time_get_year()","type":"codeVoice"},{"type":"text","text":"), except as detailed below:"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For Thursday, the week-numbering year is always equal to the usual"},{"type":"text","text":" "},{"text":"calendar year.  For other days, the number is such that every day","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"within a complete week (Monday to Sunday) is contained within the"},{"text":" ","type":"text"},{"text":"same week-numbering year.","type":"text"}]},{"inlineContent":[{"text":"For Monday, Tuesday and Wednesday occurring near the end of the year,","type":"text"},{"text":" ","type":"text"},{"text":"this may mean that the week-numbering year is one greater than the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"calendar year (so that these days have the same week-numbering year"},{"text":" ","type":"text"},{"text":"as the Thursday occurring early in the next year).","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"For Friday, Saturday and Sunday occurring near the start of the year,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"this may mean that the week-numbering year is one less than the"},{"type":"text","text":" "},{"type":"text","text":"calendar year (so that these days have the same week-numbering year"},{"text":" ","type":"text"},{"text":"as the Thursday occurring late in the previous year).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An equivalent description is that the week-numbering year is equal to"},{"type":"text","text":" "},{"text":"the calendar year containing the majority of the days in the current","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"week (Monday to Sunday)."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that January 1 0001 in the proleptic Gregorian calendar is a"},{"text":" ","type":"text"},{"text":"Monday, so this function never returns 0.","type":"text"}]}],"kind":"content"}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/DateTimeRef","doc:\/\/GLib\/documentation\/GLib\/DateTimeRef\/DateTimeProtocol-Implementations"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/datetimeref\/getweeknumberingyear()"]}],"metadata":{"externalID":"s:4GLib16DateTimeProtocolPAAE20getWeekNumberingYearSiyF::SYNTHESIZED::s:4GLib11DateTimeRefV","modules":[{"name":"GLib"}],"roleHeading":"Instance Method","title":"getWeekNumberingYear()","extendedModule":"GLib","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"getWeekNumberingYear"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"role":"symbol"},"references":{"doc://GLib/documentation/GLib/DateTimeRef/getWeekNumberingYear()":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeRef\/getWeekNumberingYear()","url":"\/documentation\/glib\/datetimeref\/getweeknumberingyear()","abstract":[{"type":"text","text":"Returns the ISO 8601 week-numbering year in which the week containing"},{"text":" ","type":"text"},{"type":"codeVoice","code":"datetime"},{"type":"text","text":" falls."}],"role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"getWeekNumberingYear","kind":"identifier"},{"kind":"text","text":"() -> "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"kind":"symbol","title":"getWeekNumberingYear()","type":"topic"},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/DateTimeRef/DateTimeProtocol-Implementations":{"title":"DateTimeProtocol Implementations","abstract":[],"kind":"article","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeRef\/DateTimeProtocol-Implementations","role":"collectionGroup","url":"\/documentation\/glib\/datetimeref\/datetimeprotocol-implementations","type":"topic"},"doc://GLib/documentation/GLib/DateTimeRef":{"title":"DateTimeRef","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"DateTimeRef"}],"navigatorTitle":[{"kind":"identifier","text":"DateTimeRef"}],"abstract":[{"code":"GDateTime","type":"codeVoice"},{"text":" is a structure that combines a Gregorian date and time","type":"text"},{"type":"text","text":" "},{"text":"into a single structure.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeRef","role":"symbol","url":"\/documentation\/glib\/datetimeref","type":"topic"}}}