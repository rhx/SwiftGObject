{"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/DateTimeRef"]]},"kind":"symbol","abstract":[{"type":"text","text":"Creates a "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTime","isActive":true,"type":"reference"},{"type":"text","text":" corresponding to the given"},{"text":" ","type":"text"},{"identifier":"https:\/\/en.wikipedia.org\/wiki\/ISO_8601","isActive":true,"type":"reference"},{"type":"text","text":" "},{"code":"text","type":"codeVoice"},{"type":"text","text":". ISO 8601 strings of the form "},{"type":"codeVoice","code":"<date><sep><time><tz>"},{"type":"text","text":" are supported, with"},{"type":"text","text":" "},{"type":"text","text":"some extensions from "},{"type":"reference","identifier":"https:\/\/tools.ietf.org\/html\/rfc3339","isActive":true},{"text":" as","type":"text"},{"text":" ","type":"text"},{"text":"mentioned below.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"init","kind":"keyword"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"TimeZoneT"},{"kind":"text","text":">("},{"text":"iso8601","kind":"externalParam"},{"kind":"text","text":" "},{"kind":"internalParam","text":"text"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier","text":"gchar"},{"text":">!, ","kind":"text"},{"text":"defaultTz","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"TimeZoneT","kind":"typeIdentifier"},{"kind":"text","text":"?) "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"TimeZoneT"},{"text":" : ","kind":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZoneProtocol","kind":"typeIdentifier","text":"TimeZoneProtocol","preciseIdentifier":"s:4GLib16TimeZoneProtocolP"}],"languages":["swift"]}]},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that as "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTime","type":"reference","isActive":true},{"text":" “is oblivious to leap seconds”, leap seconds information","type":"text"},{"type":"text","text":" "},{"type":"text","text":"in an ISO-8601 string will be ignored, so a "},{"code":"23:59:60","type":"codeVoice"},{"text":" time would be parsed as","type":"text"},{"text":" ","type":"text"},{"code":"23:59:59","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"<sep>"},{"type":"text","text":" is the separator and can be either ‘T’, ‘t’ or ’ ’. The latter two"},{"type":"text","text":" "},{"type":"text","text":"separators are an extension from"},{"text":" ","type":"text"},{"identifier":"https:\/\/tools.ietf.org\/html\/rfc3339#section-5.6","isActive":true,"type":"reference"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"<date>"},{"type":"text","text":" is in the form:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"YYYY-MM-DD","type":"codeVoice"},{"type":"text","text":" - Year\/month\/day, e.g. 2016-08-24."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"YYYYMMDD"},{"type":"text","text":" - Same as above without dividers."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"YYYY-DDD"},{"text":" - Ordinal day where DDD is from 001 to 366, e.g. 2016-237.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"YYYYDDD","type":"codeVoice"},{"text":" - Same as above without dividers.","type":"text"}]}]},{"content":[{"inlineContent":[{"code":"YYYY-Www-D","type":"codeVoice"},{"type":"text","text":" - Week day where ww is from 01 to 52 and D from 1-7,"},{"type":"text","text":" "},{"text":"e.g. 2016-W34-3.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"YYYYWwwD"},{"type":"text","text":" - Same as above without dividers."}]}]}]},{"type":"paragraph","inlineContent":[{"code":"<time>","type":"codeVoice"},{"text":" is in the form:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"hh:mm:","type":"codeVoice"},{"type":"text","text":"ss(.sss)`` - Hours, minutes, seconds (subseconds), e.g. 22:10:42.123."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"hhmmss(.sss)"},{"type":"text","text":" - Same as above without dividers."}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"<tz>"},{"text":" is an optional timezone suffix of the form:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Z"},{"type":"text","text":" - UTC."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"+hh:mm"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"-hh:mm"},{"type":"text","text":" - Offset from UTC in hours and minutes, e.g. +12:00."}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"+hh"},{"type":"text","text":" or "},{"type":"codeVoice","code":"-hh"},{"type":"text","text":" - Offset from UTC in hours, e.g. +12."}],"type":"paragraph"}]}]},{"inlineContent":[{"text":"If the timezone is not provided in ","type":"text"},{"type":"codeVoice","code":"text"},{"type":"text","text":" it must be provided in "},{"type":"codeVoice","code":"defaultTz"},{"type":"text","text":" "},{"type":"text","text":"(this field is otherwise ignored)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This call can fail (returning ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":") if "},{"type":"codeVoice","code":"text"},{"type":"te