{"sections":[],"abstract":[{"text":"Converts ","type":"text"},{"type":"codeVoice","code":"time"},{"type":"text","text":" into an RFC 3339 encoded string, relative to the"},{"type":"text","text":" "},{"text":"Coordinated Universal Time (UTC). This is one of the many formats","type":"text"},{"text":" ","type":"text"},{"text":"allowed by ISO 8601.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/timevalprotocol\/toiso8601()"]}],"metadata":{"externalID":"s:4GLib15TimeValProtocolPAAE9toIso8601SSSgyF","modules":[{"name":"GLib"}],"title":"toIso8601()","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"toIso8601","kind":"identifier"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"extendedModule":"GLib","symbolKind":"method","platforms":[],"roleHeading":"Instance Method"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/TimeValProtocol"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"toIso8601","kind":"identifier"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":"!"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"ISO 8601 allows a large number of date\/time formats, with or without"},{"type":"text","text":" "},{"type":"text","text":"punctuation and optional elements. The format returned by this function"},{"text":" ","type":"text"},{"text":"is a complete date and time, with optional punctuation included, the","type":"text"},{"type":"text","text":" "},{"text":"UTC time zone represented as “Z”, and the ","type":"text"},{"type":"codeVoice","code":"tv_usec"},{"type":"text","text":" part included if"},{"type":"text","text":" "},{"type":"text","text":"and only if it is nonzero, i.e. either"},{"text":" ","type":"text"},{"type":"text","text":"“YYYY-MM-DDTHH:MM:SSZ” or “YYYY-MM-DDTHH:MM:SS.fffffZ”."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This corresponds to the Internet date\/time format defined by"},{"text":" ","type":"text"},{"type":"reference","identifier":"https:\/\/www.ietf.org\/rfc\/rfc3339.txt","isActive":true},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"and to either of the two most-precise formats defined by","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the W3C Note"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"http:\/\/www.w3.org\/TR\/NOTE-datetime-19980827"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Both of these documents are profiles of ISO 8601."}]},{"inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":"g_date_time_format()"},{"text":" or ","type":"text"},{"code":"g_strdup_printf()","type":"codeVoice"},{"text":" if a different","type":"text"},{"type":"text","text":" "},{"type":"text","text":"variation of ISO 8601 format is required."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"time"},{"text":" represents a date which is too large to fit into a ","type":"text"},{"code":"struct tm","type":"codeVoice"},{"type":"text","text":","},{"text":" ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" will be returned. This is platform dependent. Note also that since","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"GTimeVal"},{"type":"text","text":" stores the number of seconds as a "},{"type":"codeVoice","code":"glong"},{"text":", on 32-bit systems it","type":"text"},{"type":"text","text":" "},{"text":"is subject to the year 2038 problem. Accordingly, since GLib 2.62, this","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"function has been deprecated. Equivalent functionality is available using:"}],"type":"paragraph"},{"code":["GDateTime *dt = g_date_time_new_from_unix_utc (time_val);","iso8601_string = g_date_time_format_iso8601 (dt);","g_date_time_unref (dt);"],"syntax":null,"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The return value of "},{"code":"g_time_val_to_iso8601()","type":"codeVoice"},{"type":"text","text":" has been nullable since GLib"},{"text":" ","type":"text"},{"type":"text","text":"2.54; before then, GLib would crash under the same conditions."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"to_iso8601 is deprecated:"}]},{"type":"text","text":" "},{"type":"text","text":"#GTimeVal is not year-2038-safe. Use"},{"type":"text","text":" "},{"text":"g_date_time_format_iso8601(dt) instead.","type":"text"}],"type":"paragraph"}]}],"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/TimeValProtocol\/toIso8601()"},"references":{"https://www.ietf.org/rfc/rfc3339.txt":{"identifier":"https:\/\/www.ietf.org\/rfc\/rfc3339.txt","title":"RFC 3339","type":"link","url":"https:\/\/www.ietf.org\/rfc\/rfc3339.txt","titleInlineContent":[{"text":"RFC 3339","type":"text"}]},"doc://GLib/documentation/GLib/TimeValProtocol":{"navigatorTitle":[{"kind":"identifier","text":"TimeValProtocol"}],"role":"symbol","url":"\/documentation\/glib\/timevalprotocol","title":"TimeValProtocol","type":"topic","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TimeValProtocol","kind":"identifier"}],"abstract":[{"type":"text","text":"Represents a precise time, with seconds and microseconds."}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeValProtocol","kind":"symbol"},"doc://GLib/documentation/GLib/TimeValProtocol/toIso8601()":{"abstract":[{"text":"Converts ","type":"text"},{"code":"time","type":"codeVoice"},{"text":" into an RFC 3339 encoded string, relative to the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Coordinated Universal Time (UTC). This is one of the many formats"},{"type":"text","text":" "},{"text":"allowed by ISO 8601.","type":"text"}],"title":"toIso8601()","deprecated":true,"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"toIso8601","kind":"identifier"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"text":"!","kind":"text"}],"url":"\/documentation\/glib\/timevalprotocol\/toiso8601()","role":"symbol","type":"topic","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeValProtocol\/toIso8601()"},"http://www.w3.org/TR/NOTE-datetime-19980827":{"identifier":"http:\/\/www.w3.org\/TR\/NOTE-datetime-19980827","title":"Date and Time Formats","type":"link","url":"http:\/\/www.w3.org\/TR\/NOTE-datetime-19980827","titleInlineContent":[{"text":"Date and Time Formats","type":"text"}]},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"}}}