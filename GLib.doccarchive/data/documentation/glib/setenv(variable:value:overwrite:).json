{"sections":[],"abstract":[{"text":"Sets an environment variable. On UNIX, both the variable’s name and","type":"text"},{"type":"text","text":" "},{"text":"value can be arbitrary byte strings, except that the variable’s name","type":"text"},{"type":"text","text":" "},{"text":"cannot contain ‘=’. On Windows, they should be in UTF-8.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/setenv(variable:value:overwrite:)"]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/setenv(variable:value:overwrite:)"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"setenv"},{"kind":"text","text":"("},{"kind":"externalParam","text":"variable"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"value"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier","text":"gchar"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"overwrite"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Note that on some systems, when variables are overwritten, the memory","type":"text"},{"type":"text","text":" "},{"type":"text","text":"used for the previous variables and its value isn’t reclaimed."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You should be mindful of the fact that environment variable handling"},{"type":"text","text":" "},{"text":"in UNIX is not thread-safe, and your program may crash if one thread","type":"text"},{"type":"text","text":" "},{"text":"calls ","type":"text"},{"code":"g_setenv()","type":"codeVoice"},{"type":"text","text":" while another thread is calling "},{"code":"getenv()","type":"codeVoice"},{"text":". (And note","type":"text"},{"type":"text","text":" "},{"text":"that many functions, such as ","type":"text"},{"type":"codeVoice","code":"gettext()"},{"type":"text","text":", call "},{"type":"codeVoice","code":"getenv()"},{"type":"text","text":" internally.)"},{"type":"text","text":" "},{"type":"text","text":"This function is only safe to use at the very start of your program,"},{"type":"text","text":" "},{"type":"text","text":"before creating any other threads (or creating objects that create"},{"type":"text","text":" "},{"text":"worker threads of their own).","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If you need to set up the environment for a child process, you can","type":"text"},{"type":"text","text":" "},{"type":"text","text":"use "},{"code":"g_get_environ()","type":"codeVoice"},{"text":" to get an environment array, modify that with","type":"text"},{"text":" ","type":"text"},{"code":"g_environ_setenv()","type":"codeVoice"},{"type":"text","text":" and "},{"code":"g_environ_unsetenv()","type":"codeVoice"},{"type":"text","text":", and then pass that"},{"text":" ","type":"text"},{"type":"text","text":"array directly to "},{"code":"execvpe()","type":"codeVoice"},{"type":"text","text":", "},{"code":"g_spawn_async()","type":"codeVoice"},{"text":", or the like.","type":"text"}]}]}],"metadata":{"symbolKind":"func","modules":[{"name":"GLib"}],"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"setenv","kind"