{"sections":[],"metadata":{"modules":[{"name":"GLib"}],"symbolKind":"protocol","externalID":"s:4GLib19VariantDictProtocolP","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"VariantDictProtocol","kind":"identifier"}],"role":"symbol","title":"VariantDictProtocol","navigatorTitle":[{"kind":"identifier","text":"VariantDictProtocol"}],"roleHeading":"Protocol"},"relationshipsSections":[{"kind":"relationships","identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper"],"title":"Inherits From","type":"inheritsFrom"},{"title":"Conforming Types","identifiers":["doc:\/\/GLib\/documentation\/GLib\/VariantDict","doc:\/\/GLib\/documentation\/GLib\/VariantDictRef"],"kind":"relationships","type":"conformingTypes"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/variantdictprotocol"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"VariantDictProtocol"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:4GLib14PointerWrapperP","text":"PointerWrapper","kind":"typeIdentifier","identifier":"doc:\/\/GLib\/documentation\/GLib\/PointerWrapper"}]}]},{"content":[{"level":2,"text":"Overview","anchor":"overview","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"It can be used for doing a sequence of dictionary lookups in an","type":"text"},{"type":"text","text":" "},{"type":"text","text":"efficient way on an existing "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":" dictionary or it can be used","type":"text"},{"type":"text","text":" "},{"text":"to construct new dictionaries with a hashtable-like interface.  It","type":"text"},{"type":"text","text":" "},{"text":"can also be used for taking existing dictionaries and modifying them","type":"text"},{"type":"text","text":" "},{"type":"text","text":"in order to create new ones."}]},{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict"},{"type":"text","text":" can only be used with "},{"code":"G_VARIANT_TYPE_VARDICT","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"dictionaries."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"It is possible to use ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","isActive":true},{"type":"text","text":" allocated on the stack or on the"},{"type":"text","text":" "},{"text":"heap.  When using a stack-allocated ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict"},{"type":"text","text":", you begin with a"},{"text":" ","type":"text"},{"text":"call to ","type":"text"},{"type":"codeVoice","code":"g_variant_dict_init()"},{"type":"text","text":" and free the resources with a call to"},{"text":" ","type":"text"},{"code":"g_variant_dict_clear()","type":"codeVoice"},{"text":".","type":"text"}]},{"inlineContent":[{"text":"Heap-allocated ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","isActive":true,"type":"reference"},{"text":" follows normal refcounting rules: you","type":"text"},{"type":"text","text":" "},{"type":"text","text":"allocate it with "},{"code":"g_variant_dict_new()","type":"codeVoice"},{"type":"text","text":" and use "},{"code":"g_variant_dict_ref()","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"and "},{"type":"codeVoice","code":"g_variant_dict_unref()"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"code":"g_variant_dict_end()","type":"codeVoice"},{"text":" is used to convert the ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","isActive":true,"type":"reference"},{"type":"text","text":" back into a"},{"text":" ","type":"text"},{"type":"text","text":"dictionary-type "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"text":".  When used with stack-allocated instances,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"this also implicitly frees all associated memory, but for"},{"type":"text","text":" "},{"text":"heap-allocated instances, you must still call ","type":"text"},{"code":"g_variant_dict_unref()","type":"codeVoice"},{"text":" ","type":"text"},{"text":"afterwards.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"You will typically want to use a heap-allocated ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","isActive":true},{"type":"text","text":" when"},{"type":"text","text":" "},{"type":"text","text":"you expose it as part of an API.  For most other uses, the"},{"type":"text","text":" "},{"text":"stack-allocated form will be more convenient.","type":"text"}]},{"inlineContent":[{"text":"Consider the following two examples that do the same thing in each","type":"text"},{"type":"text","text":" "},{"text":"style: take an existing dictionary and look up the “count” uint32","type":"text"},{"type":"text","text":" "},{"text":"key, adding 1 to it if it is found, or returning an error if the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"key is not found.  Each returns the new dictionary as a floating"},{"type":"text","text":" "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference","isActive":true},{"text":".","type":"text"}],"type":"paragraph"},{"anchor":"Using-a-stack-allocated-GVariantDict","text":"Using a stack-allocated GVariantDict","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"type":"codeListing","syntax":"C","code":["  GVariant *","  add_to_count (GVariant  *orig,","                GError   **error)","  {","    GVariantDict dict;","    guint32 count;","","    g_variant_dict_init (&dict, orig);","    if (!g_variant_dict_lookup (&dict, \"count\", \"u\", &count))","      {","        g_set_error (...);","        g_variant_dict_clear (&dict);","        return NULL;","      }","","    g_variant_dict_insert (&dict, \"count\", \"u\", count + 1);","","    return g_variant_dict_end (&dict);","  }"]},{"anchor":"Using-heap-allocated-GVariantDict","type":"heading","text":"Using heap-allocated GVariantDict","level":2},{"inlineContent":[{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"syntax":"C","type":"codeListing","code":["  GVariant *","  add_to_count (GVariant  *orig,","                GError   **error)","  {","    GVariantDict *dict;","    GVariant *result;","    guint32 count;","","    dict = g_variant_dict_new (orig);","","    if (g_variant_dict_lookup (dict, \"count\", \"u\", &count))","      {","        g_variant_dict_insert (dict, \"count\", \"u\", count + 1);","        result = g_variant_dict_end (dict);","      }","    else","      {","        g_set_error (...);","        result = NULL;","      }","","    g_variant_dict_unref (dict);","","    return result;","  }"]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDictProtocol","type":"reference","isActive":true},{"type":"text","text":" protocol exposes the methods and properties of an underlying "},{"type":"codeVoice","code":"GVariantDict"},{"text":" instance.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"The default implementation of these can be found in the protocol extension below."},{"text":" ","type":"text"},{"type":"text","text":"For a concrete class that implements these methods and properties, see "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"Alternatively, use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDictRef"},{"type":"text","text":" as a lighweight, "},{"type":"codeVoice","code":"unowned"},{"text":" reference if you already have an instance you just want to use.","type":"text"}]}],"kind":"content"}],"abstract":[{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict"},{"type":"text","text":" is a mutable interface to "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true,"type":"reference"},{"text":" dictionaries.","type":"text"}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/VariantDictProtocol","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"topicSections":[{"generated":true,"title":"Instance Properties","identifiers":["doc:\/\/GLib\/documentation\/GLib\/VariantDictProtocol\/variant_dict_ptr-6dgor"],"anchor":"Instance-Properties"},{"generated":true,"title":"Instance Methods","anchor":"Instance-Methods","identifiers":["doc:\/\/GLib\/documentation\/GLib\/VariantDictProtocol\/clear()","doc:\/\/GLib\/documentation\/GLib\/VariantDictProtocol\/contains(key:)","doc:\/\/GLib\/documentation\/GLib\/VariantDictProtocol\/end()","doc:\/\/GLib\/documentation\/GLib\/VariantDictProtocol\/init_(from:)-2u3tj","doc:\/\/GLib\/documentation\/GLib\/VariantDictProtocol\/init_(from:)-5rs48","doc:\/\/GLib\/documentation\/GLib\/VariantDictProtocol\/insertValue(key:value:)","doc:\/\/GLib\/documentation\/GLib\/VariantDictProtocol\/lookupValue(key:expectedType:)-7v6kw","doc:\/\/GLib\/documentation\/GLib\/VariantDictProtocol\/lookupValue(key:expectedType:)-9lxae","doc:\/\/GLib\/documentation\/GLib\/VariantDictProtocol\/ref()","doc:\/\/GLib\/documentation\/GLib\/VariantDictProtocol\/remove(key:)","doc:\/\/GLib\/documentation\/GLib\/VariantDictProtocol\/unref()"]}],"references":{"doc://GLib/documentation/GLib/VariantDict":{"role":"symbol","abstract