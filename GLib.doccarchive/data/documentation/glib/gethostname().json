{"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/getHostName()","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/gethostname()"]}],"kind":"symbol","abstract":[{"type":"text","text":"Return a name for the machine."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"getHostName","kind":"identifier"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":"!"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"inlineContent":[{"text":"The returned name is not necessarily a fully-qualified domain name,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"or even present in DNS or some other name service at all. It need"},{"type":"text","text":" "},{"text":"not even be unique on your local network or site, but usually it","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is. Callers should not rely on the return value having any specific"},{"text":" ","type":"text"},{"type":"text","text":"properties like uniqueness for security purposes. Even if the name"},{"type":"text","text":" "},{"text":"of the machine is changed while an application is running, the","type":"text"},{"text":" ","type":"text"},{"text":"return value from this function does not change. The returned","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"string is owned by GLib and should not be modified or freed. If no"},{"type":"text","text":" "},{"text":"name can be determined, a default fixed string “localhost” is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"returned."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The encoding of the returned string is UTF-8.","type":"text"}]}]}],"sections":