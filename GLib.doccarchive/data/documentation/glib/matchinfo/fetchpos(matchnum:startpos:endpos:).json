os, end_pos - start_pos);","","      g_print (\"`-9d` `-25s` `-12d` `-18d` `d`\\n\", match_num, paren_string, found_match, start_pos, end_pos);","    }","","  return 0;","}"],"syntax":"{ .c }","type":"codeListing"},{"type":"codeListing","syntax":null,"code":["match_num Contents                  Return value returned start_pos returned end_pos","0         <a> <b> <c>               1            0                  11","1         <a> <b>                   1            0                  7","2         <a>                       1            0                  3","3         N\/A                       0            2147483647         2147483647"]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/matchinfo\/fetchpos(matchnum:startpos:endpos:)"]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/MatchInfo","doc:\/\/GLib\/documentation\/GLib\/MatchInfo\/MatchInfoProtocol-Implementations"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"symbolKind":"method","extendedModule":"GLib","externalID":"s:4GLib17MatchInfoProtocolPAAE8fetchPos8matchNum05startF003endF0SbSi_Spys5Int32VGSgAKtF::SYNTHESIZED::s:4GLib9MatchInfoC","modules":[{"name":"GLib"}],"roleHeading":"Instance Method","role":"symbol","title":"fetchPos(matchNum:startPos:endPos:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"fetchPos","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"matchNum"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"startPos","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"gint","kind":"typeIdentifier","preciseIdentifier":"c:@T@gint"},{"text":">!, ","kind":"text"},{"text":"endPos","kind":"externalParam"},{"kind":"te