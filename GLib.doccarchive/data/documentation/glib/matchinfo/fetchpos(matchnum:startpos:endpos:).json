{"abstract":[{"type":"text","text":"Returns the start and end positions (in bytes) of a successfully matching"},{"text":" ","type":"text"},{"type":"text","text":"capture parenthesis."}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"fetchPos","kind":"identifier"},{"text":"(","kind":"text"},{"text":"matchNum","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"startPos","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gint","text":"gint","kind":"typeIdentifier"},{"kind":"text","text":">! = nil, "},{"text":"endPos","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"gint","kind":"typeIdentifier","preciseIdentifier":"c:@T@gint"},{"text":">! = nil) -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}]}]},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"Valid values for "},{"type":"codeVoice","code":"matchNum"},{"type":"text","text":" are "},{"type":"codeVoice","code":"0"},{"text":" for the full text of the match,","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"1"},{"text":" for the first paren set, ","type":"text"},{"type":"codeVoice","code":"2"},{"type":"text","text":" for the second, and so on."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"As "},{"type":"codeVoice","code":"endPos"},{"text":" is set to the byte after the final byte of the match (on success),","type":"text"},{"text":" ","type":"text"},{"text":"the length of the match can be calculated as ","type":"text"},{"code":"end_pos - start_pos","type":"codeVoice"},{"text":".","type":"text"}]},{"inlineContent":[{"text":"As a best practice, initialize ","type":"text"},{"type":"codeVoice","code":"startPos"},{"type":"text","text":" and "},{"code":"endPos","type":"codeVoice"},{"type":"text","text":" to identifiable"},{"type":"text","text":" "},{"text":"values, such as ","type":"text"},{"code":"G_MAXINT","type":"codeVoice"},{"text":", so that you can test if","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_match_info_fetch_pos()"},{"type":"text","text":" actually changed the value for a given"},{"type":"text","text":" "},{"type":"text","text":"capture parenthesis."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The parameter "},{"code":"matchNum","type":"codeVoice"},{"type":"text","text":" corresponds to a matched capture parenthesis. The"},{"text":" ","type":"text"},{"type":"text","text":"actual value you use for "},{"type":"codeVoice","code":"matchNum"},{"type":"text","text":" depends on the method used to generate"},{"type":"text","text":" "},{"code":"matchInfo","type":"codeVoice"},{"type":"text","text":". The following sections describe those methods."}]},{"level":2,"text":"Methods Using Non-deterministic Finite Automata Matching","anchor":"Methods-Using-Non-deterministic-Finite-Automata-Matching","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The methods [method"},{"type":"codeVoice","code":"GLib.Regex.match"},{"text":"] and [method","type":"text"},{"type":"codeVoice","code":"GLib.Regex.match_full"},{"text":"]","type":"text"},{"type":"text","text":" "},{"type":"text","text":"return a [struct"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo","isActive":true,"type":"reference"},{"type":"text","text":"] using traditional (greedy) pattern"},{"text":" ","type":"text"},{"type":"text","text":"matching, also known as"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/en.wikipedia.org\/wiki\/Nondeterministic_finite_automaton"},{"type":"text","text":" "},{"text":"(NFA) matching. You pass the returned ","type":"text"},{"code":"GMatchInfo","type":"codeVoice"},{"type":"text","text":" from these methods to"},{"type":"text","text":" "},{"code":"g_match_info_fetch_pos()","type":"codeVoice"},{"type":"text","text":" to determine the start and end positions"},{"type":"text","text":" "},{"type":"text","text":"of capture parentheses. The values for "},{"code":"matchNum","type":"codeVoice"},{"text":" correspond to the capture","type":"text"},{"type":"text","text":" "},{"type":"text","text":"parentheses in order, with "},{"code":"0","type":"codeVoice"},{"type":"text","text":" corresponding to the entire matched string."}]},{"inlineContent":[{"type":"codeVoice","code":"matchNum"},{"text":" can refer to a capture parenthesis with no match. For example,","type":"text"},{"text":" ","type":"text"},{"text":"the string ","type":"text"},{"type":"codeVoice","code":"b"},{"text":" matches against the pattern ","type":"text"},{"type":"codeVoice","code":"(a)?b"},{"type":"text","text":", but the capture"},{"type":"text","text":" "},{"text":"parenthesis ","type":"text"},{"code":"(a)","type":"codeVoice"},{"text":" has no match. In this case, ","type":"text"},{"code":"g_match_info_fetch_pos()","type":"codeVoice"},{"type":"text","text":" "},{"text":"returns true and sets ","type":"text"},{"type":"codeVoice","code":"startPos"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"endPos"},{"text":" to ","type":"text"},{"type":"codeVoice","code":"-1"},{"type":"text","text":" when called with"},{"text":" ","type":"text"},{"code":"match_num","type":"codeVoice"},{"type":"text","text":" as "},{"type":"codeVoice","code":"1"},{"type":"text","text":" (for "},{"code":"(a)","type":"codeVoice"},{"type":"text","text":")."}],"type":"paragraph"},{"inlineContent":[{"text":"For an expanded example, a regex pattern is ","type":"text"},{"type":"codeVoice","code":"(a)?(.*?)the (.*)"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"and a candidate string is "},{"type":"codeVoice","code":"glib regexes are the best"},{"text":". In this scenario","type":"text"},{"text":" ","type":"text"},{"text":"there are four capture parentheses numbered 0–3: an implicit one","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for the entire string, and three explicitly declared in the regex pattern."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Given this example, the following table describes the return values"},{"type":"text","text":" "},{"text":"from ","type":"text"},{"type":"codeVoice","code":"g_match_info_fetch_pos()"},{"type":"text","text":" for various values of "},{"code":"matchNum","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"table","rows":[[[{"inlineContent":[{"type":"codeVoice","code":"match_num"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Contents","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Return value","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Returned ","type":"text"},{"type":"codeVoice","code":"start_pos"}]}],[{"type":"paragraph","inlineContent":[{"text":"Returned ","type":"text"},{"type":"codeVoice","code":"end_pos"}]}]],[[{"inlineContent":[{"type":"text","text":"0"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Matches entire string","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"True"}]}],[{"inlineContent":[{"type":"text","text":"0"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"25"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"1"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Does not match first character"}]}],[{"inlineContent":[{"text":"True","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"-1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-1"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"2"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"All text before "},{"type":"codeVoice","code":"the "}]}],[{"inlineContent":[{"type":"text","text":"True"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"0"}]}],[{"inlineContent":[{"text":"17","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"3","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"All text after "},{"code":"the ","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"True","type":"text"}]}],[{"inlineContent":[{"text":"21","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"25"}]}]],[[{"inlineContent":[{"type":"text","text":"4"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Capture paren out of range","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"False","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Unchanged"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Unchanged"}],"type":"paragraph"}]]],"header":"row"},{"inlineContent":[{"text":"The following code sample and output implements this example.","type":"text"}],"type":"paragraph"},{"syntax":"{ .c }","type":"codeListing","code":["`include` <glib.h>","","int","main (int argc, char *argv[])","{","  `g_autoptr(GError)` local_error = NULL;","  const char *regex_pattern = \"(a)?(.*?)the (.*)\";","  const char *test_string = \"glib regexes are the best\";","  `g_autoptr(GRegex)` regex = NULL;","","  regex = g_regex_new (regex_pattern,","                       G_REGEX_DEFAULT,","                       G_REGEX_MATCH_DEFAULT,","                       &local_error);","  if (regex == NULL)","    {","      g_printerr (\"Error creating regex: `s`\\n\", local_error->message);","      return 1;","    }","","  `g_autoptr(GMatchInfo)` match_info = NULL;","  g_regex_match (regex, test_string, G_REGEX_MATCH_DEFAULT, &match_info);","","  int n_matched_strings = g_match_info_get_match_count (match_info);","","  \/\/ Print header line","  g_print (\"match_num Contents                  Return value returned start_pos returned end_pos\\n\");","","  \/\/ Iterate over each capture paren, including one that is out of range as a demonstration.","  for (int match_num = 0; match_num <= n_matched_strings; match_num++)","    {","      gboolean found_match;","      g_autofree char *paren_string = NULL;","      int start_pos = G_MAXINT;","      int end_pos = G_MAXINT;","","      found_match = g_match_info_fetch_pos (match_info,","                                            match_num,","                                            &start_pos,","                                            &end_pos);","","      \/\/ If no match, display N\/A as the found string.","      if (start_pos == G_MAXINT || start_pos == -1)","        paren_string = g_strdup (\"N\/A\");","      else","        paren_string = g_strndup (test_string + start_pos, end_pos - start_pos);","","      g_print (\"`-9d` `-25s` `-12d` `-18d` `d`\\n\", match_num, paren_string, found_match, start_pos, end_pos);","    }","","  return 0;","}"]},{"code":["match_num Contents                  Return value returned start_pos returned end_pos","0         glib regexes are the best 1            0                  25","1         N\/A                       1            -1                 -1","2         glib regexes are          1            0                  17","3         best                      1            21                 25","4         N\/A                       0            2147483647         2147483647"],"syntax":null,"type":"codeListing"},{"type":"heading","level":2,"text":"Methods Using Deterministic Finite Automata Matching","anchor":"Methods-Using-Deterministic-Finite-Automata-Matching"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The methods [method"},{"type":"codeVoice","code":"GLib.Regex.match_all"},{"type":"text","text":"] and"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"code":"GLib.Regex.match_all_full","type":"codeVoice"},{"text":"]","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"return a "},{"code":"GMatchInfo","type":"codeVoice"},{"type":"text","text":" using"},{"type":"text","text":" "},{"isActive":true,"identifier":"https:\/\/en.wikipedia.org\/wiki\/Deterministic_finite_automaton","type":"reference"},{"type":"text","text":" "},{"type":"text","text":"(DFA) pattern matching. This algorithm detects overlapping matches. You pass"},{"text":" ","type":"text"},{"text":"the returned ","type":"text"},{"type":"codeVoice","code":"GMatchInfo"},{"type":"text","text":" from these methods to "},{"type":"codeVoice","code":"g_match_info_fetch_pos()"},{"type":"text","text":" "},{"text":"to determine the start and end positions of each overlapping match. Use the","type":"text"},{"type":"text","text":" "},{"text":"method [method","type":"text"},{"type":"codeVoice","code":"GLib.MatchInfo.get_match_count"},{"type":"text","text":"] to determine the number"},{"type":"text","text":" "},{"text":"of overlapping matches.","type":"text"}]},{"inlineContent":[{"text":"For example, a regex pattern is ","type":"text"},{"type":"codeVoice","code":"<.*>"},{"text":", and a candidate string is","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"<a> <b> <c>"},{"type":"text","text":". In this scenario there are three implicit capture"},{"text":" ","type":"text"},{"type":"text","text":"parentheses: one for the entire string, one for "},{"code":"<a> <b>","type":"codeVoice"},{"text":", and one for ","type":"text"},{"type":"codeVoice","code":"<a>"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Given this example, the following table describes the return values from"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_match_info_fetch_pos()"},{"text":" for various values of ","type":"text"},{"code":"matchNum","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"match_num"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Contents"}]}],[{"inlineContent":[{"text":"Return value","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Returned "},{"type":"codeVoice","code":"start_pos"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Returned "},{"type":"codeVoice","code":"end_pos"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"0","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Matches entire string"}]}],[{"inlineContent":[{"text":"True","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"0","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"11"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"1"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Matches "},{"type":"codeVoice","code":"<a> <b>"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"True"}]}],[{"inlineContent":[{"text":"0","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"7","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"2"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Matches "},{"code":"<a>","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"True"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"0"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"3"}]}]],[[{"inlineContent":[{"type":"text","text":"3"}],"type":"paragraph"}],[{"type":"paragraph",