{"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo\/fetchPos(matchNum:startPos:endPos:)"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"fetchPos","kind":"identifier"},{"kind":"text","text":"("},{"text":"matchNum","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"kind":"text","text":", "},{"kind":"externalParam","text":"startPos"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"text":"gint","preciseIdentifier":"c:@T@gint","kind":"typeIdentifier"},{"text":">! = nil, ","kind":"text"},{"kind":"externalParam","text":"endPos"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sp","kind":"typeIdentifier","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"text":"gint","kind":"typeIdentifier","preciseIdentifier":"c:@T@gint"},{"text":">! = nil) -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Valid values for ","type":"text"},{"code":"matchNum","type":"codeVoice"},{"type":"text","text":" are "},{"type":"codeVoice","code":"0"},{"text":" for the full text of the match,","type":"text"},{"type":"text","text":" "},{"code":"1","type":"codeVoice"},{"text":" for the first paren set, ","type":"text"},{"code":"2","type":"codeVoice"},{"text":" for the second, and so on.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"As "},{"type":"codeVoice","code":"endPos"},{"type":"text","text":" is set to the byte after the final byte of the match (on success),"},{"text":" ","type":"text"},{"type":"text","text":"the length of the match can be calculated as "},{"type":"codeVoice","code":"end_pos - start_pos"},{"text":".","type":"text"}]},{"inlineContent":[{"text":"As a best practice, initialize ","type":"text"},{"type":"codeVoice","code":"startPos"},{"type":"text","text":" and "},{"code":"endPos","type":"codeVoice"},{"text":" to identifiable","type":"text"},{"type":"text","text":" "},{"type":"text","text":"values, such as "},{"code":"G_MAXINT","type":"codeVoice"},{"type":"text","text":", so that you can test if"},{"type":"text","text":" "},{"code":"g_match_info_fetch_pos()","type":"codeVoice"},{"text":" actually changed the value for a given","type":"text"},{"type":"text","text":" "},{"type":"text","text":"capture parenthesis."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The parameter "},{"type":"codeVoice","code":"matchNum"},{"text":" corresponds to a matched capture parenthesis. The","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"actual value you use for "},{"type":"codeVoice","code":"matchNum"},{"type":"text","text":" depends on the method used to generate"},{"text":" ","type":"text"},{"code":"matchInfo","type":"codeVoice"},{"type":"text","text":". The following sections describe those methods."}]},{"type":"heading","level":2,"text":"Methods Using Non-deterministic Finite Automata Matching","anchor":"Methods-Using-Non-deterministic-Finite-Automata-Matching"},{"inlineContent":[{"type":"text","text":"The methods [method"},{"code":"GLib.Regex.match","type":"codeVoice"},{"text":"] and [method","type":"text"},{"code":"GLib.Regex.match_full","type":"codeVoice"},{"text":"]","type":"text"},{"type":"text","text":" "},{"type":"text","text":"return a [struct"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo","isActive":true,"type":"reference"},{"type":"text","text":"] using traditional (greedy) pattern"},{"text":" ","type":"text"},{"type":"text","text":"matching, also known as"},{"type":"text","text":" "},{"isActive":true,"identifier":"https:\/\/en.wikipedia.org\/wiki\/Nondeterministic_finite_automaton","type":"reference"},{"text":" ","type":"text"},{"type":"text","text":"(NFA) matching. You pass the returned "},{"type":"codeVoice","code":"GMatchInfo"},{"text":" from these methods to","type":"text"},{"text":" ","type":"text"},{"code":"g_match_info_fetch_pos()","type":"codeVoice"},{"type":"text","text":" to determine the start and end positions"},{"text":" ","type":"text"},{"type":"text","text":"of capture parentheses. The values for "},{"code":"matchNum","type":"codeVoice"},{"type":"text","text":" correspond to the capture"},{"type":"text","text":" "},{"type":"text","text":"parentheses in order, with "},{"type":"codeVoice","code":"0"},{"type":"text","text":" corresponding to the entire matched string."}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"matchNum"},{"text":" can refer to a capture parenthesis with no match. For example,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the string "},{"type":"codeVoice","code":"b"},{"type":"text","text":" matches against the pattern "},{"code":"(a)?b","type":"codeVoice"},{"type":"text","text":", but the capture"},{"text":" ","type":"text"},{"type":"text","text":"parenthesis "},{"code":"(a)","type":"codeVoice"},{"text":" has no match. In this case, ","type":"text"},{"type":"codeVoice","code":"g_match_info_fetch_pos()"},{"text":" ","type":"text"},{"text":"returns true and sets ","type":"text"},{"code":"startPos","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"endPos","type":"codeVoice"},{"text":" to ","type":"text"},{"code":"-1","type":"codeVoice"},{"type":"text","text":" when called with"},{"type":"text","text":" "},{"type":"codeVoice","code":"match_num"},{"type":"text","text":" as "},{"type":"codeVoice","code":"1"},{"type":"text","text":" (for "},{"code":"(a)","type":"codeVoice"},{"type":"text","text":")."}],"type":"paragraph"},{"inlineContent":[{"text":"For an expanded example, a regex pattern is ","type":"text"},{"code":"(a)?(.*?)the (.*)","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and a candidate string is "},{"type":"codeVoice","code":"glib regexes are the best"},{"type":"text","text":". In this scenario"},{"type":"text","text":" "},{"text":"there are four capture parentheses numbered 0–3: an implicit one","type":"text"},{"text":" ","type":"text"},{"text":"for the entire string, and three explicitly declared in the regex pattern.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Given this example, the following table describes the return values"},{"type":"text","text":" "},{"type":"text","text":"from "},{"type":"codeVoice","code":"g_match_info_fetch_pos()"},{"type":"text","text":" for various values of "},{"type":"codeVoice","code":"matchNum"},{"type":"text","text":"."}]},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"code":"match_num","type":"codeVoice"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Contents"}]}],[{"inlineContent":[{"text":"Return value","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Returned ","type":"text"},{"type":"codeVoice","code":"start_pos"}]}],[{"inlineContent":[{"type":"text","text":"Returned "},{"code":"end_pos","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"0","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Matches entire string","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"True"}]}],[{"type":"paragraph","inlineContent":[{"text":"0","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"25"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"1","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Does not match first character","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"True","type":"text"}]}],[{"inlineContent":[{"text":"-1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"-1"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"2","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"All text before "},{"type":"codeVoice","code":"the "}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"True"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"0"}]}],[{"inlineContent":[{"text":"17","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"3","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"All text after "},{"type":"codeVoice","code":"the "}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"True"}]}],[{"inlineContent":[{"text":"21","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"25"}]}]],[[{"inlineContent":[{"type":"text","text":"4"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Capture paren out of range"}]}],[{"type":"paragraph","inlineContent":[{"text":"False","type":"text"}]}],[{"inlineContent":[{"text":"Unchanged","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Unchanged"}],"type":"paragraph"}]]]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following code sample and output implements this example."}]},{"code":["`include` <glib.h>","","int","main (int argc, char *argv[])","{","  `g_autoptr(GError)` local_error = NULL;","  const char *regex_pattern = \"(a)?(.*?)the (.*)\";","  const char *test_string = \"glib regexes are the best\";","  `g_autoptr(GRegex)` regex = NULL;","","  regex = g_regex_new (regex_pattern,","                       G_REGEX_DEFAULT,","                       G_REGEX_MATCH_DEFAULT,","                       &local_error);","  if (regex == NULL)","    {","      g_printerr (\"Error creating regex: `s`\\n\", local_error->message);","      return 1;","    }","","  `g_autoptr(GMatchInfo)` match_info = NULL;","  g_regex_match (regex, test_string, G_REGEX_MATCH_DEFAULT, &match_info);","","  int n_matched_strings = g_match_info_get_match_count (match_info);","","  \/\/ Print header line","  g_print (\"match_num Contents                  Return value returned start_pos returned end_pos\\n\");","","  \/\/ Iterate over each capture paren, including one that is out of range as a demonstration.","  for (int match_num = 0; match_num <= n_matched_strings; match_num++)","    {","      gboolean found_match;","      g_autofree char *paren_string = NULL;","      int start_pos = G_MAXINT;","      int end_pos = G_MAXINT;","","      found_match = g_match_info_fetch_pos (match_info,","                                            match_num,","                                            &start_pos,","                                            &end_pos);","","      \/\/ If no match, display N\/A as the found string.","      if (start_pos == G_MAXINT || start_pos == -1)","        paren_string = g_strdup (\"N\/A\");","      else","        paren_string = g_strndup (test_string + start_pos, end_pos - start_pos);","","      g_print (\"`-9d` `-25s` `-12d` `-18d` `d`\\n\", match_num, paren_string, found_match, start_pos, end_pos);","    }","","  return 0;","}"],"syntax":"{ .c }","type":"codeListing"},{"type":"codeListing","syntax":null,"code":["match_num Contents                  Return value returned start_pos returned end_pos","0         glib regexes are the best 1            0                  25","1         N\/A                       1            -1                 -1","2         glib regexes are          1            0                  17","3         best                      1            21                 25","4         N\/A                       0            2147483647         2147483647"]},{"text":"Methods Using Deterministic Finite Automata Matching","anchor":"Methods-Using-Deterministic-Finite-Automata-Matching","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The methods [method"},{"code":"GLib.Regex.match_all","type":"codeVoice"},{"type":"text","text":"] and"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.Regex.match_all_full"},{"type":"text","text":"]"},{"type":"text","text":" "},{"text":"return a ","type":"text"},{"code":"GMatchInfo","type":"codeVoice"},{"text":" using","type":"text"},{"type":"text","text":" "},{"identifier":"https:\/\/en.wikipedia.org\/wiki\/Deterministic_finite_automaton","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"type":"text","text":"(DFA) pattern matching. This algorithm detects overlapping matches. You pass"},{"text":" ","type":"text"},{"type":"text","text":"the returned "},{"type":"codeVoice","code":"GMatchInfo"},{"type":"text","text":" from these methods to "},{"type":"codeVoice","code":"g_match_info_fetch_pos()"},{"text":" ","type":"text"},{"type":"text","text":"to determine the start and end positions of each overlapping match. Use the"},{"type":"text","text":" "},{"type":"text","text":"method [method"},{"code":"GLib.MatchInfo.get_match_count","type":"codeVoice"},{"text":"] to determine the number","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of overlapping matches."}]},{"inlineContent":[{"type":"text","text":"For example, a regex pattern is "},{"type":"codeVoice","code":"<.*>"},{"text":", and a candidate string is","type":"text"},{"type":"text","text":" "},{"code":"<a> <b> <c>","type":"codeVoice"},{"text":". In this scenario there are three implicit capture","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"parentheses: one for the entire string, one for "},{"code":"<a> <b>","type":"codeVoice"},{"text":", and one for ","type":"text"},{"type":"codeVoice","code":"<a>"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Given this example, the following table describes the return values from","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_match_info_fetch_pos()"},{"text":" for various values of ","type":"text"},{"code":"matchNum","type":"codeVoice"},{"text":".","type":"text"}]},{"header":"row","rows":[[[{"inlineContent":[{"type":"codeVoice","code":"match_num"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Contents"}]}],[{"inlineContent":[{"type":"text","text":"Return value"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Returned "},{"type":"codeVoice","code":"start_pos"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Returned "},{"type":"codeVoice","code":"end_pos"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"0","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Matches entire string"}]}],[{"inlineContent":[{"text":"True","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"0"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"11","type":"text"}]}]],[[{"inlineContent":[{"text":"1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Matches "},{"type":"codeVoice","code":"<a> <b>"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"True","type":"text"}]}],[{"inlineContent":[{"text":"0","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"7","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"2"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Matches ","type":"text"},{"code":"<a>","type":"codeVoice"}]}],[{"inlineContent":[{"text":"True","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"0","type":"text"}]}],[{"inlineContent":[{"text":"3","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"3"}]}],[{"type":"paragraph","inlineContent":[{"text":"Capture paren out of range","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"False","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Unchanged","type":"text"}]}],[{"inlineContent":[{"text":"Unchanged","type":"text"}],"type":"paragraph"}]]],"type":"table"},{"inlineContent":[{"text":"The following code sample and output implements this example.","type":"text"}],"type":"paragraph"},{"syntax":"{ .c }","code":["`include` <glib.h>","","int","main (int argc, char *argv[])","{","  `g_autoptr(GError)` local_error = NULL;","  const char *regex_pattern = \"<.*>\";","  const char *test_string = \"<a> <b> <c>\";","  `g_autoptr(GRegex)` regex = NULL;","","  regex = g_regex_new (regex_pattern,","                       G_REGEX_DEFAULT,","                       G_REGEX_MATCH_DEFAULT,","                       &local_error);","  if (regex == NULL)","    {","      g_printerr (\"Error creating regex: `s`\\n\", local_error->message);","      return -1;","    }","","  `g_autoptr(GMatchInfo)` match_info = NULL;","  g_regex_match_all (regex, test_string, G_REGEX_MATCH_DEFAULT, &match_info);","","  int n_matched_strings = g_match_info_get_match_count (match_info);","","  \/\/ Print header line","  g_print (\"match_num Contents                  Return value returned start_pos returned end_pos\\n\");","","  \/\/ Iterate over each capture paren, including one that is out of range as a demonstration.","  for (int match_num = 0; match_num <= n_matched_strings; match_num++)","    {","      gboolean found_match;","      g_autofree char *paren_string = NULL;","      int start_pos = G_MAXINT;","      int end_pos = G_MAXINT;","","      found_match = g_match_info_fetch_pos (match_info, match_num, &start_pos, &end_pos);","","      \/\/ If no match, display N\/A as the found string.","      if (start_pos == G_MAXINT || start_pos == -1)","        paren_string = g_strdup (\"N\/A\");","      else","        paren_string = g_strndup (test_string + start_pos, end_pos - start_pos);","","      g_print (\"`-9d` `-25s` `-12d` `-18d` `d`\\n\", match_num, paren_string, found_match, start_pos, end_pos);","    }","","  return 0;","}"],"type":"codeListing"},{"code":["match_num Contents                  Return value returned start_pos returned end_pos","0         <a> <b> <c>               1            0                  11","1         <a> <b>                   1            0                  7","2         <a>                       1            0                  3","3         N\/A                       0            2147483647         2147483647"],"syntax":null,"type":"codeListing"}]}],"variants":[{"paths":["\/documentation\/glib\/matchinfo\/fetchpos(matchnum:startpos:endpos:)"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"Returns the start and end positions (in bytes) of a successfully matching"},{"text":" ","type":"text"},{"text":"capture parenthesis.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/MatchInfo","doc:\/\/GLib\/documentation\/GLib\/MatchInfo\/MatchInfoProtocol-Implementations"]]},"sections":[],"metadata":{"title":"fetchPos(matchNum:startPos:endPos:)","role":"symbol","roleHeading":"Instance Method","symbolKind":"method","modules":[{"name":"GLib"}],"extendedModule":"GLib","externalID":"s:4GLib17MatchInfoProtocolPAAE8fetchPos8matchNum05startF003endF0SbSi_Spys5Int32VGSgAKtF::SYNTHESIZED::s:4GLib9MatchInfoC","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"fetchPos"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"matchNum"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"startPos","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"text":"gint","kind"