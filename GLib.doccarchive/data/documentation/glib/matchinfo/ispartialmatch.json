{"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"isPartialMatch"},{"text":": ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"kind":"text","text":" }"}]}],"kind":"declarations"},{"content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"Consider, for example, an application where a human is required to"},{"type":"text","text":" "},{"text":"type in data for a field with specific formatting requirements. An","type":"text"},{"type":"text","text":" "},{"text":"example might be a date in the form ddmmmyy, defined by the pattern","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"\"^\\d?\\d(jan|feb|mar|apr|may|jun|jul|aug|sep|oct|nov|dec)"},{"text":"\\d\\d$”.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"If the application sees the user’s keystrokes one by one, and can"},{"type":"text","text":" "},{"text":"check that what has been typed so far is potentially valid, it is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"able to raise an error as soon as a mistake is made."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"GRegex supports the concept of partial matching by means of the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"partialSoft"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"partialHard"},{"text":" flags.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"When they are used, the return code for"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_regex_match()"},{"text":" or ","type":"text"},{"code":"g_regex_match_full()","type":"codeVoice"},{"text":" is, as usual, ","type":"text"},{"code":"true","type":"codeVoice"},{"type":"text","text":" "},{"text":"for a complete match, ","type":"text"},{"type":"codeVoice","code":"false"},{"text":" otherwise. But, when these functions","type":"text"},{"text":" ","type":"text"},{"text":"return ","type":"text"},{"type":"codeVoice","code":"false"},{"type":"text","text":", you can check if the match was partial calling"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_match_info_is_partial_match()"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The difference between "},{"type":"codeVoice","code":"partialSoft"},{"text":" and","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"partialHard"},{"text":" is that when a partial match is encountered","type":"text"},{"type":"text","text":" "},{"text":"with ","type":"text"},{"code":"partialSoft","type":"codeVoice"},{"text":", matching continues to search for a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"possible complete match, while with "},{"code":"partialHard","type":"codeVoice"},{"type":"text","text":" matching"},{"type":"text","text":" "},{"text":"stops at the partial match.","type":"text"},{"type":"text","text":" "},{"text":"When both ","type":"text"},{"type":"codeVoice","code":"partialSoft"},{"type":"text","text":" and "},{"code":"partialHard","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"are set, the latter takes precedence."}]},{"inlineContent":[{"type":"text","text":"There were formerly some restrictions on the pattern for partial matching."},{"text":" ","type":"text"},{"type":"text","text":"The restrictions no longer apply."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"See "},{"type":"codeVoice","code":"pcrepartial(3)"},{"type":"text","text":" for more information on partial matching."}],"type":"paragraph"}],"kind":"content"}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo\/isPartialMatch","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Usually if the string passed to g_regex_match*() matches as far as"},{"type":"text","text":" "},{"text":"it goes, but is too short to match the entire pattern, ","type":"text"},{"type":"codeVoice","code":"false"},{"type":"text","text":" is"},{"type":"text","text":" "},{"text":"returned. There are circumstances where it might be helpful to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"distinguish this case from other cases in which there is no match."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/matchinfo\/ispartialmatch"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"metadata":{"extendedModule":"GLib","externalID":"s:4GLib17MatchInfoProtocolPAAE09isPartialB0Sbvp::SYNTHESIZED::s:4GLib9MatchInfoC","modules":[{"name":"GLib"}],"title":"isPartialMatch","roleHeading":"Instance Property","symbolKind":"property","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"isPartialMatch","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"role":"symbol"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/MatchInfo","doc:\/\/GLib\/documentation\/GLib\/MatchInfo\/MatchInfoProtocol-Implementations"]]},"kind":"symbol","references":{"doc://GLib/documentation/GLib/MatchInfo":{"type":"topic","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"MatchInfo","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo","kind":"symbol","role":"symbol","title":"MatchInfo","url":"\/documentation\/glib\/matchinfo","navigatorTitle":[{"text":"MatchInfo","kind":"identifier"}],"abstract":[{"text":"A GMatchInfo is an opaque struct used to return information about","type":"text"},{"type":"text","text":" "},{"type":"text","text":"matches."}]},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/MatchInfo/isPartialMatch":{"abstract":[{"type":"text","text":"Usually if the string passed to g_regex_match*() matches as far as"},{"type":"text","text":" "},{"type":"text","text":"it goes, but is too short to match the entire pattern, "},{"type":"codeVoice","code":"false"},{"type":"text","text":" is"},{"type":"text","text":" "},{"text":"returned. There are circumstances where it might be helpful to","type":"text"},{"type":"text","text":" "},{"text":"distinguish this case from other cases in which there is no match.","type":"text"}],"title":"isPartialMatch","url":"\/documentation\/glib\/matchinfo\/ispartialmatch","kind":"symbol","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"isPartialMatch"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo\/isPartialMatch","type":"topic","role":"symbol"},"doc://GLib/documentation/GLib/MatchInfo/MatchInfoProtocol-Implementations":{"type":"topic","abstract":[],"role":"collectionGroup","url":"\/documentation\/glib\/matchinfo\/matchinfoprotocol-implementations","kind":"article","title":"MatchInfoProtocol Implementations","identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo\/MatchInfoProtocol-Implementations"}}}