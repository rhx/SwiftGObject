{"abstract":[{"text":"Usually if the string passed to g_regex_match*() matches as far as","type":"text"},{"type":"text","text":" "},{"type":"text","text":"it goes, but is too short to match the entire pattern, "},{"code":"false","type":"codeVoice"},{"text":" is","type":"text"},{"type":"text","text":" "},{"text":"returned. There are circumstances where it might be helpful to","type":"text"},{"type":"text","text":" "},{"text":"distinguish this case from other cases in which there is no match.","type":"text"}],"sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"isPartialMatch","kind":"identifier"},{"kind":"text","text":": "},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"},{"kind":"text","text":" { "},{"text":"get","kind":"keyword"},{"kind":"text","text":" }"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"inlineContent":[{"type":"text","text":"Consider, for example, an application where a human is required to"},{"text":" ","type":"text"},{"type":"text","text":"type in data for a field with specific formatting requirements. An"},{"text":" ","type":"text"},{"text":"example might be a date in the form ddmmmyy, defined by the pattern","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"\"^\\d?\\d(jan|feb|mar|apr|may|jun|jul|aug|sep|oct|nov|dec)"},{"type":"text","text":"\\d\\d$”."},{"text":" ","type":"text"},{"type":"text","text":"If the application sees the user’s keystrokes one by one, and can"},{"type":"text","text":" "},{"type":"text","text":"check that what has been typed so far is potentially valid, it is"},{"type":"text","text":" "},{"type":"text","text":"able to raise an error as soon as a mistake is made."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"GRegex supports the concept of partial matching by means of the"},{"text":" ","type":"text"},{"code":"partialSoft","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"partialHard"},{"text":" flags.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"When they are used, the return code for"},{"type":"text","text":" "},{"code":"g_regex_match()","type":"codeVoice"},{"type":"text","text":" or "},{"type":"codeVoice","code":"g_regex_match_full()"},{"type":"text","text":" is, as usual, "},{"type":"codeVoice","code":"true"},{"type":"text","text":" "},{"type":"text","text":"for a complete match, "},{"type":"codeVoice","code":"false"},{"text":" otherwise. But, when these functions","type":"text"},{"text":" ","type":"text"},{"text":"return ","type":"text"},{"code":"false","type":"codeVoice"},{"text":", you can check if the match was partial calling","type":"text"},{"text":" ","type":"text"},{"code":"g_match_info_is_partial_match()","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"The difference between ","type":"text"},{"code":"partialSoft","type":"codeVoice"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"partialHard"},{"type":"text","text":" is that when a partial match is encountered"},{"type":"text","text":" "},{"type":"text","text":"with "},{"type":"codeVoice","code":"partialSoft"},{"text":", matching continues to search for a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"possible complete match, while with "},{"type":"codeVoice","code":"partialHard"},{"text":" matching","type":"text"},{"type":"text","text":" "},{"type":"text","text":"stops at the partial match."},{"text":" ","type":"text"},{"text":"When both ","type":"text"},{"type":"codeVoice","code":"partialSoft"},{"type":"text","text":" and "},{"type":"codeVoice","code":"partialHard"},{"text":" ","type":"text"},{"text":"are set, the latter takes precedence.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"There were formerly some restrictions on the pattern for partial matching.","type":"text"},{"type":"text","text":" "},{"text":"The restrictions no longer apply.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"type":"codeVoice","code":"pcrepartial(3)"},{"text":" for more information on partial matching.","type":"text"}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/matchinfo\/ispartialmatch"]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/MatchInfo","doc:\/\/GLib\/documentation\/GLib\/MatchInfo\/MatchInfoProtocol-Implementations"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"symbolKind":"property","extendedModule":"GLib","title":"isPartialMatch","modules":[{"name":"GLib"}],"roleHeading":"Instance Property","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"isPartialMatch"},{"text":": ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"externalID":"s:4GLib17MatchInfoProtocolPAAE09isPartialB0Sbvp::SYNTHESIZED::s:4GLib9MatchInfoC","role":"symbol"},"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo\/isPartialMatch"},"references":{"doc://GLib/documentation/GLib/MatchInfo":{"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"MatchInfo"}],"kind":"symbol","title":"MatchInfo","url":"\/documentation\/glib\/matchinfo","abstract":[{"text":"A GMatchInfo is an opaque struct used to return information about","type":"text"},{"text":" ","type":"text"},{"text":"matches.","type":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo","navigatorTitle":[{"text":"MatchInfo","kind":"identifier"}],"type":"topic","role":"symbol"},"doc://GLib/documentation/GLib/MatchInfo/MatchInfoProtocol-Implementations":{"kind":"article","title":"MatchInfoProtocol Implementations","url":"\/documentation\/glib\/matchinfo\/matchinfoprotocol-implementations","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo\/MatchInfoProtocol-Implementations","type":"topic","role":"collectionGroup"},"doc://GLib/documentation/GLib/MatchInfo/isPartialMatch":{"role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"kind":"identifier","text":"isPartialMatch"},{"kind":"text","text":": "},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"kind":"symbol","title":"isPartialMatch","abstract":[{"text":"Usually if the string passed to g_regex_match*() matches as far as","type":"text"},{"text":" ","type":"text"},{"text":"it goes, but is too short to match the entire pattern, ","type":"text"},{"code":"false","type":"codeVoice"},{"text":" is","type":"text"},{"text":" ","type":"text"},{"text":"returned. There are circumstances where it might be helpful to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"distinguish this case from other cases in which there is no match."}],"url":"\/documentation\/glib\/matchinfo\/ispartialmatch","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo\/isPartialMatch"},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"}}}