{"metadata":{"roleHeading":"Instance Method","externalID":"s:4GLib17MatchInfoProtocolPAAE8fetchAllSpySpys4Int8VGSgGSgyF::SYNTHESIZED::s:4GLib9MatchInfoC","extendedModule":"GLib","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"fetchAll"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"kind":"text","text":">?>!"}],"modules":[{"name":"GLib"}],"symbolKind":"method","title":"fetchAll()"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"fetchAll","kind":"identifier"},{"kind":"text","text":"() -> "},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">?>!","kind":"text"}]}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"text":"If a sub pattern didn’t match anything (e.g. sub pattern 1, matching","type":"text"},{"type":"text","text":" "},{"text":"“b” against “(a)?b”) then an empty string is inserted.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If the last match was obtained using the DFA algorithm, that is using"},{"text":" ","type":"text"},{"code":"g_regex_match_all()","type":"codeVoice"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"g_regex_match_all_full()"},{"text":", the retrieved","type":"text"},{"type":"text","text":" "},{"type":"text","text":"strings are not that matched by sets of parentheses but that of the"},{"type":"text","text":" "},{"text":"matched substring. Substrings are matched in reverse order of length,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"so the first one is the longest match."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The strings are fetched from the string passed to the match function,"},{"type":"text","text":" "},{"type":"text","text":"so you cannot call this function after freeing the string."}],"type":"paragraph"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/MatchInfo","doc:\/\/GLib\/documentation\/GLib\/MatchInfo\/MatchInfoProtocol-Implementations"]]},"abstract":[{"type":"text","text":"Bundles up pointers to each of the matching substrings from a match"},{"text":" ","type":"text"},{"text":"and stores them in an array of gchar pointers. The first element in","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the returned array is the match number 0, i.e. the entire matched"},{"type":"text","text":" "},{"text":"text.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo\/fetchAll()"},"variants":[{"paths":["\/documentation\/glib\/matchinfo\/fetchall()"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"kind":"symbol","references":{"doc://GLib/documentation/GLib/MatchInfo/fetchAll()":{"abstract":[{"type":"text","text":"Bundles up pointers to each of the matching substrings from a match"},{"text":" ","type":"text"},{"type":"text","text":"and stores them in an array of gchar pointers. The first element in"},{"text":" ","type":"text"},{"type":"text","text":"the returned array is the match number 0, i.e. the entire matched"},{"type":"text","text":" "},{"type":"text","text":"text."}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo\/fetc