{"metadata":{"title":"URIRef","externalID":"s:4GLib6URIRefV","role":"symbol","symbolKind":"struct","modules":[{"name":"GLib"}],"fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"URIRef"}],"navigatorTitle":[{"text":"URIRef","kind":"identifier"}],"roleHeading":"Structure"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/uriref"]}],"abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"GUri"},{"type":"text","text":" type and related functions can be used to parse URIs into"},{"text":" ","type":"text"},{"type":"text","text":"their components, and build valid URIs from individual components."}],"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/GLib\/documentation\/GLib\/URIRef\/init(_:)-1m0g3","doc:\/\/GLib\/documentation\/GLib\/URIRef\/init(_:)-2ctpq","doc:\/\/GLib\/documentation\/GLib\/URIRef\/init(_:)-4kx37","doc:\/\/GLib\/documentation\/GLib\/URIRef\/init(_:)-5ugyq","doc:\/\/GLib\/documentation\/GLib\/URIRef\/init(_:)-86fph","doc:\/\/GLib\/documentation\/GLib\/URIRef\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/URIRef\/init(constPointer:)","doc:\/\/GLib\/documentation\/GLib\/URIRef\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/URIRef\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/URIRef\/init(mutating:)","doc:\/\/GLib\/documentation\/GLib\/URIRef\/init(opaquePointer:)"],"anchor":"Initializers","generated":true},{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/URIRef\/ptr"],"generated":true,"anchor":"Instance-Properties","title":"Instance Properties"},{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/URIRef\/build(flags:scheme:userinfo:host:port:path:query:fragment:)","doc:\/\/GLib\/documentation\/GLib\/URIRef\/buildWith(user:scheme:user:password:authParams:host:port:path:query:fragment:)","doc:\/\/GLib\/documentation\/GLib\/URIRef\/parse(uriString:flags:)"],"generated":true,"title":"Type Methods","anchor":"Type-Methods"},{"anchor":"Default-Implementations","identifiers":["doc:\/\/GLib\/documentation\/GLib\/URIRef\/PointerWrapper-Implementations","doc:\/\/GLib\/documentation\/GLib\/URIRef\/URIProtocol-Implementations"],"generated":true,"title":"Default Implementations"}],"relationshipsSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","doc:\/\/GLib\/documentation\/GLib\/URIProtocol"],"kind":"relationships","title":"Conforms To","type":"conformsTo"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/URIRef"},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"URIRef"}]}]},{"kind":"content","content":[{"anchor":"overview","text":"Overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Since "},{"type":"codeVoice","code":"GUri"},{"text":" only represents absolute URIs, all ","type":"text"},{"code":"GUri","type":"codeVoice"},{"type":"text","text":"s will have a"},{"type":"text","text":" "},{"type":"text","text":"URI scheme, so [method"},{"type":"codeVoice","code":"GLib.URI.get_scheme"},{"text":"] will always return a non-","type":"text"},{"type":"codeVoice","code":"NULL"},{"text":" ","type":"text"},{"type":"text","text":"answer. Likewise, by definition, all URIs have a path component, so"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GLib.URI.get_path"},{"type":"text","text":"] will always return a non-"},{"type":"codeVoice","code":"NULL"},{"text":" string (which may","type":"text"},{"type":"text","text":" "},{"text":"be empty).","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the URI string has an"},{"type":"text","text":" "},{"isActive":true,"identifier":"https:\/\/tools.ietf.org\/html\/rfc3986#section-3","type":"reference"},{"text":" (that","type":"text"},{"type":"text","text":" "},{"text":"is, if the scheme is followed by ","type":"text"},{"type":"codeVoice","code":":\/\/"},{"text":" rather than just ","type":"text"},{"type":"codeVoice","code":":"},{"type":"text","text":"), then the"},{"type":"text","text":" "},{"code":"GUri","type":"codeVoice"},{"text":" will contain a hostname, and possibly a port and ‘userinfo’.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Additionally, depending on how the "},{"type":"codeVoice","code":"GUri"},{"text":" was constructed\/parsed (for example,","type":"text"},{"text":" ","type":"text"},{"text":"using the ","type":"text"},{"code":"G_URI_FLAGS_HAS_PASSWORD","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"G_URI_FLAGS_HAS_AUTH_PARAMS","type":"codeVoice"},{"type":"text","text":" flags),"},{"text":" ","type":"text"},{"type":"text","text":"the userinfo may be split out into a username, password, and"},{"type":"text","text":" "},{"type":"text","text":"additional authorization-related parameters."}]},{"inlineContent":[{"text":"Normally, the components of a ","type":"text"},{"code":"GUri","type":"codeVoice"},{"text":" will have all ","type":"text"},{"code":"-encoded characters decoded. However, if you construct\/parse a `GUri` with `G_URI_FLAGS_ENCODED`, then the ","type":"codeVoice"},{"type":"text","text":"-encoding will be preserved instead in"},{"text":" ","type":"text"},{"text":"the userinfo, path, and query fields (and in the host field if also","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"created with "},{"type":"codeVoice","code":"G_URI_FLAGS_NON_DNS"},{"type":"text","text":"). In particular, this is necessary if"},{"text":" ","type":"text"},{"type":"text","text":"the URI may contain binary data or non-UTF-8 text, or if decoding"},{"type":"text","text":" "},{"type":"text","text":"the components might change the interpretation of the URI."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For example, with the encoded flag:"}],"type":"paragraph"},{"syntax":"c","type":"codeListing","code":["`g_autoptr(GUri)` uri = g_uri_parse (\"http:\/\/host\/path?query=http`3A``2F``2Fhost``2Fpath``3Fparam``3Dvalue`\", G_URI_FLAGS_ENCODED, &err);","g_assert_cmpstr (g_uri_get_query (uri), ==, \"query=http`3A``2F``2Fhost``2Fpath``3Fparam``3Dvalue`\");"]},{"type":"paragraph","inlineContent":[{"text":"While the default ````-decoding behaviour would give:","type":"text"}]},{"syntax":"c","code":["`g_autoptr(GUri)` uri = g_uri_parse (\"http:\/\/host\/path?query=http`3A``2F``2Fhost``2Fpath``3Fparam``3Dvalue`\", G_URI_FLAGS_NONE, &err);","g_assert_cmpstr (g_uri_get_query (uri), ==, \"query=http:\/\/host\/path?param=value\");"],"type":"codeListing"},{"inlineContent":[{"text":"During decoding, if an invalid UTF-8 string is encountered, parsing will fail","type":"text"},{"type":"text","text":" "},{"text":"with an error indicating the bad string location:","type":"text"}],"type":"paragraph"},{"syntax":"c","code":["`g_autoptr(GUri)` uri = g_uri_parse (\"http:\/\/host\/path?query=http`3A``2F``2Fhost``2Fpath``3Fbad``3D``00alue`\", G_URI_FLAGS_NONE, &err);","g_assert_error (err, G_URI_ERROR, G_URI_ERROR_BAD_QUERY);"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You should pass "},{"code":"G_URI_FLAGS_ENCODED","type":"codeVoice"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"G_URI_FLAGS_ENCODED_QUERY"},{"type":"text","text":" if you"},{"text":" ","type":"text"},{"text":"need to handle that case manually. In particular, if the query string","type":"text"},{"text":" ","type":"text"},{"text":"contains ","type":"text"},{"type":"codeVoice","code":"="},{"type":"text","text":" characters that are ````-encoded, you should let"},{"type":"text","text":" "},{"text":"[func","type":"text"},{"code":"GLib.URI.parse_params","type":"codeVoice"},{"type":"text","text":"] do the decoding once of the query."}]},{"inlineContent":[{"type":"codeVoice","code":"GUri"},{"type":"text","text":" is immutable once constructed, and can safely be accessed from"},{"type":"text","text":" "},{"type":"text","text":"multiple threads. Its reference counting is atomic."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Note that the scope of "},{"code":"GUri","type":"codeVoice"},{"type":"text","text":" is to help manipulate URIs in various applications,"},{"text":" ","type":"text"},{"type":"text","text":"following "},{"type":"reference","identifier":"https:\/\/tools.ietf.org\/html\/rfc3986","isActive":true},{"type":"text","text":". In particular,"},{"text":" ","type":"text"},{"type":"text","text":"it doesn’t intend to cover web browser needs, and doesn’t implement the"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"https:\/\/url.spec.whatwg.org\/"},{"type":"text","text":" standard. No APIs are provided to"},{"type":"text","text":" "},{"text":"help prevent","type":"text"},{"type":"text","text":" "},{"identifier":"https:\/\/en.wikipedia.org\/wiki\/IDN_homograph_attack","isActive":true,"type":"reference"},{"type":"text","text":", so"},{"type":"text","text":" "},{"type":"codeVoice","code":"GUri"},{"text":" is not suitable for formatting URIs for display to the user for making","type":"text"},{"type":"text","text":" "},{"text":"security-sensitive decisions.","type":"text"}],"type":"paragraph"},{"text":"Relative and absolute URIs","type":"heading","level":2,"anchor":"Relative-and-absolute-URIs"},{"type":"paragraph","inlineContent":[{"text":"As defined in ","type":"text"},{"identifier":"https:\/\/tools.ietf.org\/html\/rfc3986#section-4","isActive":true,"type":"reference"},{"text":", the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"hierarchical nature of URIs means that they can either be ‘relative"},{"type":"text","text":" "},{"text":"references’ (sometimes referred to as ‘relative URIs’) or ‘URIs’ (for","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"clarity, ‘URIs’ are referred to in this documentation as"},{"text":" ","type":"text"},{"type":"text","text":"‘absolute URIs’ — although"},{"text":" ","type":"text"},{"identifier":"https:\/\/tools.ietf.org\/html\/rfc3986#section-4.3","type":"reference","isActive":true},{"type":"text","text":","},{"text":" ","type":"text"},{"text":"fragment identifiers are always allowed).","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Relative references have one or more components of the URI missing. In"},{"text":" ","type":"text"},{"type":"text","text":"particular, they have no scheme. Any other component, such as hostname,"},{"text":" ","type":"text"},{"text":"query, etc. may be missing, apart from a path, which has to be specified (but","type":"text"},{"type":"text","text":" "},{"type":"text","text":"may be empty). The path may be relative, starting with "},{"code":".\/","type":"codeVoice"},{"type":"text","text":" rather than "},{"code":"\/","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, a valid relative reference is "},{"code":".\/path?query","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"codeVoice","code":"\/?query"},{"type":"text","text":"fragment`` or "},{"code":"\/\/example.com","type":"codeVoice"},{"text":".","type":"text"}]},{"inlineContent":[{"text":"Absolute URIs have a scheme specified. Any other components of the URI which","type":"text"},{"type":"text","text":" "},{"text":"are missing are specified as explicitly unset in the URI, rather than being","type":"text"},{"text":" ","type":"text"},{"text":"resolved relative to a base URI using [method","type":"text"},{"code":"GLib.URI.parse_relative","type":"codeVoice"},{"type":"text","text":"]."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, a valid absolute URI is "},{"type":"codeVoice","code":"file:\/\/\/home\/bob"},{"text":" or","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"https:\/\/search.com?query=string"},{"text":".","type":"text"}]},{"inlineContent":[{"type":"text","text":"A "},{"code":"GUri","type":"codeVoice"},{"text":" instance is always an absolute URI. A string may be an absolute URI","type":"text"},{"text":" ","type":"text"},{"text":"or a relative reference; see the documentation for individual functions as to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"what forms they accept."}],"type":"paragraph"},{"level":2,"text":"Parsing URIs","type":"heading","anchor":"Parsing-URIs"},{"inlineContent":[{"text":"The most minimalist APIs for parsing URIs are [func","type":"text"},{"type":"codeVoice","code":"GLib.URI.split"},{"type":"text","text":"] and"},{"type":"text","text":" "},{"text":"[func","type":"text"},{"code":"GLib.URI.split_with_user","type":"codeVoice"},{"text":"]. These split a URI into its component","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"parts, and return the parts; the difference between the two is that"},{"text":" ","type":"text"},{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.URI.split"},{"type":"text","text":"] treats the ‘userinfo’ component of the URI as a"},{"text":" ","type":"text"},{"text":"single element, while [func","type":"text"},{"code":"GLib.URI.split_with_user","type":"codeVoice"},{"text":"] can (depending on the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[flags"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/URIFlags","isActive":true,"type":"reference"},{"text":"] you pass) treat it as containing a username, password,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and authentication parameters. Alternatively, [func"},{"code":"GLib.URI.split_network","type":"codeVoice"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"type":"text","text":"can be used when you are only interested in the components that are"},{"type":"text","text":" "},{"text":"needed to initiate a network connection to the service (scheme,","type":"text"},{"type":"text","text":" "},{"text":"host, and port).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.URI.parse"},{"text":"] is similar to [func","type":"text"},{"type":"codeVoice","code":"GLib.URI.split"},{"type":"text","text":"], but instead of"},{"text":" ","type":"text"},{"text":"returning individual strings, it returns a ","type":"text"},{"type":"codeVoice","code":"GUri"},{"type":"text","text":" structure (and it requires"},{"type":"text","text":" "},{"type":"text","text":"that the URI be an absolute URI)."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.URI.resolve_relative"},{"type":"text","text":"] and [method"},{"type":"codeVoice","code":"GLib.URI.parse_relative"},{"text":"] allow","type":"text"},{"type":"text","text":" "},{"type":"text","text":"you to resolve a relative URI relative to a base URI."},{"type":"text","text":" "},{"text":"[func","type":"text"},{"type":"codeVoice","code":"GLib.URI.resolve_relative"},{"type":"text","text":"] takes two strings and returns a string,"},{"text":" ","type":"text"},{"type":"text","text":"and [method"},{"code":"GLib.URI.parse_relative","type":"codeVoice"},{"type":"text","text":"] takes a "},{"code":"GUri","type":"codeVoice"},{"type":"text","text":" and a string and returns a"},{"text":" ","type":"text"},{"type":"codeVoice","code":"GUri"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"All of the parsing functions take a [flags","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/URIFlags","isActive":true,"type":"reference"},{"text":"] argument describing","type":"text"},{"type":"text","text":" "},{"type":"text","text":"exactly how to parse the URI; see the documentation for that type"},{"text":" ","type":"text"},{"type":"text","text":"for more details on the specific flags that you can pass. If you"},{"text":" ","type":"text"},{"text":"need to choose different flags based on the type of URI, you can","type":"text"},{"text":" ","type":"text"},{"text":"use [func","type":"text"},{"code":"GLib.URI.peek_scheme","type":"codeVoice"},{"type":"text","text":"] on the URI string to check the scheme"},{"text":" ","type":"text"},{"type":"text","text":"first, and use that to decide what flags to parse it with."}]},{"inlineContent":[{"type":"text","text":"For example, you might want to use "},{"type":"codeVoice","code":"G_URI_PARAMS_WWW_FORM"},{"type":"text","text":" when parsing the"},{"type":"text","text":" "},{"text":"params for a web URI, so compare the result of [func","type":"text"},{"type":"codeVoice","code":"GLib.URI.peek_scheme"},{"text":"]","type":"text"},{"type":"text","text":" "},{"type":"text","text":"against "},{"type":"codeVoice","code":"http"},{"text":" and ","type":"text"},{"code":"https","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"level":2,"anchor":"Building-URIs","type":"heading","text":"Building URIs"},{"type":"paragraph","inlineContent":[{"text":"[func","type":"text"},{"code":"GLib.URI.join","type":"codeVoice"},{"type":"text","text":"] and [func"},{"type":"codeVoice","code":"GLib.URI.join_with_user"},{"text":"] can be used to construct","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"valid URI strings from a set of component strings. They are the"},{"type":"text","text":" "},{"type":"text","text":"inverse of [func"},{"code":"GLib.URI.split","type":"codeVoice"},{"type":"text","text":"] and [func"},{"code":"GLib.URI.split_with_user","type":"codeVoice"},{"text":"].","type":"text"}]},{"inlineContent":[{"type":"text","text":"Similarly, [func"},{"type":"codeVoice","code":"GLib.URI.build"},{"text":"] and [func","type":"text"},{"code":"GLib.URI.build_with_user","type":"codeVoice"},{"text":"] can be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"used to construct a "},{"type":"codeVoice","code":"GUri"},{"type":"text","text":" from a set of component strings."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"As with the parsing functions, the building functions take a"},{"type":"text","text":" "},{"text":"[flags","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/URIFlags","type":"reference"},{"text":"] argument. In particular, it is important to keep in mind","type":"text"},{"text":" ","type":"text"},{"text":"whether the URI components you are using are already ````-encoded. If so,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"you must pass the "},{"type":"codeVoice","code":"G_URI_FLAGS_ENCODED"},{"type":"text","text":" flag."}],"type":"paragraph"},{"level":2,"type":"heading","text":"`file:\/\/` URIs","anchor":"file-URIs"},{"inlineContent":[{"text":"Note that Windows and Unix both define special rules for parsing","type":"text"},{"text":" ","type":"text"},{"code":"file:\/\/","type":"codeVoice"},{"type":"text","text":" URIs (involving non-UTF-8 character sets on Unix, and the"},{"text":" ","type":"text"},{"text":"interpretation of path separators on Windows). ","type":"text"},{"type":"codeVoice","code":"GUri"},{"text":" does not","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"implement these rules. Use [func"},{"code":"GLib.filename_from_uri","type":"codeVoice"},{"type":"text","text":"] and"},{"type":"text","text":" "},{"type":"text","text":"[func"},{"code":"GLib.filename_to_uri","type":"codeVoice"},{"type":"text","text":"] if you want to properly convert between"},{"text":" ","type":"text"},{"type":"codeVoice","code":"file:\/\/"},{"text":" URIs and local filenames.","type":"text"}],"type":"paragraph"},{"text":"URI Equality","type":"heading","level":2,"anchor":"URI-Equality"},{"inlineContent":[{"type":"text","text":"Note that there is no "},{"type":"codeVoice","code":"g_uri_equal ()"},{"text":" function, because comparing","type":"text"},{"type":"text","text":" "},{"text":"URIs usefully requires scheme-specific knowledge that ","type":"text"},{"code":"GUri","type":"codeVoice"},{"type":"text","text":" does"},{"text":" ","type":"text"},{"type":"text","text":"not have. "},{"code":"GUri","type":"codeVoice"},{"type":"text","text":" can help with normalization if you use the various"},{"type":"text","text":" "},{"type":"text","text":"encoded [flags"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/URIFlags"},{"text":"] as well as ","type":"text"},{"type":"codeVoice","code":"G_URI_FLAGS_SCHEME_NORMALIZE"},{"type":"text","text":" "},{"text":"however it is not comprehensive.","type":"text"},{"type":"text","text":" "},{"text":"For example, ","type":"text"},{"code":"data:,foo","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"data:;base64,Zm9v"},{"text":" resolve to the same","type":"text"},{"text":" ","type":"text"},{"text":"thing according to the ","type":"text"},{"code":"data:","type":"codeVoice"},{"text":" URI specification which GLib does not","type":"text"},{"type":"text","text":" "},{"text":"handle.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/URIRef","isActive":true,"type":"reference"},{"text":" type acts as a lightweight Swift reference to an underlying ","type":"text"},{"code":"GUri","type":"codeVoice"},{"text":" instance.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/URIProtocol","isActive":true},{"text":" conformance.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Use "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/URIRef","isActive":true,"type":"reference"},{"type":"text","text":" only as an "},{"type":"codeVoice