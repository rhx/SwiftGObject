{"kind":"symbol","sections":[],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFile","interfaceLanguage":"swift"},"abstract":[{"type":"codeVoice","code":"GBookmarkFile"},{"type":"text","text":" lets you parse, edit or create files containing bookmarks."}],"relationshipsSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/BookmarkFileProtocol","doc:\/\/GLib\/documentation\/GLib\/PointerWrapper"],"title":"Conforms To","kind":"relationships","type":"conformsTo"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/bookmarkfile"]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"topicSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init()","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(_:)-12es4","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(_:)-39yvz","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(_:)-5gx5p","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(_:)-638ob","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(_:)-65rhv","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(opaquePointer:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(raw:)-15cs1","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(raw:)-4ack0","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(retaining:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(retainingCPointer:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(retainingOpaquePointer:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(retainingRaw:)-3hi79","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(retainingRaw:)-8ifug"],"anchor":"Initializers","generated":true,"title":"Initializers"},{"generated":true,"anchor":"Instance-Properties","title":"Instance Properties","identifiers":["doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/ptr"]},{"generated":true,"title":"Default Implementations","anchor":"Default-Implementations","identifiers":["doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/BookmarkFileProtocol-Implementations"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"BookmarkFile","kind":"identifier"}]}]},{"kind":"content","content":[{"text":"Overview","anchor":"overview","level":2,"type":"heading"},{"inlineContent":[{"text":"Bookmarks refer to a URI, along with some meta-data about the resource","type":"text"},{"type":"text","text":" "},{"text":"pointed by the URI like its MIME type, the application that is registering","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the bookmark and the icon that should be used to represent the bookmark."},{"text":" ","type":"text"},{"type":"text","text":"The data is stored using the"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/www.freedesktop.org\/wiki\/Specifications\/desktop-bookmark-spec\/","isActive":true},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The syntax of the bookmark files is described in detail inside the","type":"text"},{"text":" ","type":"text"},{"text":"Desktop Bookmark Specification, here is a quick summary: bookmark","type":"text"},{"text":" ","type":"text"},{"text":"files use a sub-class of the XML Bookmark Exchange Language","type":"text"},{"type":"text","text":" "},{"text":"specification, consisting of valid UTF-8 encoded XML, under the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"<xbel>"},{"type":"text","text":" root element; each bookmark is stored inside a"},{"type":"text","text":" "},{"type":"codeVoice","code":"<bookmark>"},{"text":" element, using its URI: no relative paths can","type":"text"},{"type":"text","text":" "},{"type":"text","text":"be used inside a bookmark file. The bookmark may have a user defined"},{"text":" ","type":"text"},{"type":"text","text":"title and description, to be used instead of the URI. Under the"},{"type":"text","text":" "},{"code":"<metadata>","type":"codeVoice"},{"type":"text","text":" element, with its owner attribute set to"},{"type":"text","text":" "},{"type":"codeVoice","code":"http:\/\/freedesktop.org"},{"text":", is stored the meta-data about a resource","type":"text"},{"type":"text","text":" "},{"type":"text","text":"pointed by its URI. The meta-data consists of the resource’s MIME"},{"type":"text","text":" "},{"type":"text","text":"type; the applications that have registered a bookmark; the groups"},{"text":" ","type":"text"},{"text":"to which a bookmark belongs to; a visibility flag, used to set the","type":"text"},{"type":"text","text":" "},{"text":"bookmark as “private” to the applications and groups that has it","type":"text"},{"type":"text","text":" "},{"text":"registered; the URI and MIME type of an icon, to be used when","type":"text"},{"text":" ","type":"text"},{"text":"displaying the bookmark inside a GUI.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Here is an example of a bookmark file:"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"https:\/\/gitlab.gnome.org\/GNOME\/glib\/-\/blob\/HEAD\/glib\/tests\/bookmarks.xbel"}]},{"inlineContent":[{"type":"text","text":"A bookmark file might contain more than one bookmark; each bookmark"},{"text":" ","type":"text"},{"text":"is accessed through its URI.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The important caveat of bookmark files is that when you add a new"},{"type":"text","text":" "},{"text":"bookmark you must also add the application that is registering it, using","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GLib.BookmarkFile.add_application"},{"type":"text","text":"] or [method"},{"code":"GLib.BookmarkFile.set_application_info","type":"codeVoice"},{"text":"].","type":"text"},{"type":"text","text":" "},{"type":"text","text":"If a bookmark has no applications then it won’t be dumped when creating"},{"type":"text","text":" "},{"type":"text","text":"the on disk representation, using [method"},{"type":"codeVoice","code":"GLib.BookmarkFile.to_data"},{"type":"text","text":"] or"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.BookmarkFile.to_file"},{"type":"text","text":"]."}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFile"},{"type":"text","text":" type acts as an owner of an underlying "},{"code":"GBookmarkFile","type":"codeVoice"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"type":"text","text":"It provides the methods that can operate on this data type through "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFileProtocol","isActive":true},{"text":" conformance.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Use "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFile","isActive":true},{"text":" as a strong reference or owner of a ","type":"text"},{"type":"codeVoice","code":"GBookmarkFile"},{"type":"text","text":" instance."}]},{"content":[{"inlineContent":[{"type":"text","text":"Use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef"},{"text":" (instead of ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFile","type":"reference","isActive":true},{"type":"text","text":") for a lightweight Swift reference to an underlying "},{"code":"GBookmarkFile","type":"codeVoice"},{"type":"text","text":" instance."}],"type":"paragraph"}],"type":"aside","name":"Note","style":"note"}]}],"metadata":{"title":"BookmarkFile","modules":[{"name":"GLib"}],"externalID":"s:4GLib12BookmarkFileC","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"BookmarkFile"}],"roleHeading":"Class","symbolKind":"class","navigatorTitle":[{"kind":"identifier","text":"BookmarkFile"}]},"schemaVersion":{"major":0,"patch":0,"minor":3},"references":{"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/BookmarkFile/init(retainingRaw:)-3hi79":{"kind":"symbol","role":"symbol","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"retainingRaw"},{"kind":"text","text":": "},{"text":"UnsafeRawPointer","kind":"typeIdentifier","preciseIdentifier":"s:SV"},{"text":")","kind":"text"}],"url":"\/documentation\/glib\/bookmarkfile\/init(retainingraw:)-3hi79","title":"init(retainingRaw:)","abstract":[{"type":"text","text":"Unsafe untyped, retaining initialiser."},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"text":"Do not use unless you know the underlying data type the pointer points to conforms to ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFileProtocol","type":"reference"},{"text":".","type":"text"}]}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(retainingRaw:)-3hi79","type":"topic"},"doc://GLib/documentation/GLib/BookmarkFile/BookmarkFileProtocol-Implementations":{"abstract":[],"role":"collectionGroup","identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/BookmarkFileProtocol-Implementations","type":"topic","title":"BookmarkFileProtocol Implementations","url":"\/documentation\/glib\/bookmarkfile\/bookmarkfileprotocol-implementations","kind":"article