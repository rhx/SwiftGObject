{"sections":[],"topicSections":[{"anchor":"Initializers","identifiers":["doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init()","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(_:)-12es4","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(_:)-39yvz","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(_:)-5gx5p","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(_:)-638ob","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(_:)-65rhv","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(opaquePointer:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(raw:)-15cs1","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(raw:)-4ack0","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(retaining:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(retainingCPointer:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(retainingOpaquePointer:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(retainingRaw:)-3hi79","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(retainingRaw:)-8ifug"],"generated":true,"title":"Initializers"},{"anchor":"Instance-Properties","title":"Instance Properties","generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/ptr"]},{"title":"Default Implementations","identifiers":["doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/BookmarkFileProtocol-Implementations"],"anchor":"Default-Implementations","generated":true}],"relationshipsSections":[{"type":"conformsTo","title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/GLib\/documentation\/GLib\/BookmarkFileProtocol","doc:\/\/GLib\/documentation\/GLib\/PointerWrapper"]}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFile"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/bookmarkfile"]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"modules":[{"name":"GLib"}],"symbolKind":"class","role":"symbol","externalID":"s:4GLib12BookmarkFileC","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"BookmarkFile","kind":"identifier"}],"title":"BookmarkFile","navigatorTitle":[{"text":"BookmarkFile","kind":"identifier"}],"roleHeading":"Class"},"abstract":[{"code":"GBookmarkFile","type":"codeVoice"},{"type":"text","text":" lets you parse, edit or create files containing bookmarks."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"BookmarkFile","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"text":"Overview","level":2,"type":"heading","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Bookmarks refer to a URI, along with some meta-data about the resource"},{"type":"text","text":" "},{"type":"text","text":"pointed by the URI like its MIME type, the application that is registering"},{"text":" ","type":"text"},{"type":"text","text":"the bookmark and the icon that should be used to represent the bookmark."},{"text":" ","type":"text"},{"text":"The data is stored using the","type":"text"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/www.freedesktop.org\/wiki\/Specifications\/desktop-bookmark-spec\/","isActive":true},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"The syntax of the bookmark files is described in detail inside the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Desktop Bookmark Specification, here is a quick summary: bookmark"},{"text":" ","type":"text"},{"text":"files use a sub-class of the XML Bookmark Exchange Language","type":"text"},{"type":"text","text":" "},{"type":"text","text":"specification, consisting of valid UTF-8 encoded XML, under the"},{"type":"text","text":" "},{"code":"<xbel>","type":"codeVoice"},{"text":" root element; each bookmark is stored inside a","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"<bookmark>"},{"type":"text","text":" element, using its URI: no relative paths can"},{"text":" ","type":"text"},{"type":"text","text":"be used inside a bookmark file. The bookmark may have a user defined"},{"text":" ","type":"text"},{"type":"text","text":"title and description, to be used instead of the URI. Under the"},{"text":" ","type":"text"},{"code":"<metadata>","type":"codeVoice"},{"type":"text","text":" element, with its owner attribute set to"},{"text":" ","type":"text"},{"type":"codeVoice","code":"http:\/\/freedesktop.org"},{"text":", is stored the meta-data about a resource","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"pointed by its URI. The meta-data consists of the resource’s MIME"},{"text":" ","type":"text"},{"text":"type; the applications that have registered a bookmark; the groups","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to which a bookmark belongs to; a visibility flag, used to set the"},{"type":"text","text":" "},{"type":"text","text":"bookmark as “private” to the applications and groups that has it"},{"type":"text","text":" "},{"text":"registered; the URI and MIME type of an icon, to be used when","type":"text"},{"text":" ","type":"text"},{"text":"displaying the bookmark inside a GUI.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Here is an example of a bookmark file:"},{"text":" ","type":"text"},{"type":"reference","identifier":"https:\/\/gitlab.gnome.org\/GNOME\/glib\/-\/blob\/HEAD\/glib\/tests\/bookmarks.xbel","isActive":true}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A bookmark file might contain more than one bookmark; each bookmark"},{"text":" ","type":"text"},{"type":"text","text":"is accessed through its URI."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The important caveat of bookmark files is that when you add a new"},{"type":"text","text":" "},{"text":"bookmark you must also add the application that is registering it, using","type":"text"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.BookmarkFile.add_application"},{"text":"] or [method","type":"text"},{"code":"GLib.BookmarkFile.set_application_info","type":"codeVoice"},{"text":"].","type":"text"},{"text":" ","type":"text"},{"text":"If a bookmark has no applications then it won’t be dumped when creating","type":"text"},{"type":"text","text":" "},{"text":"the on disk representation, using [method","type":"text"},{"code":"GLib.BookmarkFile.to_data","type":"codeVoice"},{"text":"] or","type":"text"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"code":"GLib.BookmarkFile.to_file","type":"codeVoice"},{"type":"text","text":"]."}]},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFile","type":"reference","isActive":true},{"text":" type acts as an owner of an underlying ","type":"text"},{"type":"codeVoice","code":"GBookmarkFile"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"It provides the methods that can operate on this data type through "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFileProtocol","isActive":true,"type":"reference"},{"type":"text","text":" conformance."},{"text":" ","type":"text"},{"type":"text","text":"Use "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFile","type":"reference"},{"text":" as a strong reference or owner of a ","type":"text"},{"type":"codeVoice","code":"GBookmarkFile"},{"type":"text","text":" instance."}],"type":"paragraph"},{"type":"aside","name":"Note","style":"note","content":[{"inlineContent":[{"text":"Use ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef","type":"reference","isActive":true},{"type":"text","text":" (instead of "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFile","isActive":true,"type":"reference"},{"text":") for a lightweight Swift reference to an underlying ","type":"text"},{"code":"GBookmarkFile","type":"codeVoice"},{"type":"text","text":" instance."}],"type":"paragraph"}]}],"kind":"content"}],"references":{"https://gitlab.gnome.org/GNOME/glib/-/blob/HEAD/glib/tests/bookmarks.xbel":{"url":"https:\/\/gitlab.gnome.org\/GNOME\/glib\/-\/blob\/HEAD\/glib\/tests\/bookmarks.xbel","titleInlineContent":[{"text":"bookmarks.xbel","type":"text"}],"type":"link","identifier":"https:\/\/gitlab.gnome.org\/GNOME\/glib\/-\/blob\/HEAD\/glib\/tests\/bookmarks.xbel","title":"bookmarks.xbel"},"doc://GLib/documentation/GLib/PointerWrapper":{"abstract":[{"text":"Protocol for GLib types that wrap pointers.","type":"text"}],"role":"symbol","url":"\/documentation\/glib\/pointerwrapper","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","title":"PointerWrapper","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"PointerWrapper"}],"type":"topic","navigatorTitle":[{"text":"PointerWrapper","kind":"identifier"}]},"doc://GLib/documentation/GLib/BookmarkFile/init(_:)-5gx5p":{"type":"topic","url":"\/documentation\/glib\/bookmarkfile\/init(_:)-5gx5p","kind":"symbol","title":"init(_:)","fragments":[{"kind":"identifier","text":"init"},{"text":"(","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"GBookmarkFile","kind":"typeIdentifier"},{"kind":"text","text":">)"}],"abstract":[{"text":"Designated initialiser from a constant pointer to the underlying ","type":"text"},{"type":"codeVoice","code":"C"},{"text":" data type.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This cr