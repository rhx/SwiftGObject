{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/RefArrayRef","doc:\/\/GLib\/documentation\/GLib\/RefArrayRef\/PtrArrayProtocol-Implementations"]]},"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/RefArrayRef\/steal(len:)"},"abstract":[{"text":"Frees the data in the array and resets the size to zero, while","type":"text"},{"text":" ","type":"text"},{"text":"the underlying array is preserved for use elsewhere and returned","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to the caller."}],"metadata":{"title":"steal(len:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"steal","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"len"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"gsize","preciseIdentifier":"c:@T@gsize","kind":"typeIdentifier"},{"text":">!) -> ","kind":"text"},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"gpointer","preciseIdentifier":"c:@T@gpointer"},{"text":"?>!","kind":"text"}],"role":"symbol","roleHeading":"Instance Method","modules":[{"name":"GLib"}],"extendedModule":"GLib","externalID":"s:4GLib16PtrArrayProtocolPAAE5steal3lenSpySvSgGSgSpySuGSg_tF::SYNTHESIZED::s:4GLib08RefArrayB0V","symbolKind":"method"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"steal","kind":"identifier"},{"text":"(","kind":"text"},{"text":"len","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"text":"gsize","kind":"typeIdentifier","preciseIdentifier":"c:@T@gsize"},{"text":">! = nil) -> ","kind":"tex