{"abstract":[{"type":"text","text":"Frees the data in the array and resets the size to zero, while"},{"type":"text","text":" "},{"text":"the underlying array is preserved for use elsewhere and returned","type":"text"},{"type":"text","text":" "},{"text":"to the caller.","type":"text"}],"sections":[],"metadata":{"roleHeading":"Instance Method","extendedModule":"GLib","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"steal","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"len"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gsize","text":"gsize","kind":"typeIdentifier"},{"kind":"text","text":">!) -> "},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gpointer","preciseIdentifier":"c:@T@gpointer"},{"kind":"text","text":"?>!"}],"symbolKind":"method","role":"symbol","externalID":"s:4GLib16PtrArrayProtocolPAAE5steal3lenSpySvSgGSgSpySuGSg_tF::SYNTHESIZED::s:4GLib08RefArrayB0V","modules":[{"name":"GLib"}],"title":"steal(len:)"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/RefArrayRef","doc:\/\/GLib\/documentation\/GLib\/RefArrayRef\/PtrArrayProtocol-Implementations"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/RefArrayRef\/steal(len:)"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"steal","kind":"identifier"},{"kind":"text","text":"("},{"text":"len","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sp","kind":"typeIdentifier","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gsize","text":"gsize"},{"kind":"text","text":">! = nil) -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"text":"?>!","kind":"text"}]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Note that if the array is "},{"type":"codeVoice","code":"NULL"},{"type":"text","text":" terminated this may still return"},{"type":"text","text":" "},{"type":"codeVoice","code":"NULL"},{"text":" if the length of the array was zero and pdata was not yet","type":"text"},{"text":" ","type":"text"},{"text":"allocated.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Even if set, the [callback","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/DestroyNotify","type":"reference"},{"text":"] function will never be called","type":"text"},{"type":"text","text":" "},{"text":"on the current contents of the array and the caller is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"responsible for freeing the array elements."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"An example of use:","type":"text"}]},{"type":"codeListing","syntax":"c","code":["`g_autoptr(GPtrArray)` chunk_buffer = g_ptr_array_new_with_free_func (g_bytes_unref);","","\/\/ Some part of your application appends a number of chunks to the pointer array.","g_ptr_array_add (chunk_buffer, g_bytes_new_static (\"hello\", 5));","g_ptr_array_add (chunk_buffer, g_bytes_new_static (\"world\", 5));","","…","","\/\/ Periodically, the chunks need to be sent as an array-and-length to some","\/\/ other part of the program.","GBytes **chunks;","gsize n_chunks;","","chunks = g_ptr_array_steal (chunk_buffer, &n_chunks);","for (gsize i = 0; i < n_chunks; i++)","  {","    \/\/ Do something with each chunk here, and then free them, since","    \/\/ `g_ptr_array_steal()` transfers ownership of all the elements and the","    \/\/ array to the caller.","    …","","    g_bytes_unref (chunks[i]);","  }","","g_free (chunks);","","\/\/ After calling `g_ptr_array_steal()`, the pointer array can be reused for the","\/\/ next set of chunks.","g_assert (chunk_buffer->len == 0);"]}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/refarrayref\/steal(len:)"]}],"references":{"doc://GLib/documentation/GLib/DestroyNotify":{"url":"\/documentation\/glib\/destroynotify","title":"DestroyNotify","role":"symbol","fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"DestroyNotify"}],"type":"topic","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/DestroyNotify","abstract":[{"text":"Specifies the type of function which is called when a data element","type":"text"},{"type":"text","text":" "},{"text":"is destroyed. It is passed the pointer to the data element and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"should free any memory and resources allocated for it."}],"navigatorTitle":[{"text":"DestroyNotify","kind":"identifier"}]},"doc://GLib/documentation/GLib/RefArrayRef/steal(len:)":{"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"steal"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"len"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sp","kind":"typeIdentifier","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gsize","text":"gsize","kind":"typeIdentifier"},{"text":">!) -> ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"kind":"text","text":"?>!"}],"abstract":[{"type":"text","text"