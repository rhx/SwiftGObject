{"abstract":[{"text":"Splits ","type":"text"},{"code":"string","type":"codeVoice"},{"text":" into a number of tokens not containing any of the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"bytes in "},{"type":"codeVoice","code":"delimiters"},{"text":".","type":"text"}],"metadata":{"modules":[{"name":"GLib"}],"externalID":"s:4GLib11strsplitSet6string10delimiters9maxTokensSpySpys4Int8VGSgGSgSPyAGGSg_AMSitF","title":"strsplitSet(string:delimiters:maxTokens:)","symbolKind":"func","roleHeading":"Function","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"strsplitSet"},{"text":"(","kind":"text"},{"text":"string","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier","text":"gchar"},{"kind":"text","text":">!, "},{"text":"delimiters","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"maxTokens"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier","text":"gchar"},{"text":">?>!","kind":"text"}],"role":"symbol"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"strsplitSet","kind":"identifier"},{"text":"(","kind":"text"},{"text":"string","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"kind":"text","text":">!, "},{"text":"delimiters","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"text":">!, ","kind":"text"},{"text":"maxTokens","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":") -> ","kind":"text"},{"text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier","text":"gchar"},{"text":">?>!","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"A token is the (possibly empty) longest string that does not"},{"type":"text","text":" "},{"text":"contain any of the bytes in ","type":"text"},{"type":"codeVoice","code":"delimiters"},{"text":". Note that separators","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"will only be single bytes from "},{"code":"delimiters","type":"codeVoice"},{"type":"text","text":". If "},{"type":"codeVoice","code":"maxTokens"},{"type":"text","text":" is reached,"},{"type":"text","text":" "},{"text":"the remainder is appended to the last token.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, the result of "},{"code":"g_strsplit_set (\"abc:def\/ghi\", \":\/\", -1)","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"is an array containing the three strings "},{"type":"codeVoice","code":"\"abc\""},{"type":"text","text":", "},{"code":"\"def\"","type":"codeVoice"},{"type":"text","text":", and "},{"code":"\"ghi\"","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The result of "},{"type":"codeVoice","code":"g_strsplit_set (\":def\/ghi:\/x\", \":\/\", -1)"},{"type":"text","text":" is an array"},{"type":"text","text":" "},{"type":"text","text":"containing the five strings "},{"code":"\"\"","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"\"def\""},{"type":"text","text":", "},{"code":"\"ghi\"","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"\"\""},{"text":", ","type":"text"},{"type":"codeVoice","code":"\"x\""},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"As a special case, the result of splitting the empty string "},{"type":"codeVoice","code":"\"\""},{"type":"text","text":" is an empty"},{"type":"text","text":" "},{"type":"text","text":"array, not an array containing a single string. The reason for this"},{"text":" ","type":"text"},{"type":"text","text":"special case is that being able to represent an empty array is typically"},{"text":" ","type":"text"},{"text":"more useful than consistent handling of empty elements. If you do need","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to represent empty elements, you’ll need to check for the empty string"},{"type":"text","text":" "},{"type":"text","text":"before calling "},{"type":"codeVoice","code":"g_strsplit_set()"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that this function works on bytes not characters, so it can’t be used"},{"text":" ","type":"text"},{"type":"text","text":"to delimit UTF-8 strings for anything but ASCII characters."}]}]}],"schemaVersion":{"minor":3,