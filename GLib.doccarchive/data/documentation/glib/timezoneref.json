{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TimeZoneRef"}],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"text":"Overview","type":"heading","anchor":"overview"},{"inlineContent":[{"text":"The ","type":"text"},{"code":"GTimeZone","type":"codeVoice"},{"type":"text","text":" struct is refcounted and immutable."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Each time zone has an identifier (for example, ‘Europe\/London’) which is"},{"text":" ","type":"text"},{"text":"platform dependent. See [ctor","type":"text"},{"code":"GLib.TimeZone.new","type":"codeVoice"},{"text":"] for information on the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"identifier formats. The identifier of a time zone can be retrieved using"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.TimeZone.get_identifier"},{"type":"text","text":"]."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A time zone contains a number of intervals. Each interval has an abbreviation"},{"text":" ","type":"text"},{"type":"text","text":"to describe it (for example, ‘PDT’), an offset to UTC and a flag indicating"},{"text":" ","type":"text"},{"text":"if the daylight savings time is in effect during that interval. A time zone","type":"text"},{"type":"text","text":" "},{"type":"text","text":"always has at least one interval — interval 0. Note that interval abbreviations"},{"text":" ","type":"text"},{"text":"are not the same as time zone identifiers (apart from ‘UTC’), and cannot be","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"passed to [ctor"},{"type":"codeVoice","code":"GLib.TimeZone.new"},{"text":"].","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Every UTC time is contained within exactly one interval, but a given"},{"type":"text","text":" "},{"type":"text","text":"local time may be contained within zero, one or two intervals (due to"},{"text":" ","type":"text"},{"text":"incontinuities associated with daylight savings time).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An interval may refer to a specific period of time (eg: the duration"},{"text":" ","type":"text"},{"text":"of daylight savings time during 2010) or it may refer to many periods","type":"text"},{"text":" ","type":"text"},{"text":"of time that share the same properties (eg: all periods of daylight","type":"text"},{"text":" ","type":"text"},{"text":"savings time).  It is also possible (usually for political reasons)","type":"text"},{"type":"text","text":" "},{"text":"that some properties (like the abbreviation) change between intervals","type":"text"},{"text":" ","type":"text"},{"text":"without other properties changing.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef"},{"text":" type acts as a lightweight Swift reference to an underlying ","type":"text"},{"type":"codeVoice","code":"GTimeZone"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZoneProtocol","isActive":true,"type":"reference"},{"type":"text","text":" conformance."},{"text":" ","type":"text"},{"type":"text","text":"Use "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef","type":"reference","isActive":true},{"text":" only as an ","type":"text"},{"code":"unowned","type":"codeVoice"},{"text":" reference to an existing ","type":"text"},{"type":"codeVoice","code":"GTimeZone"},{"type":"text","text":" instance."}]},{"name":"Note","type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone"},{"text":" (instead of ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef"},{"text":") if you want to use Automatic Reference Counting for memory management of the underlying ","type":"text"},{"code":"GTimeZone","type":"codeVoice"},{"text":" instance.","type":"text"}]}]}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/timezoneref"]}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef","interfaceLanguage":"swift"},"sections":[],"topicSections":[{"generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef\/init(_:)-3wi4a","doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef\/init(_:)-5j2y","doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef\/init(_:)-7gvn1","doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef\/init(_:)-8j5ou","doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef\/init(_:)-8m404","doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef\/init(constPointer:)","doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef\/init(identifier:)","doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef\/init(identifierOrUtc:)","doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef\/init(mutating:)","doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef\/init(offset:)","doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef\/init(opaquePointer:)"],"title":"Initializers","anchor":"Initializers"},{"generated":true,"title":"Instance Properties","anchor":"Instance-Properties","identifiers":["doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef\/ptr"]},{"title":"T