{"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"sections":[],"metadata":{"externalID":"s:4GLib6remove8filenameSiSPys4Int8VGSg_tF","title":"remove(filename:)","symbolKind":"func","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"remove"},{"text":"(","kind":"text"},{"text":"filename","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">!) -> ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"roleHeading":"Function","modules":[{"name":"GLib"}],"role":"symbol"},"kind":"symbol","primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"remove"},{"text":"(","kind":"text"},{"text":"filename","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">!) -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"See your C library manual for more details about how "},{"type":"codeVoice","code":"remove()"},{"text":" works","type":"text"},{"type":"text","text":" "},{"text":"on your system. On Unix, ","type":"text"},{"type":"codeVoice","code":"remove()"},{"text":" removes also directories, as it","type":"text"},{"type":"text","text":" "},{"type":"text","text":"calls "},{"code":"unlink()","type":"codeVoice"},{"type":"text","text":" for files and "},{"type":"codeVoice","code":"rmdir()"},{"text":" for directories. On Windows,","type":"text"},{"text":" ","type":"text"},{"text":"although ","type":"text"},{"type":"codeVoice","code":"remove()"},{"text":" in the C library only works for files, this","type":"text"},{"type":"text","text":" "},{"type":"text","text":"function tries first "},{"code":"remove()","type":"codeVoice"},{"text":" and then if that fails ","type":"text"},{"code":"rmdir()","type":"codeVoice"},{"type":"text","text":", and"},{"type":"text","text":" "},{"text":"thus works for both files and directories. Note however, that on","type":"text"},{"type":"text","text":" "},{"text":"Windows, it is in general not possible to remove a file that is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"open to some process, or mapped into memory."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If this function fails on Windows you can’t infer too much from the"},{"type":"text","text":" "},{"type":"text","text":"errno value. "},{"code":"rmdir()","type":"codeVoice"},{"text":" is tried regardless of what caused ","type":"text"},{"type":"codeVoice","code":"remove()"},{"type":"text","text":" to"},{"type":"text","text":" "},{"type":"text","text":"fail. Any errno value set by "},{"type":"codeVoice","code":"remove()"},{"type":"text","text":" will be overwritten by that"},{"text":" ","type":"text"},{"text":"set by ","type":"text"},{"code":"rmdir()","type":"codeVoice"},{"text":".","type":"text"}]}]}],"variants":[{"paths":["\/documentation\/glib\/remove(filename:)"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"A wrapper for the POSIX "},{"type":"codeVoice","code":"remove()"},{"text":" function. The ","type":"text"},{"type":"codeVoice","code":"remove()"},{"type":"text","text":" function"},{"text":" ","type":"text"},{"type":"text","text":"deletes a name from the filesystem."}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/remove(filename:)","interfaceLanguage":"swift"},"references":{"doc://GLib/documentation/GLib/remove(filename:)":{"type":"topic","title":"remove(filename:)","abstract":[{"type":"text","text":"A wrapper for the POSIX "},{"type":"codeVoice","code":"remove()"},{"text":" function. The ","type":"text"},{"type":"codeVoice","code":"remove()"},{"type":"text","text":" function"},{"text":" ","type":"text"},{"type":"text","text":"deletes a name from the filesystem."}],"url":"\/documentation\/glib\/remove(filename:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"remove"},{"kind":"text","text":"("},{"text":"filename","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier","text":"gchar"},{"text":">!) -> ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/remove(filename:)","kind":"symbol","role":"symbol"},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"}}}