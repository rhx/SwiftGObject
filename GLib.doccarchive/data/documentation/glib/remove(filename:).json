ugh "},{"code":"remove()","type":"codeVoice"},{"text":" in the C library only works for files, this","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"function tries first "},{"code":"remove()","type":"codeVoice"},{"text":" and then if that fails ","type":"text"},{"type":"codeVoice","code":"rmdir()"},{"text":", and","type":"text"},{"text":" ","type":"text"},{"text":"thus works for both files and directories. Note however, that on","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Windows, it is in general not possible to remove a file that is"},{"type":"text","text":" "},{"text":"open to some process, or mapped into memory.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If this function fails on Windows you can’t infer too much from the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"errno value. "},{"code":"rmdir()","type":"codeVoice"},{"type":"text","text":" is tried regardless of what caused "},{"type":"codeVoice","code":"remove()"},{"type":"text","text":" to"},{"text":" ","type":"text"},{"type":"text","text":"fail. Any errno value set by "},{"type":"codeVoice","code":"remove()"},{"text":" will be overwritten by that","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"set by "},{"code":"rmdir()","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/remove(filename:)"]}],"abstract":[{"type":"text","text":"A wrapper for the POSIX "},{"code":"remove()","type":"codeVoice"},{"text":" function. The ","type":"text"},{"type":"codeVoice","code":"remove()"},{"text":" function","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"deletes a name from the filesystem."}],"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/remove(filename:)","interfaceLanguage":"swift"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib