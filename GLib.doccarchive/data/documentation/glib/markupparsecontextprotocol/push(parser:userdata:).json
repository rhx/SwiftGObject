{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/markupparsecontextprotocol\/push(parser:userdata:)"]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/MarkupParseContextProtocol"]]},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"push","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"MarkupParserT"},{"kind":"text","text":">("},{"text":"parser","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"MarkupParserT","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"userData"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@T@gpointer","kind":"typeIdentifier","text":"gpointer"},{"text":"? = nil) ","kind":"text"},{"text":"where","kind":"keyword"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"MarkupParserT"},{"text":" : ","kind":"text"},{"kind":"typeIdentifier","identifier":"doc:\/\/GLib\/documentation\/GLib\/MarkupParserProtocol","text":"MarkupParserProtocol","preciseIdentifier":"s:4GLib20MarkupParserProtocolP"}],"languages":["swift"]}]},{"content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function may only be called from the start_element handler of"},{"type":"text","text":" "},{"type":"text","text":"a "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MarkupParser","isActive":true,"type":"reference"},{"type":"text","text":". It must be matched with a corresponding call to"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_markup_parse_context_pop()"},{"text":" in the matching end_element handler","type":"text"},{"type":"text","text":" "},{"text":"(except in the case that the parser aborts due to an error).","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"All tags, text and other data between the matching tags is","type":"text"},{"type":"text","text":" "},{"text":"redirected to the subparser given by ","type":"text"},{"type":"codeVoice","code":"parser"},{"text":". ","type":"text"},{"type":"codeVoice","code":"userData"},{"type":"text","text":" is used"},{"type":"text","text":" "},{"text":"as the user_data for that parser. ","type":"text"},{"type":"codeVoice","code":"userData"},{"text":" is also passed to the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"error callback in the event that an error occurs. This includes"},{"type":"text","text":" "},{"type":"text","text":"errors that occur in subparsers of the subparser."}]},{"type":"paragraph","inlineContent":[{"text":"The end tag matching the start tag for which this call was made is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"handled by the previous parser (which is given its own user_data)"},{"text":" ","type":"text"},{"type":"text","text":"which is why "},{"code":"g_markup_parse_context_pop()","type":"codeVoice"},{"type":"text","text":" is provided to allow “one"},{"text":" ","type":"text"},{"type":"text","text":"last access” to the "},{"code":"userData","type":"codeVoice"},{"type":"text","text":" provided to this function. In the"},{"type":"text","text":" "},{"text":"case of error, the ","type":"text"},{"type":"codeVoice","code":"userData"},{"type":"text","text":" provided here is passed directly to"},{"type":"text","text":" "},{"type":"text","text":"the error callback of the subparser and "},{"code":"g_markup_parse_context_pop()","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"should not be called. In either case, if "},{"code":"userData","type":"codeVoice"},{"type":"text","text":" was allocated"},{"type":"text","text":" "},{"text":"then it ought to be freed from both of these locations.","type":"text"}]},{"inlineContent":[{"type":"text","text":"This function is not intended to be directly called by users"},{"text":" ","type":"text"},{"text":"interested in invoking subparsers. Instead, it is intended to be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"used by the subparsers themselves to implement a higher-level"},{"text":" ","type":"text"},{"type":"text","text":"interface."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"As an example, see the following implementation of a simple"},{"text":" ","type":"text"},{"type":"text","text":"parser that counts the number of tags encountered."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"(C Language Example):","type":"text"}]},{"code":["typedef struct","{","  gint tag_count;","} CounterData;","","static void","counter_start_element (GMarkupParseContext  *context,","                       const gchar          *element_name,","                       const gchar         **attribute_names,","                       const gchar         **attribute_values,","                       gpointer              user_data,","                       GError              **error)","{","  CounterData *data = user_data;","","  data->tag_count++;","}","","static void","counter_error (GMarkupParseContext *context,","               GError              *error,","               gpointer             user_data)","{","  CounterData *data = user_data;","","  g_slice_free (CounterData, data);","}","","static GMarkupParser counter_subparser =","{","  counter_start_element,","  NULL,","  NULL,","  NULL,","  counter_error","};"],"type":"codeListing","syntax":"C"},{"inlineContent":[{"text":"In order to allow this parser to be easily used as a subparser, the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"following interface is provided:"}],"type":"paragraph"},{"inlineContent":[{"text":"(C Language Example):","type":"text"}],"type":"paragraph"},{"code":["void","start_counting (GMarkupParseContext *context)","{","  CounterData *data = g_slice_new (CounterData);","","  data->tag_count = 0;","  g_markup_parse_context_push (context, &counter_subparser, data);","}","","gint","end_counting (GMarkupParseContext *context)","{","  CounterData *data = g_markup_parse_context_pop (context);","  int result;","","  result = data->tag_count;","  g_slice_free (CounterData, data);","","  return result;","}"],"syntax":"C","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"The subparser would then be used as follows:","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"(C Language Example):","type":"text"}]},{"type":"codeListing","syntax":"C","code":["static void start_element (context, element_name, ...)","{","  if (strcmp (element_name, \"count-these\") == 0)","    start_counting (context);","","  \/\/ else, handle other tags...","}","","static void end_element (context, element_name, ...)","{","  if (strcmp (element_name, \"count-these\") == 0)","    g_print (\"Counted %d tags\\n\", end_counting (context));","","  \/\/ else, handle other tags...","}"]}],"kind":"content"}],"metadata":{"modules":[{"name":"GLib"}],"extendedModule":"GLib","symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"push"},{"kind":"text","text":"<"},{"text":"MarkupParserT","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"parser","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"MarkupParserT"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"userData"},{"text":": ","kind":"text"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:@T@gpointer"},{"kind":"text","text":"?)"}],"title":"push(parser:userData:)","roleHeading":"Instance Method","externalID":"s:4GLib26MarkupParseContextProtocolPAAE4push6parser8userDatayqd___SvSgtAA0b6ParserE0Rd__lF","role":"symbol"},"abstract":[{"text":"Temporarily redirects markup data to a sub-parser.","type":"text"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/MarkupParseContextProtocol\/push(parser:userData:)","interfaceLanguage":"swift"},"references":{"doc://GLib/documentation/GLib/MarkupParser":{"title":"MarkupParser","url":"\/documentation\/glib\/markupparser","identifier":"doc:\/\/GLib\/documentation\/GLib\/MarkupParser","abstract":[{"type":"text","text":"Any of the fields in "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MarkupParser","isActive":true,"type":"reference"},{"type":"text","text":" can be "},{"code":"nil","type":"codeVoice"},{"text":", in which case they","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"will be ignored. Except for the "},{"type":"codeVoice","code":"error"},{"type":"text","text":" function, any of these callbacks"},{"type":"text","text":" "},{"text":"can set an error; in particular the ","type":"text"},{"code":"unknownElement","type":"codeVoice"},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"codeVoice","code":"unknownAttribute"},{"type":"text","text":", and "},{"code":"invalidContent","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"errors are intended to be set from these callbacks. If you set an error"},{"type":"text","text":" "},{"type":"text","text":"from a callback, "},{"code":"g_markup_parse_context_parse()","type":"codeVoice"},{"text":" will report that error","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"back to its caller."}],"role":"symbol","type":"topic","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"MarkupParser","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"MarkupParser","kind":"identifier"}]},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/MarkupParseContextProtocol":{"url":"\/documentation\/glib\/markupparsecontextprotocol","title":"MarkupParseContextProtocol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"text":"MarkupParseContextProtocol","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/MarkupParseContextProtocol","abstract":[{"text":"A parse context is used to parse a stream of bytes that","type":"text"},{"type":"text","text":" "},{"text":"you expect to contain marked-up text.","type":"text"}],"kind":"symbol","navigatorTitle":[{"text":"MarkupParseContextProtocol","kind":"identifier"}],"role":"symbol","type":"topic"},"doc://GLib/documentation/GLib/MarkupParserProtocol":{"type":"topic","kind":"symbol","url":"\/documentation\/glib\/markupparserprotocol","navigatorTitle":[{"text":"MarkupParserProtocol","kind":"identifier"}],"fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"MarkupParserProtocol","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/MarkupParserProtocol","role":"symbol","abstract":[{"type":"text","text":"Any of the fields in "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/MarkupParser"},{"text":" can be ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", in which case they"},{"type":"text","text":" "},{"type":"text","text":"will be ignored. Except for the "},{"type":"codeVoice","code":"error"},{"text":" function, any of these callbacks","type":"text"},{"type":"text","text":" "},{"type":"text","text":"can set an error; in particular the "},{"type":"codeVoice","code":"unknownElement"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"codeVoice","code":"unknownAttribute"},{"type":"text","text":", and "},{"code":"invalidContent","type":"codeVoice"},{"text":" ","type":"text"},{"text":"errors are intended to be set from these callbacks. If you set an error","type":"text"},{"type":"text","text":" "},{"text":"from a callback, ","type":"text"},{"code":"g_markup_parse_context_parse()","type":"codeVoice"},{"text":" will report that error","type":"text"},{"text":" ","type":"text"},{"text":"back to its caller.","type":"text"}],"title":"MarkupParserProtocol"},"doc://GLib/documentation/GLib/MarkupParseContextProtocol/push(parser:userData:)":{"title":"push(parser:userData:)","abstract":[{"text":"Temporarily redirects markup data to a sub-parser.","type":"text"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"push"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"MarkupParserT"},{"text":">(","kind":"text"},{"text":"parser","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"MarkupParserT","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"userData","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gpointer","text":"gpointer"},{"text":"?)","kind":"text"}],"url":"\/documentation\/glib\/markupparsecontextprotocol\/push(parser:userdata:)","role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/MarkupParseContextProtocol\/push(parser:userData:)","type":"topic"}}}