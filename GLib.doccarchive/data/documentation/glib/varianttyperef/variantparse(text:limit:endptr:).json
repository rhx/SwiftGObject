ence","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":" is parsed from the content of ","type":"text"},{"code":"text","type":"codeVoice"},{"text":".","type":"text"}]},{"inlineContent":[{"type":"text","text":"The format is described "},{"type":"reference","identifier":"gvariant-text-format.html","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The memory at "},{"type":"codeVoice","code":"limit"},{"type":"text","text":" will never be accessed and the parser behaves as"},{"type":"text","text":" "},{"type":"text","text":"if the character at "},{"code":"limit","type":"codeVoice"},{"type":"text","text":" is the nul terminator.  This has the"},{"type":"text","text":" "},{"text":"effect of bounding ","type":"text"},{"code":"text","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"endptr","type":"codeVoice"},{"text":" is non-","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" then ","type":"text"},{"code":"text","type":"codeVoice"},{"type":"text","text":" is permitted to contain data"},{"type":"text","text":" "},{"text":"following the value that this function parses and ","type":"text"},{"code":"endptr","type":"codeVoice"},{"type":"text","text":" will be"},{"type":"text","text":" "},{"text":"updated to point to the first character past the end of the text","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"parsed by this function.  If "},{"type":"codeVoice","code":"endptr"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" and there is extra data","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"then an error is returned."}]},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"type"},{"type":"text","text":" is non-"},{"code":"nil","type":"codeVoice"},{"type":"text","text":" then the value will be parsed to have that"},{"type"