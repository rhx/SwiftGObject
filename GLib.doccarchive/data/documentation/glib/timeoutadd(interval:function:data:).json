{"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/timeoutAdd(interval:function:data:)"},"abstract":[{"type":"text","text":"Sets a function to be called at regular intervals, with the default"},{"type":"text","text":" "},{"type":"text","text":"priority, [const"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/priorityDefault","type":"reference","isActive":true},{"text":"].","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/timeoutadd(interval:function:data:)"]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"roleHeading":"Function","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"timeoutAdd","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"interval"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"function","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@GSourceFunc","kind":"typeIdentifier","text":"GSourceFunc"},{"text":"?, ","kind":"text"},{"text":"data","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"gpointer","preciseIdentifier":"c:@T@gpointer"},{"text":"?) -> ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}],"symbolKind":"func","role":"symbol","externalID":"s:4GLib10timeoutAdd8interval8function4dataS2i_s5Int32VSvSgXCSgAHtF","modules":[{"name":"GLib"}],"title":"timeoutAdd(interval:function:data:)"},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"timeoutAdd","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"interval"},{"text":": ","kind":"text"},{"text":"Int","