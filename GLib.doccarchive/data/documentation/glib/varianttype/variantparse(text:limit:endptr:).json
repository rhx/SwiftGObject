ode":"text","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The format is described "},{"type":"reference","isActive":true,"identifier":"gvariant-text-format.html"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The memory at "},{"code":"limit","type":"codeVoice"},{"text":" will never be accessed and the parser behaves as","type":"text"},{"type":"text","text":" "},{"text":"if the character at ","type":"text"},{"code":"limit","type":"codeVoice"},{"type":"text","text":" is the nul terminator.  This has the"},{"text":" ","type":"text"},{"text":"effect of bounding ","type":"text"},{"code":"text","type":"codeVoice"},{"type":"text","text":"."}]},{"inlineContent":[{"text":"If ","type":"text"},{"code":"endptr","type":"codeVoice"},{"type":"text","text":" is non-"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" then "},{"type":"codeVoice","code":"text"},{"text":" is permitted to contain data","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"following the value that this function parses and "},{"type":"codeVoice","code":"endptr"},{"type":"text","text":" will be"},{"type":"text","text":" "},{"type":"text","text":"updated to point to the first character past the end of the text"},{"type":"text","text":" "},{"type":"text","text":"parsed by this function.  If "},{"code":"endptr","type":"codeVoice"},{"type":"text","text":" is "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" and there is extra data"},{"text":" ","type":"text"},{"text":"then an error is returned.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"type","type":"codeVoice"},{"type":"text","text":" is non-"},{"code":"nil","type":"codeVoice"},{"type":"text","text":" then the value will be parsed to have that"},{"text":" ","type":"text"},{"type":"text","text":"type.  This may result in additional parse errors (in the case that"},{"text":" ","type":"text"},{"type":"text","text":"the parsed value doesn’t fit the type) but may also result in fewer"},{"type":"text","text":" "},{"text":"errors (in the case that the type would have been ambiguous, such as","type":"text"},{"type":"text","text":" "},{"text":"with empty arrays).","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the event that the parsing is successful, the resulting "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference"},{"type":"text","text":" "},{"text":"is returned. It is never floating, and must be freed with","type":"text"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.Variant.unref"},{"text":"].","type":"text"}]},{"inlineContent":[{"text":"In case of any error, ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" will be returned.  If ","type":"text"},{"code":"error","type":"codeVoice"},{"type":"text","text":" is non-"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" "},{"text":"then it will be set to reflect the error that occurred.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Officially, the language understood by the parser is “any string"},{"text":" ","type":"text"},{"type":"text","text":"produced by [method"},{"type":"codeVoice","code":"GLib.Variant.print"},{"text":"]”. This explicitly includes","type":"text"},{"text":" ","type":"text"},{"code":"g_variant_print()","type":"codeVoice"},{"text":"’s annotated types like ","type":"text"},{"code":"int64 -1000","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"There may be implementation specific restrictions on deeply nested values,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"which would result in a "},{"type":"codeVoice","code":"recursion"},{"type":"text","text":" error. "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"type":"text","text":" is"},{"text":" ","type":"text"},{"type":"text","text":"guaranteed to handle nesting up to at least 64 levels."}]}]}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/varianttype\/variantparse(text:limit:endptr:)"]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/VariantType","doc:\/\/GLib\/documentation\/GLib\/VariantType\/VariantTypeProtocol-Implementations"]]},"metadata":{"extendedModule":"GLib","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"variantParse","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"text"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"gchar","preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"limit"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"text":">?, ","kind":"text"},{"text":"endptr","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"text":">?>?) ","kind":"text"},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef"},{"kind":"text","text":"!"}],"title":"variantParse(text:limit:endptr:)","externalID":"s:4GLib19VariantTypeProtocolPAAE12variantParse4text5limit6endptrAA0B3RefVSgSPys4Int8V