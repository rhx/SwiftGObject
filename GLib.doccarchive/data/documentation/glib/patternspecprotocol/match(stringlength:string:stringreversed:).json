tifier"},{"kind":"text","text":">?) -> "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"abstract":[{"type":"text","text":"Matches a string against a compiled pattern."}],"type":"topic","role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/PatternSpecProtocol\/match(stringLength:string:stringReversed:)","url":"\/documentation\/glib\/patternspecprotocol\/match(stringlength:string:stringreversed:)"},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/PatternSpecProtocol":{"type":"topic","abstract":[{"type":"text","text":"A "},{"code":"GPatternSpec","type":"codeVoice"},{"type":"text","text":" struct is the ‘compiled’ form of a glob-style pattern."}],"title":"PatternSpecProtocol","kind":"symbol","role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"PatternSpecProtocol","kind":"identifier"}],"url":"\/documentation\/glib\/patternspecprotocol","navigatorTitle":[{"text":"PatternSpecProtocol","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/PatternSpecProtocol"}}}