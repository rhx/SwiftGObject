{"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"title":"match(stringLength:string:stringReversed:)","roleHeading":"Instance Method","externalID":"s:4GLib19PatternSpecProtocolPAAE5match12stringLength0F00F8ReversedSbSi_SPys4Int8VGSgAKtF","symbolKind":"method","modules":[{"name":"GLib"}],"extendedModule":"GLib","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"match","kind":"identifier"},{"text":"(","kind":"text"},{"text":"stringLength","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"string"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"stringReversed"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"kind":"text","text":">?) -> "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"role":"symbol"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/PatternSpecProtocol"]]},"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/PatternSpecProtocol\/match(stringLength:string:stringReversed:)"},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/patternspecprotocol\/match(stringlength:string:stringreversed:)"]}],"abstract":[{"type":"text","text":"Matches a string against a compiled pattern."}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"match"},{"text":"(","kind":"text"},{"text":"stringLength","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"text":", ","kind":"text"},{"text":"string","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">!, ","kind":"text"},{"text":"stringReversed","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"text":">? = nil) -> ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}]}],"kind":"declarations"},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"text":"Passing the correct","type":"text"},{"type":"text","text":" "},{"text":"length of the string given is mandatory. The reversed string can be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"omitted by passing "},{"code":"NULL","type":"codeVoice"},{"text":", this is more efficient if the reversed","type":"text"},{"text":" ","type":"text"},{"text":"version of the string to be matched is not at hand, as","type":"text"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.PatternSpec.match"},{"text":"] will only construct it if the compiled pattern","type":"text"},{"type":"text","text":" "},{"type":"text","text":"requires reverse matches."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Note that, if the user code will (possibly) match a string against a"},{"type":"text","text":" "},{"text":"multitude of patterns containing wildcards, chances are high that","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"some patterns will require a reversed string. In this case, it’s"},{"text":" ","type":"text"},{"type":"text","text":"more efficient to provide the reversed string to avoid multiple"},{"text":" ","type":"text"},{"type":"text","text":"constructions thereof in the various calls to [method"},{"type":"codeVoice","code":"GLib.PatternSpec.match"},{"type":"text","text":"]."}],"type":"paragraph"},{"inlineContent":[{"text":"Note also that the reverse of a UTF-8 encoded string can in general","type":"text"},{"text":" ","type":"text"},{"text":"not be obtained by [func","type":"text"},{"code":"GLib.strreverse","type":"codeVoice"},{"type":"text","text":"]. This works only if the string"},{"type":"text","text":" "},{"text":"does not contain any multibyte characters. GLib offers the","type":"text"},{"type":"text","text":" "},{"text":"[func","type":"text"},{"code":"GLib.utf8_strreverse","type":"codeVoice"},{"type":"text","text":"] function to reverse UTF-8 encoded strings."}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://GLib/documentation/GLib/PatternSpecProtocol":{"title":"PatternSpecProtocol","abstract":[{"type":"text","text":"A "},{"code":"GPatternSpec","type":"codeVoice"},{"text":" struct is the ‘compiled’ form of a glob-style pattern.","type":"text"}],"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"PatternSpecProtocol","kind":"identifier"}],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"PatternSpecProtocol"}],"url":"\/documentation\/glib\/patternspecprotocol","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/PatternSpecProtocol"},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/PatternSpecProtocol/match(stringLength:string:stringReversed:)":{"title":"match(stringLength:string:stringReversed:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"match"},{"kind":"text","text":"("},{"kind":"externalParam","text":"stringLength"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"text":", ","kind":"text"},{"text":"string","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"kind":"text","text":"<"},{"text":"gchar","preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"text":"stringReversed","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"text":"gchar","preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier"},{"kind":"text","text":">?) -> "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"type":"topic","url":"\/documentation\/glib\/patternspecprotocol\/match(stringlength:string:stringreversed:)","abstract":[{"type":"text","text":"Matches a string against a compiled pattern."}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/PatternSpecProtocol\/match(stringLength:string:stringReversed:)"}}}