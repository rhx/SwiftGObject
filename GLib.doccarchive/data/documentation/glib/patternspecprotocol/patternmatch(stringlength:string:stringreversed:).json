{"metadata":{"role":"symbol","roleHeading":"Instance Method","platforms":[],"externalID":"s:4GLib19PatternSpecProtocolPAAE12patternMatch12stringLength0G00G8ReversedSbSi_SPys4Int8VGSgAKtF","extendedModule":"GLib","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"patternMatch","kind":"identifier"},{"kind":"text","text":"("},{"text":"stringLength","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"string","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"gchar","preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"stringReversed"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"text":">?) -> ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"modules":[{"name":"GLib"}],"title":"patternMatch(stringLength:string:stringReversed:)","symbolKind":"method"},"sections":[],"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/patternspecprotocol\/patternmatch(stringlength:string:stringreversed:)"]}],"abstract":[{"text":"Matches a string against a compiled pattern.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/PatternSpecProtocol\/patternMatch(stringLength:string:stringReversed:)"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/PatternSpecProtocol"]]},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"patternMatch"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"stringLength"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"string"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier","text":"gchar"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"stringReversed"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"text":">? = nil) -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Passing the correct"},{"type":"text","text":" "},{"type":"text","text":"length of the string given is mandatory. The reversed string can be"},{"type":"text","text":" "},{"type":"text","text":"omitted by passing "},{"code":"NULL","type":"codeVoice"},{"text":", this is more efficient if the reversed","type":"text"},{"type":"text","text":" "},{"type":"text","text":"version of the string to be matched is not at hand, as"},{"text":" ","type":"text"},{"code":"g_pattern_match()","type":"codeVoice"},{"type":"text","text":" will only construct it if the compiled pattern"},{"type":"text","text":" "},{"type":"text","text":"requires reverse matches."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Note that, if the user code will (possibly) match a string against a"},{"type":"text","text":" "},{"type":"text","text":"multitude of patterns containing wildcards, chances are high that"},{"type":"text","text":" "},{"text":"some patterns will require a reversed string. In this case, it’s","type":"text"},{"text":" ","type":"text"},{"text":"more efficient to provide the reversed string to avoid multiple","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"constructions thereof in the various calls to "},{"code":"g_pattern_match()","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Note also that the reverse of a UTF-8 encoded string can in general","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"not be obtained by [func"},{"type":"codeVoice","code":"GLib.strreverse"},{"type":"text","text":"]. This works only if the string"},{"type":"text","text":" "},{"text":"does not contain any multibyte characters. GLib offers the","type":"text"},{"text":" ","type":"text"},{"text":"[func","type":"text"},{"type":"codeVoice","code":"GLib.utf8_strreverse"},{"type":"text","text":"] function to reverse UTF-8 encoded strings."}]},{"inlineContent":[{"inlineContent":[{"type":"text","text":"pattern_match is deprecated:"}],"type":"strong"},{"type":"text","text":" "},{"type":"text","text":"Use [method@GLib.PatternSpec.match] instead"}],"type":"paragraph"}]}],"references":{"doc://GLib/documentation/GLib/PatternSpecProtocol":{"type":"topic","abstract":[{"type":"text","text":"A "},{"code":"GPatternSpec","type":"codeVoice"},{"type":"text","text":" struct is the ‘compiled’ form of a glob-style pattern."}],"title":"PatternSpecProtocol","kind":"symbol","role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"PatternSpecProtocol","kind":"identifier"}],"url":"\/documentation\/glib\/patternspecprotocol","navigatorTitle":[{"text":"PatternSpecProtocol","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/PatternSpecProtocol"},"doc://GLib/documentation/GLib/PatternSpecProtocol/patternMatch(stringLength:string:stringReversed:)":{"role":"symbol","deprecated":true,"fragmen