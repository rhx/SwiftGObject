type":"codeVoice","code":"NULL"},{"type":"text","text":", this is more efficient if the reversed"},{"type":"text","text":" "},{"type":"text","text":"version of the string to be matched is not at hand, as"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_pattern_match()"},{"type":"text","text":" will only construct it if the compiled pattern"},{"type":"text","text":" "},{"type":"text","text":"requires reverse matches."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Note that, if the user code will (possibly) match a string against a"},{"type":"text","text":" "},{"type":"text","text":"multitude of patterns containing wildcards, chances are high that"},{"text":" ","type":"text"},{"type":"text","text":"some patterns will require a reversed string. In this case, it’s"},{"type":"text","text":" "},{"type":"text","text":"more efficient to provide the reversed string to avoid multiple"},{"type":"text","text":" "},{"text":"constructions thereof in the various calls to ","type":"text"},{"type":"codeVoice","code":"g_pattern_match()"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Note also that the reverse of a UTF-8 encoded string can in general","type":"text"},{"type":"text","text":" "},{"type":"text","text":"not be obtained by [func"},{"type":"codeVoice","code":"GLib.strreverse"},{"text":"]. This works only if the string","type":"text"},{"text":" ","type":"text"},{"text":"does not contain any multibyte characters. GLib offers the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.utf8_strreverse"},{"type":"text","text":"] function to reverse UTF-8 encoded strings."}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"text":"pattern_match is deprecated:","type":"text"}],"type":"strong"},{"type":"text","text":" "},{"text":"Use [method@GLib.PatternSpec.match] instead","type":"text"}],"type":"paragraph"}],"kind":"content"}],"metadata":{"modules":[{"name":"GLib"}],"