e cleared (as if you’d called "},{"code":"g_date_clear()","type":"codeVoice"},{"type":"text","text":") but invalid (it won’t"},{"text":" ","type":"text"},{"type":"text","text":"represent an existing day). Free the return value with "},{"type":"codeVoice","code":"g_date_free()"},{"text":".","type":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/Date\/init()","role":"symbol","fragments":[{"text":"init","kind":"identifier"},{"text":"()","kind":"text"}]},"doc://GLib/documentation/GLib/Date/init(_:)-1xuni":{"url":"\/documentation\/glib\/date\/init(_:)-1xuni","kind":"symbol","type":"topic","title":"init(_:)","abstract":[{"text":"Designated initialiser from the underlying ","type":"text"},{"code":"C","type":"codeVoice"},{"text":" data type.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This creates an instance without performing an unbalanced retain"},{"type":"text","text":" "},{"type":"text","text":"i.e., ownership is transferred to the "},{"code":"Date","type":"codeVoice"},{"type":"text","text":" instance."}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/Date\/init(_:)-1xuni","role":"symbol","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"GDate","kind":"typeIdentifier"},{"kind":"text","text":">)"}]},"doc://GLib/documentation/GLib/Date/init(_:)-46imp":{"title":"init(_:)","abstract":[{"text":"Optional initialiser from a constant pointer to the underlying ","type":"text"},{"code":"C","type":"codeVoice"},{"type":"text","text":" data type."},{"type":"text","text":" "},{"type":"text","text":"This creates an instance without performing an unbalanced retain"},{"text":" ","type":"text"},{"type":"text","text":"i.e., ownership is transferred to the "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Date","type":"reference","isActive":true},{"type":"text","text":" instance."}],"url":"\/documentation\/gli