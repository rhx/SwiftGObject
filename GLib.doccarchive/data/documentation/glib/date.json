{"relationshipsSections":[{"kind":"relationships","type":"conformsTo","title":"Conforms To","identifiers":["doc:\/\/GLib\/documentation\/GLib\/DateProtocol","doc:\/\/GLib\/documentation\/GLib\/PointerWrapper"]}],"topicSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/Date\/init()","doc:\/\/GLib\/documentation\/GLib\/Date\/init(_:)-1xuni","doc:\/\/GLib\/documentation\/GLib\/Date\/init(_:)-46imp","doc:\/\/GLib\/documentation\/GLib\/Date\/init(_:)-4ld1t","doc:\/\/GLib\/documentation\/GLib\/Date\/init(_:)-6bawz","doc:\/\/GLib\/documentation\/GLib\/Date\/init(_:)-827x2","doc:\/\/GLib\/documentation\/GLib\/Date\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/Date\/init(dmy:month:year:)","doc:\/\/GLib\/documentation\/GLib\/Date\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/Date\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/Date\/init(julian:)","doc:\/\/GLib\/documentation\/GLib\/Date\/init(opaquePointer:)","doc:\/\/GLib\/documentation\/GLib\/Date\/init(raw:)-5r9lx","doc:\/\/GLib\/documentation\/GLib\/Date\/init(raw:)-8w9i2","doc:\/\/GLib\/documentation\/GLib\/Date\/init(retaining:)","doc:\/\/GLib\/documentation\/GLib\/Date\/init(retainingCPointer:)","doc:\/\/GLib\/documentation\/GLib\/Date\/init(retainingOpaquePointer:)","doc:\/\/GLib\/documentation\/GLib\/Date\/init(retainingRaw:)-39bfb","doc:\/\/GLib\/documentation\/GLib\/Date\/init(retainingRaw:)-745yi"],"generated":true,"title":"Initializers","anchor":"Initializers"},{"title":"Instance Properties","identifiers":["doc:\/\/GLib\/documentation\/GLib\/Date\/ptr"],"anchor":"Instance-Properties","generated":true},{"anchor":"Type-Methods","title":"Type Methods","generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/Date\/new(dmy:month:year:)","doc:\/\/GLib\/documentation\/GLib\/Date\/new(julian:)"]},{"title":"Default Implementations","generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/Date\/DateProtocol-Implementations"],"anchor":"Default-Implementations"}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/Date","interfaceLanguage":"swift"},"kind":"symbol","abstract":[{"code":"GDate","type":"codeVoice"},{"type":"text","text":" is a struct for calendrical calculations."}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Date"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"level":2,"text":"Overview","anchor":"overview","type":"heading"},{"inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"GDate"},{"text":" data structure represents a day between January 1, Year 1,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and sometime a few thousand years in the future (right now it will go"},{"text":" ","type":"text"},{"text":"to the year 65535 or so, but [method","type":"text"},{"type":"codeVoice","code":"GLib.Date.set_parse"},{"type":"text","text":"] only parses up to the"},{"type":"text","text":" "},{"text":"year 8000 or so - just count on “a few thousand”). ","type":"text"},{"type":"codeVoice","code":"GDate"},{"text":" is meant to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"represent everyday dates, not astronomical dates or historical dates"},{"type":"text","text":" "},{"text":"or ISO timestamps or the like. It extrapolates the current Gregorian","type":"text"},{"type":"text","text":" "},{"type":"text","text":"calendar forward and backward in time; there is no attempt to change"},{"type":"text","text":" "},{"text":"the calendar to match time periods or locations. ","type":"text"},{"type":"codeVoice","code":"GDate"},{"text":" does not store","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"time information; it represents a day."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"code":"GDate","type":"codeVoice"},{"type":"text","text":" implementation has several nice features; it is only a"},{"text":" ","type":"text"},{"text":"64-bit struct, so storing large numbers of dates is very efficient. It","type":"text"},{"type":"text","text":" "},{"text":"can keep both a Julian and day-month-year representation of the date,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"since some calculations are much easier with one representation or the"},{"text":" ","type":"text"},{"text":"other. A Julian representation is simply a count of days since some","type":"text"},{"type":"text","text":" "},{"text":"fixed day in the past; for ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Date","isActive":true},{"text":" the fixed day is January 1, 1 AD.","type":"text"},{"text":" ","type":"text"},{"text":"(“Julian” dates in the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Date"},{"text":" API aren’t really Julian dates in the","type":"text"},{"type":"text","text":" "},{"text":"technical sense; technically, Julian dates count from the start of the","type":"text"},{"text":" ","type":"text"},{"text":"Julian period, Jan 1, 4713 BC).","type":"text"}]},{"inlineContent":[{"code":"GDate","type":"codeVoice"},{"text":" is simple to use. First you need a “blank” date; you can get a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"dynamically allocated date from [ctor"},{"code":"GLib.Date.new","type":"codeVoice"},{"type":"text","text":"], or you can declare an"},{"text":" ","type":"text"},{"text":"automatic variable or array and initialize it by calling [method","type":"text"},{"type":"codeVoice","code":"GLib.Date.clear"},{"type":"text","text":"]."},{"type":"text","text":" "},{"text":"A cleared date is safe; it’s safe to call [method","type":"text"},{"type":"codeVoice","code":"GLib.Date.set_dmy"},{"type":"text","text":"] and the other"},{"type":"text","text":" "},{"type":"text","text":"mutator functions to initialize the value of a cleared date. However, a cleared date"},{"type":"text","text":" "},{"text":"is initially invalid, meaning that it doesn’t represent a day that exists.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"It is undefined to call any of the date calculation routines on an invalid date."},{"type":"text","text":" "},{"text":"If you obtain a date from a user or other unpredictable source, you should check","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"its validity with the [method"},{"code":"GLib.Date.valid","type":"codeVoice"},{"type":"text","text":"] predicate. [method"},{"type":"codeVoice","code":"GLib.Date.valid"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"type":"text","text":"is also used to check for errors with [method"},{"type":"codeVoice","code":"GLib.Date.set_parse"},{"type":"text","text":"] and other functions"},{"type":"text","text":" "},{"text":"that can fail. Dates can be invalidated by calling [method","type":"text"},{"code":"GLib.Date.clear","type":"codeVoice"},{"text":"] again.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"It is very important to use the API to access the ","type":"text"},{"type":"codeVoice","code":"GDate"},{"text":" struct. Often only the","type":"text"},{"text":" ","type":"text"},{"text":"day-month-year or only the Julian representation is valid. Sometimes neither is valid.","type":"text"},{"text":" ","type":"text"},{"text":"Use the API.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"GLib also features "},{"type":"codeVoice","code":"GDateTime"},{"type":"text","text":" which represents a precise time."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Date","type":"reference","isActive":true},{"text":" type acts as an owner of an underlying ","type":"text"},{"code":"GDate","type":"codeVoice"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"type":"text","text":"It provides the methods that can operate on this data type through "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateProtocol","isActive":true,"type":"reference"},{"type":"text","text":" conformance."},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Date"},{"text":" as a strong reference or owner of a ","type":"text"},{"code":"GDate","type":"codeVoice"},{"type":"text","text":" instance."}],"type":"paragraph"},{"type":"aside","name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateRef","isActive":true,"type":"reference"},{"text":" (instead of ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Date","isActive":true,"type":"reference"},{"text":") for a lightweight Swift reference to an underlying ","type":"text"},{"type":"codeVoice","code":"GDate"},{"type":"text","text":" instance."}]}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/date"]}],"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"navigatorTitle":[{"kind":"identifier","text":"Date"}],"roleHeading":"Class","externalID":"s:4GLib4DateC","title":"Date","symbolKind":"class","modules":[{"name":"GLib"}],"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"Date"}],"role":"symbol"},"references":{"doc://GLib/documentation/GLib/Date/init(_:)-4ld1t":{"title":"init(_:)","identifier":"doc:\/\/GLib\/documentation\/GLib\/Date\/init(_:)-4ld1t","type":"topic","abstract":[{"type":"text","text":"Reference intialiser for a related type that implements "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateProtocol"},{"text":" ","type":"text"},{"code":"GDate","type":"codeVoice"},{"type":"text",