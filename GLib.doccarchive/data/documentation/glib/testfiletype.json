{"metadata":{"role":"symbol","title":"TestFileType","symbolKind":"typealias","externalID":"s:4GLib12TestFileTypea","modules":[{"name":"GLib"}],"roleHeading":"Type Alias","fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"text":"TestFileType","kind":"identifier"}],"navigatorTitle":[{"text":"TestFileType","kind":"identifier"}]},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"text":"TestFileType","kind":"identifier"},{"text":" = ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@EA@GTestFileType","text":"GTestFileType"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"inlineContent":[{"text":"These two options correspond rather directly to the ‘dist’ and","type":"text"},{"type":"text","text":" "},{"text":"‘built’ terminology that automake uses and are explicitly used to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"distinguish between the ‘srcdir’ and ‘builddir’ being separate. All"},{"text":" ","type":"text"},{"type":"text","text":"files in your project should either be dist (in the "},{"type":"codeVoice","code":"EXTRA_DIST"},{"text":" or","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"dist_schema_DATA"},{"type":"text","text":" sense, in which case they will always be in the"},{"type":"text","text":" "},{"type":"text","text":"srcdir) or built (in the "},{"code":"BUILT_SOURCES","type":"codeVoice"},{"type":"text","text":" sense, in which case they"},{"type":"text","text":" "},{"text":"will always be in the builddir).","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Note: As a general rule of automake, files that are generated only as"},{"text":" ","type":"text"},{"text":"part of the build-from-git process (but then are distributed with the","type":"text"},{"text":" ","type":"text"},{"text":"tarball) always go in srcdir (even if doing a srcdir != builddir","type":"text"},{"text":" ","type":"text"},{"text":"build from git) and are considered as distributed files.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The same principles apply for other build systems, such as meson.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/testfiletype"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/TestFileType","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"The type of file to return the filename for, when used with"},{"text":" ","type":"text"},{"text":"[func","type":"text"},{"type":"codeVoice","code":"GLib.test_build_filename"},{"type":"text","text":"]."}],"sections":[],"kind":"symbol","references":{"doc://GLib/documentation/GLib/TestFileType":{"title":"TestFileType","kind":"symbol","role":"symbol","type":"topic","fragments":[{"text":"typealias","kind":"keyword"},{"kind":"text","text":" "},{"text":"TestFileType","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/TestFileType","abstract":[{"type":"text","text":"The type of file to return the filename for, when used with"},{"type":"text","text":" "},{"text":"[func","type":"text"},{"type":"codeVoice","code":"GLib.test_build_filename"},{"type":"text","text":"]."}],"navigatorTitle":[{"text":"TestFileType","kind":"identifier"}],"url":"\/documentation\/glib\/testfiletype"},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"}}}