LogLevelFlagsV","kind":"typeIdentifier","identifier":"doc:\/\/GLib\/documentation\/GLib\/LogLevelFlags"},{"kind":"text","text":", "},{"kind":"externalParam","text":"pattern"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">!)"}],"platforms":["macOS"]}]},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When this message is logged, it will not be printed, and the test case will"},{"text":" ","type":"text"},{"type":"text","text":"not abort."}]},{"inlineContent":[{"text":"This API may only be used with the old logging API ([func","type":"text"},{"code":"GLib.log","type":"codeVoice"},{"type":"text","text":"] without"},{"type":"text","text":" "},{"type":"codeVoice","code":"G_LOG_USE_STRUCTURED"},{"text":" defined). It will not work with the structured logging","type":"text"},{"type":"text","text":" "},{"type":"text","text":"API. See "},{"identifier":"logging.html#testing-for-messages","isActive":true,"type":"reference"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Use [func","type":"text"},{"code":"GLib.test_assert_expected_messages","type":"codeVoice"},{"text":"] to assert that all","type":"text"},{"type":"text","text":" "},{"type":"text","text":"previously-expected messages have been seen and suppressed."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can call this multiple times in a row, if multiple messages are"},{"text":" ","type":"text"},{"type":"text","text":"expected as a result of a single call. (The messages must appear in"},{"text":" ","type":"text"},{"text":"the same order as the calls to [func","type":"text"},{"type":"codeVoice","code":"GLib.test_expect_message"},{"text":"].)","type":"text"}]},{"inlineContent":[{"type":"text","text":"For example:"}],"type":"paragraph"},{"syntax":"c","code":["\/\/ `g_main_context_push_thread_default()` should fail if the","\/\/ context is already owned by another thread.","g_test_expect_message (G_LOG_DOMAIN,","                       G_LOG_LEVEL_CRITICAL,","                       \"assertion*acquired_context*failed\");","g_main_context_push_thread_default (bad_context);","g_test_assert_expected_messages ();"],"type":"codeListing"},{"inlineContent":[{"text":"Note that you cannot use this to test [func","type":"text"},{"type":"codeVoice","code":"GLib.error"},{"text":"] messages, since","type":"text"},{"type":"text","text":" "},{"text":"[func","type":"text"},{"code":"GLib.error","type":"codeVoice"},{"type":"text","text":"] intentionally never returns even if the program doesn’t"},{"text":" ","type":"text"},{"text":"abort; use [func","type":"text"},{"type":"codeVoice","code":"GLib.test_trap_subprocess"},{"text":"] in this case.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If messages at [flags","type":"text"},{"code":"GLib.LogLevelFlags.LEVEL_DEBUG","type":"codeVoice"},{"type":"text","text":"] are emitted, but not explicitly"},{"type":"text","text":" "},{"type":"text","text":"expected via [func"},{"type":"codeVoice","code":"GLib.test_expect_message"},{"type":"text","text":"] then they will be ignored."}]}],"kind":"content"}],"kind":"symbol","sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"Indicates that a message with the given "},{"code":"logDomain","type":"codeVoice"},{"type":"text","text":" and "},{"code":"logLevel","type":"codeVoice"},{"text":",","type":"text"},{"type":"text","text":" "},{"text":"with text matching ","type":"text"},{"type":"codeVoice","code":"pattern"},{"text":", is expected to be logged.","type":"text"}],"variants":[{"paths":["\/documentation\/glib\/testexpectmessage(logdomain:loglevel:pattern:)"],"traits":[{"interfaceLanguage":"swift"}]}],"refere