anchor":"discussion","type":"heading","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that you should use "},{"code":"g_iconv()","type":"codeVoice"},{"type":"text","text":" for streaming conversions."},{"type":"text","text":" "},{"type":"text","text":"Despite the fact that "},{"type":"codeVoice","code":"bytesRead"},{"type":"text","text":" can return information about partial"},{"text":" ","type":"text"},{"type":"text","text":"characters, the g_convert_… functions are not generally suitable"},{"type":"text","text":" "},{"type":"text","text":"for streaming. If the underlying converter maintains internal state,"},{"text":" ","type":"text"},{"text":"then this won’t be preserved across successive calls to ","type":"text"},{"code":"g_convert()","type":"codeVoice"},{"text":",","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_convert_with_iconv()"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"g_convert_with_fallback()"},{"type":"text","text":". (An example of"},{"text":" ","type":"text"},{"text":"this is the GNU C converter for CP1255 which does not emit a base","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"character until it knows that the next character is not a mark that"},{"type":"text","text":" "},{"text":"could combine with the base character.)","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Characters which are valid in the input character set, but which have no"},{"type":"text","text":" "},{"type":"text","text":"representation in the output character set will result in a"},{"type":"text","text":" "},{"type":"codeVoice","code":"illegalSequence"},{"type":"text","text":" error. This is in contrast to the "},{"type":"codeVoice","code":"iconv()"},{"type":"text","text":" "},{"text":"specification, which leaves this behaviour implementation defined. Note that","type":"text"},{"type":"text","text":" "},{"type":"text","text":"this is the same error code as is returned for an invalid byte sequence in"},{"type":"text","text":" "},{"type":"text","text":"the input character set. To get defined behaviour for conversion of"},{"text":" ","type":"text"},{"type":"text","text":"unrepresentable characters, use "},{"code":"g_convert_with_fallback()","type":"codeVoice"},{"text":".","type":"text"}]}],"kind":"content"}],"kind":"symbol","metadata":{"role":"symbol","roleHeading":"Function","externalID":"s:4GLib16convertWithIconv3str3len9converter9bytesRead0H7WrittenSSSgSPys4Int8VGSg_SiSpySo7_GIConvVGSpySuGSgAQtKF","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"convertWithIconv"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"str"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier","text":"gchar"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"len"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gssize","text":"gssize"},{"kind":"text","text":", "},{"kind":"externalParam","text":"converter"},{"text":": ","kind":"text"},{"text":"GIConv","kind":"typeIdentifier","preciseIdentifier":"c:@T@GIConv"},{"text":", ","kind":"text"},{"text":"bytesRead","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gsize","text":"gsize","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"text":"bytesWritten","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gsize","kind":"typeIdentifier","text":"gsize"},{"text":">!) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:SS",