":2,"type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Note that you should use ","type":"text"},{"code":"g_iconv()","type":"codeVoice"},{"type":"text","text":" for streaming conversions."},{"text":" ","type":"text"},{"type":"text","text":"Despite the fact that "},{"code":"bytesRead","type":"codeVoice"},{"text":" can return information about partial","type":"text"},{"type":"text","text":" "},{"text":"characters, the g_convert_… functions are not generally suitable","type":"text"},{"type":"text","text":" "},{"text":"for streaming. If the underlying converter maintains internal state,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"then this won’t be preserved across successive calls to "},{"code":"g_convert()","type":"codeVoice"},{"type":"text","text":","},{"text":" ","type":"text"},{"code":"g_convert_with_iconv()","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"g_convert_with_fallback()","type":"codeVoice"},{"text":". (An example of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this is the GNU C converter for CP1255 which does not emit a base"},{"text":" ","type":"text"},{"type":"text","text":"character until it knows that the next character is not a mark that"},{"type":"text","text":" "},{"text":"could combine with the base character.)","type":"text"}]},{"inlineContent":[{"text":"Characters which are valid in the input character set, but which have no","type":"text"},{"text":" ","type":"text"},{"text":"representation in the output character set will result in a","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"illegalSequence"},{"type":"text","text":" error. This is in contrast to the "},{"code":"iconv()","type":"codeVoice"},{"text":" ","type":"text"},{"text":"specification, which leaves this behaviour implementation defined. Note that","type":"text"},{"text":" ","type":"text"},{"text":"this is the same error code as is returned for an invalid byte sequence in","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the input character set. To get defined behaviour for conversion of"},{"text":" ","type":"text"},{"type":"text","text":"unrepresentable characters, use "},{"type":"codeVoice","code":"g_convert_with_fallback()"},{"type":"text","text":"."}],"type":"paragraph"}]}],"sections":[],"references":{"doc://GLib/documentation/GLib/convertWithIconv(str:len:converter:bytesRead:bytesWritten:)":{"abstract":[{"type":"text","text":"Converts a string from one character set to another."}],"title":"convertWithIconv(str:len:converter:bytesRead:bytesWritten:)","type":"topic","kind":"symbol","url":"\/documentation\/glib\/convertwithiconv(str:len:converter:bytesread:byteswritten:)","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"convertWithIconv","kind":"identifier"},{"kind":"text","text":"("},{"text":"str","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">!, ","kind":"text"},{"text":"len","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@gssize","text":"gssize","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"converter"},{"text":": ","kind":"text"},{"text":"GIConv","kind":"typeIdentifier","preciseIdentifier":"c:@T@GIConv"},{"kind":"text","text":", "},{"text":"bytesRead","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gsize","preciseIdentifier":"c:@T@gsize"},{"text":">!, ","kind":"text"},{"text":"bytesWritten","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"gsize"