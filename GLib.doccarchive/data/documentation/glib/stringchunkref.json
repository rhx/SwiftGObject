{"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"StringChunkRef","kind":"identifier"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","text":"Overview","anchor":"overview","level":2},{"inlineContent":[{"type":"text","text":"String chunks are used to store groups of strings. Memory is"},{"type":"text","text":" "},{"type":"text","text":"allocated in blocks, and as strings are added to the "},{"type":"codeVoice","code":"GStringChunk"},{"text":" ","type":"text"},{"type":"text","text":"they are copied into the next free position in a block. When a block"},{"type":"text","text":" "},{"type":"text","text":"is full a new block is allocated."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"When storing a large number of strings, string chunks are more","type":"text"},{"type":"text","text":" "},{"type":"text","text":"efficient than using [func"},{"code":"GLib.strdup","type":"codeVoice"},{"type":"text","text":"] since fewer calls to "},{"type":"codeVoice","code":"malloc()"},{"type":"text","text":" "},{"text":"are needed, and less memory is wasted in memory allocation overheads.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"By adding strings with [method","type":"text"},{"type":"codeVoice","code":"GLib.StringChunk.insert_const"},{"type":"text","text":"] it is also"},{"type":"text","text":" "},{"type":"text","text":"possible to remove duplicates."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To create a new "},{"code":"GStringChunk","type":"codeVoice"},{"text":" use [func","type":"text"},{"type":"codeVoice","code":"GLib.StringChunk.new"},{"type":"text","text":"]."}]},{"inlineContent":[{"text":"To add strings to a ","type":"text"},{"code":"GStringChunk","type":"codeVoice"},{"type":"text","text":" use [method"},{"code":"GLib.StringChunk.insert","type":"codeVoice"},{"type":"text","text":"]."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"To add strings to a ","type":"text"},{"code":"GStringChunk","type":"codeVoice"},{"text":", but without duplicating strings","type":"text"},{"type":"text","text":" "},{"text":"which are already in the ","type":"text"},{"code":"GStringChunk","type":"codeVoice"},{"type":"text","text":", use [method"},{"type":"codeVoice","code":"GLib.StringChunk.insert_const"},{"type":"text","text":"]."}]},{"type":"paragraph","inlineContent":[{"text":"To free the entire ","type":"text"},{"code":"GStringChunk","type":"codeVoice"},{"type":"text","text":" use [method"},{"type":"codeVoice","code":"GLib.StringChunk.free"},{"type":"text","text":"]."},{"text":" ","type":"text"},{"text":"It is not possible to free individual strings.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StringChunkRef","type":"reference","isActive":true},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GStringChunk"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"text":"It exposes methods that can operate on this data type through ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/StringChunkProtocol"},{"text":" conformance.","type":"text"},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/StringChunkRef"},{"text":" only as an ","type":"text"},{"code":"unowned","type":"codeVoice"},{"type":"text","text":" reference to an existing "},{"type":"codeVoice","code":"GStringChunk"},{"type":"text","text":" instance."}]},{"name":"Note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StringChunk","isActive":true,"type":"reference"},{"type":"text","tex