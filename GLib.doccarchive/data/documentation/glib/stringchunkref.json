{"abstract":[{"code":"GStringChunk","type":"codeVoice"},{"text":" provides efficient storage of groups of strings","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"StringChunkRef"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","text":"Overview","level":2,"anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"String chunks are used to store groups of strings. Memory is"},{"type":"text","text":" "},{"type":"text","text":"allocated in blocks, and as strings are added to the "},{"type":"codeVoice","code":"GStringChunk"},{"type":"text","text":" "},{"type":"text","text":"they are copied into the next free position in a block. When a block"},{"text":" ","type":"text"},{"type":"text","text":"is full a new block is allocated."}]},{"inlineContent":[{"type":"text","text":"When storing a large number of strings, string chunks are more"},{"type":"text","text":" "},{"text":"efficient than using [func","type":"text"},{"code":"GLib.strdup","type":"codeVoice"},{"text":"] since fewer calls to ","type":"text"},{"type":"codeVoice","code":"malloc()"},{"type":"text","text":" "},{"text":"are needed, and less memory is wasted in memory allocation overheads.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"By adding strings with [method","type":"text"},{"type":"codeVoice","code":"GLib.StringChunk.insert_const"},{"text":"] it is also","type":"text"},{"text":" ","type":"text"},{"text":"possible to remove duplicates.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"To create a new ","type":"text"},{"code":"GStringChunk","type":"codeVoice"},{"text":" use [func","type":"text"},{"type":"codeVoice","code":"GLib.StringChunk.new"},{"type":"text","text":"]."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To add strings to a "},{"type":"codeVoice","code":"GStringChunk"},{"type":"text","text":" use [method"},{"type":"codeVoice","code":"GLib.StringChunk.insert"},{"type":"text","text":"]."}]},{"type":"paragraph","inlineContent":[{"text":"To add strings to a ","type":"text"},{"type":"codeVoice","code":"GStringChunk"},{"text":", but without duplicating strings","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"which are already in the "},{"type":"codeVoice","code":"GStringChunk"},{"type":"text","text":", use [method"},{"code":"GLib.StringChunk.insert_const","type":"codeVoice"},{"type":"text","text":"]."}]},{"inlineContent":[{"type":"text","text":"To free the entire "},{"type":"codeVoice","code":"GStringChunk"},{"text":" use [method","type":"text"},{"code":"GLib.StringChunk.free","type":"codeVoice"},{"text":"].","type":"text"},{"type":"text","text":" "},{"text":"It is not possible to free individual strings.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StringChunkRef"},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"code":"GStringChunk","type":"codeVoice"},{"text":" instance.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StringChunkProtocol","isActive":true},{"text":" conformance.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StringChunkRef"},{"text":" only as an ","type":"text"},{"code":"unowned","type":"codeVoice"},{"text":" reference to an existing ","type":"text"},{"code":"GStringChunk","type":"codeVoice"},{"text":" instance.","type":"text"}]},{"style":"note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"Use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/StringChunk"},{"type":"text","text":" (instead of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StringChunkRef"},{"text":") if you want to use Automatic Reference Counting for memory management of the underlying ","type":"text"},{"code":"GStringChunk","type":"codeVoice"},{"type":"text","text":" instance."}],"type":"paragraph"}],"name":"Note"}]}],"topicSections":[{"generated":true,"anchor":"Initializers","title":"Initializers","identifiers":["doc:\/\/GLib\/documentation\/GLib\/StringChunkRef\/init(_:)-2b1td","doc:\/\/GLib\/documentation\/GLib\/StringChunkRef\/init(_:)-3hmw3","doc:\/\/GLib\/documentation\/GLib\/StringChunkRef\/init(_:)-47idj","doc:\/\/GLib\/documentation\/GLib\/StringChunkRef\/init(_:)-7mrrb","doc:\/\/GLib\/documentation\/GLib\/StringChunkRef\/init(_:)-7w9mc","doc:\/\/GLib\/documentation\/GLib\/StringChunkRef\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/StringChunkRef\/init(constPointer:)","doc:\/\/GLib\/documentation\/GLib\/StringChunkRef\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/StringChunkRef\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/StringChunkRef\/init(mutating:)","doc:\/\/GLib\/documentation\/GLib\/StringChunkRef\/init(opaquePointer:)"]},{"anchor":"Instance-Properties","identifiers":["doc:\/\/GLib\/documentation\/GLib\/StringChunkRef\/ptr"],"generated":true,"title":"Instance Properties"},{"title":"Default Implementations","identifiers":["doc:\/\/GLib\/documentation\/GLib\/StringChunkRef\/PointerWrapper-Implementations","doc:\/\/GLib\/documentation\/GLib\/StringChunkRef\/StringChunkProtocol-Implementations"],"anchor":"Default-Implementations","generated":true}],"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"symbol","sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"relationshipsSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper",