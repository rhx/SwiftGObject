{"kind":"symbol","sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"getTmpDir","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":"!","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"On UNIX, this is taken from the ","type":"text"},{"type":"codeVoice","code":"TMPDIR"},{"text":" environment variable.","type":"text"},{"text":" ","type":"text"},{"text":"If the variable is not set, ","type":"text"},{"type":"codeVoice","code":"P_tmpdir"},{"text":" is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"used, as defined by the system C library. Failing that, a"},{"type":"text","text":" "},{"type":"text","text":"hard-coded default of “\/tmp” is returned."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On Windows, the "},{"code":"TEMP","type":"codeVoice"},{"type":"text","text":" environment variable is used, with the"},{"type":"text","text":" "},{"text":"root directory of the Windows installation (eg: “C:\") used","type":"text"},{"text":" ","type":"text"},{"text":"as a default.","type":"text"}]},{"inlineContent":[{"type":"text","text":"The encoding of the returned string is system-defined. On Windows,"},{"text":" ","type":"text"},{"text":"it is always UTF-8. The return value is never ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" or the empty"},{"type":"text","text":" "},{"type":"text","text":"string."}],"type":"paragraph"}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/getTmpDir()"},"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"metadata":{"externalID":"s:4GLib9getTmpDirSSSgyF","title":"getTmpDir()","symbolKind":"func","role":"symbol","modules":[{"name":"GLib"}],"roleHeading":"Function","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"getTmpDir"},{"text":"() -> ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":"!","kind":"text"}]},"variants":[{"paths":["\/documentation\/glib\/gettmpdir()"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"Gets the directory to use for temporary files."}],"references":{"doc://GLib/documentation/GLib/getTmpDir()":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/getTmpDir()","kind":"symbol","title":"getTmpDir()","role":"symbol","url":"\/documentation\/glib\/gettmpdir()","type":"topic","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"getTmpDir","kind":"identifier"},{"kind":"text","text":"() -> "},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":"!","kind":"text"}],"abstract":[{"type":"text","text":"Gets the directory to use for temporary files."}]},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"}}}