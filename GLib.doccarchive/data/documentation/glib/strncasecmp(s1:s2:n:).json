{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"sections":[],"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"strncasecmp","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"s1"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"gchar","preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"text":"s2","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"gchar","preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"text":"n","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"kind":"text","text":") -> "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}]}],"kind":"declarations"},{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Strncasecmp is deprecated:"}]},{"type":"text","text":" "},{"text":"The problem with ","type":"text"},{"type":"codeVoice","code":"g_strncasecmp()"},{"type":"text","text":" is that it does"},{"type":"text","text":" "},{"type":"text","text":"the comparison by calling "},{"type":"codeVoice","code":"toupper()"},{"type":"text","text":"\/"},{"code":"tolower()","type":"codeVoice"},{"text":". These functions","type":"text"},{"type":"text","text":" "},{"text":"are locale-specific and operate on single bytes. However, it is","type":"text"},{"type":"text","text":" "},{"text":"impossible to handle things correctly from an internationalization","type":"text"},{"type":"text","text":" "},{"type":"text","text":"standpoint by operating on bytes, since characters may be multibyte."},{"type":"text","text":" "},{"text":"Thus ","type":"text"},{"type":"codeVoice","code":"g_strncasecmp()"},{"type":"text","text":" is broken if your string is guaranteed to be"},{"text":" ","type":"text"},{"text":"ASCII, since it is locale-sensitive, and it’s broken if your string","type":"text"},{"type":"text","text":" "},{"text":"is localized, since it doesn’t work on many encodings at all,","type":"text"},{"type":"text","text":" "},{"text":"including UTF-8, EUC-JP, etc.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"There are therefore two replacement techniques: [func@GLib.ascii_strncasecmp],","type":"text"},{"text":" ","type":"text"},{"text":"which only works on ASCII and is not locale-sensitive, and","type":"text"},{"type":"text","text":" "},{"text":"[func@GLib.utf8_casefold] followed by ","type":"text"},{"type":"codeVoice","code":"strcmp()"},{"type":"text","text":" on the resulting strings,"},{"type":"text","text":" "},{"text":"which is good for case-insensitive sorting of UTF-8.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/glib\/strncasecmp(s1:s2:n:)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"A case-insensitive string comparison, corresponding to the standard"},{"type":"text","text":" "},{"type":"codeVoice","code":"strncasecmp()"},{"text":" function on platforms which support it. It is similar","type":"text"},{"text":" ","type":"text"},{"text":"to [func","type":"text"},{"code":"GLib.strcasecmp","type":"codeVoice"},{"text":"] except it only compares the first ","type":"text"},{"type":"codeVoice","code":"n"},{"text":" characters of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the strings."}],"metadata":{"symbolKind":"func","role":"symbol","externalID":"s:4GLib11strncasecmp2s12s21nSiSPys4Int8VGSg_AISitF","title":"strncasecmp(s1:s2:n:)","fragm