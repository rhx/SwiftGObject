{"metadata":{"title":"readerLock()","externalID":"s:4GLib14RWLockProtocolPAAE10readerLockyyF","role":"symbol","symbolKind":"method","extendedModule":"GLib","modules":[{"name":"GLib"}],"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"readerLock"},{"text":"()","kind":"text"}],"roleHeading":"Instance Method"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/rwlockprotocol\/readerlock()"]}],"abstract":[{"type":"text","text":"Obtain a read lock on "},{"type":"codeVoice","code":"rwLock"},{"type":"text","text":". If another thread currently holds"},{"type":"text","text":" "},{"type":"text","text":"the write lock on "},{"code":"rwLock","type":"codeVoice"},{"text":", the current thread will block until the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"write lock was (held and) released. If another thread does not hold"},{"type":"text","text":" "},{"text":"the write lock, but is waiting for it, it is implementation defined","type":"text"},{"type":"text","text":" "},{"type":"text","text":"whether the reader or writer will block. Read locks can be taken"},{"type":"text","text":" "},{"text":"recursively.","type":"text"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol\/readerLock()","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"readerLock"},{"text":"()","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Calling "},{"code":"g_rw_lock_reader_lock()","type":"codeVoice"},{"text":" while the current thread already","type":"text"},{"type":"text","text":" "},{"text":"owns a write lock leads to undefined behaviour. Read locks however","type":"text"},{"type":"text","text":" "},{"type":"text","text":"can be taken recursively, in which case you need to make sure to"},{"type":"text","text":" "},{"text":"call ","type":"text"},{"code":"g_rw_lock_reader_unlock()","type":"codeVoice"},{"type":"text","text":" the same amount of times."}]},{"inlineContent":[{"text":"It is implementation-defined how many read locks are allowed to be","type":"text"},{"text":" ","type":"text"},{"text":"held on the same lock simultaneously. If the limit is hit,","type":"text"},{"type":"text","text":" "},{"text":"or if a deadlock is detected, a critical warning will be emitted.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol"]]},"references":{"doc://GLib/documentation/GLib/RWLockProtocol":{"kind":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"text":"RWLockProtocol","kind":"identifier"}],"abstract":[{"type":"text","text":"The GRWLock struct is an opaque data structure to represent a"},{"type":"text","text":" "},{"type":"text","text":"reader-writer lock. It is similar to a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex"},{"type":"text","text":" in that it allows"},{"type":"text","text":" "},{"text":"multiple threads to coordinate access to a shared resource.","type":"text"}],"url":"\/documentation\/glib\/rwlockprotocol","title":"RWLockProtocol","type":"topic","role":"symbol","navigatorTitle":[{"text":"RWLockProtocol","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol"},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/Mutex":{"kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","role":"symbol","abstract":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","type":"reference","isActive":true},{"text":" struct is an opaque data structure to represent a mutex","type":"text"},{"type":"text","text":" "},{"text":"(mutual exclusion). It can be used to protect data against shared","type":"text"},{"type":"text","text":" "},{"text":"access.","type":"text"}],"type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"Mutex","kind":"identifier"}],"title":"Mutex","navigatorTitle":[{"kind":"identifier","text":"Mutex"}],"url":"\/documentation\/glib\/mutex"},"doc://GLib/documentation/GLib/RWLockProtocol/readerLock()":{"title":"readerLock()","abstract":[{"type":"text","text":"Obtain a read lock on "},{"type":"codeVoice","code":"rwLock"},{"type":"text","text":". If another thread currently holds"},{"type":"text","text":" "},{"type":"text","text":"the write lock on "},{"type":"codeVoice","code":"rwLock"},{"text":", the current thread will block until the","type":"text"},{"text":" ","type":"text"},{"text":"write lock was (held and) released. If another thread does not hold","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the write lock, but is waiting for it, it is implementation defined"},{"text":" ","type":"text"},{"type":"text","text":"whether the reader or writer will block. Read locks can be taken"},{"type":"text","text":" "},{"type":"text","text":"recursively."}],"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol\/readerLock()","type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"readerLock"},{"text":"()","kind":"text"}],"url":"\/documentation\/glib\/rwlockprotocol\/readerlock()"}}}