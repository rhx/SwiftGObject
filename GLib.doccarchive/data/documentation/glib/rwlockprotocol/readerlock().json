{"kind":"symbol","sections":[],"metadata":{"title":"readerLock()","symbolKind":"method","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"readerLock"},{"kind":"text","text":"()"}],"modules":[{"name":"GLib"}],"roleHeading":"Instance Method","externalID":"s:4GLib14RWLockProtocolPAAE10readerLockyyF","extendedModule":"GLib"},"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol\/readerLock()"},"abstract":[{"type":"text","text":"Obtain a read lock on "},{"type":"codeVoice","code":"rwLock"},{"text":". If another thread currently holds","type":"text"},{"text":" ","type":"text"},{"text":"the write lock on ","type":"text"},{"type":"codeVoice","code":"rwLock"},{"text":", the current thread will block until the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"write lock was (held and) released. If another thread does not hold"},{"type":"text","text":" "},{"text":"the write lock, but is waiting for it, it is implementation defined","type":"text"},{"type":"text","text":" "},{"type":"text","text":"whether the reader or writer will block. Read locks can be taken"},{"type":"text","text":" "},{"text":"recursively.","type":"text"}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"readerLock","kind":"identifier"},{"kind":"text","text":"()"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Calling "},{"type":"codeVoice","code":"g_rw_lock_reader_lock()"},{"type":"text","text":" while the current thread already"},{"type":"text","text":" "},{"type":"text","text":"owns a write lock leads to undefined behaviour. Read locks however"},{"text":" ","type":"text"},{"text":"can be taken recursively, in which case you need to make sure to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"call "},{"type":"codeVoice","code":"g_rw_lock_reader_unlock()"},{"type":"text","text":" the same amount of times."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is implementation-defined how many read locks are allowed to be"},{"type":"text","text":" "},{"type":"text","text":"held on the same lock simultaneously. If the limit is hit,"},{"text":" ","type":"text"},{"text":"or if a deadlock is detected, a critical warning will be emitted.","type":"text"}]}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol"]]},"variants":[{"paths":["\/documentation\/glib\/rwlockprotocol\/readerlock()"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GLib/documentation/GLib/RWLockProtocol":{"title":"RWLockProtocol","identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"RWLockProtocol","kind":"identifier"}],"abstract":[{"text":"The GRWLock struct is an opaque data structure to represent a","type":"text"},{"text":" ","type":"text"},{"text":"reader-writer lock. It is similar to a ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","isActive":true,"type":"reference"},{"type":"text","text":" in that it allows"},{"text":" ","type":"text"},{"type":"text","text":"multiple threads to coordinate access to a shared resource."}],"kind":"symbol","url":"\/documentation\/glib\/rwlockprotocol","navigatorTitle":[{"kind":"identifier","text":"RWLockProtocol"}],"type":"topic","role":"symbol"},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/RWLockProtocol/readerLock()":{"url":"\/documentation\/glib\/rwlockprotocol\/readerlock()","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"readerLock","kind":"identifier"},{"kind":"text","text":"()"}],"type":"topic","abstract":[{"type":"text","text":"Obtain a read lock on "},{"code":"rwLock","type":"codeVoice"},{"type":"text","text":". If another thread currently holds"},{"type":"text","text":" "},{"type":"text","text":"the write lock on "},{"code":"rwLock","type":"codeVoice"},{"type":"text","text":", the current thread will block until the"},{"type":"text","text":" "},{"type":"text","text":"write lock was (held and) released. If another thread does not hold"},{"type":"text","text":" "},{"text":"the write lock, but is waiting for it, it is implementation defined","type":"text"},{"type":"text","text":" "},{"type":"text","text":"whether the reader or writer will block. Read locks can be taken"},{"type":"text","text":" "},{"text":"recursively.","type":"text"}],"role":"symbol","kind":"symbol","title":"readerLock()","identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol\/readerLock()"},"doc://GLib/documentation/GLib/Mutex":{"title":"Mutex","type":"topic","abstract":[{"text":"The ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex"},{"text":" struct is an opaque data structure to represent a mutex","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(mutual exclusion). It can be used to protect data against shared"},{"text":" ","type":"text"},{"text":"access.","type":"text"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Mutex"}],"navigatorTitle":[{"kind":"identifier","text":"Mutex"}],"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","url":"\/documentation\/glib\/mutex","kind":"symbol"}}}