{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/CondRef","doc:\/\/GLib\/documentation\/GLib\/CondRef\/CondProtocol-Implementations"]]},"variants":[{"paths":["\/documentation\/glib\/condref\/waituntil(mutex:endtime:)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","abstract":[{"type":"text","text":"Waits until either "},{"type":"codeVoice","code":"cond"},{"text":" is signalled or ","type":"text"},{"type":"codeVoice","code":"endTime"},{"type":"text","text":" has passed."}],"schemaVersion":{"major":0,"patch":0,"minor":3},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"waitUntil","kind":"identifier"},{"kind":"text","text":"<"},{"text":"MutexT","kind":"genericParameter"},{"kind":"text","text":">("},{"kind":"externalParam","text":"mutex"},{"kind":"text","text":": "},{"text":"MutexT","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"endTime"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gint64","text":"gint64"},{"kind":"text","text":") -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":" ","kind":"text"},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"text":"MutexT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"MutexProtocol","preciseIdentifier":"s:4GLib13MutexProtocolP","kind":"typeIdentifier","identifier":"doc:\/\/GLib\/documentation\/GLib\/MutexProtocol"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"As with ","type":"text"},{"code":"g_cond_wait()","type":"codeVoice"},{"type":"text","text":" it is possible that a spurious or stolen wakeup"},{"text":" ","type":"text"},{"type":"text","text":"could occur.  For that reason, waiting on a condition variable should"},{"text":" ","type":"text"},{"text":"always be in a loop, based on an explicitly-checked predicate.","type":"text"}]},{"inlineContent":[{"code":"true","type":"codeVoice"},{"text":" is returned if the condition variable was signalled (or in the","type":"text"},{"type":"text","text":" "},{"text":"case of a spurious wakeup).  ","type":"text"},{"code":"false","type":"codeVoice"},{"text":" is returned if ","type":"text"},{"type":"codeVoice","code":"endTime"},{"type":"text","text":" has"},{"type":"text","text":" "},{"text":"passed.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The following code shows how to correctly perform a timed wait on a","type":"text"},{"type":"text","text":" "},{"text":"condition variable (extending the example presented in the","type":"text"},{"type":"text","text":" "},{"text":"documentation for ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","type":"reference","isActive":true},{"text":"):","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"(C Language Example):","type":"text"}]},{"type":"codeListing","syntax":"C","code":["gpointer","pop_data_timed (void)","{","  gint64 end_time;","  gpointer data;","","  g_mutex_lock (&data_mutex);","","  end_time = g_get_monotonic_time () + 5 * G_TIME_SPAN_SECOND;","  while (!current_data)","    if (!g_cond_wait_until (&data_cond, &data_mutex, end_time))","      {","        \/\/ timeout has passed.","        g_mutex_unlock (&data_mutex);","        return NULL;","      }","","  \/\/ there is data for us","  data = current_data;","  current_data = NULL;","","  g_mutex_unlock (&data_mutex);","","  return data;","}"]},{"inlineContent":[{"type":"text","text":"Notice that the end time is calculated once, before entering the"},{"text":" ","type":"text"},{"type":"text","text":"loop and reused.  This is the motivation behind the use of absolute"},{"text":" ","type":"text"},{"type":"text","text":"time on this API – if a relative time of 5 seconds were passed"},{"type":"text","text":" "},{"text":"directly to the call and a spurious wakeup occurred, the program would","type":"text"},{"type":"text","text":" "},{"type":"text","text":"have to start over waiting again (which would lead to a total wait"},{"type":"text","text":" "},{"text":"time of more than 5 seconds).","type":"text"}],"type":"paragraph"}],"kind":"content"}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/CondRef\/waitUntil(mutex:endTime:)"},"metadata":{"symbolKind":"method","extendedModule":"GLib","title":"waitUntil(mutex:endTime:)","modules":[{"name":"GLib"}],"roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"waitUntil","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"MutexT"},{"kind":"text","text":">("},{"text":"mutex","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"MutexT"},{"kind":"text","text":", "},{"kind":"externalParam","text":"endTime"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@gint64","text":"gint64","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"externalID":"s:4GLib12CondProtocolPAAE9waitUntil5mutex7endTimeSbqd___s5Int64VtAA05MutexC0Rd__lF::SYNTHESIZED::s:4GLib7CondRefV","role":"symbol"},"references":{"doc://GLib/documentation/GLib/CondRef/CondProtocol-Implementations":{"abstract":[],"url":"\/documentation\/glib\/condref\/condprotocol-implementations","role":"collectionGroup","identifier":"doc:\/\/GLib\/documentation\/GLib\/CondRef\/CondProtocol-Implementations","title":"CondProtocol Implementations","kind":"article","type":"topic"},"doc://GLib/documentation/GLib/CondRef":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/CondRef","type":"topic","abstract":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GL