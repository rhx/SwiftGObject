ext","text":" is signalled or "},{"code":"endTime","type":"codeVoice"},{"type":"text","text":" has passed."}]},"doc://GLib/documentation/GLib/Cond":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","type":"topic","abstract":[{"text":"The ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond"},{"text":" struct is an opaque data structure that represents a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"condition. Threads can block on a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond"},{"text":" if they find a certain","type":"text"},{"type":"text","text":" "},{"text":"condition to be false. If other threads change the state of this","type":"text"},{"type":"text","text":" "},{"text":"condition they signal the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","type":"reference"},{"text":", and that causes the waiting","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"threads to be woken up."}],"title":"Cond","navigatorTitle":[{"kind":"identifier","text":"Cond"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Cond"}],"url":"\/documentation\/glib\/cond","kind":"symbol","role":"symbol"},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/Mutex":{"title":"Mutex","type":"topic","abstract":[{"text":"The ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex"},{"text":" struct is an opaque data structure to represent a mutex","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(mutual exclusion). It can be used to protect data against shared"},{"text":" ","type":"text"},{"text":"access.","type":"text"}],"fragments"