{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/CondRef","doc:\/\/GLib\/documentation\/GLib\/CondRef\/CondProtocol-Implementations"]]},"sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"text":"Waits until either ","type":"text"},{"code":"cond","type":"codeVoice"},{"text":" is signalled or ","type":"text"},{"type":"codeVoice","code":"endTime"},{"type":"text","text":" has passed."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"waitUntil","kind":"identifier"},{"text":"<","kind":"text"},{"text":"MutexT","kind":"genericParameter"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"mutex"},{"text":": ","kind":"text"},{"text":"MutexT","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"endTime"},{"kind":"text","text":": "},{"text":"gint64","kind":"typeIdentifier","preciseIdentifier":"c:@T@gint64"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"},{"kind":"text","text":" "},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MutexT","kind":"typeIdentifier"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","identifier":"doc:\/\/GLib\/documentation\/GLib\/MutexProtocol","preciseIdentifier":"s:4GLib13MutexProtocolP","text":"MutexProtocol"}],"languages":["swift"]}]},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"inlineContent":[{"text":"As with ","type":"text"},{"type":"codeVoice","code":"g_cond_wait()"},{"text":" it is possible that a spurious or stolen wakeup","type":"text"},{"text":" ","type":"text"},{"text":"could occur.  For that reason, waiting on a condition variable should","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"always be in a loop, based on an explicitly-checked predicate."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"code":"true","type":"codeVoice"},{"text":" is returned if the condition variable was signalled (or in the","type":"text"},{"type":"text","text":" "},{"text":"case of a spurious wakeup).  ","type":"text"},{"type":"codeVoice","code":"false"},{"type":"text","text":" is returned if "},{"code":"endTime","type":"codeVoice"},{"type":"text","text":" has"},{"type":"text","text":" "},{"type":"text","text":"passed."}]},{"inlineContent":[{"text":"The following code shows how to correctly perform a timed wait on a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"condition variable (extending the example presented in the"},{"type":"text","text":" "},{"type":"text","text":"documentation for "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","isActive":true,"type":"reference"},{"type":"text","text":"):"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"(C Language Example):","type":"text"}]},{"syntax":"C","code":["gpointer","pop_data_timed (void)","{","  gint64 end_time;","  gpointer data;","","  g_mutex_lock (&data_mutex);","","  end_time = g_get_monotonic_time () + 5 * G_TIME_SPAN_SECOND;","  while (!current_data)","    if (!g_cond_wait_until (&data_cond, &data_mutex, end_time))","      {","        \/\/ timeout has passed.","        g_mutex_unlock (&data_mutex);","        return NULL;","      }","","  \/\/ there is data for us","  data = current_data;","  current_data = NULL;","","  g_mutex_unlock (&data_mutex);","","  return data;","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Notice that the end time is calculated once, before entering the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"loop and reused.  This is the motivation behind the use of absolute"},{"text":" ","type":"text"},{"type":"text","text":"time on this API – if a relative time of 5 seconds were passed"},{"text":" ","type":"text"},{"type":"text","text":"directly to the call and a spurious wakeup occurred, the program would"},{"type":"text","text":" "},{"type":"text","text":"have to start over waiting again (which would lead to a total wait"},{"text":" ","type":"text"},{"type":"text","text":"time of more than 5 seconds)."}]}],"kind":"content"}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/CondRef\/waitUntil(mutex:endTime:)","interfaceLanguage":"swift"},"metadata":{"role":"symbol","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"waitUntil"},{"kind":"text","text":"<"},{"text":"MutexT","kind":"genericParameter"},{"kind":"text","text":">("},{"text":"mutex","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"MutexT"},{"kind":"text","text":", "},{"text":"endTime","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"gint64","kind":"typeIdentifier","preciseIdentifier":"c:@T@gint64"},{"text":") -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"externalID":"s:4GLib12CondProtocolPAAE9waitUntil5mutex7endTimeSbqd___s5Int64VtAA05MutexC0Rd__lF::SYNTHESIZED::s:4GLib7CondRefV","title":"waitUntil(mutex:endTime:)","extendedModule":"GLib","modules":[{"name":"GLib"}],"roleHeading":"Instance Method"},"variants":[{"paths":["\/documentation\/glib\/condref\/waituntil(mutex:endtime:)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","references":{"doc://GLib/documentation/GLib/Mutex":{"kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","role":"symbol","abstract":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","type":"reference","isActive":true},{"text":" struct is an opaque data structure to represent a mutex","type":"text"},{"type":"text","text":" "},{"text":"(mutual exclusion). It can be used to protect data against shared","type":"text"},{"type":"text","text":" "},{"text":"access.","type":"text"}],"type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"Mutex","kind":"identifier"}],"title":"Mutex","navigatorTitle":[{"kind":"identifier","text":"Mutex"}],"url":"\/documentation\/glib\/mutex"},"doc://GLib/documentation/GLib/Cond":{"role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"Cond"}],"navigatorTitle":[{"text":"Cond","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","abstract":[{"type":"text","text":"The "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","type":"reference"},{"text":" struct is an opaque data structure that represents a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"condition. Threads can block on a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond"},{"text":" if they find a certain","type":"text"},{"type":"text","text":" "},{"text":"condition to be false. If other threads change the state of this","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"condition they signal the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond"},{"text":", and that causes the waiting","type":"text"},{"type":"text","text":" "},{"type":"text","text":"threads to be woken up."}],"kind":"symbol","url":"\/documentation\/glib\/cond","type":"topic","title":"Cond"},"doc://GLib/documentation/GLib/MutexProtocol":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MutexProtocol","role":"symbol","type":"topic","navigatorTitle":[{"text":"MutexProtocol","kind":"identifier"}],"abstract":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","isActive":true,"type":"reference"},{"text":" struct is an opaque data structure to represent a mutex","type":"text"},{"type":"text","text":" "},{"text":"(mutual exclusion). It can be used to protect data against shared","type":"text"},{"type":"text","text":" "},{"text":"access.","type":"text"}],"fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"MutexProtocol","kind":"identifier"}],"title":"MutexProtocol","url":"\/documentation\/glib\/mutexprotocol","kind":"symbol"},"doc://GLib/documentation/GLib/CondRef/CondProtocol-Implementations":{"abstract":[],"title":"CondProtocol Implementations","type":"topic","role":"collectionGroup","kind":"article","identifier":"doc:\/\/GLib\/documentation\/GLib\/CondRef\/CondProtocol-Implementations","url":"\/documentation\/glib\/condref\/condprotocol-implementations"},"doc://GLib/documentation/GLib/CondRef":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/CondRef","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"CondRef"}],"role":"symbol","url":"\/documentation\/glib\/condref","kind":"symbol","title":"CondRef","type":"topic","navigatorTitle":[{"text":"CondRef","kind":"identifier"}],"abstract":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","isActive":true},{"text":" struct is an opaque data structure that represents a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"condition. Threads can block on a "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","isActive":true,"type":"reference"},{"text":" if they find a certain","type":"text"},{"type":"text","text":" "},{"text":"condition to be false. If other threads change the state of this","type":"text"},{"type":"text","text":" "},{"type":"text","text":"condition they signal the "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","isActive":true,"type":"reference"},{"text":", and that causes the waiting","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"threads to be woken up."}]},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/docu