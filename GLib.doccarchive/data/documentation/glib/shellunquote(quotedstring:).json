"},{"type":"codeVoice","code":"g_shell_unquote()"},{"type":"text","text":" simply goes through the string and unquotes\/unescapes"},{"text":" ","type":"text"},{"type":"text","text":"anything that the shell would. Both single and double quotes are"},{"type":"text","text":" "},{"text":"handled, as are escapes including escaped newlines.","type":"text"}]},{"inlineContent":[{"type":"text","text":"The return value must be freed with "},{"type":"codeVoice","code":"g_free()"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Possible errors are in the "},{"code":"G_SHELL_ERROR","type":"codeVoice"},{"type":"text","text":" domain."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Shell quoting rules are a bit strange. Single quotes preserve the"},{"text":" ","type":"text"},{"type":"text","text":"literal string exactly. escape sequences are not allowed; not even"},{"type":"text","text":" "},{"type":"codeVoice","code":"\\'"},{"text":" - if you want a ","type":"text"},{"type":"codeVoice","code":"'"},{"type":"text","text":" in the quoted text, you have to do something"},{"text":" ","type":"text"},{"type":"text","text":"like "},{"type":"codeVoice","code":"'foo'\\''bar'"},{"type":"text","text":". Double quotes allow "},{"code":"$","type":"codeVoice"},{"type":"text","text":", ```, "},{"code":"\"","type":"codeVoice"},{"type":"text","text":", ``, and"},{"type":"text","text":" "},{"type":"text","text":"newline to be escaped with backslash. Otherwise double quotes"},{"text":" ","type":"text"},{"type":"text","text":"preserve things literally."}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/shellunquote(quotedstring:)"]}],"metadata":{"modules":[{"name":"GLib"}],"role":"symbol","symbolKind":"func","title":"shellUnquote(quotedString:)","roleHeading":"Function","externalID":"s:4GLib12shellUnquote12quotedStringSSSgSPys4Int8VGSg_tKF","fragments":[{"text":"func","kind":"keyword