{"abstract":[{"type":"text","text":"Determines the preferred character sets used for filenames."},{"type":"text","text":" "},{"type":"text","text":"The first character set from the "},{"code":"charsets","type":"codeVoice"},{"type":"text","text":" is the filename encoding, the"},{"type":"text","text":" "},{"type":"text","text":"subsequent character sets are used when trying to generate a displayable"},{"type":"text","text":" "},{"text":"representation of a filename, see ","type":"text"},{"code":"g_filename_display_name()","type":"codeVoice"},{"type":"text","text":"."}],"sections":[],"metadata":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"get"},{"kind":"text","text":"("},{"text":"filenameCharsets","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"kind":"text","text":">?>?>!) -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"role":"symbol","externalID":"s:4GLib3get16filenameCharsetsSbSpySpySPys4Int8VGSgGSgGSg_tF","symbolKind":"func","title":"get(filenameCharsets:)","roleHeading":"Function","modules":[{"name":"GLib"}]},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/get(filenameCharsets:)"},"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"get","kind":"identifier"},{"text":"(","kind":"text"},{"text":"filenameCharsets","kind":"externalParam"},{"text":": ","kind":"text"}