as the filename","type":"text"},{"type":"text","text":" "},{"type":"text","text":"encoding. If neither environment variable  is set, UTF-8 is taken"},{"type":"text","text":" "},{"type":"text","text":"as the filename encoding, but the character set of the current locale"},{"type":"text","text":" "},{"type":"text","text":"is also put in the list of encodings."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The returned ","type":"text"},{"type":"codeVoice","code":"charsets"},{"text":" belong to GLib and must not be freed.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that on Unix, regardless of the locale character set or"},{"type":"text","text":" "},{"code":"G_FILENAME_ENCODING","type":"codeVoice"},{"text":" value, the actual file names present","type":"text"},{"text":" ","type":"text"},{"text":"on a system might be in any random encoding or just gibberish.","type":"text"}]}]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/get(filenamecharsets:)"]}],"references":{"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"running.html#locale":{"type":"link","titleInlineContent":[{"type":"text","text":"current locale"}],"identifier":"running.html#locale","title":"current locale","url":"running.html#locale"},"doc://GLib/documentation/GLib/get(filenameCharsets:)":{"abstract":[{"text":"Determines the preferred character sets used for filenames.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The first character set from the "},{"type":"codeVoice","code":"charsets"},{"text":" is the filename encoding, the","type":"text"},{"text":" ","type":"text"},{"text":"subsequent character sets are used when trying to generate a displayable","type":"text"},{"type":"text","text":" "},{"type":"