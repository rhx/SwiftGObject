e":"text","text":"On Unix, the character sets are determined by consulting the"},{"text":" ","type":"text"},{"type":"text","text":"environment variables "},{"type":"codeVoice","code":"G_FILENAME_ENCODING"},{"text":" and ","type":"text"},{"code":"G_BROKEN_FILENAMES","type":"codeVoice"},{"text":".","type":"text"},{"type":"text","text":" "},{"text":"On Windows, the character set used in the GLib API is always UTF-8","type":"text"},{"type":"text","text":" "},{"text":"and said environment variables have no effect.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"code":"G_FILENAME_ENCODING","type":"codeVoice"},{"type":"text","text":" may be set to a comma-separated list of"},{"type":"text","text":" "},{"text":"character set names. The special token ","type":"text"},{"type":"codeVoice","code":"locale"},{"type":"text","text":" is taken to mean the"},{"text":" ","type":"text"},{"text":"character set for the ","type":"text"},{"isActive":true,"type":"reference","identifier":"running.html#locale"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"If "},{"type":"codeVoice","code":"G_FILENAME_ENCODING"},{"text":" is not set, but ","type":"text"},{"type":"codeVoice","code":"G_BROKEN_FILENAMES"},{"text":" is,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the character set of the current locale is taken as the filename"},{"type":"text","text":" "},{"text":"encoding. If neither environment variable  is set, UTF-8 is taken","type":"text"},{"text":" ","type":"text"},{"text":"as the filename encoding, but the character set of the current locale","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is also put in the list of encodings."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The returned "},{"code":"charsets","type":"codeVoice"},{"text":" belong to GLib and must not be freed.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Note that on Unix, regardless of the locale character set or","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"G_FILENAME_ENCODING"},{"text":" value, the actual file names present","type":"text"},{"type":"text","text":" "},{"type":"text","text":"on a system might be in any random encoding or just gibberish."}]}]}],"abstract":[{"text":"Determines the preferred character sets used for filenames.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"The first character set from the "},{"code":"charsets","type":"codeVoice"},{"type":"text","text":" is the filename encoding, the"},{"type":"text","text":" "},{"type":"text","text":"subsequent character sets are used when trying to generate a displayable"},{"type":"text","text":" "},{"type":"text","text":"representation of a filename, see "},{"type":"codeVoice","code":"g_filename_display_name()"},{"type":"text","text":"."}],"variants":[{"paths":["\/documentation\/glib\/get(filenamecharsets:)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/get(filenameCharsets:)"},"references":{"doc://GLib/documentation/GLib/get(filenameCharsets:)":{"url":"\/documentation\/glib\/get(filenamecharsets:)","abstract":[{"type":"text","text":"Determines the preferred character sets used for filenames."},{"text":" ","type":"text"},{"type":"text","text":"The first character set from the "},{"code":"charsets","type":"codeVoice"},{"type":"text","text":" is the filename encoding, the"},{"type":"text","text":" "},{"type":"text","text":"subsequent character sets are used when trying to generate a displayable"},{"text":" ","type":"text"},{"type":"text","text":"representation of a filename, see "},{"code":"g_filename_display_name()","type":"codeVoice"},{"text":".","type":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/get(filenameCharsets:)","title":"get(filenameCharsets:)","type":"topic","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"f