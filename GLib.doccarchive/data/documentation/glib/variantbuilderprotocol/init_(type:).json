{"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"externalID":"s:4GLib22VariantBuilderProtocolPAAE5init_4typeyqd___tAA0b4TypeD0Rd__lF","title":"init_(type:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"init_","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"VariantTypeT"},{"text":">(","kind":"text"},{"text":"type","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"VariantTypeT","kind":"typeIdentifier"},{"kind":"text","text":")"}],"symbolKind":"method","modules":[{"name":"GLib"}],"extendedModule":"GLib","roleHeading":"Instance Method","role":"symbol"},"sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"init_"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"VariantTypeT"},{"text":">(","kind":"text"},{"text":"type","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"VariantTypeT"},{"kind":"text","text":") "},{"kind":"keyword","text":"where"},{"text":" ","kind":"text"},{"text":"VariantTypeT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:4GLib19VariantTypeProtocolP","text":"VariantTypeProtocol","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantTypeProtocol","kind":"typeIdentifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"code":"type","type":"codeVoice"},{"text":" must be non-","type":"text"},{"code":"nil","type":"codeVoice"},{"text":".  It specifies the type of container to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"construct.  It can be an indefinite type such as"},{"type":"text","text":" "},{"code":"G_VARIANT_TYPE_ARRAY","type":"codeVoice"},{"type":"text","text":" or a definite type such as “as” or “(ii)”."},{"text":" ","type":"text"},{"type":"text","text":"Maybe, array, tuple, dictionary entry and variant-typed values may be"},{"type":"text","text":" "},{"type":"text","text":"constructed."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If using a static type such as one of the "},{"code":"G_VARIANT_TYPE_*","type":"codeVoice"},{"text":" constants","type":"text"},{"text":" ","type":"text"},{"text":"or a ","type":"text"},{"type":"codeVoice","code":"G_VARIANT_TYPE (\"(ii)\")"},{"text":" macro, it is more performant to use","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_variant_builder_init_static()"},{"type":"text","text":" rather than "},{"type":"codeVoice","code":"g_variant_builder_init()"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"After the builder is initialised, values are added using","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_variant_builder_add_value()"},{"type":"text","text":" or "},{"type":"codeVoice","code":"g_variant_builder_add()"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"After all the child values are added, "},{"code":"g_variant_builder_end()","type":"codeVoice"},{"type":"text","text":" frees"},{"type":"text","text":" "},{"type":"text","text":"the memory associated with the builder and returns the "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"text":" that","type":"text"},{"type":"text","text":" "},{"text":"was created.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function completely ignores the previous contents of "},{"code":"builder","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"On one hand this means that it is valid to pass in completely","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"uninitialised memory.  On the other hand, this means that if you are"},{"text":" ","type":"text"},{"type":"text","text":"initialising over top of an existing "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder","isActive":true,"type":"reference"},{"text":" you need to","type":"text"},{"type":"text","text":" "},{"text":"first call ","type":"text"},{"type":"codeVoice","code":"g_variant_builder_clear()"},{"text":" in order to avoid leaking","type":"text"},{"type":"text","text":" "},{"text":"memory.","type":"text"}]},{"inlineContent":[{"type":"text","text":"You must not call "},{"type":"codeVoice","code":"g_variant_builder_ref()"},{"type":"text","text":" or"},{"type":"text","text":" "},{"code":"g_variant_builder_unref()","type":"codeVoice"},{"text":" on a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder"},{"text":" that was initialised","type":"text"},{"type":"text","text":" "},{"text":"with this function.  If you ever pass a reference to a","type":"text"},{"type":"text","text":" "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder","type":"reference","isActive":true},{"type":"text","text":" outside of the control of your own code then you"},{"text":" ","type":"text"},{"text":"should assume that the person receiving that reference may try to use","type":"text"},{"text":" ","type":"text"},{"text":"reference counting; you should use ","type":"text"},{"code":"g_variant_builder_new()","type":"codeVoice"},{"type":"text","text":" instead of"},{"text":" ","type":"text"},{"type":"text","text":"this function."}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/variantbuilderprotocol\/init_(type:)"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilderProtocol\/init_(type:)"},"abstract":[{"text":"Initialises a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder"},{"