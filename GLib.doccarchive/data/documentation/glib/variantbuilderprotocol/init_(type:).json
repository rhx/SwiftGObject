using a static type such as one of the ","type":"text"},{"code":"G_VARIANT_TYPE_*","type":"codeVoice"},{"type":"text","text":" constants"},{"type":"text","text":" "},{"text":"or a ","type":"text"},{"code":"G_VARIANT_TYPE (\"(ii)\")","type":"codeVoice"},{"text":" macro, it is more performant to use","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_variant_builder_init_static()"},{"type":"text","text":" rather than "},{"type":"codeVoice","code":"g_variant_builder_init()"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"After the builder is initialised, values are added using","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_variant_builder_add_value()"},{"type":"text","text":" or "},{"code":"g_variant_builder_add()","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"After all the child values are added, "},{"code":"g_variant_builder_end()","type":"codeVoice"},{"type":"text","text":" frees"},{"text":" ","type":"text"},{"type":"text","text":"the memory associated with the builder and returns the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":" that","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"was created."}]},{"type":"paragraph","inlineContent":[{"text":"This function completely ignores the previous contents of ","type":"text"},{"type":"codeVoice","code":"builder"},{"type":"text","text":"."},{"text":" ","type":"text"},{"type":"text","text":"On one hand this means that it is valid to pass in completely"},{"text":" ","type":"text"},{"type":"text","text":"uninitialised memory.  On the other hand, this means that if you are"},{"type":"text","text":" "},{"text":"initialising over top of an existing ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder","isActive":true},{"text":" you need to","type":"text"},{"type":"text","text":" "},{"text":"first call ","type":"text"},{"code":"g_variant_builder_clear()","type":"codeVoice"},{"text":" in order to avoid leaking","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"memory."}]},{"type":"paragraph","inlineContent":[{"text":"You must not call ","type":"text"},{"code":"g_variant_builder_ref()","type":"codeVoice"},{"type":"text","text":" or"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_variant_builder_unref()"},{"type":"text","text":" on a "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder","type":"reference"},{"text":" that was initialised","type":"text"},{"type":"text","text":" "},{"text":"with this function.  If you ever pass a reference to a","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder","type":"reference","isActive":true},{"type":"text","text":" outside of the control of your own code then you"},{"type":"text","text":" "},{"type":"text","text":"should assume that the person receiving that reference may try to use"},{"type":"text","text":" "},{"type":"text","text":"reference counting; you should use "},{"code":"g_variant_builder_new()","type":"codeVoice"},{"type":"text","text":" instead of"},{"type":"text","text":" "},{"text":"this function.","type":"text"}]}]}],"sections":[],"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"role":"symbol","roleHeading":"Instance Method","externalID":"s:4GLib22VariantBuilderProtocolPAAE5init_4typeyqd___tAA0b4TypeD0Rd__lF","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"init_"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"VariantTypeT"},{"text":">(","kind":"text"},{"text":"type","kind":"externalParam"},{"kind":"text","text":": "},{"text":"VariantTypeT","kind":"typeIdentifier"},{"kind":"text","text":")"}],"extendedModule":"GLib","modules":[{"name":"GLib"}],"title":"init_(t