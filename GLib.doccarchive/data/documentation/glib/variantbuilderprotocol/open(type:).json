{"abstract":[{"text":"Opens a subcontainer inside the given ","type":"text"},{"code":"builder","type":"codeVoice"},{"text":".  When done adding","type":"text"},{"type":"text","text":" "},{"type":"text","text":"items to the subcontainer, "},{"code":"g_variant_builder_close()","type":"codeVoice"},{"text":" must be called. ","type":"text"},{"code":"type","type":"codeVoice"},{"text":" ","type":"text"},{"text":"is the type of the container: so to build a tuple of several values, ","type":"text"},{"type":"codeVoice","code":"type"},{"type":"text","text":" "},{"type":"text","text":"must include the tuple itself."}],"metadata":{"role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"open","kind":"identifier"},{"text":"<","kind":"text"},{"text":"VariantTypeT","kind":"genericParameter"},{"kind":"text","text":">("},{"text":"type","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"VariantTypeT"},{"text":")","kind":"text"}],"symbolKind":"method","modules":[{"name":"GLib"}],"extendedModule":"GLib","roleHeading":"Instance Method","externalID":"s:4GLib22VariantBuilderProtocolPAAE4open4typeyqd___tAA0b4TypeD0Rd__lF","title":"open(type:)"},"sections":[],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilderProtocol\/open(type:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/VariantBuilderProtocol"]]},"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/variantbuilderprotocol\/open(type:)"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"open","kind":"identifier"},{"text":"<","kind":"text"},{"text":"VariantTypeT","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"type","kind":"externalParam"},{"text":": ","kind":"