":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">!) -> ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"role":"symbol","modules":[{"name":"GLib"}],"title":"stat(filename:)"},"variants":[{"paths":["\/documentation\/glib\/statbufref\/stat(filename:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/StatBufRef","doc:\/\/GLib\/documentation\/GLib\/StatBufRef\/StatBufProtocol-Implementations"]]},"references":{"doc://GLib/documentation/GLib/StatBufRef/stat(filename:)":{"type":"topic","abstract":[{"type":"text","text":"A wrapper for the POSIX "},{"type":"codeVoice","code":"stat()"},{"text":" function. The ","type":"text"},{"code":"stat()","type":"codeVoice"},{"text":" function","type":"text"},{"type":"text","text":" "},{"type":"text","text":"returns information about a file. On Windows the "},{"code":"stat()","type":"codeVoice"},{"text":" function in","type":"text"},{"type":"text","text":" "},{"text":"the C library checks only the FAT-style READONLY attribute and does","type":"text"},{"type":"text","text":" "},{"type":"text","text":"not look at the ACL at all. Thus on Windows the protection bits in"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"code":"st_mode","type":"codeVoice"},{"text":" field are a fabrication of little use.","type":"text"}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"stat","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"filename"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">!) -> ","kind":"text"},{"text":"Int","preciseIdentifier":"s: