{"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"findProgramInPath","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"program"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"text":">!) -> ","kind":"text"},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"},{"text":"!","kind":"text"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"text":"On Windows, if ","type":"text"},{"type":"codeVoice","code":"program"},{"type":"text","text":" does not have a file type suffix, tries"},{"type":"text","text":" "},{"text":"with the suffixes .exe, .cmd, .bat and .com, and the suffixes in","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the "},{"type":"codeVoice","code":"PATHEXT"},{"type":"text","text":" environment variable."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"On Windows, it looks for the file in the same way as "},{"type":"codeVoice","code":"CreateProcess()"},{"text":" ","type":"text"},{"type":"text","text":"would. This means first in the directory where the executing"},{"text":" ","type":"text"},{"type":"text","text":"program was loaded from, then in the current directory, then in the"},{"type":"text","text":" "},{"text":"Windows 32-bit system directory, then in the Windows directory, and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"finally in the directories in the "},{"type":"codeVoice","code":"PATH"},{"type":"text","text":" environment variable. If"},{"type":"text","text":" "},{"type":"text","text":"the program is foun