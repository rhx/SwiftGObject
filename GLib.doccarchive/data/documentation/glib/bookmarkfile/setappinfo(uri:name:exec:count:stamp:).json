{"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/setAppInfo(uri:name:exec:count:stamp:)","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"setAppInfo"},{"text":"(","kind":"text"},{"text":"uri","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">!, "},{"text":"name","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"exec"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier","text":"gchar"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"count"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"stamp"},{"kind":"text","text":": "},{"text":"time_t","kind":"typeIdentifier","preciseIdentifier":"c:@T@time_t"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"You should rarely use this function; use ","type":"text"},{"type":"codeVoice","code":"g_bookmark_file_add_application()"},{"type":"text","text":" "},{"type":"text","text":"and "},{"type":"codeVoice","code":"g_bookmark_file_remove_application()"},{"text":" instead.","type":"text"}]},{"type":"paragraph","inlineContent":[{"code":"name","type":"codeVoice"},{"text":" can be any UTF-8 encoded string used to identify an","type":"text"},{"type":"text","text":" "},{"text":"application.","type":"text"},{"type":"text","text":" "},{"code":"exec","type":"codeVoice"},{"type":"text","text":" can have one of these two modifiers: “`f"},{"type":"codeVoice","code":"\", which will be expanded as the local file name retrieved from the bookmark's URI; \"\\"},{"type":"text","text":"u"},{"type":"codeVoice","code":"\", which will be expanded as the bookmark's URI. The expansion is done automatically when retrieving the stored command line using the "},{"text":"g_bookmark_file_get_application_info()","type":"text"},{"type":"codeVoice","code":"function."},{"type":"text","text":"count"},{"code":"is the number of times the application has registered the bookmark; if is < 0, the current registration count will be increased by one, if is 0, the application with","type":"codeVoice"},{"text":"name","type":"text"},{"code":"will be removed from the list of registered applications.","type":"codeVoice"},{"text":"stamp` is the Unix time of the last registration; if it is -1, the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"current time will be used."}]},{"type":"paragraph","inlineContent":[{"text":"If you try to remove an application by setting its registration count to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"zero, and no bookmark for "},{"type":"codeVoice","code":"uri"},{"text":" is found, ","type":"text"},{"code":"false","type":"codeVoice"},{"type":"text","text":" is returned and"},{"type":"text","text":" "},{"type":"codeVoice","code":"error"},{"type":"text","text":" is set to "},{"type":"codeVoice","code":"uriNotFound"},{"type":"text","text":"; similarly,"},{"text":" ","type":"text"},{"text":"in the event that no application ","type":"text"},{"code":"name","type":"codeVoice"},{"type":"text","text":" has registered a bookmark"},{"text":" ","type":"text"},{"text":"for ","type":"text"},{"code":"uri","type":"codeVoice"},{"type":"text","text":",  "},{"type":"codeVoice","code":"false"},{"type":"text","text":" is returned and error is set to"},{"type":"text","text":" "},{"code":"appNotRegistered","type":"codeVoice"},{"text":".  Otherwise, if no bookmark","type":"text"},{"type":"text","text":" "},{"text":"for ","type":"text"},{"type":"codeVoice","code":"uri"},{"type":"text","text":" is found, one is created."}]},{"inlineContent":[{"inlineContent":[{"type":"text","text":"set_app_info is deprecated:"}],"type":"strong"},{"text":" ","type":"text"},{"text":"Use g_bookmark_file_set_application_info() instead, as","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"time_t"},{"text":" is deprecated due to the year 2038 problem.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"metadata":{"roleHeading":"Instance Method","externalID":"s:4GLib20BookmarkFileProtocolPAAE10setAppInfo3uri4name4exec5count5stampSbSPys4Int8VGSg_A2MS2itKF::SYNTHESIZED::s:4GLib12BookmarkFileC","symbolKind":"method","title":"setAppInfo(uri:name:exec:count:stamp:)","platforms":[],"extendedModule":"GLib","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"setAppInfo"},{"kind":"text","text":"("},{"text":"uri","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">!, "},{"text":"name","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifie