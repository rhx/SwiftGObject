{"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/testFail()","interfaceLanguage":"swift"},"metadata":{"roleHeading":"Function","externalID":"s:4GLib8testFailyyF","symbolKind":"func","title":"testFail()","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"testFail","kind":"identifier"},{"text":"()","kind":"text"}],"role":"symbol","modules":[{"name":"GLib"}]},"kind":"symbol","abstract":[{"type":"text","text":"Indicates that a test failed."}],"variants":[{"paths":["\/documentation\/glib\/testfail()"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"testFail","kind":"identifier"},{"kind":"text","text":"()"}],"languages":["swift"]}]},{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function can be called multiple times from the same test."},{"type":"text","text":" "},{"text":"You can use this function if your test failed in a recoverable way.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Do not use this function if the failure of a test could cause"},{"text":" ","type":"text"},{"type":"text","text":"other tests to malfunction."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Calling this function will not stop the test from running, you"},{"text":" ","type":"text"},{"type":"text","text":"need to return from the test function yourself. So you can"},{"text":" ","type":"text"},{"type":"text","text":"produce additional diagnostic messages or even continue running"},{"type":"text","text":" "},{"type":"text","text":"the test."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If not called from inside a test, this function does nothing."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Note that unlike [func"},{"code":"GLib.test_skip","type":"codeVoice"},{"text":"] and [func","type":"text"},{"code":"GLib.test_incomplete","type":"codeVoice"},{"type":"text","text":"],"},{"text":" ","type":"text"},{"text":"this function does not log a message alongside the test failure.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"If details of the test failure are available, either log them with"},{"type":"text","text":" "},{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.test_message"},{"type":"text","text":"] before [func"},{"type":"codeVoice","code":"GLib.test_fail"},{"text":"], or use","type":"text"},{"type":"text","text":" "},{"text":"[func","type":"text"},{"type":"codeVoice","code":"GLib.test_fail_printf"},{"type":"text","text":"] instead."}],"type":"paragraph"}],"kind":"content"}],"sections":[],"references":{"doc://GLib/documentation/GLib/testFail()":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/testFail()","title":"testFail()","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"testFail"},{"text":"()","kind":"text"}],"url":"\/documentation\/glib\/testfail()","abstract":[{"type":"text","text":"Indicates that a test failed."}],"type":"topic","role":"symbol"},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"}}}