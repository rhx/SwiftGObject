{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/testfail()"]}],"sections":[],"abstract":[{"text":"Indicates that a test failed.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"metadata":{"symbolKind":"func","modules":[{"name":"GLib"}],"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"testFail"},{"kind":"text","text":"()"}],"roleHeading":"Function","title":"testFail()","role":"symbol","externalID":"s:4GLib8testFailyyF"},"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"testFail","kind":"identifier"},{"kind":"text","text":"()"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"This function can be called multiple times from the same test.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"You can use this function if your test failed in a recoverable way."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Do not use this function if the failure of a test could cause"},{"text":" ","type":"text"},{"text":"other tests to malfunction.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Calling this function will not stop the test from running, you"},{"type":"text","text":" "},{"text":"need to return from the test function yourself. So you can","type":"text"},{"text":" ","type":"text"},{"text":"produce additional diagnostic messages or even continue running","type":"text"},{"text":" ","type":"text"},{"text":"the test.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If not called from inside a test, this function does nothing.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that unlike [func"},{"type":"codeVoice","code":"GLib.test_skip"},{"type":"text","text":"] and [func"},{"type":"codeVoice","code":"GLib.test_incomplete"},{"type":"text","text":"],"},{"text":" ","type":"text"},{"text":"this function does not log a message alongside the test failure.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"If details of the test failure are available, either log them with"},{"type":"text","text":" "},{"type":"text","text":"[func"},{"code":"GLib.test_message","type":"codeVoice"},{"type":"text","text":"] before [func"},{"code":"GLib.test_fail","type":"codeVoice"},{"text":"], or use","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[func"},{"code":"GLib.test_fail_printf","type":"codeVoice"},{"text":"] instead.","type":"text"}]}],"kind":"content"}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/testFail()","interfaceLanguage":"swift"},"kind":"symbol","references":{"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/testFail()":{"type":"topic","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"testFail","kind":"identifier"},{"text":"()","kind":"text"}],"url":"\/documentation\/glib\/testfail()","title":"testFail()","abstract":[{"text":"Indicates that a test failed.","type":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/testFail()","kind":"symbol"}}}