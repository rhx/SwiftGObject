{"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/PatternSpecRef\/match(stringLength:string:stringReversed:)","interfaceLanguage":"swift"},"metadata":{"roleHeading":"Instance Method","role":"symbol","title":"match(stringLength:string:stringReversed:)","symbolKind":"method","modules":[{"name":"GLib"}],"externalID":"s:4GLib19PatternSpecProtocolPAAE5match12stringLength0F00F8ReversedSbSi_SPys4Int8VGSgAKtF::SYNTHESIZED::s:4GLib14PatternSpecRefV","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"match","kind":"identifier"},{"kind":"text","text":"("},{"text":"stringLength","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"string","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">!, ","kind":"text"},{"text":"stringReversed","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"text":"gchar","preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier"},{"text":">?) -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"extendedModule":"GLib"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/PatternSpecRef","doc:\/\/GLib\/documentation\/GLib\/PatternSpecRef\/PatternSpecProtocol-Implementations"]]},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"match","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"stringLength"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"string","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">!, ","kind":"text"},{"text":"stringReversed","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">? = nil) -> ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"inlineContent":[{"text":"Passing the correct","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"length of the string given is mandatory. The reversed string can be"},{"type":"text","text":" "},{"text":"omitted by passing ","type":"text"},{"code":"NULL","type":"codeVoice"},{"text":", this is more efficient if the reversed","type":"text"},{"type":"text","text":" "},{"text":"version of the string to be matched is not at hand, as","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"code":"GLib.PatternSpec.match","type":"codeVoice"},{"type":"text","text":"] will only construct it if the compiled pattern"},{"type":"text","text":" "},{"type":"text","text":"requires reverse matches."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that, if the user code will (possibly) match a string against a"},{"type":"text","text":" "},{"type":"text","text":"multitude of patterns containing wildcards, chances are high that"},{"type":"text","text":" "},{"type":"text","text":"some patterns will require a reversed string. In this case, it’s"},{"text":" ","type":"text"},{"type":"text","text":"more efficient to provide the reversed string to avoid multiple"},{"text":" ","type":"text"},{"type":"text","text":"constructions thereof in the various calls to [method"},{"code":"GLib.PatternSpec.match","type":"codeVoice"},{"text":"].","type":"text"}]},{"inlineContent":[{"text":"Note also that the reverse of a UTF-8 encoded string can in general","type":"text"},{"type":"text","text":" "},{"type":"text","text":"not be obtained by [func"},{"code":"GLib.strreverse","type":"codeVoice"},{"text":"]. This works only if the string","type":"text"},{"type":"text","text":" "},{"text":"does not contain any multibyte characters. GLib offers the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[func"},{"code":"GLib.utf8_strreverse","type":"codeVoice"},{"type":"text","text":"] function to reverse UTF-8 encoded strings."}],"type":"paragraph"}]}],"variants":[{"paths":["\/documentation\/glib\/patternspecref\/match(stringlength:string:stringreversed:)"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"abstract":[{"type":"text","text":"Matches a string against a compiled pattern."}],"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://GLib/documentation/GLib/PatternSpecRef/PatternSpecProtocol-Implementations":{"title":"PatternSpecProtocol Implementations","abstract":[],"kind":"article","url":"\/documentation\/glib\/patternspecref\/patternspecprotocol-implementations","role":"collectionGroup","identifier":"doc:\/\/GLib\/documentation\/GLib\/PatternSpecRef\/PatternSpecProtocol-Implementations","type":"topic"},"doc://GLib/documentation/GLib/PatternSpecRef":{"abstract":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"GPatternSpec"},{"text":" struct is the ‘compiled’ form of a glob-style pattern.","type":"text"}],"kind":"symbol","title":"PatternSpecRef","role":"symbol","navigatorTitle":[{"text":"PatternSpecRef","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"PatternSpecRef"}],"url":"\/documentation\/glib\/patte