{"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"toIso8601","kind":"identifier"},{"kind":"text","text":"() -> "},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"kind":"text","text":"!"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"ISO 8601 allows a large number of date\/time formats, with or without","type":"text"},{"text":" ","type":"text"},{"text":"punctuation and optional elements. The format returned by this function","type":"text"},{"type":"text","text":" "},{"text":"is a complete date and time, with optional punctuation included, the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"UTC time zone represented as “Z”, and the "},{"type":"codeVoice","code":"tv_usec"},{"text":" part included if","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and only if it is nonzero, i.e. either"},{"type":"text","text":" "},{"type":"text","text":"“YYYY-MM-DDTHH:MM:SSZ” or “YYYY-MM-DDTHH:MM:SS.fffffZ”."}]},{"inlineContent":[{"text":"This corresponds to the Internet date\/time format defined by","type":"text"},{"type":"text","text":" "},{"identifier":"https:\/\/www.ietf.org\/rfc\/rfc3339.txt","type":"reference","isActive":true},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"text","text":"and to either of the two most-precise formats defined by"},{"type":"text","text":" "},{"type":"text","text":"the W3C Note"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"http:\/\/www.w3.org\/TR\/NOTE-datetime-19980827"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"Both of these documents are profiles of ISO 8601.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Use ","type":"text"},{"code":"g_date_time_format()","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"g_strdup_printf()","type":"codeVoice"},{"type":"text","text":" if a different"},{"type":"text","text":" "},{"text":"variation of ISO 8601 format is required.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"time","type":"codeVoice"},{"type":"text","text":" represents a date which is too large to fit into a "},{"type":"codeVoice","code":"struct tm"},{"text":",","type":"text"},{"type":"text","text":" "},{"code":"nil","type":"codeVoice"},{"text":" will be returned. This is platform dependent. Note also that since","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"GTimeVal"},{"text":" stores the number of seconds as a ","type":"text"},{"code":"glong","type":"codeVoice"},{"type":"text","text":", on 32-bit systems it"},{"type":"text","text":" "},{"type":"text","text":"is subject to the year 2038 problem. Accordingly, since GLib 2.62, this"},{"type":"text","text":" "},{"text":"function has been deprecated. Equivalent functionality is available using:","type":"text"}]},{"type":"codeListing","syntax":null,"code":["GDateTime *dt = g_date_time_new_from_unix_utc (time_val);","iso8601_string = g_date_time_format_iso8601 (dt);","g_date_time_unref (dt);"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The return value of "},{"code":"g_time_val_to_iso8601()","type":"codeVoice"},{"text":" has been nullable since GLib","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"2.54; before then, GLib would crash under the same conditions."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"to_iso8601 is deprecated:"}]},{"type":"text","text":" "},{"type":"text","text":"#GTimeVal is not year-2038-safe. Use"},{"text":" ","type":"text"},{"type":"text","text":"g_date_time_format_iso8601(dt) instead."}]}]}],"variants":[{"paths":["\/documentation\/glib\/timeval\/toiso8601()"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"role":"symbol","extendedModule":"GLib","externalID":"s:4GLib15TimeValProtocolPAAE9toIso8601SSSgyF::SYNTHESIZED::s:4GLib7TimeValC","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"toIso8601","kind":"identifier"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":"!"}],"title":"toIso8601()","modules":[{"name":"GLib"}],"platforms":[],"roleHeading":"Instance Method"},"abstract":[{"type":"text","text":"Converts "},{"code":"time","type":"codeVoice"},{"type":"text","text":" into an RFC 3339 encoded string, relative to the"},{"type":"text","text":" "},{"text":"Coordinated Universal Time (UTC). This is one of the many formats","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"allowed by ISO 8601."}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/TimeVal","doc:\/\/GLib\/documentation\/GLib\/TimeVal\/TimeValProtocol-Implementations"]]},"sections":[],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/TimeVal\/toIso8601()","interfaceLanguage":"swift"},"references":{"doc://GLib/documentation/GLib/TimeVal/toIso8601()":{"deprecated":true,"type":"topic","url":"\/documentation\/glib\/timeval\/toiso8601()","abstract":[{"type":"text","text":"Converts "},{"code":"time","type":"codeVoice"},{"type":"text","text":" into an RFC 3339 encoded string, relative to the"},{"text":" ","type":"text"},{"text":"Coordinated Universal Time (UTC). This is one of the many formats","type":"text"},{"text":" ","type":"text"},{"text":"allowed by ISO 8601.","type":"text"}],"title":"toIso8601()","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"toIso8601"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"},{"kind":"text","text":"!"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeVal\/toIso8601()","kind":"symbol"},"doc://GLib/documentation/GLib/TimeVal/TimeValProtocol-Implementations":{"kind":"article","type":"topic","title":"TimeValProtocol Implementations","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeVal\/TimeValProtocol-Implementations","role":"collectionGroup","url":"\/documentation\/glib\/timeval\/timevalprotocol-implementations"},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/TimeVal":{"url":"\/documentation\/glib\/timeval","title":"TimeVal","navigatorTitle":[{"kind":"identifier","text":"TimeVal"}],"kind":"symbol","abstract":[{"type":"text","text":"Represents a precise time, with seconds and microseconds."}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeVal","type":"topic","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TimeVal","kind":"identifier"}],"role":"symbol"},"https://www.ietf.org/rfc/rfc3339.txt":{"type":"link","identifier":"https:\/\/www.ietf.org\/rfc\/rfc3339.txt","title":"RFC 3339","titleInlineContent":[{"type":"text","text":"RFC 3339"}],"url":"https:\/\/www.ietf.org\/rfc\/rfc3339.txt"},"http://www.w3.org/TR/NOTE-datetime-19980827":{"type":"link","identifier":"http:\/\/www.w3.org\/TR\/NOTE-datetime-19980827","title":"Date and Time Formats","titleInlineContent":[{"type":"text","text":"Date and Time Formats"}],"url":"http:\/\/www.w3.org\/TR\/NOTE-datetime-19980827"}}}