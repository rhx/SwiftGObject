text","text":" time would be parsed as"},{"type":"text","text":" "},{"code":"23:59:59","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"<sep>"},{"type":"text","text":" is the separator and can be either ‘T’, ‘t’ or ’ ’. The latter two"},{"type":"text","text":" "},{"type":"text","text":"separators are an extension from"},{"text":" ","type":"text"},{"type":"reference","identifier":"https:\/\/tools.ietf.org\/html\/rfc3339#section-5.6","isActive":true},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"<date>"},{"text":" is in the form:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"code":"YYYY-MM-DD","type":"codeVoice"},{"text":" - Year\/month\/day, e.g. 2016-08-24.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"YYYYMMDD","type":"codeVoice"},{"type":"text","text":" - Same as above without dividers."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"YYYY-DDD"},{"text":" - Ordinal day where DDD is from 001 to 366, e.g. 2016-237.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"YYYYDDD"},{"text":" - Same as above without dividers.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"YYYY-Www-D","type":"codeVoice"},{"text":" - Week day where ww is from 01 to 52 and D from 1-7,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"e.g. 2016-W34-3."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"YYYYWwwD"},{"text":" - Same as above without dividers.","type":"text"}]}]}]},{"inlineContent":[{"type":"codeVoice","code":"<time>"},{"text":" is in the form:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"code":"hh:mm:","type":"codeVoice"},{"type":"text","text":"ss(.sss)`` - Hours, minutes,