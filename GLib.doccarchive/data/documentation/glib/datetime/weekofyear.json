{"metadata":{"title":"weekOfYear","modules":[{"name":"GLib"}],"roleHeading":"Instance Property","extendedModule":"GLib","role":"symbol","externalID":"s:4GLib16DateTimeProtocolPAAE10weekOfYearSivp::SYNTHESIZED::s:4GLib8DateTimeC","symbolKind":"property","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"weekOfYear"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"weekOfYear"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"kind":"text","text":" }"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"The first week of the year is week 1.  This is the week that contains","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the first Thursday of the year.  Equivalently, this is the first week"},{"type":"text","text":" "},{"type":"text","text":"that has more than 4 of its days falling within the calendar year."}]},{"inlineContent":[{"text":"The value 0 is never returned by this function.  Days contained","type":"text"},{"type":"text","text":" "},{"type":"text","text":"within a year but occurring before the first ISO 8601 week of that"},{"type":"text","text":" "},{"type":"text","text":"year are considered as being contained in the last week of the"},{"type":"text","text":" "},{"text":"previous year.  Similarly, the final days of a calendar year may be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"considered as being part of the first ISO 8601 week of the next year"},{"type":"text","text":" "},{"text":"if 4 or more days of that week are c