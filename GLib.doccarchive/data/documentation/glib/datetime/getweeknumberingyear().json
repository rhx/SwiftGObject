{"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/datetime\/getweeknumberingyear()"]}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"getWeekNumberingYear"},{"kind":"text","text":"() -> "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function, taken together with "},{"type":"codeVoice","code":"g_date_time_get_week_of_year()"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_date_time_get_day_of_week()"},{"type":"text","text":" can be used to determine the full ISO"},{"text":" ","type":"text"},{"text":"week date on which ","type":"text"},{"type":"codeVoice","code":"datetime"},{"type":"text","text":" falls."}]},{"type":"paragraph","inlineContent":[{"text":"This is usually equal to the normal Gregorian year (as returned by","type":"text"},{"type":"text","text":" "},{"code":"g_date_time_get_year()","type":"codeVoice"},{"type":"text","text":"), except as detailed below:"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For Thursday, the week-numbering year is always equal to the usual"},{"type":"text","text":" "},{"text":"calendar year.  For other days, the number is such that every day","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"within a complete week (Monday to Sunday) is contained within the"},{"type":"text","text":" "},{"text":"same week-numbering year.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For Monday, Tuesday and Wednesday occurring near the end of the year,"},{"text":" ","type":"text"},{"type":"text","text":"this may mean that the week-numbering year is one greater than the"},{"type":"text","text":" "},{"type":"text","text":"calendar year (so that these days have the same week-numbering year"},{"text":" ","type":"text"},{"type":"text","text":"as the Thursday occurring early in the next year)."}]},{"type":"paragraph","inlineContent":[{"text":"For Friday, Saturday and Sunday occurring near the start of the year,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"this may mean that the week-numbering year is one less than the"},{"type":"text","text":" "},{"type":"text","text":"calendar year (so that these days have the same week-numbering year"},{"type":"text","text":" "},{"text":"as the Thursday occurring late in the previous year).","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"An equivalent description is that the week-numbering year is equal to","type":"text"},{"type":"text","text":" "},{"text":"the calendar year containing the majority of the days in the current","type":"text"},{"text":" ","type":"text"},{"text":"week (Monday to Sunday).","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that January 1 0001 in the proleptic Gregorian calendar is a"},{"type":"text","text":" "},{"text":"Monday, so this function never returns 0.","type":"text"}]}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/DateTime\/getWeekNumberingYear()"},"metadata":{"title":"getWeekNumberingYear()","modules":[{"name":"GLib"}],"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"getWeekNumberingYear","kind":"identifier"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}],"role":"symbol","extendedModule":"GLib","symbolKind":"method","externalID":"s:4GLib16DateTimeProtocolPAAE20getWeekNumberingYearSiyF::SYNTHESIZED::s:4GLib8DateTimeC","roleHeading":"Instance Method"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/DateTime","doc:\/\/GLib\/documentation\/GLib\/DateTime\/DateTimeProtocol-Implementations"]]},"abstract":[{"text":"Returns the ISO 8601 week-numbering year in which the week containing","type":"text"},{"type":"text","text":" "},{"code":"datetime","type":"codeVoice"},{"text":" falls.","type":"text"}],"references":{"doc://GLib/documentation/GLib/DateTime":{"role":"symbol","navigatorTitle":[{"text":"DateTime","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTime","type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"DateTime"}],"title":"DateTime","url":"\/documentation\/glib\/datetime","abstract":[{"code":"GDateTime","type":"codeVoice"},{"text":" is a structure that combines a Gregorian date and time","type":"text"},{"type":"text","text":" "},{"text":"into a single structure.","type":"text"}]},"doc://GLib/documentation/GLib/DateTime/getWeekNumberingYear()":{"role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"getWeekNumberingYear","kind":"identifier"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"type":"topic","abstract":[{"type":"text","text":"Returns the ISO 8601 week-numbering year in which the week containing"},{"type":"text","text":" "},{"type":"codeVoice","code":"datetime"},{"type":"text","text":" falls."}],"url":"\/documentation\/glib\/datetime\/getweeknumberingyear()","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTime\/getWeekNumberingYear()","title":"getWeekNumberingYear()"},"doc://GLib/documentation/GLib/DateTime/DateTimeProtocol-Implementations":{"type":"topic","title":"DateTimeProtocol Implementations","kind":"article","abstract":[],"url":"\/documentation\/glib\/datetime\/datetimeprotocol-implementations","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTime\/DateTimeProtocol-Implementations","role":"collectionGroup"},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"}}}