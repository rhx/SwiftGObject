de":"tz"},{"type":"text","text":"."}],"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/DateTime\/init(tz:year:month:day:hour:minute:seconds:)"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/DateTime"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"init"},{"kind":"text","text":"<"},{"text":"TimeZoneT","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"tz","kind":"externalParam"},{"kind":"text","text":": "},{"text":"TimeZoneT","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"year"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"month"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"kind":"externalParam","text":"day"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"hour","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"minute"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"seconds"},{"kind":"text","text":": "},{"text":"Double","kind":"typeIdentifier","preciseIdentifier":"s:Sd"},{"kind":"text","text":") "},{"text":"where","kind":"keyword"},{"kind":"text","text":" "},{"text":"TimeZoneT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib16TimeZoneProtocolP","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZoneProtocol","text":"TimeZoneProtocol"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"year"},{"text":" must be between 1 and 9999, ","type":"text"},{"type":"codeVoice","code":"month"},{"type":"text","text":" between 1 and 12 and "},{"code":"day","type":"codeVoice"},{"type":"text","text":" "},{"text":"between 1 and 28, 29, 30 or 31 depending on the month and the year.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"hour"},{"type":"text","text":" must be between 0 and 23 and "},{"type":"codeVoice","code":"minute"},{"type":"text","text":" must be between 0 and 59."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"seconds"},{"text":" must be at least 0.0 and must be strictly less than 60.0.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It will be rounded down to the nearest microsecond."}]},{"inlineContent":[{"type":"text","text":"If the given time is not representable in the given time zone (for"},{"text":" ","type":"text"},{"text":"example, 02:30 on March 14th 2010 in Toronto, due to daylight savings","type":"text"},{"type":"text","text":" "},{"text":"time) then the time will be rounded up to the nearest existing time","type":"text"},{"text":" ","type":"text"},{"text":"(in this case, 03:00).  If this matters to you then you should verify","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the return value for containing the same as the numbers you gave."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In the case that the given time is ambiguous in the given time zone"},{"text":" ","type":"text"},{"text":"(for example, 01:30 on November 7th 2010 in Toronto, due to daylight","type":"text"},{"type":"text","text":" "},{"type":"text","text":"savings time) then the time falling within standard (ie:"},{"text":" ","type":"text"},{"text":"non-daylight) time is taken.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"It not considered a programmer error for the values to this function","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to be out of range, but in the case that they are, the function will"},{"type":"text","text":" "},{"type":"text","text":"return "},{"type":"codeVoice","code":"nil"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"You should release the return value by calling ","type":"text"},{"code":"g_date_time_unref()","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"when you are done with it."}]}],"kind":"content"}],"references":{"doc://GLib/documentation/GLib/TimeZoneProtocol":{"title":"TimeZoneProtocol","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZoneProtocol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"text":"TimeZoneProtocol","kind":"identifier"}],"abstract":[{"type":"text","text":"A "},{"code":"GTimeZone","type":"codeVoice"},{"type":"text","text":" represents a time zone, at no particular point in time."}],"kind":"symbol","url":"\/documentation\/glib\/timezoneprotocol","navigatorTitle":[{"text":"TimeZoneProtocol","kind":"identifier"}],"type":"topic","role":"symbol"},"doc://GLib/documentation/GLib/DateTime/init(tz:year:month:day:hour:minute:seconds:)":{"url":"\/documentation\/glib\/datetime\/init(tz:year:month:day:hour:minute:seconds:)","title":"init(tz:year:month:day:hour:minute:seconds:)","abstract":[{"text":"Creates a new ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTime"},{"text":" corresponding to the given date and time in","type":"text"},{"type":"text","text":" "},{"text":"the time zone ","type":"text"},{"type":"codeVoice","code":"tz"},{"text":".","type":"text"}],"type":"topic","role":"symbol","kind":"symbol","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"<"},{"kind":"gener