{"sections":[],"abstract":[{"text":"Returns the ISO 8601 week-numbering year in which the week containing","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"datetime"},{"text":" falls.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/DateTime","doc:\/\/GLib\/documentation\/GLib\/DateTime\/DateTimeProtocol-Implementations"]]},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/DateTime\/weekNumberingYear","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/datetime\/weeknumberingyear"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"weekNumberingYear"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":" { ","kind":"text"},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function, taken together with "},{"type":"codeVoice","code":"g_date_time_get_week_of_year()"},{"type":"text","text":" and"},{"text":" ","type":"text"},{"code":"g_date_time_get_day_of_week()","type":"codeVoice"},{"type":"text","text":" can be used to determine the full ISO"},{"text":" ","type":"text"},{"type":"text","text":"week date on which "},{"type":"codeVoice","code":"datetime"},{"type":"text","text":" falls."}]},{"inlineContent":[{"type":"text","text":"This is usually equal to the normal Gregorian year (as returned by"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_date_time_get_year()"},{"type":"text","text":"), except as detailed below:"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"For Thursday, the week-numbering year is always equal to the usual","type":"text"},{"type":"text","text":" "},{"type":"text","text":"calendar year.  For other days, the number is such that every day"},{"type":"text","text":" "},{"type":"text","text":"within a complete week (Monday to Sunday) is contained within the"},{"text":" ","type":"text"},{"type":"text","text":"same week-numbering year."}]},{"inlineContent":[{"type":"text","text":"For Monday, Tuesday and Wednesday occurring near the end of the year,"},{"type":"text","text":" "},{"type":"text","text":"this may mean that the week-numbering year is one greater than the"},{"type":"text","text":" "},{"text":"calendar year (so that these days have the same week-numbering year","type":"text"},{"type":"text","text":" "},{"type":"text","text":"as the Thursday occurring early in the next year)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For Friday, Saturday and Sunday occurring near the start of the year,"},{"type":"text","text":" "},{"text":"this may mean that the week-numbering year is one less than the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"calendar year (so that these days have the same week-numbering year"},{"type":"text","text":" "},{"text":"as the Thursday occurring late in the previous year).","type":"text"}]},{"inlineContent":[{"type":"text","text":"An equivalent description is that the week-numbering year is equal to"},{"type":"text","text":" "},{"text":"the calendar year containing the majority of the days in the current","type":"text"},{"type":"text","text":" "},{"type":"text","text":"week (Monday to Sunday)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Note that January 1 0001 in the proleptic Gregorian calendar is a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Monday, so this function never returns 0."}]}]}],"metadata":{"extendedModule":"GLib","modules":[{"name":"GLib"}],"externalID":"s:4GLib16DateTimeProtocolPAAE17weekNumberingYearSivp::SYNTHESIZED::s:4GLib8DateTimeC","role":"symbol","roleHeading":"Instance Property","title":"weekNumberingYear","symbolKind":"property","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"weekNumberingYear"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}]},"references":{"doc://GLib/documentation/GLib/DateTime":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTime","kind":"symbol","role":"symbol","abstract":[{"type":"codeVoice","code":"GDateTime"},{"type":"text","text":" is a structure that combines a Gregorian date and time"},{"type":"text","text":" "},{"type":"text","text":"into a single structure."}],"type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"DateTime","kind":"identifier"}],"title":"DateTime","navigatorTitle":[{"text":"DateTime","kind":"identifier"}],"url":"\/documentation\/glib\/datetime"},"doc://GLib/documentation/GLib/DateTime/DateTimeProtocol-Implementations":{"role":"collectionGroup","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTime\/DateTimeProtocol-Implementations","abstract":[],"url":"\/documentation\/glib\/datetime\/datetimeprotocol-implementations","type":"topic","kind":"article","title":"DateTimeProtocol Implementations"},"doc://GLib/documentation/GLib/DateTime/weekNumberingYear":{"title":"weekNumberingYear","url":"\/documentation\/glib\/datetime\/weeknumberingyear","abstract":[{"text":"Returns the ISO 8601 week-numbering year in which the week containing","type":"text"},{"type":"text","text":" "},{"code":"datetime","type":"codeVoice"},{"text":" falls.","type":"text"}],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTime\/weekNumberingYear","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"weekNumberingYear","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"role":"symbol","kind":"symbol"},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"}}}