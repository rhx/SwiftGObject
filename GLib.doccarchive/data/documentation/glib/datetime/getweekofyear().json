{"metadata":{"role":"symbol","externalID":"s:4GLib16DateTimeProtocolPAAE13getWeekOfYearSiyF::SYNTHESIZED::s:4GLib8DateTimeC","title":"getWeekOfYear()","symbolKind":"method","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"getWeekOfYear"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"extendedModule":"GLib","modules":[{"name":"GLib"}]},"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"paths":["\/documentation\/glib\/datetime\/getweekofyear()"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/DateTime\/getWeekOfYear()"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/DateTime","doc:\/\/GLib\/documentation\/GLib\/DateTime\/DateTimeProtocol-Implementations"]]},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"getWeekOfYear"},{"text":"() -> ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"inlineContent":[{"type":"text","text":"The first week of the year is week 1.  This is the week that contains"},{"type":"text","text":" "},{"text":"the first Thursday of the year.  Equivalently, this is the first week","type":"text"},{"text":" ","type":"text"},{"text":"that has more than 4 of its days falling within the calendar year.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The value 0 is never returned by this function.  Days contained"},{"text":" ","type":"text"},{"type":"text","text":"within a year but occurring before the first ISO 8601 week of that"},{"type":"text","text":" "},{"type":"text","text":"year are considered as being contained in the last week of the"},{"type":"text","text":" "},{"type":"text","text":"previous year.  Similarly, the final days of a calendar year may be"},{"text":" ","type":"text"},{"type":"text","text":"considered as being part of the first ISO 8601 week of the next year"},{"type":"text","text":" "},{"type":"text","text":"if 4 or more days of that week are contained within the new year."}],"type":"paragraph"}],"kind":"content"}],"kind":"symbol","abstract":[{"type":"text","text":"Returns the ISO 8601 week number for the week containing "},{"type":"codeVoice","code":"datetime"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The ISO 8601 week number is the same for every day of the week (from"},{"text":" ","type":"text"},{"type":"text","text":"Moday through Sunday).  That can produce some unusual results"},{"type":"text","text":" "},{"type":"text","text":"(described below)."}],"references":{"doc://GLib/documentation/GLib/DateTime/DateTimeProtocol-Implementations":{"role":"collectionGroup","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTime\/DateTimeProtocol-Implementations","abstract":[],"url":"\/documentation\/glib\/datetime\/datetimeprotocol-implementations","type":"topic","kind":"article","title":"DateTimeProtocol Implementations"},"doc://GLib/documentation/GLib/DateTime/getWeekOfYear()":{"url":"\/documentation\/glib\/datetime\/getweekofyear()","title":"getWeekOfYear()","abstract":[{"type":"text","text":"Returns the ISO 8601 week number for the week containing "},{"type":"codeVoice","code":"datetime"},{"type":"text","text":"."},{"text":" ","type":"text"},{"type":"text","text":"The ISO 8601 week number is the same for every day of the week (from"},{"type":"text","text":" "},{"type":"text","text":"Moday through Sunday).  That can produce some unusual results"},{"type":"text","text":" "},{"type":"text","text":"(described below)."}],"fragments":[{"text":"func","kind":"keyword"},{"text":" 