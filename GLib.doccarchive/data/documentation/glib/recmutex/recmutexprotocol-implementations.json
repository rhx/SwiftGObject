":" ","type":"text"},{"type":"text","text":"unlocked by the other thread. If "},{"type":"codeVoice","code":"recMutex"},{"text":" is already locked","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"by the current thread, the ‘lock count’ of "},{"type":"codeVoice","code":"recMutex"},{"text":" is increased.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"The mutex will only become available again when it is unlocked"},{"text":" ","type":"text"},{"text":"as many times as it has been locked.","type":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex\/lock()","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"lock"},{"text":"()","kind":"text"}],"role":"symbol","url":"\/documentation\/glib\/recmutex\/lock()","kind":"symbol","type":"topic","title":"lock()"},"doc://GLib/documentation/GLib/RecMutex/trylock()":{"type":"topic","abstract":[{"text":"Tries to lock ","type":"text"},{"type":"codeVoice","code":"recMutex"},{"text":". If ","type":"text"},{"code":"recMutex","type":"codeVoice"},{"text":" is already locked","type":"text"},{"type":"text","text":" "},{"type":"text","text":"by another thread, it immediately returns "},{"code":"false","type":"codeVoice"},{"type":"text","text":". Otherwise"},{"type":"text","text":" "},{"text":"it locks ","type":"text"},{"type":"codeVoice","code":"recMutex"},{"type":"text","text":" and returns "},{"type":"codeVoice","code":"true"},{"text":".","type":"text"}],"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"trylock","kind":"identifier"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"url":"\/documentation\/glib\/recmutex\/trylock()","kind":"symbol","title":"trylock()","role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex\/trylock()"},"doc://GLib/documentation/GLib/RecMutex/clear()":{"title":"clear()","type":"topic","fragments":[{"text":"func"