tax":"C"},{"inlineContent":[{"type":"text","text":"Calling "},{"type":"codeVoice","code":"g_rec_mutex_init()"},{"type":"text","text":" on an already initialized "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex","isActive":true},{"type":"text","text":" "},{"type":"text","text":"leads to undefined behaviour."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To undo the effect of "},{"code":"g_rec_mutex_init()","type":"codeVoice"},{"type":"text","text":" when a recursive mutex"},{"text":" ","type":"text"},{"type":"text","text":"is no longer needed, use "},{"code":"g_rec_mutex_clear()","type":"codeVoice"},{"text":".","type":"text"}]}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"paths":["\/documentation\/glib\/recmutex\/init_()"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/Mutex":{"kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","role":"symbol","abstract":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","type":"reference","isActive":true},{"text":" struct is an opaque data structure to represent a mutex","type":"text"},{"type":"text","text":" "},{"text":"(mutual exclusion). It can be used to protect data against shared","type":"text"},{"type":"text","text":" "},{"text":"access.","type":"text"}],"type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"Mutex","kind":"identifier"}],"title":"Mutex","navigatorTitle":[{"kind":"identifier","text":"Mutex"}],"url":"\/documentation\/glib\/mutex"},"doc://GLib/documentation/GLib/RecMutex/init_()":{"url":"\/documentation\/glib\/recmutex\/init_()","identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex\/init_()","role":"symbol","title":"init_()","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"init_"},{"text":"()","kind":"text"}],"abstract":[{"type":"text","text":"Initializes a "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex","type":"reference","isActive":true},{"text":" so that it can be used.","type":"text"}],"kind":"symbol","type":"topic"},"doc://GLib/documentation/GLib/RecMutex":{"abstract":[{"text":"The GRecMutex struct is an opaque data structure to represent a","type":"text"},{"type":"text","text":" "},{"text":"recursive mutex. It is similar to a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex"},{"text":" with the difference","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"that it is possible to lock a GRecMutex multiple times in the same"},{"type":"text","text":" "},{"type":"text","text":"thread without deadlock. When doing so, care has to be taken to"},{"text":" ","type":"text"},{"type":"text","text":"unlock the recursive mutex as often as it has been locked."}],"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex","navigatorTitle":[{"text":"RecMutex","kind":"identifier"}],"url":"\/documentation\/glib\/recmutex","type":"topic","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RecMutex","kind":"identifier"}],"kind":"symbol","title":"RecMutex"},"doc://GLib/documentation/GLib/RecMutex/RecMutexProtocol-Implementations":{"type":"topic","url":"\/documentation\/glib\/recmutex\/recmutexprotocol-implementations","identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex\/RecMutexProtocol-Implementations","role":"collectionGroup","abstract":[],"kind":"article","title":"RecMutexProtocol Implementations"}}}