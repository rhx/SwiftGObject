, 1);","g_rec_mutex_init (&b->m);"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Calling "},{"type":"codeVoice","code":"g_rec_mutex_init()"},{"type":"text","text":" on an already initialized "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex","isActive":true,"type":"reference"},{"type":"text","text":" "},{"text":"leads to undefined behaviour.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To undo the effect of "},{"type":"codeVoice","code":"g_rec_mutex_init()"},{"text":" when a recursive mutex","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is no longer needed, use "},{"code":"g_rec_mutex_clear()","type":"codeVoice"},{"type":"text","text":"."}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/recmutex\/init_()"]}],"references":{"doc://GLib/documentation/GLib/RecMutex/RecMutexProtocol-Implementations":{"type":"topic","role":"collectionGroup","identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex\/RecMutexProtocol-Implementations","title":"RecMutexProtocol Implementations","url":"\/documentation\/glib\/recmutex\/recmutexprotocol-implementations","abstract":[],"kind":"article"},"doc://GLib/documentation/GLib/RecMutex/init_()":{"kind":"symbol","abstract":[{"text":"Initializes a ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex","isActive":true,"type":"reference"},{"text":" so that it can be used.","type":"text"}],"url":"\/documentation\/glib\/recmutex\/init_()","identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex\/init_()","title":"init_()","type":"topic","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"init_"},{"text":"()","kind":"text"}]},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/RecMutex":{"title":"RecMutex","type":"topic","abstract":[{"type":"text","text":"The GRecMutex struct is an opaque data structure to represent a"},{"text":" ","type":"text"},{"text":"recursive mutex. It is similar to a ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","type":"reference","isActive":true},{"type":"text","text":" with the difference"},{"type":"text","text":" "},{"text":"that it is possible to lock a GRecMutex multiple times in the same","type":"text"},{"text":" ","type":"text"},{"text":"thread without deadlock. When doing so, care has to be taken to","type":"text"},{"type":"text","text":" "},{"text":"unlock the recursive mutex as often as it has been locked.","type":"text"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"RecMutex","kind":"identifier"}],"navigatorTitle":[{"text":"RecMutex","kind":"identifier"}],"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex","url":"\/documentation\/glib\/recmutex","kind":"symbol"},"doc://GLib/documentation/GLib/Mutex":{"title":"Mutex","type":"topic","abstract":[{"text":"The ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex"},{"text":" struct is an opaque data structure to represent a mutex","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(mutual exclusion). It can be used to protect data against shared"},{"text":" ","type":"text"},{"text":"access.","type":"text"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Mutex"}],"navigatorTitle":[{"kind":"identifier","text":"Mutex"}],"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","url":"\/documentation\/glib\/mutex","kind":"symbol"}}}