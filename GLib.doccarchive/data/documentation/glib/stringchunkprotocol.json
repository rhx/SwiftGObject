{"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","abstract":[{"code":"GStringChunk","type":"codeVoice"},{"type":"text","text":" provides efficient storage of groups of strings"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/StringChunkProtocol"},"metadata":{"navigatorTitle":[{"text":"StringChunkProtocol","kind":"identifier"}],"roleHeading":"Protocol","externalID":"s:4GLib19StringChunkProtocolP","title":"StringChunkProtocol","symbolKind":"protocol","modules":[{"name":"GLib"}],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"StringChunkProtocol","kind":"identifier"}],"role":"symbol"},"topicSections":[{"anchor":"Instance-Methods","generated":true,"title":"Instance Methods","identifiers":["doc:\/\/GLib\/documentation\/GLib\/StringChunkProtocol\/clear()","doc:\/\/GLib\/documentation\/GLib\/StringChunkProtocol\/free()","doc:\/\/GLib\/documentation\/GLib\/StringChunkProtocol\/insert(string:)","doc:\/\/GLib\/documentation\/GLib\/StringChunkProtocol\/insertConst(string:)","doc:\/\/GLib\/documentation\/GLib\/StringChunkProtocol\/insertLen(string:len:)"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"StringChunkProtocol"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","identifier":"doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","text":"PointerWrapper","preciseIdentifier":"s:4GLib14PointerWrapperP"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","anchor":"overview","level":2,"text":"Overview"},{"inlineContent":[{"text":"String chunks are used to store groups of strings. Memory is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"allocated in blocks, and as strings are added to the "},{"type":"codeVoice","code":"GStringChunk"},{"type":"text","text":" "},{"text":"they are copied into the next free position in a block. When a block","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is full a new block is allocated."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"When storing a large number of strings, string chunks are more","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"efficient than using [func"},{"type":"codeVoice","code":"GLib.strdup"},{"text":"] since fewer calls to ","type":"text"},{"type":"codeVoice","code":"malloc()"},{"text":" ","type":"text"},{"type":"text","text":"are needed, and less memory is wasted in memory allocation overheads."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"By adding strings with [method"},{"type":"codeVoice","code":"GLib.StringChunk.insert_const"},{"text":"] it is also","type":"text"},{"type":"text","text":" "},{"type":"text","text":"possible to remove duplicates."}]},{"type":"paragraph","inlineContent":[{"text":"To create a new ","type":"text"},{"type":"codeVoice","code":"GStringChunk"},{"type":"text","text":" use [func"},{"code":"GLib.StringChunk.new","type":"codeVoice"},{"type":"text","text":"]."}]},{"inlineContent":[{"text":"To add strings to a ","type":"text"},{"code":"GStringChunk","type":"codeVoice"},{"type":"text","text":" use [method"},{"type":"codeVoice","code":"GLib.StringChunk.insert"},{"type":"text","text":"]."}],"type":"paragraph"},{"inlineContent":[{"text":"To add strings to a ","type":"text"},{"type":"codeVoice","code":"GStringChunk"},{"type":"text","text":", but without duplicating strings"},{"type":"text","text":" "},{"text":"which are already in the ","type":"text"},{"type":"codeVoice","code":"GStringChunk"},{"text":", use [method","type":"text"},{"type":"codeVoice","code":"GLib.StringChunk.insert_const"},{"text":"].","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"To free the entire ","type":"text"},{"code":"GStringChunk","type":"codeVoice"},{"type":"text","text":" use [method"},{"type":"codeVoice","code":"GLib.StringChunk.free"},{"type":"text","text":"]."},{"text":" ","type":"text"},{"type":"text","text":"It is not possible to free individual strings."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/StringChunkProtocol","type":"reference"},{"type":"text","text":" protocol exposes the methods and properties of an underlying "},{"code":"GStringChunk","type":"codeVoice"},{"text":" instance.","type":"text"},{"text":" ","type":"text"},{"text":"The default implementation of these can be found in the protocol extension below.","type":"text"},{"type":"text","text":" "},{"text":"For a concrete class that implements these methods and properties, see ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StringChunk","isActive":true,"type":"reference"},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"Alternatively, use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/StringChunkRef","type":"reference"},{"type":"text","text":" as a lighweight, "},{"code":"unowned","type":"codeVoice"},{"text":" reference if you already have an instance you just want to use.","type":"text"}],"type":"paragraph"}]}],"relationshipsSections":[{"title":"Inherits From","kind":"relationships","type":"inheritsFrom","identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper"]},{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/StringChunk","doc:\/\/GLib\/documentation\/GLib\/StringChunkRef"],"title":"Conforming Types","type":"conformingTypes","kind":"relationships"}],"variants":[{"paths":["\/documentation\/glib\/stringchunkprotocol"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"references":{"doc://GLib/documentation/GLib/StringChunkProtocol/insertLen(string:len:)":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StringChunkProtocol\/insertLen(string:len:)","kind":"symbol","type":"topic","r