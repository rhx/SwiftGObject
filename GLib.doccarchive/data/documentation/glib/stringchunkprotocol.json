{"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/StringChunkProtocol","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"relationshipsSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper"],"kind":"relationships","title":"Inherits From","type":"inheritsFrom"},{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/StringChunk","doc:\/\/GLib\/documentation\/GLib\/StringChunkRef"],"type":"conformingTypes","title":"Conforming Types","kind":"relationships"}],"topicSections":[{"title":"Instance Methods","identifiers":["doc:\/\/GLib\/documentation\/GLib\/StringChunkProtocol\/clear()","doc:\/\/GLib\/documentation\/GLib\/StringChunkProtocol\/free()","doc:\/\/GLib\/documentation\/GLib\/StringChunkProtocol\/insert(string:)","doc:\/\/GLib\/documentation\/GLib\/StringChunkProtocol\/insertConst(string:)","doc:\/\/GLib\/documentation\/GLib\/StringChunkProtocol\/insertLen(string:len:)"],"anchor":"Instance-Methods","generated":true}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"StringChunkProtocol"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib14PointerWrapperP","text":"PointerWrapper","identifier":"doc:\/\/GLib\/documentation\/GLib\/PointerWrapper"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"overview","text":"Overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"String chunks are used to store groups of strings. Memory is"},{"type":"text","text":" "},{"text":"allocated in blocks, and as strings are added to the ","type":"text"},{"code":"GStringChunk","type":"codeVoice"},{"text":" ","type":"text"},{"text":"they are copied into the next free position in a block. When a block","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is full a new block is allocated."}]},{"inlineContent":[{"type":"text","text":"When storing a large number of strings, string chunks are more"},{"type":"text","text":" "},{"type":"text","text":"efficient than using [func"},{"code":"GLib.strdup","type":"codeVoice"},{"text":"] since fewer calls to ","type":"text"},{"type":"codeVoice","code":"malloc()"},{"type":"text","text":" "},{"type":"text","text":"are needed, and less memory is wasted in memory allocation overheads."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"By adding strings with [method"},{"code":"GLib.StringChunk.insert_const","type":"codeVoice"},{"text":"] it is also","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"possible to remove duplicates."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To create a new "},{"code":"GStringChunk","type":"codeVoice"},{"text":" use [func","type":"text"},{"code":"GLib.StringChunk.new","type":"codeVoice"},{"type":"text","text":"]."}]},{"type":"paragraph","inlineContent":[{"text":"To add strings to a ","type":"text"},{"type":"codeVoice","code":"GStringChunk"},{"type":"text","text":" use [method"},{"type":"codeVoice","code":"GLib.StringChunk.insert"},{"text":"].","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"To add strings to a ","type":"text"},{"code":"GStringChunk","type":"codeVoice"},{"text":", but without duplicating strings","type":"text"},{"type":"text","text":" "},{"type":"text","text":"which are already in the "},{"code":"GStringChunk","type":"codeVoice"},{"type":"text","text":", use [method"},{"code":"GLib.StringChunk.insert_const","type":"codeVoice"},{"text":"].","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To free the entire "},{"type":"codeVoice","code":"GStringChunk"},{"type":"text","text":" use [method"},{"code":"GLib.StringChunk.free","type":"codeVoice"},{"text":"].","type":"text"},{"text":" ","type":"text"},{"text":"It is not possible to free individual strings.","type":"text"}]},{"inlineContent":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StringChunkProtocol","isActive":true},{"type":"text","text":" protocol exposes the methods and properties of an underlying "},{"code":"GStringChunk","type":"codeVoice"},{"text":" instance.","type":"text"},{"text":" ","type":"text"},{"text":"The default implementation of these can be found in the protocol extension below.","type":"text"},{"type":"text","text":" "},{"text":"For a concrete class that implements these methods and properties, see ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StringChunk","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"Alternatively, use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/StringChunkRef","type":"reference"},{"type":"text","text":" as a lighweight, "},{"code":"unowned","type":"codeVoice"},{"type":"text","text":" reference if you already have an instance you just want to use."}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/stringchunkprotocol"]}],"kind":"symbol","abstract":[{"code":"GStringChunk","type":"codeVoice"},{"text":" provides efficient storage of groups of strings","type":"text"}],"metadata":{"symbolKind":"protocol","modules":[{"name":"GLib"}],"role":"symbol","roleHeading":"Protocol","navigatorTitle":[{"text":"StringChunkProtocol","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"StringChunkProtocol"}],"title":"StringChunkProtocol","externalID":"s:4GLib19StringChunkProtocolP"},"references":{"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLi