{"abstract":[{"type":"text","text":"Sets a function to clear an element of "},{"code":"array","type":"codeVoice"},{"type":"text","text":"."}],"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"set"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"clearFunc"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GDestroyNotify","text":"GDestroyNotify"},{"kind":"text","text":"? = nil)"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"clearFunc"},{"type":"text","text":" will be called when an element in the array"},{"text":" ","type":"text"},{"type":"text","text":"data segment is removed and when the array is freed and data"},{"type":"text","text":" "},{"type":"text","text":"segment is deallocated as well. "},{"type":"codeVoice","code":"clearFunc"},{"text":" will be passed a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"pointer to the element to clear, rather than the element itself."}],"type":"paragraph"},{"inlineContent":[{"text":"Note that in contrast with other uses of [callback","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/DestroyNotify","type":"reference","isActive":true},{"type":"text","text":"]"},{"text":" ","type":"text"},{"type":"text","text":"functions, "},{"code":"clearFunc","type":"codeVoice"},{"type":"text","text":" is expected to clear the contents of"},{"type":"text","text":" "},{"text":"the array element it is given, but not free the element itself.","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["typedef struct","{","  gchar *str;","  GObject *obj;","} ArrayElement;","","static void","array_element_clear (ArrayElement *element)","{","  g_clear_pointer (&element->str, g_free);","  g_clear_object (&element->obj);","}","","\/\/ main code","GArray *garray = g_array_new (FALSE, FALSE, sizeof (ArrayElement));","g_array_set_clear_func (garray, (GDestroyNotify) array_element_clear);","\/\/ assign data to the structure","g_array_free (garray, TRUE);"],"syntax":"c"}]}],"sections":[],"variants":[{"paths":["\/documentation\/glib\/arraytype\/set(clearfunc:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/ArrayType","doc:\/\/GLib\/documentation\/GLib\/ArrayType\/ArrayProtocol-Implementations"]]},"kind":"symbol","metadata":{"extendedModule":"GLib","externalID":"s:4GLib13ArrayProtocolPAAE3set9clearFuncyySvSgXCSg_tF::SYNTHESIZED::s:4GLib9ArrayTypeC","title":"set(clearFunc:)","roleHeading":"Instance Method","role":"symbol","modules":[{"name":"GLib"}],"symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"set","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"clearFunc"},{"kind":"text","text":": "},{"text":"GDestroyNotify","kind":"typeIdentifier","preciseIdentifier":"c:@T@GDestroyNotify"},{"text":"?)","kind":"text"}]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/ArrayType\/set(clearFunc:)"},"references":{"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/ArrayType/ArrayProtocol-Implementations":{"url":"\/documentation\/glib\/arraytype\/arrayprotocol-implementations","kind":"article","title":"ArrayProtocol Implementations","type":"topic","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib\/ArrayType\/ArrayProtocol-Implementations","role":"collectionGroup"},"doc://GLib/documentation/GLib/ArrayType":{"title":"ArrayType","identifier":"doc:\/\/GLib\/documentation\/GLib\/ArrayType","navigatorTitle":[{"text":"ArrayType","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/glib\/arraytype","abstract":[{"type":"text","text":"Contains the public fields of a "},{"type":"codeVoice","code":"GArray"},{"text":".","type":"text"}],"type":"topic","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ArrayType","kind":"identifier"}]},"doc://GLib/documentation/GLib/ArrayType/set(clearFunc:)":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/ArrayType\/set(clearFunc:)","url":"\/documentation\/glib\/arraytype\/set(clearfunc:)","title":"set(clearFunc:)","type":"topic","abstract":[{"text":"Sets a function to clear an element of ","type":"text"},{"type":"codeVoice","code":"array"},{"type":"text","text":"."}],"role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"set"},{"text":"(","kind":"text"},{"text":"clearFunc","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@GDestroyNotify","text":"GDestroyNotify","kind":"typeIdentifier"},{"text":"?)","kind":"text"}],"kind":"symbol"},"doc://GLib/documentation/GLib/DestroyNotify":{"title":"DestroyNotify","identifier":"doc:\/\/GLib\/documentation\/GLib\/DestroyNotify","kind":"symbol","type":"topic","url":"\/documentation\/glib\/destroynotify","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"DestroyNotify"}],"fragments":[{"kind":"keyword","text":"typealias"},{"text":" ","kind":"text"},{"kind":"identifier","text":"DestroyNotify"}],"abstract":[{"type":"text","text":"Specifies the type of function which is called when a data element"},{"type":"text","text":" "},{"type":"text","text":"is destroyed. It is passed the pointer to the data element and"},{"type":"text","text":" "},{"type":"text","text":"should free any memory and resources allocated for it."}]}}}