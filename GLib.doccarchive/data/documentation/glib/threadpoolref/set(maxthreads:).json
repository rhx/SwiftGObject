{"abstract":[{"type":"text","text":"Sets the maximal allowed number of threads for "},{"type":"codeVoice","code":"pool"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"A value of -1 means that the maximal number of threads"},{"text":" ","type":"text"},{"type":"text","text":"is unlimited. If "},{"code":"pool","type":"codeVoice"},{"text":" is an exclusive thread pool, setting","type":"text"},{"type":"text","text":" "},{"text":"the maximal number of threads to -1 is not allowed.","type":"text"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"set","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"maxThreads"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":") ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"inlineContent":[{"type":"text","text":"Setting "},{"code":"maxThreads","type":"codeVoice"},{"text":" to 0 means stopping all work for ","type":"text"},{"code":"pool","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"It is effectively frozen until "},{"type":"codeVoice","code":"maxThreads"},{"type":"text","text":" is set to a non-zero"},{"text":" ","type":"text"},{"type":"text","text":"value again."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A thread is never terminated while calling "},{"code":"func","type":"codeVoice"},{"type":"text","text":", as supplied by"},{"text":" ","type":"text"},{"code":"g_thread_pool_new()","type":"codeVoice"},{"text":". Instead the maximal number of threads only","type":"te