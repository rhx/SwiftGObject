ext":"let","kind":"keyword"},{"kind":"text","text":" "},{"text":"newlineCrlf","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib17RegexCompileFlagsV","text":"RegexCompileFlags"}],"abstract":[{"text":"Usually any newline character or character sequence is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"recognized. If this option is set, the only recognized newline character"},{"type":"text","text":" "},{"type":"text","text":"sequence is ‘\\r\\n’."}],"role":"symbol"},"doc://GLib/documentation/GLib/RegexCompileFlags/init(_:)-iemw":{"role":"symbol","abstract":[{"type":"text","text":"Creates a new instance with the specified "},{"type":"codeVoice","code":"GRegexCompileFlags"},{"type":"text","text":" enum value"}],"kind":"symbol","fragments":[{"kind":"identifier","text":"init"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:@EA@GRegexCompileFlags","text":"GRegexCompileFlags","kind":"typeIdentifier"},{"kind":"text","text":")"}],"url":"\/documentation\/glib\/regexcompileflags\/init(_:)-iemw","title":"init(_:)","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags\/init(_:)-iemw"},"doc://GLib/documentation/GLib/RegexCompileFlags/ungreedy":{"type":"topic","url":"\/documentation\/glib\/regexcompileflags\/ungreedy","abstract":[{"text":"Inverts the “greediness” of the quantifiers so that","type":"text"},{"text":" ","type":"text"},{"text":"they are not greedy by default, but become greedy if followed by “?”.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It can also be set by a “(?U)” option setting within the pattern."}],"fragments":[{"text":"static","kind":"keyword"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ungreedy"},{"kind":"text","text":": "},{"text":"RegexCompileFlags","kind":"typeIdentifier","preciseIdentifier":"s:4GLib17RegexCompileFlagsV"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags\/ungreedy","role":"symbol","kind":"symbol","title":"ungreedy"},"doc://GLib/documentation/GLib/RegexCompileFlags/raw":{"title":"raw","fragments":[{"text":"static","kind":"keyword"},{"kind":"text","text":" "},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"raw","kind":"identifier"},{"kind":"text","text":": "},{"text":"RegexCompileFlags","kind":"typeIdentifier","preciseIdentifier":"s:4GLib17RegexCompileFlagsV"}],"kind":"symbol","url":"\/documentation\/glib\/regexcompileflags\/raw","abstract":[{"type":"text","text":"Usually strings must be valid UTF-8 strings, using this"},{"text":" ","type":"text"},{"type":"text","text":"flag they are considered as a raw sequence of bytes."}],"type":"topic","role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags\/raw"},"doc://GLib/documentation/GLib/RegexCompileFlags/anchored":{"type":"topic","kind":"symbol","url":"\/documentation\/glib\/regexcompileflags\/anchored","abstract":[{"type":"text","text":"The pattern is forced to be “anchored”, that is,"},{"type":"text","text":" "},{"type":"text","text":"it is constrained to match only at the first matching point in the"},{"text":" ","type":"text"},{"type":"text","text":"string that is being searched. This effect can also be achieved by"},{"text":" ","type":"text"},{"text":"appropriate constructs in the pattern itself such as the “^”","type":"text"},{"type":"text","text":" "},{"type":"text","text":"metacharacter."}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags\/anchored","role":"symbol","title":"anchored","fragments":[{"text":"static","kind":"keyword"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"text":"anchored","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"RegexCompileFlags","preciseIdentifier":"s:4GLib17RegexCompileFlagsV"}]},"doc://GLib/documentation/GLib/RegexCompileFlags/multiline":{"title":"multiline","fragment