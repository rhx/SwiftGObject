":"be unique. This can be helpful for certain types of pattern when it","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is known that only one instance of the named subpattern can ever be"},{"type":"text","text":" "},{"text":"matched.","type":"text"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags\/dupnames"},"doc://GLib/documentation/GLib/RegexCompileFlags/caseless":{"abstract":[{"text":"Letters in the pattern match both upper- and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"lowercase letters. This option can be changed within a pattern"},{"type":"text","text":" "},{"type":"text","text":"by a “(?i)” option setting."}],"url":"\/documentation\/glib\/regexcompileflags\/caseless","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"caseless"},{"kind":"text","text":": "},{"text":"RegexCompileFlags","kind":"typeIdentifier","preciseIdentifier":"s:4GLib17RegexCompileFlagsV"}],"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags\/caseless","title":"caseless","kind":"symbol","type":"topic"},"doc://GLib/SQ":{"title":"Swift.Equatable","identifier":"doc:\/\/GLib\/SQ","type":"unresolvable"},"doc://GLib/documentation/GLib/RegexCompileFlags/init(rawValue:)":{"role":"symbol","type":"topic","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags\/init(rawValue:)","title":"init(rawValue:)","url":"\/documentation\/glib\/regexcompileflags\/init(rawvalue:)","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"rawValue"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:s6UInt32V","text":"UInt32","kind":"typeIdentifier"},{"text":")","kind":"text"}],"abstract":[{"text":"Creates a new instance with the specified raw value","type":"text"}]},"doc://GLib/documentation/GLib/RegexCompileFlags/optimize":{"fragments":[{"kind":"keyword","text":"static"},{"text":" ","kind":"text"},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"optimize","kind":"identifier"},{"kind":"text","text":": "},{"preciseIdentifier":"s:4GLib17RegexCompileFlagsV","text":"RegexCompileFlags","kind":"typeIdentifier"}],"url":"\/documentation\/glib\/regexcompileflags\/optimize","type":"topic","abstract":[{"text":"Since 2.74 and the port to pcre2, requests JIT","type":"text"},{"type":"text","text":" "},{"text":"compilation, which, if the just-in-time compiler is available, further","type":"text"},{"type":"text","text":" "},{"type":"text","text":"processes a compiled pattern into machine code that executes much"},{"text":" ","type":"text"},{"type":"text","text":"faster. However, it comes at the cost of extra processing before the"},{"text":" ","type":"text"},{"text":"match is performed, so it is most beneficial to use this when the same","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"compiled pattern is used for matching many times. Before 2.74 this"},{"type":"text","text":" "},{"type":"text","text":"option used the built-in non-JIT optimizations in pcre1."}],"kind":"symbol","title":"optimize","role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags\/optimize"}}}