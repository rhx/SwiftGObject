er":"s:4GLib17RegexCompileFlagsV","text":"RegexCompileFlags"}],"url":"\/documentation\/glib\/regexcompileflags\/newlinelf"},"doc://GLib/documentation/GLib/RegexCompileFlags/default":{"abstract":[{"text":"No special options set. Since: 2.74","type":"text"}],"title":"default","role":"symbol","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags\/default","fragments":[{"text":"static","kind":"keyword"},{"kind":"text","text":" "},{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"text":"`default`","kind":"identifier"},{"text":": ","kind":"text"},{"text":"RegexCompileFlags","preciseIdentifier":"s:4GLib17RegexCompileFlagsV","kind":"typeIdentifier"}],"url":"\/documentation\/glib\/regexcompileflags\/default","kind":"symbol"},"doc://GLib/documentation/GLib/RegexCompileFlags/dollarEndonly":{"abstract":[{"type":"text","text":"A dollar metacharacter (”$”) in the pattern"},{"text":" ","type":"text"},{"type":"text","text":"matches only at the end of the string. Without this option, a"},{"type":"text","text":" "},{"text":"dollar also matches immediately before the final character if","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"it is a newline (but not before any other newlines). This option"},{"type":"text","text":" "},{"type":"text","text":"is ignored if "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags\/multiline","isActive":true},{"type":"text","text":" is set."}],"title":"dollarEndonly","role":"symbol","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags\/dollarEndonly","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"dollarEndonly"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib17RegexCompileFlagsV","text":"RegexCompileFlags"}],"url":"\/documentation\/glib\/regexcompileflags\/dollarendonly","kind":"symbol"},"doc://GLib/documentation/GLib/RegexCompileFlags/firstline":{"title":"firstline","kind":"symbol","fragments":[{"text":"static","kind":"keyword"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"text":" ","kind":"text"},{"text":"firstline","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib17RegexCompileFlagsV","text":"RegexCompileFlags"}],"abstract":[{"text":"Limits an unanchored pattern to match before (or at) the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"first newline. Since: 2.34"}],"type":"topic","role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags\/firstline","url":"\/documentation\/glib\/regexcompileflags\/firstline"},"doc://GLib/s9OptionSetP":{"title":"Swift.OptionSet","type":"unresolvable","identifier":"doc:\/\/GLib\/s9OptionSetP"},"doc://GLib/documentation/GLib/RegexCompileFlags/extended":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags\/extended","kind":"symbol","type":"topic","title":"extended","abstract":[{"type":"text","text":"Whitespace data characters in the pattern are"},{"type":"text","text":" "},{"text":"totally ignored except when escaped or inside a character class.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Whitespace does not include the VT character (code 11). In addition,"},{"text":" ","type":"text"},{"text":"characters between an unescaped “#” outside a character class and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the next newline character, inclusive, are also ignored. This can"},{"text":" ","type":"text"},{"type":"text","text":"be changed within a pattern by a “(?x)” option setting."}],"role":"symbol","fragments":[{"kind":"keyword","text":"static"},{"text":" ","kind":"text"},{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"extended"},{"text":": ","kind":"text"},{"text":"RegexCompileFlags","preciseIdentifier":"s:4GLib1