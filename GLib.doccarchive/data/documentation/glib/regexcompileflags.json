ned to match only at the first matching point in the"},{"text":" ","type":"text"},{"type":"text","text":"string that is being searched. This effect can also be achieved by"},{"type":"text","text":" "},{"text":"appropriate constructs in the pattern itself such as the “^”","type":"text"},{"text":" ","type":"text"},{"text":"metacharacter.","type":"text"}],"fragments":[{"text":"static","kind":"keyword"},{"kind":"text","text":" "},{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"anchored"},{"kind":"text","text":": "},{"preciseIdentifier":"s:4GLib17RegexCompileFlagsV","text":"RegexCompileFlags","kind":"typeIdentifier"}]},"doc://GLib/documentation/GLib/RegexCompileFlags/newlineReserved1":{"role":"symbol","kind":"symbol","url":"\/documentation\/glib\/regexcompileflags\/newlinereserved1","fragments":[{"text":"static","kind":"keyword"},{"kind":"text","text":" "},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"newlineReserved1","kind":"identifier"},{"text":": ","kind":"text"},{"text":"RegexCompileFlags","preciseIdentifier":"s:4GLib17RegexCompileFlagsV","kind":"typeIdentifier"}],"title":"newlineReserved1","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags\/newlineReserved1","abstract":[],"type":"topic"},"doc://GLib/documentation/GLib/RegexCompileFlags/multiline":{"title":"multiline","kind":"symbol","role":"symbol","type":"topic","fragments":[{"text":"static","kind":"keyword"},{"kind":"text","text":" "},{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"text":"multiline","kind":"identifier"},{"kind":"text","text":": "},{"preciseIdentifier":"s:4GLib17RegexCompileFlagsV","text":"RegexCompileFlags","kind":"typeIdentifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags\/multiline","abstract":[{"type":"text","text":"By default, GRegex treats the strings as consisting"},{"text":" ","type":"text"},{"text":"of a single line of characters (even if it actually contains","type":"text"},{"text":" ","type":"text"},{"text":"newlines). The “start of line” metacharacter (”^”) matches only","type":"text"},{"type":"text","text":" "},{"type":"text","text":"at the start of the string, while the “end of line” metacharacter"},{"text":" ","type":"text"},{"type":"text","text":"(”$”) matches only at the end of the string, or before a terminating"},{"text":" ","type":"text"},{"type":"text","text":"newline (unless "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags\/dollarEndonly","type":"reference","isActive":true},{"text":" is set). When","type":"text"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags\/multiline","isActive":true},{"type":"text","text":" is set, the “start of line” and “end of line”"},{"type":"text","text":" "},{"type":"text","text":"constructs match immediately following or immediately before any"},{"text":" ","type":"text"},{"text":"newline in the string, respectively, as well as at the very start","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and end. This can be changed within a pattern by a “(?m)” option"},{"text":" ","type":"text"},{"type":"text","text":"setting."}],"url":"\/documentation\/glib\/regexcompileflags\/multiline"},"doc://GLib/documentation/GLib/RegexCompileFlags/dotall":{"title":"dotall","role":"symbol","abstract":[{"text":"A dot metacharacter (”.”) in the pattern matches all","type":"text"},{"type":"text","text":" "},{"type":"text","text":"characters, including newlines. Without it, newlines are excluded."},{"type":"text","text":" "},{"type":"text","text":"This option can be changed within a pattern by a (”?s”) option setting."}],"type":"topic","kind":"symbol","url":"\/documentation\/glib\/regexcompileflags\/dotall","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags\/dotall","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{