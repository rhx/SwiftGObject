{"metadata":{"title":"init(identifier:)","externalID":"s:4GLib8TimeZoneC10identifierACSPys4Int8VGSg_tcfc","modules":[{"name":"GLib"}],"symbolKind":"init","role":"symbol","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"text":"identifier","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"kind":"text","text":">?)"}],"roleHeading":"Initializer"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"init","kind":"keyword"},{"kind":"text","text":"("},{"text":"identifier","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">? = nil)","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"inlineContent":[{"type":"codeVoice","code":"identifier"},{"type":"text","text":" can either be an RFC3339\/ISO 8601 time offset or"},{"type":"text","text":" "},{"type":"text","text":"something that would pass as a valid value for the "},{"type":"codeVoice","code":"TZ"},{"text":" environment","type":"text"},{"type":"text","text":" "},{"text":"variable (including ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":").","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In Windows, "},{"type":"codeVoice","code":"identifier"},{"text":" can also be the unlocalized name of a time","type":"text"},{"type":"text","text":" "},{"text":"zone for standard time, for example “Pacific Standard Time”.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Valid RFC3339 time offsets are ","type":"text"},{"type":"codeVoice","code":"\"Z\""},{"text":" (for UTC) or","type":"text"},{"text":" ","type":"text"},{"code":"\"±hh:mm\"","type":"codeVoice"},{"text":".  ISO 8601 additionally specifies","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"\"±hhmm\""},{"text":" and ","type":"text"},{"code":"\"±hh\"","type":"codeVoice"},{"type":"text","text":".  Offsets are"},{"text":" ","type":"text"},{"type":"text","text":"time values to be added to Coordinated Universal Time (UTC) to get"},{"text":" ","type":"text"},{"type":"text","text":"the local time."}]},{"inlineContent":[{"text":"In UNIX, the ","type":"text"},{"type":"codeVoice","code":"TZ"},{"text":" environment variable typically corresponds","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to the name of a file in the zoneinfo database, an absolute path to a file"},{"text":" ","type":"text"},{"text":"somewhere else, or a string in","type":"text"},{"type":"text","text":" "},{"type":"text","text":"“std offset [dst [offset],start[\/time],end[\/time]]” (POSIX) format."},{"type":"text","text":" "},{"type":"text","text":"There  are  no spaces in the specification. The name of standard"},{"type":"text","text":" "},{"text":"and daylight savings time zone must be three or more alphabetic","type":"text"},{"type":"text","text":" "},{"type":"text","text":"characters. Offsets are time values to be added to local time to"},{"type":"text","text":" "},{"text":"get Coordinated Universal Time (UTC) and should be","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"\"[±]hh[[:]mm[:ss]]\""},{"text":".  Dates are either","type":"text"},{"text":" ","type":"text"},{"code":"\"Jn\"","type":"codeVoice"},{"text":" (Julian day with n between 1 and 365, leap","type":"text"},{"type":"text","text":" "},{"text":"years not counted), ","type":"text"},{"code":"\"n\"","type":"codeVoice"},{"type":"text","text":" (zero-based Julian day"},{"type":"text","text":" "},{"type":"text","text":"with n between 0 and 365) or "},{"type":"codeVoice","code":"\"Mm.w.d\""},{"text":" (day d","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(0 <= d <= 6) of week w (1 <= w <= 5) of month m (1 <= m <= 12), day"},{"text":" ","type":"text"},{"text":"0 is a Sunday).  Times are in local wall clock time, the default is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"02:00:00."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"In Windows, the “tzn[+|–]hh","type":"text"},{"type":"reference","identifier":"#dzn","isActive":true},{"type":"text","text":"” format is used, but also"},{"text":" ","type":"text"},{"text":"accepts POSIX format.  The Windows format uses US rules for all time","type":"text"},{"type":"text","text":" "},{"type":"text","text":"zones; daylight savings time is 60 minutes behind the standard time"},{"text":" ","type":"text"},{"text":"with date and time of change taken from Pacific Standard Time.","type":"text"},{"type":"text","text":" "},{"text":"Offsets are time values to be added to the local time to get","type":"text"},{"text":" ","type":"text"},{"text":"Coordinated Universal Time (UTC).","type":"text"}]},{"type":"paragraph","inlineContent":[{"code":"g_time_zone_new_local()","type":"codeVoice"},{"type":"text","text":" calls this function with the value of the"},{"type":"text","text":" "},{"code":"TZ","type":"codeVoice"},{"type":"text","text":" environment variable. This function itself is independent of"},{"type":"text","text":" "},{"text":"the value of ","type":"text"},{"type":"codeVoice","code":"TZ"},{"text":", but if ","type":"text"},{"type":"codeVoice","code":"identifier"},{"type":"text","text":" is "},{"type":"codeVoice","code":"nil"},{"text":" then ","type":"text"},{"type":"codeVoice","code":"\/etc\/localtime"},{"text":" ","type":"text"},{"type":"text","text":"will be consulted to discover the correct time zone on UNIX and the"},{"type":"text","text":" "},{"type":"text","text":"registry will be consulted or "},{"code":"GetTimeZoneInformation()","type":"codeVoice"},{"type":"text","text":" will be used"},{"type":"text","text":" "},{"type":"text","text":"to get the local time zone on Windows."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If intervals are not available, only time zone rules from "},{"code":"TZ","type":"codeVoice"},{"text":" ","type":"text"},{"text":"environment variable or other means, then they will be computed","type":"text"},{"type":"text","text":" "},{"type":"text","text":"from year 1900 to 2037.  If the maximum year for the rules is"},{"type":"text","text":" "},{"type":"text","text":"available and it is greater than 2037, then it will followed"},{"text":" ","type":"text"},{"text":"instead.","type":"text"}]},{"inlineContent":[{"type":"text","text":"See"},{"type":"text","text":" "},{"identifier":"http:\/\/tools.ietf.org\/html\/rfc3339#section-5.6","type":"reference","isActive":true},{"text":" ","type":"text"},{"type":"text","text":"for a precise definition of valid RFC3339 time offsets"},{"text":" ","type":"text"},{"text":"(the ","type":"text"},{"code":"time-offset","type":"codeVoice"},{"type":"text","text":" expansion) and ISO 8601 for the"},{"text":" ","type":"text"},{"text":"full list of valid time offsets.  See","type":"text"},{"text":" ","type":"text"},{"identifier":"http:\/\/www.gnu.org\/s\/libc\/manual\/html_node\/TZ-Variable.html","type":"reference","isActive":true},{"text":" ","type":"text"},{"type":"text","text":"for an explanation of the possible"},{"text":" ","type":"text"},{"type":"text","text":"values of the "},{"type":"codeVoice","code":"TZ"},{"text":" environment variable. See","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"http:\/\/msdn.microsoft.com\/en-us\/library\/ms912391%28v=winembedded.11%29.aspx"},{"text":" ","type":"text"},{"text":"for the list of time zones on Windows.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You should release the return value by calling "},{"type":"codeVoice","code":"g_time_zone_unref()"},{"type":"text","text":" "},{"type":"text","text":"when you are done with it."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/TimeZone"]]},"variants":[{"paths":["\/documentation\/glib\/timezone\/init(identifier:)"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/TimeZone\/init(identifier:)","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Creates a "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone","isActive":true},{"text":" corresponding to ","type":"text"},{"code":"identifier","type":"codeVoice"},{"text":". If ","type":"text"},{"type":"codeVoice","code":"identifier"},{"type":"text","text":" cannot be"},{"text":" ","type":"text"},{"text":"parsed or loaded, ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" is returned."}],"sections":[],"kind":"symbol","references":{"http://msdn.microsoft.com/en-us/library/ms912391%28v=winembedded.11%29.aspx":{"identifier":"http:\/\/msdn.microsoft.com\/en-us\/library\/ms912391%28v=winembedded.11%29.aspx","title":"Microsoft Time Zone Index Values","type":"link","url":"http:\/\/msdn.microsoft.com\/en-us\/library\/ms912391%28v=winembedded.11%29.aspx","titleInlineContent":[{"type":"text","text":"Microsoft Time Zone Index Values"}]},"#dzn":{"identifier":"#dzn","title":":mm[:ss]","type":"link","url":"#dzn","titleInlineContent":[{"type":"text","text":":mm[:ss]"}]},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"http://tools.ietf.org/html/rfc3339#section-5.6":{"identifier":"http:\/\/tools.ietf.org\/html\/rfc3339#section-5.6","title":"RFC3339 §5.6","type":"link","url":"http:\/\/tools.ietf.org\/html\/rfc3339#section-5.6","titleInlineContent":[{"type":"text","text":"RFC3339 §5.6"}]},"doc://GLib/documentation/GLib/TimeZone":{"url":"\/documentation\/glib\/timezone","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"TimeZone","kind":"identifier"}],"type":"topic","title":"TimeZone","navigatorTitle":[{"text":"TimeZone","kind":"identifier"}],"abstract":[{"type":"text","text":"A "},{"type":"codeVoice","code":"GTimeZone"},{"text":" represents a time zone, at no particular point in time.","type":"text"}]},"doc://GLib/documentation/GLib/TimeZone/init(identifier:)":{"url":"\/documentation\/glib\/timezone\/init(identifier:)","title":"init(identifier:)","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone\/init(identifier:)","role":"symbol","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"identifier","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"text":">?)","kind":"text"}],"kind":"symbol","abstract":[{"type":"text","text":"Creates a "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone","type":"reference"},{"type":"text","text":" corresponding to "},{"type":"codeVoice","code":"identifier"},{"type":"text","text":". If "},{"type":"codeVoice","code":"identifier"},{"type":"text","text":" cannot be"},{"type":"text","text":" "},{"text":"parsed or loaded, ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":" is returned."}]},"http://www.gnu.org/s/libc/manual/html_node/TZ-Variable.html":{"identifier":"http:\/\/www.gnu.org\/s\/libc\/manual\/html_node\/TZ-Variable.html","title":"The GNU C Library manual","type":"link","url":"http:\/\/www.gnu.org\/s\/libc\/manual\/html_node\/TZ-Variable.html","titleInlineContent":[{"type":"text","text":"The GNU C Library manual"}]}}}