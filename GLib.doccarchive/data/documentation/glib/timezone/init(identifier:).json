{"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"init","kind":"keyword"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"identifier"},{"kind":"text","text":": "},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">? = nil)","kind":"text"}],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"inlineContent":[{"code":"identifier","type":"codeVoice"},{"type":"text","text":" can either be an RFC3339\/ISO 8601 time offset or"},{"text":" ","type":"text"},{"type":"text","text":"something that would pass as a valid value for the "},{"code":"TZ","type":"codeVoice"},{"text":" environment","type":"text"},{"type":"text","text":" "},{"text":"variable (including ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":")."}],"type":"paragraph"},{"inlineContent":[{"text":"In Windows, ","type":"text"},{"type":"codeVoice","code":"identifier"},{"text":" can also be the unlocalized name of a time","type":"text"},{"type":"text","text":" "},{"type":"text","text":"zone for standard time, for example “Pacific Standard Time”."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Valid RFC3339 time offsets are ","type":"text"},{"code":"\"Z\"","type":"codeVoice"},{"text":" (for UTC) or","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"\"±hh:mm\""},{"type":"text","text":".  ISO 8601 additionally specifies"},{"text":" ","type":"text"},{"code":"\"±hhmm\"","type":"codeVoice"},{"type":"text","text":" and "},{"code":"\"±hh\"","type":"codeVoice"},{"text":".  Offsets are","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"time values to be added to Coordinated Universal Time (UTC) to get"},{"type":"text","text":" "},{"type":"text","text":"the local time."}]},{"type":"paragraph","inlineContent":[{"text":"In UNIX, the ","type":"text"},{"type":"codeVoice","code":"TZ"},{"text":" environment variable typically corresponds","type":"text"},{"text":" ","type":"text"},{"text":"to the name of a file in the zoneinfo database, an absolute path to a file","type":"text"},{"type":"text","text":" "},{"type":"text","text":"somewhere else, or a string in"},{"text":" ","type":"text"},{"text":"“std offset [dst [offset],start[\/time],end[\/time]]” (POSIX) format.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"There  are  no spaces in the specification. The name of standard"},{"text":" ","type":"text"},{"text":"and daylight savings time zone must be three or more alphabetic","type":"text"},{"type":"text","text":" "},{"text":"characters. Offsets are time values to be added to local time to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"get Coordinated Universal Time (UTC) and should be"},{"text":" ","type":"text"},{"type":"codeVoice","code":"\"[±]hh[[:]mm[:ss]]\""},{"text":".  Dates are either","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"\"Jn\""},{"type":"text","text":" (Julian day with n between 1 and 365, leap"},{"type":"text","text":" "},{"text":"years not counted), ","type":"text"},{"type":"codeVoice","code":"\"n\""},{"text":" (zero-based Julian day","type":"text"},{"text":" ","type":"text"},{"text":"with n between 0 and 365) or ","type":"text"},{"type":"codeVoice","code":"\"Mm.w.d\""},{"text":" (day d","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(0 <= d <= 6) of week w (1 <= w <= 5) of month m (1 <= m <= 12), day"},{"type":"text","text":" "},{"type":"text","text":"0 is a Sunday).  Times are in local wall clock time, the default is"},{"type":"text","text":" "},{"text":"02:00:00.","type":"text"}]},{"inlineContent":[{"type":"text","text":"In Windows, the “tzn[+|–]hh"},{"isActive":true,"type":"reference","identifier":"#dzn"},{"text":"” format is used, but also","type":"text"},{"type":"text","text":" "},{"type":"text","text":"accepts POSIX format.  The Windows format uses US rules for all time"},{"text":" ","type":"text"},{"type":"text","text":"zones; daylight savings time is 60 minutes behind the standard time"},{"text":" ","type":"text"},{"text":"with date and time of change taken from Pacific Standard Time.","type":"text"},{"text":" ","type":"text"},{"text":"Offsets are time values to be added to the local time to get","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Coordinated Universal Time (UTC)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"code":"g_time_zone_new_local()","type":"codeVoice"},{"text":" calls this function with the value of the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"TZ"},{"text":" environment variable. This function itself is independent of","type":"text"},{"text":" ","type":"text"},{"text":"the value of ","type":"text"},{"type":"codeVoice","code":"TZ"},{"type":"text","text":", but if "},{"type":"codeVoice","code":"identifier"},{"type":"text","text":" is "},{"type":"codeVoice","code":"nil"},{"text":" then ","type":"text"},{"code":"\/etc\/localtime","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"will be consulted to discover the correct time zone on UNIX and the"},{"type":"text","text":" "},{"type":"text","text":"registry will be consulted or "},{"code":"GetTimeZoneInformation()","type":"codeVoice"},{"text":" will be used","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to get the local time zone on Windows."}]},{"inlineContent":[{"type":"text","text":"If intervals are not available, only time zone rules from "},{"code":"TZ","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"environment variable or other means, then they will be computed"},{"text":" ","type":"text"},{"text":"from year 1900 to 2037.  If the maximum year for the rules is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"available and it is greater than 2037, then it will followed"},{"text":" ","type":"text"},{"type":"text","text":"instead."}],"type":"paragraph"},{"inlineContent":[{"text":"See","type":"text"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"http:\/\/tools.ietf.org\/html\/rfc3339#section-5.6"},{"type":"text","text":" "},{"type":"text","text":"for a precise definition of valid RFC3339 time offsets"},{"text":" ","type":"text"},{"text":"(the ","type":"text"},{"type":"codeVoice","code":"time-offset"},{"type":"text","text":" expansion) and ISO 8601 for the"},{"type":"text","text":" "},{"text":"full list of valid time offsets.  See","type":"text"},{"type":"text","text":" "},{"isActive":true,"identifier":"http:\/\/www.gnu.org\/s\/libc\/manual\/html_node\/TZ-Variable.html","type":"reference"},{"type":"text","text":" "},{"text":"for an explanation of the possible","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"values of the "},{"code":"TZ","type":"codeVoice"},{"text":" environment variable. See","type":"text"},{"type":"text","text":" "},{"type":"reference","identifier":"http:\/\/msdn.microsoft.com\/en-us\/library\/ms912391%28v=winembedded.11%29.aspx","isActive":true},{"type":"text","text":" "},{"text":"for the list of time zones on Windows.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"You should release the return value by calling ","type":"text"},{"code":"g_time_zone_unref()","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"when you are done with it."}],"type":"paragraph"}]}],"abstract":[{"type":"text","text":"Creates a "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone","isActive":true},{"type":"text","text":" corresponding to "},{"type":"codeVoice","code":"identifier"},{"text":". If ","type":"text"},{"type":"codeVoice","code":"identifier"},{"text":" cannot be","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"parsed or loaded, "},{"code":"nil","type":"codeVoice"},{"text":" is returned.","type":"text"}],"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/TimeZone"]]},"metadata":{"roleHeading":"Initializer","title":"init(identifier:)","externalID":"s:4GLib8TimeZoneC10identifierACSPys4Int8VGSg_tcfc","symbolKind":"init","modules":[{"name":"GLib"}],"role":"symbol","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"identifier"},{"kind":"text","text":": "},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">?)","kind":"text"}]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/TimeZone\/init(identifier:)"},"variants":[{"paths":["\/documentation\/glib\/timezone\/init(identifier:)"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"http://tools.ietf.org/html/rfc3339#section-5.6":{"url":"http:\/\/tools.ietf.org\/html\/rfc3339#section-5.6","type":"link","titleInlineContent":[{"text":"RFC3339 §5.6","type":"text"}],"identifier":"http:\/\/tools.ietf.org\/html\/rfc3339#section-5.6","title":"RFC3339 §5.6"},"doc://GLib/documentation/GLib/TimeZone":{"title":"TimeZone","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TimeZone"}],"abstract":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"GTimeZone"},{"text":" represents a time zone, at no particular point in time.","type":"text"}],"kind":"symbol","url":"\/documentation\/glib\/timezone","navigatorTitle":[{"kind":"identifier","text":"TimeZone"}],"type":"topic","role":"symbol"},"http://www.gnu.org/s/libc/manual/html_node/TZ-Variable.html":{"url":"http:\/\/www.gnu.org\/s\/libc\/manual\/htm