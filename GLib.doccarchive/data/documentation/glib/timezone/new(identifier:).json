{"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/TimeZone\/new(identifier:)","interfaceLanguage":"swift"},"metadata":{"roleHeading":"Type Method","externalID":"s:4GLib8TimeZoneC3new10identifierACSgSPys4Int8VGSg_tFZ","modules":[{"name":"GLib"}],"role":"symbol","symbolKind":"method","fragments":[{"text":"static","kind":"keyword"},{"kind":"text","text":" "},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"new"},{"kind":"text","text":"("},{"text":"identifier","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"text":">?) -> ","kind":"text"},{"text":"TimeZone","kind":"typeIdentifier","preciseIdentifier":"s:4GLib8TimeZoneC"},{"text":"!","kind":"text"}],"title":"new(identifier:)"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/TimeZone"]]},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"static"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"new"},{"kind":"text","text":"("},{"kind":"externalParam","text":"identifier"},{"kind":"text","text":": "},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">? = nil) -> "},{"text":"TimeZone","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone","kind":"typeIdentifier","preciseIdentifier":"s:4GLib8TimeZoneC"},{"text":"!","kind":"text"}]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"inlineContent":[{"type":"codeVoice","code":"identifier"},{"type":"text","text":" can either be an RFC3339\/ISO 8601 time offset or"},{"text":" ","type":"text"},{"text":"something that would pass as a valid value for the ","type":"text"},{"type":"codeVoice","code":"TZ"},{"text":" environment","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"variable (including "},{"type":"codeVoice","code":"nil"},{"type":"text","text":")."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"In Windows, ","type":"text"},{"code":"identifier","type":"codeVoice"},{"text":" can also be the unlocalized name of a time","type":"text"},{"type":"text","text":" "},{"type":"text","text":"zone for standard time, for example “Pacific Standard Time”."}]},{"type":"paragraph","inlineContent":[{"text":"Valid RFC3339 time offsets are ","type":"text"},{"type":"codeVoice","code":"\"Z\""},{"text":" (for UTC) or","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"\"±hh:mm\""},{"type":"text","text":".  ISO 8601 additionally specifies"},{"text":" ","type":"text"},{"code":"\"±hhmm\"","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"\"±hh\""},{"text":".  Offsets are","type":"text"},{"text":" ","type":"text"},{"text":"time values to be added to Coordinated Universal Time (UTC) to get","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the local time."}]},{"inlineContent":[{"type":"text","text":"In UNIX, the "},{"type":"codeVoice","code":"TZ"},{"type":"text","text":" environment variable typically corresponds"},{"text":" ","type":"text"},{"text":"to the name of a file in the zoneinfo database, an absolute path to a file","type":"text"},{"type":"text","text":" "},{"text":"somewhere else, or a string in","type":"text"},{"type":"text","text":" "},{"text":"“std offset [dst [offset],start[\/time],end[\/time]]” (POSIX) format.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"There  are  no spaces in the specification. The name of standard"},{"type":"text","text":" "},{"type":"text","text":"and daylight savings time zone must be three or more alphabetic"},{"type":"text","text":" "},{"type":"text","text":"characters. Offsets are time values to be added to local time to"},{"type":"text","text":" "},{"text":"get Coordinated Universal Time (UTC) and should be","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"\"[±]hh[[:]mm[:ss]]\""},{"text":".  Dates are either","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"\"Jn\""},{"text":" (Julian day with n between 1 and 365, leap","type":"text"},{"type":"text","text":" "},{"type":"text","text":"years not counted), "},{"type":"codeVoice","code":"\"n\""},{"text":" (zero-based Julian day","type":"text"},{"type":"text","text":" "},{"type":"text","text":"with n between 0 and 365) or "},{"code":"\"Mm.w.d\"","type":"codeVoice"},{"text":" (day d","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(0 <= d <= 6) of week w (1 <= w <= 5) of month m (1 <= m <= 12), day"},{"type":"text","text":" "},{"text":"0 is a Sunday).  Times are in local wall clock time, the default is","type":"text"},{"type":"text","text":" "},{"text":"02:00:00.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In Windows, the “tzn[+|–]hh"},{"identifier":"#dzn","type":"reference","isActive":true},{"text":"” format is used, but also","type":"text"},{"type":"text","text":" "},{"text":"accepts POSIX format.  The Windows format uses US rules for all time","type":"text"},{"type":"text","text":" "},{"type":"text","text":"zones; daylight savings time is 60 minutes behind the standard time"},{"type":"text","text":" "},{"type":"text","text":"with date and time of change taken from Pacific Standard Time."},{"type":"text","text":" "},{"type":"text","text":"Offsets are time values to be added to the local time to get"},{"type":"text","text":" "},{"type":"text","text":"Coordinated Universal Time (UTC)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"g_time_zone_new_local()"},{"type":"text","text":" calls this function with the value of the"},{"type":"text","text":" "},{"code":"TZ","type":"codeVoice"},{"text":" environment variable. This function itself is independent of","type":"text"},{"text":" ","type":"text"},{"text":"the value of ","type":"text"},{"type":"codeVoice","code":"TZ"},{"type":"text","text":", but if "},{"code":"identifier","type":"codeVoice"},{"text":" is ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" then ","type":"text"},{"type":"codeVoice","code":"\/etc\/localtime"},{"type":"text","text":" "},{"type":"text","text":"will be consulted to discover the correct time zone on UNIX and the"},{"text":" ","type":"text"},{"text":"registry will be consulted or ","type":"text"},{"type":"codeVoice","code":"GetTimeZoneInformation()"},{"type":"text","text":" will be used"},{"type":"text","text":" "},{"text":"to get the local time zone on Windows.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If intervals are not available, only time zone rules from "},{"code":"TZ","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"environment variable or other means, then they will be computed"},{"type":"text","text":" "},{"text":"from year 1900 to 2037.  If the maximum year for the rules is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"available and it is greater than 2037, then it will followed"},{"text":" ","type":"text"},{"type":"text","text":"instead."}]},{"inlineContent":[{"text":"See","type":"text"},{"type":"text","text":" "},{"identifier":"http:\/\/tools.ietf.org\/html\/rfc3339#section-5.6","type":"reference","isActive":true},{"text":" ","type":"text"},{"text":"for a precise definition of valid RFC3339 time offsets","type":"text"},{"type":"text","text":" "},{"text":"(the ","type":"text"},{"type":"codeVoice","code":"time-offset"},{"text":" expansion) and ISO 8601 for the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"full list of valid time offsets.  See"},{"type":"text","text":" "},{"identifier":"http:\/\/www.gnu.org\/s\/libc\/manual\/html_node\/TZ-Variable.html","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"for an explanation of the possible","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"values of the "},{"type":"codeVoice","code":"TZ"},{"type":"text","text":" environment variable. See"},{"type":"text","text":" "},{"identifier":"http:\/\/msdn.microsoft.com\/en-us\/library\/ms912391%28v=winembedded.11%29.aspx","type":"reference","isActive":true},{"type":"text","text":" "},{"text":"for the list of time zones on Windows.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"You should release the return value by calling ","type":"text"},{"type":"codeVoice","code":"g_time_zone_unref()"},{"type":"text","text":" "},{"text":"when you are done with it.","type":"text"}],"type":"paragraph"}]}],"variants":[{"paths":["\/documentation\/glib\/timezone\/new(identifier:)"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"abstract":[{"type":"text","text":"Creates a "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone","isActive":true,"type":"reference"},{"type":"text","text":" corresponding to "},{"type":"codeVoice","code":"identifier"},{"text":". If ","type":"text"},{"type":"codeVoice","code":"identifier"},{"type":"text","text":" cannot be"},{"type":"text","text":" "},{"type":"text","text":"parsed or loaded, "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" is returned."}],"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"#dzn":{"title":":mm[:ss]","identifier":"#dzn","titleInlineContent":[{"type":"text","text":":mm[:ss]"}],"url":"#dzn","type":"link"},"http://tools.ietf.org/html/rfc3339#section-5.6":{"title":"RFC3339 §5.6","identifier":"http:\/\/tools.ietf.org\/html\/rfc3339#section-5.6","titleInlineContent":[{"type":"text","text":"RFC3339 §5.6"}],"url":"http:\/\/tools.ietf.org\/html\/rfc3339#section-5.6","type":"link"},"http://www.gnu.org/s/libc/manual/html_node/TZ-Variable.html":{"title":"The GNU C Library manual","identifier":"http:\/\/www.gnu.org\/s\/libc\/manual\/html_node\/TZ-Variable.html","titleInlineContent":[{"type":"text","text":"The GNU C Library manual"}],"url":"http:\/\/www.gnu.org\/s\/libc\/manual\/html_node\/TZ-Variable.html","type":"link"},"doc://GLib/documentation/GLib/TimeZone/new(identifier:)":{"title":"new(identifier:)","url":"\/documentation\/glib\/timezone\/new(identifier:)","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone\/new(identifier:)","fragments":[{"kind":"keyword","text":"static"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"new","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">?) -> "},{"text":"TimeZone","kind":"typeIdentifier","preciseIdentifier":"s:4GLib8TimeZoneC"},{"text":"!","kind":"text"}],"role":"symbol","type":"topic","abstract":[{"type":"text","text":"Creates a "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone","type":"reference","isActive":true},{"text":" corresponding to ","type":"text"},{"type":"codeVoice","code":"identifier"},{"type":"text","text":". If "},{"type":"codeVoice","code":"identifier"},{"type":"text","text":" cannot be"},{"type":"text","text":" "},{"type":"text","text":"parsed or loaded, "},{"code":"nil","type":"codeVoice"},{"text":" is returned.","type":"text"}],"kind":"symbol"},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/TimeZone":{"title":"TimeZone","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TimeZone"}],"abstract":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"GTimeZone"},{"text":" represents a time zone, at no particular point in time.","type":"text"}],"kind":"symbol","url":"\/documentation\/glib\/timezone","navigatorTitle":[{"kind":"identifier","text":"TimeZone"}],"type":"topic","role":"symbol"},"http://msdn.microsoft.com/en-us/library/ms912391%28v=winembedded.11%29.aspx":{"title":"Microsoft Time Zone Index Values","identifier":"http:\/\/msdn.microsoft.com\/en-us\/library\/ms912391%28v=winembedded.11%29.aspx","titleInlineContent":[{"type":"text","text":"Microsoft Time Zone Index Values"}],"url":"http:\/\/msdn.microsoft.com\/en-us\/library\/ms912391%28v=winembedded.11%29.aspx","type":"link"}}}