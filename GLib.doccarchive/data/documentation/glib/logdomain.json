{"kind":"symbol","sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/logDomain"},"abstract":[{"type":"text","text":"Defines the log domain. See "},{"isActive":true,"identifier":"#log-domains","type":"reference"},{"text":".","type":"text"}],"variants":[{"paths":["\/documentation\/glib\/logdomain"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"text":"logDomain","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Libraries should define this so that any messages"},{"text":" ","type":"text"},{"type":"text","text":"which they log can be differentiated from messages from other"},{"type":"text","text":" "},{"type":"text","text":"libraries and application code. But be careful not to define"},{"type":"text","text":" "},{"text":"it in any public header files.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Log domains must be unique, and it is recommended that they are the","type":"text"},{"text":" ","type":"text"},{"text":"application or library name, optionally followed by a hyphen and a sub-domain","type":"text"},{"type":"text","text":" "},{"type":"text","text":"name. For example, "},{"code":"bloatpad","type":"codeVoice"},{"type":"text","text":" or "},{"code":"bloatpad-io","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If undefined, it defaults to the default "},{"type":"codeVoice","code":"nil"},{"text":" (or ","type":"text"},{"code":"\"\"","type":"codeVoice"},{"type":"text","text":") log domain; this is"},{"type":"text","text":" "},{"type":"text","text":"not advisable, as it cannot be filtered against using the "},{"type":"codeVoice","code":"G_MESSAGES_DEBUG"},{"type":"text","text":" "},{"type":"text","text":"environment variable."}]},{"type":"paragraph","inlineContent":[{"text":"For example, GTK uses this in its ","type":"text"},{"type":"codeVoice","code":"Makefile.am"},{"text":":","type":"text"}]},{"code":["AM_CPPFLAGS = -DG_LOG_DOMAIN=\\\"Gtk\\\""],"syntax":null,"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Applications can choose to leave it as the default "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" (or "},{"code":"\"\"","type":"codeVoice"},{"type":"text","text":")"},{"type":"text","text":" "},{"text":"domain. However, defining the domain offers the same advantages as","type":"text"},{"type":"text","text":" "},{"type":"text","text":"above."}]}]}],"metadata":{"modules":[{"name":"GLib"}],"externalID":"s:4GLib9logDomainSivp","title":"logDomain","fragments":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"text":"logDomain","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"}],"role":"symbol","roleHeading":"Global Variable","symbolKind":"var"},"schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"doc://GLib/documentation/GLib/logDomain":{"fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"text":"logDomain","kind":"identifier"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"title":"logDomain","abstract":[{"type":"text","text":"Defines the log domain. See "},{"type":"reference","identifier":"#log-domains","isActive":true},{"type":"text","text":"."}],"kind":"symbol","url":"\/documentation\/glib\/logdomain","role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/logDomain","type":"topic"},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"#log-domains":{"titleInlineContent":[{"type":"text","text":"Log Domains"}],"title":"Log Domains","identifier":"#log-domains","type":"link","url":"#log-domains"}}}