{"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"abstract":[{"type":"text","text":"Queries the system monotonic time in microseconds."}],"metadata":{"role":"symbol","modules":[{"name":"GLib"}],"symbolKind":"func","externalID":"s:4GLib16getMonotonicTimes5Int64VyF","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"getMonotonicTime"},{"kind":"text","text":"() -> "},{"text":"gint64","preciseIdentifier":"c:@T@gint64","kind":"typeIdentifier"}],"title":"getMonotonicTime()","roleHeading":"Function"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/getmonotonictime()"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"getMonotonicTime","kind":"identifier"},{"kind":"text","text":"() -> "},{"text":"gint64","kind":"typeIdentifier","preciseIdentifier":"c:@T@gint64"}],"languages":["swift"]}]},{"content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"inlineContent":[{"type":"text","text":"The monotonic clock will always increase and doesn’t suffer"},{"text":" ","type":"text"},{"type":"text","text":"discontinuities when the user (or NTP) changes the system time.  It"},{"type":"text","text":" "},{"type":"text","text":"may or may not continue to tick during times where the machine is"},{"type":"text","text":" "},{"text":"suspended.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"We try to use the clock that corresponds as closely as possible to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the passage of time as measured by system calls such as"},{"type":"text","text":" "},{"isActive":true,"identifier":"man:poll(2)","type":"reference"},{"text":" but it","type":"text"},{"text":" ","type":"text"},{"text":"may not always be possible to do this.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"A more accurate version of this function exists.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.get_monotonic_time_ns"},{"type":"text","text":"] returns the time in nanoseconds."}]}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/getMonotonicTime()"},"references":{"man:poll(2)":{"url":"man:poll(2)","identifier":"man:poll(2)","titleInlineContent":[{"type":"codeVoice","code":"poll()"}],"type":"link","title":"poll()"},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/getMonotonicTime()":{"url":"\/documentation\/glib\/getmonotonictime()","identifier":"doc:\/\/GLib\/documentation\/GLib\/getMonotonicTime()","abstract":[{"text":"Queries the system monotonic time in microseconds.","type":"text"}],"role":"symbol","kind":"symbol","type":"topic","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"getMonotonicTime"},{"kind":"text","text":"() -> "},{"text":"gint64","kind":"typeIdentifier","preciseIdentifier":"c:@T@gint64"}],"title":"getMonotonicTime()"}}}