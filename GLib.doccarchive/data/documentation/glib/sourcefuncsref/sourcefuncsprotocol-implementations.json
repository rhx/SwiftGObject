odeVoice","code":"poll()"},{"type":"text","text":" call) it should return "},{"code":"true","type":"codeVoice"},{"text":". It can also return","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a "},{"type":"codeVoice","code":"timeout_"},{"text":" value which should be the maximum timeout (in milliseconds)","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"which should be passed to the "},{"code":"poll()","type":"codeVoice"},{"text":" call. The actual timeout used will","type":"text"},{"type":"text","text":" "},{"text":"be -1 if all sources returned -1, or it will be the minimum of all","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the "},{"type":"codeVoice","code":"timeout_"},{"text":" values returned which were >= 0.  Since 2.36 this may","type":"text"},{"type":"text","text":" "},{"type":"text","text":"be "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", in which case the effect is as if the function always returns"},{"type":"text","text":" "},{"code":"false","type":"codeVoice"},{"type":"text","text":" with a timeout of -1.  If "},{"type":"codeVoice","code":"prepare"},{"text":" returns a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"timeout and the source also has a ready time set, then the"},{"text":" ","type":"text"},{"type":"text","text":"lower of the two will be used."}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/prepare","role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"prepare","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@GSourceFuncsPrepareFunc","kind":"typeIdentifier","text":"GSourceFuncsPrepareFunc"},{"kind":"text","text":"!"}]},"doc://GLib/documentation/GLib/SourceFuncsRef":{"title":"SourceFuncsRef","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef","url":"\/documentation\/glib\/sourcefuncsref","role":"symbol","fragments":[{"text":"struct","kind":"