{"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"role":"collectionGroup","modules":[{"name":"GLib"}],"title":"SourceFuncsProtocol Implementations","roleHeading":"API Collection"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef"]]},"kind":"article","topicSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/check","doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/dispatch","doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/finalize","doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/prepare"],"anchor":"Instance-Properties","generated":true,"title":"Instance Properties"},{"generated":true,"title":"Instance Methods","anchor":"Instance-Methods","identifiers":["doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/sourceRemoveByFuncs(userData:)"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/SourceFuncsProtocol-Implementations"},"sections":[],"variants":[{"paths":["\/documentation\/glib\/sourcefuncsref\/sourcefuncsprotocol-implementations"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GLib/documentation/GLib/SourceFuncsRef":{"abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"GSourceFuncs"},{"text":" struct contains a table of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"functions used to handle event sources in a generic manner."}],"title":"SourceFuncsRef","url":"\/documentation\/glib\/sourcefuncsref","type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"SourceFuncsRef"}],"role":"symbol","kind":"symbol","navigatorTitle":[{"text":"SourceFuncsRef","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef"},"doc://GLib/documentation/GLib/MainContext":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MainContext"}],"url":"\/documentation\/glib\/maincontext","kind":"symbol","abstract":[{"type":"text","text":"The "},{"code":"GMainContext","type":"codeVoice"},{"type":"text","text":" struct is an opaque data"},{"text":" ","type":"text"},{"text":"type representing a set of sources to be handled in a main loop.","type":"text"}],"title":"MainContext","role":"symbol","navigatorTitle":[{"text":"MainContext","kind":"identifier"}]},"doc://GLib/documentation/GLib/SourceFuncsRef/check":{"title":"check","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"check","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"GSourceFuncsCheckFunc","preciseIdentifier":"c:@T@GSourceFuncsCheckFunc"},{"text":"!","kind":"text"}],"role":"symbol","kind":"symbol","url":"\/documentation\/glib\/sourcefuncsref\/check","type":"topic","abstract":[{"type":"text","text":"Called after all the file descriptors are polled. The"},{"type":"text","text":" "},{"text":"source should return ","type":"text"},{"code":"true","type":"codeVoice"},{"type":"text","text":" if it is ready to be dispatched. Note that"},{"type":"text","text":" "},{"text":"some time may have passed since the previous prepare function was called,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"so the source should be checked again here.  Since 2.36 this may"},{"text":" ","type":"text"},{"type":"text","text":"be "},{"code":"nil","type":"codeVoice"},{"text":", in which case the effect is as if the function always returns","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"false"},{"type":"text","text":"."}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/check"},"doc://GLib/documentation/GLib/SourceFuncsRef/finalize":{"type":"topic","url":"\/documentation\/glib\/sourcefuncsref\/finalize","title":"finalize","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/finalize","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"finalize"},{"text":": ","kind":"text"},{"text":"GSourceFuncsFinalizeFunc","kind":"typeIdentifier","preciseIdentifier":"c:@T@GSourceFuncsFinalizeFunc"},{"text":"!","kind":"text"}],"abstract":[{"type":"text","text":"Called when the source is finalized. At this point,"},{"type":"text","text":" "},{"type":"text","text":"the source will have been destroyed, had its callback cleared, and have"},{"text":" ","type":"text"},{"type":"text","text":"been removed from its [struct"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","isActive":true},{"text":"], but it will still have","type":"text"},{"type":"text","text":" "},{"type":"text","text":"its final reference count, so methods can be called on it from within"},{"text":" ","type":"text"},{"type":"text","text":"this function. This may be "},{"type":"codeVoice","code":"nil"},{"text":", in which case the effect is as if the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"function does nothing and returns."}],"role":"symbol"},"doc://GLib/documentation/GLib/SourceFuncsRef/prepare":{"title":"prepare","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"prepare"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GSourceFuncsPrepareFunc","text":"GSourceFuncsPrepareFunc"},{"text":"!","kind":"text"}],"role":"symbol","kind":"symbol","url":"\/documentation\/glib\/sourcefuncsref\/prepare","type":"topic","abstract":[{"type":"text","text":"Called before all the file descriptors are polled. If"},{"text":" ","type":"text"},{"text":"the source can determine that it is ready here (without waiting for the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"results of the "},{"code":"poll()","type":"codeVoice"},{"type":"text","text":" call) it should return "},{"type":"codeVoice","code":"true"},{"text":". It can also return","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a "},{"code":"timeout_","type":"codeVoice"},{"type":"text","text":" value which should be the maximum timeout (in milliseconds)"},{"type":"text","text":" "},{"type":"text","text":"which should be passed to the "},{"type":"codeVoice","code":"poll()"},{"type":"text","text":" call. The actual timeout used will"},{"text":" ","type":"text"},{"type":"text","text":"be -1 if all sources returned -1, or it will be the minimum of all"},{"type":"text","text":" "},{"type":"text","text":"the "},{"type":"codeVoice","code":"timeout_"},{"type":"text","text":" values returned which were >= 0.  Since 2.36 this may"},{"type":"text","text":" "},{"type":"text","text":"be "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", in which case the effect is as if the function always returns"},{"text":" ","type":"text"},{"code":"false","type":"codeVoice"},{"text":" with a timeout of -1.  If ","type":"text"},{"type":"codeVoice","code":"prepare"},{"text":" returns a","type":"text"},{"text":" ","type":"text"},{"text":"timeout and the source also has a ready time set, then the","type":"text"},{"text":" ","type":"text"},{"text":"lower of the two will be used.","type":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/prepare"},"doc://GLib/documentation/GLib/sourceRemove":{"type":"topic","role":"symbol","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"sourceRemove"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:s5Int32V","text":"Int32","kind":"typeIdentifier"}],"kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/sourceRemove","url":"\/documentation\/glib\/sourceremove","abstract":[{"text":"Use this macro as the return value of a [callback","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFunc","type":"reference","isActive":true},{"type":"text","text":"] to remove"},{"type":"text","text":" "},{"type":"text","text":"the [struct"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Source"},{"type":"text","text":"] from the main loop."}],"title":"sourceRemove"},"doc://GLib/documentation/GLib/sourceContinue":{"kind":"symbol","role":"symbol","title":"sourceContinue","url":"\/documentation\/glib\/sourcecontinue","abstract":[{"type":"text","text":"Use this macro as the return value of a [callback"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFunc"},{"type":"text","text":"] to leave"},{"type":"text","text":" "},{"type":"text","text":"the [struct"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","type":"reference","isActive":true},{"text":"] in the main loop.","type":"text"}],"fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"sourceContinue"},{"text":": ","kind":"text"},{"text":"gboolean","kind":"typeIdentifier","preciseIdentifier":"c:@T@gboolean"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/sourceContinue","type":"topic"},"doc://GLib/documentation/GLib/SourceFuncsRef/sourceRemoveByFuncs(userData:)":{"role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"sourceRemoveByFuncs"},{"text":"(","kind":"text"},{"text":"userData","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gpointer","text":"gpointer"},{"text":"?) -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"title":"sourceRemoveByFuncs(userData:)","kind":"symbol","abstract":[{"type":"text","text":"Removes a source from the default main loop context given the"},{"text":" ","type":"text"},{"type":"text","text":"source functions and user data."}],"url":"\/documentation\/glib\/sourcefuncsref\/sourceremovebyfuncs(userdata:)","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/sourceRemoveByFuncs(userData:)"},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/SourceFuncsRef/dispatch":{"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"dispatch"},{"kind":"text","text":": "},{"text":"GSourceFuncsDispatchFunc","preciseIdentifier":"c:@T@GSourceFuncsDispatchFunc","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"url":"\/documentation\/glib\/sourcefuncsref\/dispatch","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/dispatch","abstract":[{"text":"Called to dispatch the event source, after it has returned","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"true"},{"text":" in either its ","type":"text"},{"code":"prepare","type":"codeVoice"},{"type":"text","text":" or its "},{"type":"codeVoice","code":"check"},{"type":"text","text":" function, or if a ready time"},{"text":" ","type":"text"},{"text":"has been reached. The ","type":"text"},{"code":"dispatch","type":"codeVoice"},{"text":" function receives a callback function and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"user data. The callback function may be "},{"type":"codeVoice","code":"nil"},{"text":" if the source was never","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"connected to a callback using [method"},{"type":"codeVoice","code":"GLib.Source.set_callback"},{"type":"text","text":"]. The"},{"type":"text","text":" "},{"type":"codeVoice","code":"dispatch"},{"text":" function should call the callback function with ","type":"text"},{"code":"user_data","type":"codeVoice"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"text","text":"whatever additional parameters are needed for this type of event source."},{"type":"text","text":" "},{"type":"text","text":"The return value of the "},{"type":"codeVoice","code":"dispatch"},{"text":" function should be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[const"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/sourceRemove","type":"reference","isActive":true},{"type":"text","text":"] if the source should be removed or"},{"type":"text","text":" "},{"text":"[const","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/sourceContinue","isActive":true},{"text":"] to keep it.","type":"text"}],"kind":"symbol","type":"topic","role":"symbol","title":"dispatch"}}}