ool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"roleHeading":"Instance Method","extendedModule":"GLib","title":"setAppInfo(uri:name:exec:count:stamp:)","role":"symbol","platforms":[],"externalID":"s:4GLib20BookmarkFileProtocolPAAE10setAppInfo3uri4name4exec5count5stampSbSPys4Int8VGSg_A2MS2itKF"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/bookmarkfileprotocol\/setappinfo(uri:name:exec:count:stamp:)"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"setAppInfo"},{"text":"(","kind":"text"},{"text":"uri","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"name"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"text":"exec","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"count"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"text":"stamp","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"time_t","preciseIdentifier":"c:@T@time_t","kind":"typeIdentifier"},{"kind":"text","text":") "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}]}]},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You should rarely use this function; use "},{"type":"codeVoice","code":"g_bookmark_file_add_application()"},{"type":"text","text":" "},{"type":"text","text":"and "},{"type":"codeVoice","code":"g_bookmark_file_remove_application()"},{"text":" instead.","type":"text"}]},{"type":"paragraph","inlineContent":[{"code":"name","type":"codeVoice"},{"type":"text","text":" can be any UTF-8 encoded string used to identify an"},{"type":"text","text":" "},{"type":"text","text":"application."},{"type":"text","text":" "},{"type":"codeVoice","code":"exec"},{"type":"text","text":" can have one of these two modifiers: “`f"},{"code":"\", which will be expanded as the local file name retrieved from the bookmark's URI; \"\\","type":"codeVoice"},{"type":"text","text":"u"},{"type":"codeVoice","code":"\", which will be expanded as the bookmark's URI. The expansion is done automatically when retrieving the stored command line using the "},{"text":"g_bookmark_file_get_application_info()","type":"text"},{"type":"codeVoice","code":"function."},{"type":"text","text":"count"},{"type":"codeVoice","code":"is the number of times the application has registered the bookmark; if is < 0, the current registration count will be increased by one, if is 0, the application with"},{"type":"text","text":"name"},{"type":"codeVoice","code":"will be removed from the list of registered applications."},{"text":"stamp` is the Unix time of the last registration; if it is -1, the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"current time will be used."}]},{"inlineContent":[{"type":"text","text":"If you try to remove an application by setting its registration count to"},{"type":"text","text":" "},{"type":"text","text":"zero, and no bookmark for "},{"code":"uri","type":"codeVoice"},{"type":"text","text":" is found, "},{"type":"codeVoice","code":"false"},{"type":"text","text":" is returned and"},{"type":"text","text":" "},{"type":"codeVoice","code":"error"},{"text":" is set to ","type":"text"},{"type":"codeVoice","code":"uriNotFound"},{"type":"text","text":"; similarly,"},{"type":"text","text":" "},{"text":"in the event that no application ","type":"text"},{"type":"codeVoice","code":"name"},{"type":"text","text":" has registered a bookmark"},{"type":"text","text":" "},{"text":"for ","type":"text"},{"type":"codeVoice","code":"uri"},{"text":",  ","type":"text"},{"code":"false","type":"codeVoice"},{"type":"text","text":" is returned and error is set to"},{"text":" ","type":"text"},{"type":"codeVoice","code":"appNotRegistered"},{"type":"text","text":".  Otherwise, if no bookmark"},{"type":"text","text":" "},{"type":"text","text":"for "},{"type":"codeVoice","code":"uri"},{"type":"text","text":" is found, one is created."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"set_app_info is deprecated:"}]},{"type":"text","text":" "},{"type":"text","text":"Use g_bookmark_file_set_application_info() instead, as"},{"type":"text","text":" "},{"type":"codeVoice","code":"time_t"},{"text":" is deprecated due to the year 2038 problem.","type":"text"}]}],"kind":"content"}],"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFileProtocol\/setAppInfo(uri:name:exec:count:stamp:)","interfaceLanguage":"swift"},"references":{"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/BookmarkFileProtocol":{"role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"BookmarkFileProtocol"}],"navigatorTitle":[{"kind":"identifier","text":"BookmarkFileProtocol"}],"identifier":"doc:\/\/GLib\/documentation\/G