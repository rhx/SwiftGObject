{"abstract":[{"type":"text","text":"Maps a file into memory. On UNIX, this is using the "},{"type":"codeVoice","code":"mmap()"},{"text":" function.","type":"text"}],"metadata":{"modules":[{"name":"GLib"}],"extendedModule":"GLib","externalID":"s:4GLib13MappedFileRefV8filename8writableACSPys4Int8VGSg_SbtKcfc","title":"init(filename:writable:)","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"text":"filename","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"writable"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":") ","kind":"text"},{"kind":"keyword","text":"throws"}],"role":"symbol","roleHeading":"Initializer","symbolKind":"init"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/MappedFileRef"]]},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"init"},{"text":"(","kind":"text"},{"text":"filename","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"text":">!, ","kind":"text"},{"text":"writable","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"kind":"text","text":") "},{"text":"throws","kind":"keyword"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"inlineContent":[{"text":"If ","type":"text"},{"code":"writable","type":"codeVoice"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"true"},{"text":", the mapped buffer may be modified, otherwise","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"it is an error to modify the mapped buffer. Modifications to the buffer"},{"text":" ","type":"text"},{"type":"text","text":"are not visible to other processes mapping the same file, and are not"},{"type":"text","text":" "},{"type":"text","text":"written back to the file."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that modifications of the underlying file might affect the contents"},{"type":"text","text":" "},{"type":"text","text":"of the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/MappedFile"},{"type":"text","text":". Therefore, mapping should only be used if the file"},{"type":"text","text":" "},{"type":"text","text":"will not be modified, or if all modifications of the file are done"},{"text":" ","type":"text"},{"text":"atomically (e.g. using ","type":"text"},{"type":"codeVoice","code":"g_file_set_contents()"},{"type":"text","text":")."}]},{"inlineContent":[{"text":"If ","type":"text"},{"code":"filename","type":"codeVoice"},{"text":" is the name of an empty, regular file, the function","type":"text"},{"type":"text","text":" "},{"type":"text","text":"will successfully return an empty "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/MappedFile"},{"type":"text","text":". In other cases of"},{"text":" ","type":"text"},{"type":"text","text":"size 0 (e.g. device files such as \/dev\/null), "},{"code":"error","type":"codeVoice"},{"text":" will be set","type":"text"},{"text":" ","type":"text"},{"text":"to the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/FileError","type":"reference"},{"text":" value ","type":"text"},{"type":"codeVoice","code":"inval"},{"type":"text","text":"."}],"type":"paragraph"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"