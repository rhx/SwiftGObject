{"abstract":[{"text":"Sets a function to clear an element of ","type":"text"},{"type":"codeVoice","code":"array"},{"type":"text","text":"."}],"sections":[],"metadata":{"extendedModule":"GLib","role":"symbol","roleHeading":"Instance Method","modules":[{"name":"GLib"}],"title":"set(clearFunc:)","externalID":"s:4GLib13ArrayProtocolPAAE3set9clearFuncyySvSgXCSg_tF::SYNTHESIZED::s:4GLib13TypedArrayRefV","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"set"},{"kind":"text","text":"("},{"kind":"externalParam","text":"clearFunc"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GDestroyNotify","text":"GDestroyNotify"},{"text":"?)","kind":"text"}]},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/TypedArrayRef","doc:\/\/GLib\/documentation\/GLib\/TypedArrayRef\/ArrayProtocol-Implementations"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/TypedArrayRef\/set(clearFunc:)"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"set","kind":"identifier"},{"kind":"text","text":"("},{"text":"clearFunc","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GDestroyNotify","text":"GDestroyNotify"},{"kind":"text","text":"? = nil)"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"clearFunc","type":"codeVoice"},{"type":"text","text":" will be called when an element in the array"},{"type":"text","text":" "},{"text":"data segment is removed and when the array is freed and data","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"segment is deallocated as well. "},{"type":"codeVoice