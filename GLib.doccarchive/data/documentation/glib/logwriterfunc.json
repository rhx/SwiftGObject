,"text":" "},{"text":"send messages to a remote logging server and there is a network error), it","type":"text"},{"text":" ","type":"text"},{"text":"should return ","type":"text"},{"code":"unhandled","type":"codeVoice"},{"type":"text","text":". This allows writer functions to be"},{"text":" ","type":"text"},{"text":"chained and fall back to simpler handlers in case of failure.","type":"text"}]}]}],"metadata":{"navigatorTitle":[{"kind":"identifier","text":"LogWriterFunc"}],"role":"symbol","fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LogWriterFunc","kind":"identifier"}],"symbolKind":"typealias","modules":[{"name":"GLib"}],"roleHeading":"Type Alias","externalID":"s:4GLib13LogWriterFunca","title":"LogWriterFunc"},"abstract":[{"type":"text","text":"Writer function for log entries. A log entry is a collection of one or more"},{"text":" ","type":"text"},{"type":"codeVoice","code":"GLogFields"},{"text":", using the standard ","type":"text"},{"type":"reference","identifier":"https:\/\/www.freedesktop.org\/software\/systemd\/man\/systemd.journal-fields.html","isActive":true},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"See "},{"code":"g_log_structured()","type":"codeVoice"},{"type":"text","text":" for more information."}],"references":{"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"https://www.freedesktop.org/software/systemd/man/systemd.journal-fields.html":{"url":"https:\/\/www.freedesktop.org\/software\/systemd\/man\/systemd.journal-fields.html","titleInlineContent":[{"type":"text","text":"field names from journal"},{"text":" ","type":"text"},{"text":"specification","type":"text"}],"title":"field names from journal specification","identifier":"https:\/\/www.freedesktop.org\/software\/systemd\/man\/systemd.journal-fields.html","type":"link"},"doc://GLib/doc