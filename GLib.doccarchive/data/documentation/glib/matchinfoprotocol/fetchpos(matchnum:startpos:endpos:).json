":"text"},{"type":"codeVoice","code":"endPos"},{"type":"text","text":" to identifiable"},{"text":" ","type":"text"},{"type":"text","text":"values, such as "},{"type":"codeVoice","code":"G_MAXINT"},{"type":"text","text":", so that you can test if"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_match_info_fetch_pos()"},{"text":" actually changed the value for a given","type":"text"},{"type":"text","text":" "},{"type":"text","text":"capture parenthesis."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The parameter "},{"type":"codeVoice","code":"matchNum"},{"text":" corresponds to a matched capture parenthesis. The","type":"text"},{"type":"text","text":" "},{"text":"actual value you use for ","type":"text"},{"code":"matchNum","type":"codeVoice"},{"type":"text","text":" depends on the method used to generate"},{"type":"text","text":" "},{"code":"matchInfo","type":"codeVoice"},{"text":". The following sections describe those methods.","type":"text"}],"type":"paragraph"},{"text":"Methods Using Non-deterministic Finite Automata Matching","anchor":"Methods-Using-Non-deterministic-Finite-Automata-Matching","type":"heading","level":2},{"inlineContent":[{"text":"The methods [method","type":"text"},{"type":"codeVoice","code":"GLib.Regex.match"},{"text":"] and [method","type":"text"},{"type":"codeVoice","code":"GLib.Regex.match_full"},{"type":"text","text":"]"},{"type":"text","text":" "},{"text":"return a [struct","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo","isActive":true,"type":"reference"},{"text":"] using traditional (greedy) pattern","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"matching, also known as"},{"text":" ","type":"text"},{"type":"reference","identifier":"https:\/\/en.wikipedia.org\/wiki\/Nondeterministic_finite_automaton","isActive":true},{"text":" ","type":"text"},{"text":"(NFA) matching. You pass the returned ","type":"text"},{"type":"codeVoice","code":"GMatchInfo"},{"text":" from these methods to","type":"text"},{"text":" ","type":"text"},{"code":"g_match_info_fetch_pos()","type":"codeVoice"},{"type":"text","text":" to determine the start and end positions"},{"type":"text","text":" "},{"text":"of capture parentheses. The values for ","type":"text"},{"code":"matchNum","type":"codeVoice"},{"type":"text","text":" correspond to the capture"},{"type":"text","text":" "},{"type":"text","text":"parentheses in order, with "},{"code":"0","type":"codeVoice"},{"type":"text","text":" corresponding to the entire matched string."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"code":"matchNum","type":"codeVoice"},{"text":" can refer to a capture parenthesis with no match. For example,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the string "},{"code":"b","type":"codeVoice"},{"type":"text","text":" matches against the pattern "},{"type":"codeVoice","code":"(a)?b"},{"type":"text","text":", but the capture"},{"type":"text","text":" "},{"type":"text","text":"parenthesis "},{"type":"codeVoice","code":"(a)"},{"text":" has no match. In this case, ","type":"text"},{"type":"codeVoice","code":"g_match_info_fetch_pos()"},{"type":"text","text":" "},{"text":"returns true and sets ","type":"text"},{"code":"startPos","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"endPos"},{"type":"text","text":" to "},{"type":"codeVoice","code":"-1"},{"type":"text","text":" when called with"},{"text":" ","type":"text"},{"type":"codeVoice","code":"match_num"},{"type":"text","text":" as "},{"type":"codeVoice","code":"1"},{"text":" (for ","type":"text"},{"code":"(a)","type":"codeVoice"},{"text":").","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For an expanded example, a regex pattern is "},{"type":"codeVoice","code":"(a)?(.*?)the (.*)"},{"type":"text","text":","},{"type":"text","text":" "},{"text":"and a candidate string is ","type":"text"},{"type":"codeVoice","code":"glib regexes are the best"},{"type":"text","text":". In this scenario"},{"text":" ","type":"text"},{"text":"there are four capture parentheses numbered 0–3: an implicit one","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for the entire string, and three explicitly declared in the regex pattern."}]},{"inlineContent":[{"type":"text","text":"Given this example, the following table describes the return values"},{"type":"text","text":" "},{"type":"text","text":"from "},{"type":"codeVoice","code":"g_match_info_fetch_pos()"},{"type":"text","text":" for various values of "},{"type":"codeVoice","code":"matchNum"},{"text":".","type":"text"}],"type":"paragraph"},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"match_num"}]}],[{"type":"paragraph","inlineContent":[{"text":"Contents","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Return value"}]}],[{"type":"paragraph","inlineContent":[{"text":"Returned ","type":"text"},{"type":"codeVoice","code":"start_pos"}]}],[{"inlineContent":[{"type":"text","text":"Returned "},{"code":"end_pos","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"0"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Matches entire string","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"True"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"0"}]}],[{"inlineContent":[{"text":"25","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"1"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Does not match first character","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"True","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"-1"}]}],[{"type":"paragraph","inlineContent":[{"text":"-1","type":"text"}]}]],[[{"inlineContent":[{"text":"2","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"All text before ","type":"text"},{"type":"codeVoice","code":"the "}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"True"}]}],[{"type":"paragraph","inlineContent":[{"text":"0","type":"text"}]}],[{"inlineContent":[{"text":"17","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"3","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"All text after "},{"type":"codeVoice","code":"the "}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"True"}]}],[{"inlineContent":[{"text":"21","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"25"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"4","type":"text"}]}],[{"inlineContent":[{"text":"Capture paren out of range","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"False"}]}],[{"inlineContent":[{"text":"Unchanged","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Unchanged","type":"text"}]}]]],"type":"table","header":"row"},{"inlineContent":[{"text":"The following code sample and output implements this example.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"{ .c }","code":["`include` <glib.h>","","int","main (int argc, char *argv[])","{","  `g_autoptr(GError)` local_error = NULL;","  const char *regex_pattern = \"(a)?(.*?)the (.*)\";","  const char *test_string = \"glib regexes are the best\";","  `g_autoptr(GRegex)` regex = NULL;","","  regex = g_regex_new (regex_pattern,","                       G_REGEX_DEFAULT,","                       G_REGEX_MATCH_DEFAULT,","                       &local_error);","  if (regex == NULL)","    {","      g_printerr (\"Error creating regex: `s`\\n\", local_error->message);","      return 1;","    }","","  `g_autoptr(GMatchInfo)` match_info = NULL;","  g_regex_match (regex, test_string, G_REGEX_MATCH_DEFAULT, &match_info);","","  int n_matched_strings = g_match_info_get_match_count (match_info);","","  \/\/ Print header line","  g_print (\"match_num Contents                  Return value returned start_pos returned end_pos\\n\");","","  \/\/ Iterate over each capture paren, including one that is out of range as a demonstration.","  for (int match_num = 0; match_num <= n_matched_strings; match_num++)","    {","      gboolean found_match;","      g_autofree char *paren_string = NULL;","      int start_pos = G_MAXINT;","      int end_pos = G_MAXINT;","","      found_match = g_match_info_fetch_pos (match_info,","                                            match_num,","                                            &start_pos,","                                            &end_pos);","","      \/\/ If no match, display N\/A as the found string.","      if (start_pos == G_MAXINT || start_pos == -1)","        paren_string = g_strdup (\"N\/A\");","      else","        paren_string = g_strndup (test_string + start_pos, end_pos - start_pos);","","      g_print (\"`-9d` `-25s` `-12d` `-18d` `d`\\n\", match_num, paren_string, found_match, start_pos, end_pos);","    }","","  return 0;","}"]},{"type":"codeListing","syntax":null,"code":["match_num Contents                  Return value returned start_pos returned end_pos","0         glib regexes are the best 1            0                  25","1         N\/A                       1            -1                 -1","2         glib regexes are          1            0                  17","3         best                      1            21                 25","4         N\/A                       0            2147483647         2147483647"]},{"type":"heading","level":2,"text":"Methods Using Deterministic Finite Automata Matching","anchor":"Methods-Using-Deterministic-Finite-Automata-Matching"},{"inlineContent":[{"text":"The methods [method","type":"text"},{"code":"GLib.Regex.match_all","type":"codeVoice"},{"type":"text","text":"] and"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"code":"GLib.Regex.match_all_full","type":"codeVoice"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"text":"return a ","type":"text"},{"code":"GMatchInfo","type":"codeVoice"},{"type":"text","text":" using"},{"type":"text","text":" "},{"identifier":"https:\/\/en.wikipedia.org\/wiki\/Deterministic_finite_automaton","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"(DFA) pattern matching. This algorithm detects overlapping matches. You pass"},{"type":"text","text":" "},{"text":"the returned ","type":"text"},{"code":"GMatchInfo","type":"codeVoice"},{"type":"text","text":" from these methods to "},{"type":"codeVoice","code":"g_match_info_fetch_pos()"},{"type":"text","text":" "},{"text":"to determine the start and end positions of each overlapping match. Use the","type":"text"},{"text":" ","type":"text"},{"text":"method [method","type":"text"},{"type":"codeVoice","code":"GLib.MatchInfo.get_match_count"},{"type":"text","text":"] to determine the number"},{"type":"text","text":" "},{"type":"text","text":"of overlapping matches."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For example, a regex pattern is "},{"type":"codeVoice","code":"<.*>"},{"type":"text","text":", and a candidate string is"},{"text":" ","type":"text"},{"type":"codeVoice","code":"<a> <b> <c>"},{"text":". In this scenario there are three implicit capture","type":"text"},{"type":"text","text":" "},{"text":"parentheses: one for the entire string, one for ","type":"text"},{"type":"codeVoice","code":"<a> <b>"},{"type":"text","text":", and one for "},{"code":"<a>","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"Given this example, the following table describes the return values from","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_match_info_fetch_pos()"},{"type":"text","text":" for various values of "},{"type":"codeVoice","code":"matchNum"},{"type":"text","text":"."}],"type":"paragraph"}