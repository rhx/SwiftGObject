"text","text":"As a best practice, initialize "},{"type":"codeVoice","code":"startPos"},{"type":"text","text":" and "},{"code":"endPos","type":"codeVoice"},{"type":"text","text":" to identifiable"},{"text":" ","type":"text"},{"type":"text","text":"values, such as "},{"type":"codeVoice","code":"G_MAXINT"},{"type":"text","text":", so that you can test if"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_match_info_fetch_pos()"},{"text":" actually changed the value for a given","type":"text"},{"type":"text","text":" "},{"text":"capture parenthesis.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The parameter ","type":"text"},{"code":"matchNum","type":"codeVoice"},{"text":" corresponds to a matched capture parenthesis. The","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"actual value you use for "},{"type":"codeVoice","code":"matchNum"},{"text":" depends on the method used to generate","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"matchInfo"},{"text":". The following sections describe those methods.","type":"text"}]},{"text":"Methods Using Non-deterministic Finite Automata Matching","type":"heading","level":2,"anchor":"Methods-Using-Non-deterministic-Finite-Automata-Matching"},{"type":"paragraph","inlineContent":[{"text":"The methods [method","type":"text"},{"code":"GLib.Regex.match","type":"codeVoice"},{"type":"text","text":"] and [method"},{"type":"codeVoice","code":"GLib.Regex.match_full"},{"type":"text","text":"]"},{"type":"text","text":" "},{"type":"text","text":"return a [struct"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo","type":"reference","isActive":true},{"type":"text","text":"] using traditional (greedy) pattern"},{"text":" ","type":"text"},{"type":"text","text":"matching, also known as"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/en.wikipedia.org\/wiki\/Nondeterministic_finite_automaton","isActive":true},{"type":"text","text":" "},{"text":"(NFA) matching. You pass the returned ","type":"text"},{"type":"codeVoice","code":"GMatchInfo"},{"type":"text","text":" from these methods to"},{"text":" ","type":"text"},{"code":"g_match_info_fetch_pos()","type":"codeVoice"},{"type":"text","text":" to determine the start and end positions"},{"type":"text","text":" "},{"type":"text","text":"of capture parentheses. The values for "},{"code":"matchNum","type":"codeVoice"},{"text":" correspond to the capture","type":"text"},{"text":" ","type":"text"},{"text":"parentheses in order, with ","type":"text"},{"type":"codeVoice","code":"0"},{"type":"text","text":" corresponding to the entire matched string."}]},{"type":"paragraph","inlineContent":[{"code":"matchNum","type":"codeVoice"},{"type":"text","text":" can refer to a capture parenthesis with no match. For example,"},{"type":"text","text":" "},{"type":"text","text":"the string "},{"code":"b","type":"codeVoice"},{"type":"text","text":" matches against the pattern "},{"type":"codeVoice","code":"(a)?b"},{"text":", but the capture","type":"text"},{"type":"text","text":" "},{"type":"text","text":"parenthesis "},{"type":"codeVoice","code":"(a)"},{"type":"text","text":" has no match. In this case, "},{"code":"g_match_info_fetch_pos()","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"returns true and sets "},{"type":"codeVoice","code":"startPos"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"endPos"},{"text":" to ","type":"text"},{"type":"codeVoice","code":"-1"},{"type":"text","text":" when called with"},{"text":" ","type":"text"},{"type":"codeVoice","code":"match_num"},{"type":"text","text":" as "},{"type":"codeVoice","code":"1"},{"type":"text","text":" (for "},{"code":"(a)","type":"codeVoice"},{"type":"text","text":")."}]},{"inlineContent":[{"text":"For an expanded example, a regex pattern is ","type":"text"},{"type":"codeVoice","code":"(a)?(.*?)the (.*)"},{"type":"text","text":","},{"type":"text","text":" "},{"text":"and a candidate string is ","type":"text"},{"type":"codeVoice","code":"glib regexes are the best"},{"type":"text","text":". In this scenario"},{"type":"text","text":" "},{"type":"text","text":"there are four capture parentheses numbered 0–3: an implicit one"},{"type":"text","text":" "},{"text":"for the entire string, and three explicitly declared in the regex pattern.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Given this example, the following table describes the return values"},{"type":"text","text":" "},{"type":"text","text":"from "},{"code":"g_match_info_fetch_pos()","type":"codeVoice"},{"type":"text","text":" for various values of "},{"code":"matchNum","type":"codeVoice"},{"text":".","type":"text"}]},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"match_num"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Contents"}]}],[{"inlineContent":[{"type":"text","text":"Return value"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Returned ","type":"text"},{"type":"codeVoice","code":"start_pos"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Returned "},{"type":"codeVoice","code":"end_pos"}]}]],[[{"inlineContent":[{"type":"text","text":"0"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Matches entire string","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"True","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"0"}]}],[{"inlineContent":[{"text":"25","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"1"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Does not match first character"}],"type":"paragraph"}],[{"inlineContent":[{"text":"True","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"-1","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"-1"}]}]],[[{"inlineContent":[{"type":"text","text":"2"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"All text before "},{"code":"the ","type":"codeVoice"}]}],[{"inlineContent":[{"type":"text","text":"True"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"0","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"17"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"3","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"All text after "},{"code":"the ","type":"codeVoice"}]}],[{"inlineContent":[{"text":"True","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"21","type":"text"}]}],[{"inlineContent":[{"text":"25","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"4","type":"text"}]}],[{"inlineContent":[{"text":"Capture paren out of range","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"False"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Unchanged"}]}],[{"inlineContent":[{"text":"Unchanged","type":"text"}],"type":"paragraph"}]]],"header":"row","type":"table"},{"inlineContent":[{"text":"The following code sample and output implements this example.","type":"text"}],"type":"paragraph"},{"code":["`include` <glib.h>","","int","main (int argc, char *argv[])","{","  `g_autoptr(GError)` local_error = NULL;","  const char *regex_pattern = \"(a)?(.*?)the (.*)\";","  const char *test_string = \"glib regexes are the best\";","  `g_autoptr(GRegex)` regex = NULL;","","  regex = g_regex_new (regex_pattern,","                       G_REGEX_DEFAULT,","                       G_REGEX_MATCH_DEFAULT,","                       &local_error);","  if (regex == NULL)","    {","      g_printerr (\"Error creating regex: `s`\\n\", local_error->message);","      return 1;","    }","","  `g_autoptr(GMatchInfo)` match_info = NULL;","  g_regex_match (regex, test_string, G_REGEX_MATCH_DEFAULT, &match_info);","","  int n_matched_strings = g_match_info_get_match_count (match_info);","","  \/\/ Print header line","  g_print (\"match_num Contents                  Return value returned start_pos returned end_pos\\n\");","","  \/\/ Iterate over each capture paren, including one that is out of range as a demonstration.","  for (int match_num = 0; match_num <= n_matched_strings; match_num++)","    {","      gboolean found_match;","      g_autofree char *paren_string = NULL;","      int start_pos = G_MAXINT;","      int end_pos = G_MAXINT;","","      found_match = g_match_info_fetch_pos (match_info,","                                            match_num,","                                            &start_pos,","                                            &end_pos);","","      \/\/ If no match, display N\/A as the found string.","      if (start_pos == G_MAXINT || start_pos == -1)","        paren_string = g_strdup (\"N\/A\");","      else","        paren_string = g_strndup (test_string + start_pos, end_pos - start_pos);","","      g_print (\"`-9d` `-25s` `-12d` `-18d` `d`\\n\", match_num, paren_string, found_match, start_pos, end_pos);","    }","","  return 0;","}"],"type":"codeListing","syntax":"{ .c }"},{"code":["match_num Contents                  Return value returned start_pos returned end_pos","0         glib regexes are the best 1            0                  25","1         N\/A                       1            -1                 -1","2         glib regexes are          1            0                  17","3         best                      1            21                 25","4         N\/A                       0            2147483647         2147483647"],"type":"codeListing","syntax":null},{"type":"heading","text":"Methods Using Deterministic Finite Automata Matching","level":2,"anchor":"Methods-Using-Deterministic-Finite-Automata-Matching"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The methods [method"},{"type":"codeVoice","code":"GLib.Regex.match_all"},{"text":"] and","type":"text"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.Regex.match_all_full"},{"text":"]","type":"text"},{"type":"text","text":" "},{"text":"return a ","type":"text"},{"type":"codeVoice","code":"GMatchInfo"},{"type":"text","text":" using"},{"text":" ","type":"text"},{"isActive":true,"identifier":"https:\/\/en.wikipedia.org\/wiki\/Deterministic_finite_automaton","type":"reference"},{"type":"text","text":" "},{"text":"(DFA) pattern matching. This algorithm detects overlapping matches. You pass","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the returned "},{"code":"GMatchInfo","type":"codeVoice"},{"type":"text","text":" from these methods to "},{"type":"codeVoice","code":"g_match_info_fetch_pos()"},{"text":" ","type":"text"},{"type":"text","text":"to determine the start and end positions of each overlapping match. Use the"},{"text":" ","type":"text"},{"type":"text","text":"method [method"},{"code":"GLib.MatchInfo.get_match_count","type":"codeVoice"},{"type":"text","text":"] to determine the number"},{"type":"text","text":" "},{"text":"of overlapping matches.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"For example, a regex pattern is ","type":"text"},{"type":"codeVoice","code":"<.*>"},{"type":"text","text":", and a candidate string is"},{"type":"text","text":" "},{"type":"codeVoice","code":"<a> <b> <c>"},{"text":". In this scenario there are three implicit capture","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"parentheses: one for the entire string, one for "},{"code":"<a> <b>","type":"codeVoice"},{"type":"text","text":", and one for "},{"code":"<a>","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Given this example, the following table describes the return values from"},{"text":" ","type":"text"},{"code":"g_match_info_fetch_pos()","type":"codeVoice"},{"type"