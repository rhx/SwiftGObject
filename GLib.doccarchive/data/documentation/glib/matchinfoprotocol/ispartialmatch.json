{"primaryContentSections":[{"declarations":[{"tokens":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"isPartialMatch","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"},{"text":" { ","kind":"text"},{"kind":"keyword","text":"get"},{"text":" }","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Consider, for example, an application where a human is required to"},{"text":" ","type":"text"},{"type":"text","text":"type in data for a field with specific formatting requirements. An"},{"text":" ","type":"text"},{"text":"example might be a date in the form ddmmmyy, defined by the pattern","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"\"^\\d?\\d(jan|feb|mar|apr|may|jun|jul|aug|sep|oct|nov|dec)"},{"type":"text","text":"\\d\\d$”."},{"type":"text","text":" "},{"type":"text","text":"If the application sees the user’s keystrokes one by one, and can"},{"type":"text","text":" "},{"type":"text","text":"check that what has been typed so far is potentially valid, it is"},{"text":" ","type":"text"},{"type":"text","text":"able to raise an error as soon as a mistake is made."}]},{"inlineContent":[{"text":"GRegex supports the concept of partial matching by means of the","type":"text"},{"type":"text","text":" "},{"code":"partialSoft","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"partialHard","type":"codeVoice"},{"type":"text","text":" flags."},{"type":"text","text":" "},{"text":"When they are used, the return code for","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_regex_match()"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"g_regex_match_full()"},{"text":" is, as usual, ","type":"text"},{"code":"true","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"for a complete match, "},{"code":"false","type":"codeVoice"},{"text":" otherwise. But, when these functions","type":"text"},{"type":"text","text":" "},{"text":"return ","type":"text"},{"code":"false","type":"codeVoice"},{"type":"text","text":", you can check if the match was partial calling"},{"type":"text","text":" "},{"code":"g_match_info_is_partial_match()","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"The difference between ","type":"text"},{"code":"partialSoft","type":"codeVoice"},{"type":"text","text":" and"},{"text":" ","type":"text"},{"type":"codeVoice","code":"partialHard"},{"type":"text","text":" is that when a partial match is encountered"},{"text":" ","type":"text"},{"type":"text","text":"with "},{"type":"codeVoice","code":"partialSoft"},{"type":"text","text":", matching continues to search for a"},{"type":"text","text":" "},{"text":"possible complete match, while with ","type":"text"},{"type":"codeVoice","code":"partialHard"},{"type":"text","text":" matching"},{"text":" ","type":"text"},{"type":"text","text":"stops at the partial match."},{"text":" ","type":"text"},{"text":"When both ","type":"text"},{"type":"codeVoice","code":"partialSoft"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"partialHard"},{"type":"text","text":" "},{"text":"are set, the latter takes precedence.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"There were formerly some restrictions on the pattern for partial matching."},{"text":" ","type":"text"},{"type":"text","text":"The restrictions no longer apply."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"code":"pcrepartial(3)","type":"codeVoice"},{"type":"text","text":" for more information on partial matching."}]}]}],"abstract":[{"type":"text","text":"Usually if the string passed to g_regex_match*() matches as far as"},{"type":"text","text":" "},{"text":"it goes, but is too short to match the entire pattern, ","type":"text"},{"type":"codeVoice","code":"false"},{"type":"text","text":" is"},{"type":"text","text":" "},{"type":"text","text":"returned. There are circumstances where it might be helpful to"},{"text":" ","type":"text"},{"text":"distinguish this case from other cases in which there is no match.","type":"text"}],"sections":[],"kind":"symbol","schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"modules":[{"name":"GLib"}],"extendedModule":"GLib","symbolKind":"property","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"kind":"identifier","text":"isPartialMatch"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"roleHeading":"Instance Property","title":"isPartialMatch","externalID":"s:4GLib17MatchInfoProtocolPAAE09isPartialB0Sbvp","role":"symbol"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/MatchInfoProtocol"]]},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/MatchInfoProtocol\/isPartialMatch","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/matchinfoprotocol\/ispartialmatch"]}],"references":{"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/MatchInfoProtocol/isPartialMatch":{"fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"isPartialMatch","kind":"identifier"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfoProtocol\/isPartialMatch","type":"topic","abstract":[{"type":"text","text":"Usually if the string passed to g_regex_match*() matches as far as"},{"text":" ","type":"text"},{"type":"text","text":"it goes, but is too short to match the entire pattern, "},{"type":"codeVoice","code":"false"},{"text":" is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"returned. There are circumstances where it might be helpful to"},{"type":"text","text":" "},{"text":"distinguish this case from other cases in which there is no match.","type":"text"}],"title":"isPartialMatch","role":"symbol","kind":"symbol","url":"\/documentation\/glib\/matchinfoprotocol\/ispartialmatch"},"doc://GLib/documentation/GLib/MatchInfoProtocol":{"url":"\/documentation\/glib\/matchinfoprotocol","navigatorTitle":[{"kind":"identifier","text":"MatchInfoProtocol"}],"title":"MatchInfoProtocol","identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfoProtocol","type":"topic","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MatchInfoProtocol"}],"role":"symbol","kind":"symbol","abstract":[{"text":"A GMatchInfo is an opaque struct used to return information about","type":"text"},{"type":"text","text":" "},{"text":"matches.","type":"text"}]}}}