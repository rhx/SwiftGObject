{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/log_domain"]}],"metadata":{"modules":[{"name":"GLib"}],"externalID":"s:4GLib10LOG_DOMAINSivp","roleHeading":"Global Variable","symbolKind":"var","platforms":[],"role":"symbol","title":"LOG_DOMAIN","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"text":"LOG_DOMAIN","kind":"identifier"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}]},"kind":"symbol","abstract":[{"text":"Libraries should define this so that any messages","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"which they log can be differentiated from messages from other"},{"text":" ","type":"text"},{"type":"text","text":"libraries and application code. But be careful not to define"},{"type":"text","text":" "},{"text":"it in any public header files.","type":"text"}],"schemaVersion":{"patch":0,"minor":3,"major":0},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"sections":[],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/LOG_DOMAIN","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"let"},{"text":" ","kind":"text"},{"text":"LOG_DOMAIN","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Log domains must be unique, and it is recommended that they are the"},{"type":"text","text":" "},{"type":"text","text":"application or library name, optionally followed by a hyphen and a sub-domain"},{"text":" ","type":"text"},{"text":"name. For example, ","type":"text"},{"type":"codeVoice","code":"bloatpad"},{"type":"text","text":" or "},{"code":"bloatpad-io","type":"codeVoice"},{"text":".","type":"text"}]},{"inlineContent":[{"type":"text","text":"If undefined, it defaults to the default "},{"type":"codeVoice","code":"nil"},{"text":" (or ","type":"text"},{"type":"codeVoice","code":"\"\""},{"text":") log domain; this is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"not advisable, as it cannot be filtered against using the "},{"code":"G_MESSAGES_DEBUG","type":"codeVoice"},{"text":" ","type":"text"},{"text":"environment variable.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For example, GTK uses this in its "},{"code":"Makefile.am","type":"codeVoice"},{"type":"text","text":":"}],"type":"paragraph"},{"type":"codeListing","syntax":null,"code":["AM_CPPFLAGS = -DG_LOG_DOMAIN=\\\"Gtk\\\""]},{"type":"paragraph","inlineContent":[{"text":"Applications can choose to leave it as the default ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" (or "},{"code":"\"\"","type":"codeVoice"},{"text":")","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"domain. However, defining the domain offers the same advantages as"},{"text":" ","type":"text"},{"type":"text","text":"above."}]}]}],"references":{"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/LOG_DOMAIN":{"abstract":[{"type":"text","text":"Libraries should define this so that any messages"},{"text":" ","type":"text"},{"text":"which they log can be differentiated from messages from other","type":"text"},{"type":"text","text":" "},{"type":"text","text":"libraries and application code. But be careful not to define"},{"type":"text","text":" "},{"type":"text","text":"it in any public header files."}],"title":"LOG_DOMAIN","identifier":"doc:\/\/GLib\/documentation\/GLib\/LOG_DOMAIN","url":"\/documentation\/glib\/log_domain","role":"symbol","deprecated":true,"fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"text":"LOG_DOMAIN","kind":"identifier"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"kind":"symbol","type":"topic"}}}