{"abstract":[{"type":"text","text":"Libraries should define this so that any messages"},{"type":"text","text":" "},{"type":"text","text":"which they log can be differentiated from messages from other"},{"type":"text","text":" "},{"type":"text","text":"libraries and application code. But be careful not to define"},{"text":" ","type":"text"},{"type":"text","text":"it in any public header files."}],"metadata":{"title":"LOG_DOMAIN","role":"symbol","roleHeading":"Global Variable","symbolKind":"var","platforms":[],"externalID":"s:4GLib10LOG_DOMAINSivp","modules":[{"name":"GLib"}],"fragments":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"text":"LOG_DOMAIN","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"}]},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"LOG_DOMAIN"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"platforms":["macOS"]}]},{"content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"inlineContent":[{"type":"text","text":"Log domains must be unique, and it is recommended that they are the"},{"text":" ","type":"text"},{"type":"text","text":"application or library name, optionally followed by a hyphen and a sub-domain"},{"type":"text","text":" "},{"type":"text","text":"name. For example, "},{"type":"codeVoice","code":"bloatpad"},{"type":"text","text":" or "},{"type":"codeVoice","code":"bloatpad-io"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If undefined, it defaults to the default "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" (or "},{"type":"codeVoice","code":"\"\""},{"type":"text","text":") log domain; this is"},{"type":"text","text":" "},{"type":"text","text":"not advisable, as it cannot be filtered against using the "},{"type":"codeVoice","code":"G_MESSAGES_DEBUG"},{"type":"text","text":" "},{"type":"text","text":"environment variable."}]},{"inlineContent":[{"type":"text","text":"For example, GTK uses this in its "},{"type":"codeVoice","code":"Makefile.am"},{"type":"text","text":":"}],"type":"paragraph"},{"type":"codeListing","code":["AM_CPPFLAGS = -DG_LOG_DOMAIN=\\\"Gtk\\\""],"syntax":null},{"type":"paragraph","inlineContent":[{"type":"text","text":"Applications can choose to leave it as the default "},{"type":"codeVoice","code":"nil"},{"text":" (or ","type":"text"},{"type":"codeVoice","code":"\"\""},{"type":"text","text":")"},{"type":"text","text":" "},{"text":"domain. However, defining the domain offers the same advantages as","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"above."}]}],"kind":"content"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/LOG_DOMAIN","interfaceLanguage":"swift"},"sections":[],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/log_domain"]}],"references":{"doc://GLib/documentation/GLib/LOG_DOMAIN":{"deprecated":true,"abstract":[{"type":"text","text":"Libraries should define this so that any messages"},{"text":" ","type":"text"},{"type":"text","text":"which they log can be differentiated from messages from other"},{"type":"text","text":" "},{"type":"text","text":"libraries and application code. But be careful not to define"},{"type":"text","text":" "},{"type":"text","text":"it in any public header files."}],"title":"LOG_DOMAIN","role":"symbol","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/LOG_DOMAIN","fragments":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"text":"LOG_DOMAIN","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"url":"\/documentation\/glib\/log_domain","kind":"symbol"},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"}}}