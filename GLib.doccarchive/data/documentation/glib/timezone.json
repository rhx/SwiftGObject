{"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"TimeZone"}]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"anchor":"overview","text":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"GTimeZone"},{"type":"text","text":" struct is refcounted and immutable."}],"type":"paragraph"},{"inlineContent":[{"text":"Each time zone has an identifier (for example, ‘Europe\/London’) which is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"platform dependent. See [ctor"},{"type":"codeVoice","code":"GLib.TimeZone.new"},{"text":"] for information on the","type":"text"},{"text":" ","type":"text"},{"text":"identifier formats. The identifier of a time zone can be retrieved using","type":"text"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"code":"GLib.TimeZone.get_identifier","type":"codeVoice"},{"type":"text","text":"]."}],"type":"paragraph"},{"inlineContent":[{"text":"A time zone contains a number of intervals. Each interval has an abbreviation","type":"text"},{"text":" ","type":"text"},{"text":"to describe it (for example, ‘PDT’), an offset to UTC and a flag indicating","type":"text"},{"type":"text","text":" "},{"text":"if the daylight savings time is in effect during that interval. A time zone","type":"text"},{"type":"text","text":" "},{"type":"text","text":"always has at least one interval — interval 0. Note that interval abbreviations"},{"type":"text","text":" "},{"text":"are not the same as time zone identifiers (apart from ‘UTC’), and cannot be","type":"text"},{"type":"text","text":" "},{"text":"passed to [ctor","type":"text"},{"code":"GLib.TimeZone.new","type":"codeVoice"},{"type":"text","text":"]."}],"type":"paragraph"},{"inlineContent":[{"text":"Every UTC time is contained within exactly one interval, but a given","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"local time may be contained within zero, one or two intervals (due to"},{"type":"text","text":" "},{"type":"text","text":"incontinuities associated with daylight savings time)."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"An interval may refer to a specific period of time (eg: the duration"},{"text":" ","type":"text"},{"type":"text","text":"of daylight savings time during 2010) or it may refer to many periods"},{"type":"text","text":" "},{"text":"of time that share the same properties (eg: all periods of daylight","type":"text"},{"type":"text","text":" "},{"text":"savings time).  It is also possible (usually for political reasons)","type":"text"},{"type":"text","text":" "},{"text":"that some properties (like the abbreviation) change between intervals","type":"text"},{"text":" ","type":"text"},{"text":"without other properties changing.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone"},{"type":"text","text":" type acts as a reference-counted owner of an underlying "},{"code":"GTimeZone","type":"codeVoice"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"It provides the methods that can operate on this data type through "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZoneProtocol","isActive":true},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone","isActive":true,"type":"reference"},{"text":" as a strong reference or owner of a ","type":"text"},{"type":"codeVoice","code":"GTimeZone"},{"type":"text","text":" instance."}]},{"style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef","type":"reference"},{"type":"text","text":" (instead of "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone","isActive":true},{"type":"text","text":") for a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GTimeZone"},{"text":" instance.","type":"text"}]}],"name":"Note"}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"abstract":[{"type":"text","text":"A "},{"type":"codeVoice","code":"GTimeZone"},{"text":" represents a time zone, at no particular point in time.","type":"text"}],"metadata":{"title":"TimeZone","externalID":"s:4GLib8TimeZoneC","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"TimeZone"}],"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"TimeZone","kind":"identifier"}],"symbolKind":"class","modules":[{"name":"GLib"}],"roleHeading":"Class"},"sections":[],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/TimeZone","interfaceLanguage":"swift"},"topicSections":[{"generated":true,"title":"Initializers","anchor":"Initializers","identifiers":["doc:\/\/GLib\/documentation\/GLib\/TimeZone\/init(_:)-3m8y2","doc:\/\/GLib\/documentation\/GLib\/TimeZone\/init(_:)-6hi6j","doc:\/\/GLib\/documentation\/GLib\/TimeZone\/init(_:)-8wflv","doc:\/\/GLib\/documentation\/GLib\/TimeZone\/init(_:)-9sndc","doc:\/\/GLib\/documentation\/GLib\/TimeZone\/init(_:)-fwfq","doc:\/\/GLib\/documentation\/GLib\/TimeZone\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/TimeZone\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/TimeZone\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/TimeZone\/init(identiferOrUtc:)","doc:\/\/GLib\/documentation\/GLib\/TimeZone\/init(identifier:)","doc:\/\/GLib\/documentation\/GLib\/TimeZone\/init(offset:)","doc:\/\/GLib\/documentation\/GLib\/TimeZone\/init(opaquePointer:)","doc:\/\/GLib\/documentation\/GLib\/TimeZone\/init(raw:)-3dq4s","doc:\/\/GLib\/d