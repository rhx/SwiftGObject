aragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"See your C library manual for more details about "},{"code":"open()","type":"codeVoice"},{"type":"text","text":"."}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"sections":[],"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/open(filename:flags:mode:)","interfaceLanguage":"swift"},"references":{"doc://GLib/documentation/GLib/open(filename:flags:mode:)":{"type":"topic","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"open","kind":"identifier"},{"kind":"text","text":"("},{"text":"filename","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":", "},{"kind":"externalParam","text":"mode"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"url":"\/documentation\/glib\/open(filename:flags:mode:)","title":"open(filename:flags:mode:)","abstract":[{"type":"text","text":"A wrapper for the POSIX "},{"type":"codeVoice","code":"open()"},{"text":" function. The ","type":"text"},{"type":"codeVoice","code":"open()"},{"type":"text","text":" function is"},{"text":" ","type":"text"},{"type":"text","text":"used to convert a pathname into a file descriptor."}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/open(filename:flags:mode:)","kind":"symbol"},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"to