["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"On POSIX systems file descriptors are implemented by the operating","type":"text"},{"type":"text","text":" "},{"type":"text","text":"system. On Windows, it’s the C library that implements "},{"type":"codeVoice","code":"open()"},{"type":"text","text":" and"},{"text":" ","type":"text"},{"text":"file descriptors. The actual Win32 API for opening files is quite","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"different, see MSDN documentation for "},{"type":"codeVoice","code":"CreateFile()"},{"text":". The Win32 API","type":"text"},{"type":"text","text":" "},{"type":"text","text":"uses file handles, which are more randomish integers, not small"},{"text":" ","type":"text"},{"text":"integers like file descriptors.","type":"text"}]},{"inlineContent":[{"text":"Because file descriptors are specific to the C library on Windows,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the file descriptor returned by this function makes sense only to"},{"type":"text","text":" "},{"type":"text","text":"functions in the same C library. Thus if the GLib-using code uses a"},{"text":" ","type":"text"},{"type":"text","text":"different C library than GLib does, the file descriptor returned by"},{"type":"text","text":" "},{"text":"this function cannot be passed to C library functions like ","type":"text"},{"code":"write()","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"or "},{"type":"codeVoice","code":"read()"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"See your C library manual for more details about ","type":"text"},{"code":"open()","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"kind":"content"}],"abstract":[{"text":"A wrapper for the POSIX ","type":"text"},{"type":"codeVoice","code":"open()"},{"text":" function. The ","type":"text"},{"type":"codeVoice","code":"open()"},{"type":"text","text":" function is"},{"text":" ","type":"text"},{"text":"used to convert a pathname into a file descriptor.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/open(filename:flags:mode:)"]}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/open(filename:flags:mode:)"},"references":{"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/open(filename:flags:mode:)":{"role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"open","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"filename"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"mode"},{"kind":"text","text":": "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"kind":"symbol","title":"open(filename:flags:mode:)","abstract":[{"type":"text","text":"A wrapper for the POSIX "},{"code":"open()","type":"codeVoice"},{"type":"text","text":" function. The "},{"code":"open()","type":"codeVoice"},{"text":" function is","type":"text"},{"text":" ","type":"text"},{"text":"used to convert a pathname into a file descriptor.","type":"text"}],"url":"\/documentation\/glib\/open(filename:flags:mode:)","type":"topic","id