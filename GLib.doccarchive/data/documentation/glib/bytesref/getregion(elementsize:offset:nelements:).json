type":"text"},{"code":"NULL","type":"codeVoice"},{"text":" pointer if the","type":"text"},{"type":"text","text":" "},{"text":"specified region lies entirely within the ","type":"text"},{"code":"bytes","type":"codeVoice"},{"type":"text","text":". If the region is"},{"type":"text","text":" "},{"type":"text","text":"in some way out of range, or if an overflow has occurred, then "},{"code":"NULL","type":"codeVoice"},{"type":"text","text":" "},{"text":"is returned.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Note: it is possible to have a valid zero-size region. In this case,"},{"type":"text","text":" "},{"text":"the returned pointer will be equal to the base pointer of the data of","type":"text"},{"text":" ","type":"text"},{"code":"bytes","type":"codeVoice"},{"text":", plus ","type":"text"},{"code":"offset","type":"codeVoice"},{"type":"text","text":".  This will be non-"},{"code":"NULL","type":"codeVoice"},{"text":" except for the case","type":"text"},{"type":"text","text":" "},{"type":"text","text":"where "},{"type":"codeVoice","code":"bytes"},{"text":" itself was a zero-sized region.  Since it is unlikely","type":"text"},{"type":"text","text":" "},{"text":"that you will be using this function to check for a zero-sized region","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"in a zero-sized "},{"type":"codeVoice","code":"bytes"},{"type":"text","text":", "},{"type":"codeVoice","code":"NULL"},{"text":" effectively always means ‘error’.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"metadata":{"title":"getRegion(elementSize:offset:nElements:)","roleHeading":"Instance Method","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"getRegion","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"elementSize"},{"kind":"text","text":": "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"offset","kind":"externalP