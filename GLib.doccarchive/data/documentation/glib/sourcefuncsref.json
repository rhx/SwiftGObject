{"kind":"symbol","topicSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/init(_:)-1il83","doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/init(_:)-5idr3","doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/init(_:)-891i5","doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/init(_:)-937im","doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/init(_:)-9qm49","doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/init(constPointer:)","doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/init(mutating:)","doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/init(opaquePointer:)"],"generated":true,"anchor":"Initializers","title":"Initializers"},{"title":"Instance Properties","identifiers":["doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/ptr"],"generated":true,"anchor":"Instance-Properties"},{"title":"Default Implementations","identifiers":["doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/PointerWrapper-Implementations","doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/SourceFuncsProtocol-Implementations"],"anchor":"Default-Implementations","generated":true}],"metadata":{"symbolKind":"struct","modules":[{"name":"GLib"}],"role":"symbol","externalID":"s:4GLib14SourceFuncsRefV","navigatorTitle":[{"text":"SourceFuncsRef","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"SourceFuncsRef","kind":"identifier"}],"title":"SourceFuncsRef","roleHeading":"Structure"},"abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"GSourceFuncs"},{"type":"text","text":" struct contains a table of"},{"type":"text","text":" "},{"type":"text","text":"functions used to handle event sources in a generic manner."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"SourceFuncsRef"}]}]},{"content":[{"text":"Overview","type":"heading","level":2,"anchor":"overview"},{"inlineContent":[{"type":"text","text":"For idle sources, the prepare and check functions always return "},{"type":"codeVoice","code":"true"},{"type":"text","text":" "},{"type":"text","text":"to indicate that the source is always ready to be processed. The prepare"},{"text":" ","type":"text"},{"type":"text","text":"function also returns a timeout value of 0 to ensure that the "},{"type":"codeVoice","code":"poll()"},{"type":"text","text":" call"},{"text":" ","type":"text"},{"type":"text","text":"doesn’t block (since that would be time wasted which could have been spent"},{"type":"text","text":" "},{"type":"text","text":"running the idle function)."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For timeout sources, the prepare and check functions both return "},{"type":"codeVoice","code":"true"},{"type":"text","text":" "},{"text":"if the timeout interval has expired. The prepare function also returns","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a timeout value to ensure that the "},{"type":"codeVoice","code":"poll()"},{"type":"text","text":" call doesn’t block too long"},{"type":"text","text":" "},{"text":"and miss the next timeout.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"For file descriptor sources, the prepare function typically returns ","type":"text"},{"type":"codeVoice","code":"false"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"since it must wait until "},{"code":"poll()","type":"codeVoice"},{"text":" has been called before it knows whether","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"any events need to be processed. It sets the returned timeout to -1 to"},{"type":"text","text":" "},{"type":"text","text":"indicate that it doesn’t mind how long the "},{"type":"codeVoice","code":"poll()"},{"type":"text","text":" call blocks. In the"},{"text":" ","type":"text"},{"type":"text","text":"check function, it tests the results of the "},{"code":"poll()","type":"codeVoice"},{"type":"text","text":" call to see if the"},{"text":" ","type":"text"},{"text":"required condition has been met, and returns ","type":"text"},{"code":"true","type":"codeVoice"},{"type":"text","text":" if so."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef","type":"reference"},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GSourceFuncs"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsProtocol"},{"text":" conformance.","type":"text"},{"type":"text","text":" "},{"text":"Use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef"},{"type":"text","text":" only as an "},{"type":"codeVoice","code":"unowned"},{"type":"text","text":" reference to an existing "},{"type":"codeVoice","code":"GSourceFuncs"},{"text":" instance.","type":"text"}]},{"type":"aside","name":"Note","style":"note","content":[{"inlineContent":[{"type":"text","text":"Use "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncs","type":"reference"},{"type":"text","text":" (instead of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef"},{"type":"text","text":") if you want to use Automatic Reference Counting for memory management of the underlying "},{"type":"codeVoice","code":"GSourceFuncs"},{"text":" instance.","type":"text"}],"type":"parag