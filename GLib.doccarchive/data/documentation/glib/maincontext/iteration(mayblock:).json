{"metadata":{"title":"iteration(mayBlock:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"iteration"},{"text":"(","kind":"text"},{"text":"mayBlock","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"extendedModule":"GLib","roleHeading":"Instance Method","symbolKind":"method","externalID":"s:4GLib19MainContextProtocolPAAE9iteration8mayBlockS2b_tF::SYNTHESIZED::s:4GLib11MainContextC","modules":[{"name":"GLib"}],"role":"symbol"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/MainContext","doc:\/\/GLib\/documentation\/GLib\/MainContext\/MainContextProtocol-Implementations"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"iteration","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"mayBlock"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"This involves","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"checking to see if any event sources are ready to be processed,"},{"text":" ","type":"text"},{"text":"then if no events sources are ready and ","type":"text"},{"code":"mayBlock","type":"codeVoice"},{"type":"text","text":" is true, waiting"},{"type":"text","text":" "},{"text":"for a source to become ready, then dispatching the highest priority","type":"text"},{"type":"text","text":" "},{"text":"events sources that are ready. Otherwise, if ","type":"text"},{"code":"mayBlock","type":"codeVoice"},{"text":" is false,","type":"text"},{"type":"text","text":" "},{"text":"this function does not wait for sources to become ready, and only the highest","type":"text"},{"type":"text","text":" "},{"type":"text","text":"priority sources which are already ready (if any) will be dispatched."}]},{"inlineContent":[{"text":"Note that even when ","type":"text"},{"code":"mayBlock","type":"codeVoice"},{"type":"text","text":" is true, it is still possible for"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.MainContext.iteration"},{"text":"] to return false, since the wait may","type":"text"},{"type":"text","text":" "},{"type":"text","text":"be interrupted for other reasons than an event source becoming ready."}],"type":"paragraph"}]}],"abstract":[{"type":"text","text":"Runs a single iteration for the given main loop."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/MainContext\/iteration(mayBlock:)"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/maincontext\/iteration(mayblock:)"]}],"kind":"symbol","references":{"doc://GLib/documentation/GLib/MainContext/MainContextProtocol-Implementations":{"type":"topic","abstract":[],"role":"collectionGroup","kind":"article","url":"\/documentation\/glib\/maincontext\/maincontextprotocol-implementations","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext\/MainContextProtocol-Implementations","title":"MainContextProtocol Implementations"},"doc://GLib/documentation/GLib/MainContext/iteration(mayBlock:)":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext\/iteration(mayBlock:)","type":"topic","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"iteration","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"mayBlock"},{"text"