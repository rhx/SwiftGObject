"},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"context"},{"text":" is ","type":"text"},{"code":"NULL","type":"codeVoice"},{"type":"text","text":" then the global-default main context — as"},{"type":"text","text":" "},{"type":"text","text":"returned by [func"},{"type":"codeVoice","code":"GLib.MainContext.default"},{"type":"text","text":"] — is used."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"context"},{"type":"text","text":" is owned by the current thread, "},{"type":"codeVoice","code":"function"},{"type":"text","text":" is called"},{"type":"text","text":" "},{"type":"text","text":"directly.  Otherwise, if "},{"type":"codeVoice","code":"context"},{"text":" is the thread-default main context","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of the current thread and [method"},{"code":"GLib.MainContext.acquire","type":"codeVoice"},{"text":"] succeeds,","type":"text"},{"type":"text","text":" "},{"text":"then ","type":"text"},{"type":"codeVoice","code":"function"},{"type":"text","text":" is called and [method"},{"code":"GLib.MainContext.release","type":"codeVoice"},{"type":"text","text":"] is called"},{"text":" ","type":"text"},{"type":"text","text":"afterwards."}]},{"inlineContent":[{"type":"text","text":"In any other case, an idle source is created to call "},{"code":"function","type":"codeVoice"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"text","text":"that source is attached to "},{"type":"codeVoice","code":"context"},{"type":"text","text":" (presumably to be run in another"},{"text":" ","type":"text"},{"text":"thread).  The idle source is attached with [const","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/priorityDefault"},{"text":"]","type":"text"},{"type":"text","text":" "},{"text":"priority.  If you want a different priority, use","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GLib.MainContext.invoke_full"},{"type":"text","text":"]."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that, as with normal idle functions, "},{"type":"codeVoice","code":"function"},{"text":" should probably return","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[const"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/sourceRemove","type":"reference","isActive":true},{"type":"text","text":"].  If it returns [const"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/sourceContinue"},{"type":"text","text":"], it"},{"text":" ","type":"text"},{"type":"text","text":"will be continuously run in a loop (and may prevent this call from returning)."}]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/MainContext\/invoke(function:data:)","interfaceLanguage":"swift"},"sections":[],"kind":"symbol","variants":[{"paths":["\/documentation\/glib\/maincontext\/invoke(function:data:)"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GLib/documentation/GLib/MainContext/invoke(function:data:)":{"title":"invoke(function:data:)","type":"topic","url":"\/documentation\/glib\/maincontext\/invoke(function:data:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"invoke"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"function"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GSourceFunc","text":"GSourceFunc"},{"text":"?, ","kind":"text"},{"text":"data","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"gpointer","preciseIdentifier":"c:@T@gpointer","kind":"typeIdentifier"},{"text":"?)","kind":"text"}],"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext\/invoke(function:data:)","abstract":[{"type":"text","text":"Invokes a function in s