{"metadata":{"role":"symbol","symbolKind":"method","modules":[{"name":"GLib"}],"extendedModule":"GLib","title":"pushThreadDefault()","externalID":"s:4GLib19MainContextProtocolPAAE17pushThreadDefaultyyF::SYNTHESIZED::s:4GLib11MainContextC","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"pushThreadDefault","kind":"identifier"},{"kind":"text","text":"()"}],"roleHeading":"Instance Method"},"sections":[],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/MainContext\/pushThreadDefault()","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/MainContext","doc:\/\/GLib\/documentation\/GLib\/MainContext\/MainContextProtocol-Implementations"]]},"kind":"symbol","schemaVersion":{"patch":0,"minor":3,"major":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/maincontext\/pushthreaddefault()"]}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"pushThreadDefault"},{"kind":"text","text":"()"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Normally you would call this function shortly after creating a new","type":"text"},{"text":" ","type":"text"},{"text":"thread, passing it a [struct","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext"},{"type":"text","text":"] which will be run by a"},{"type":"text","text":" "},{"text":"[struct","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainLoop"},{"text":"] in that thread, to set a new default context for all","type":"text"},{"type":"text","text":" "},{"type":"text","text":"async operations in that thread. In this case you may not need to"},{"type":"text","text":" "},{"type":"text","text":"ever call [method"},{"code":"GLib.MainContext.pop_thread_default","type":"codeVoice"},{"text":"], assuming you want","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the new [struct"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","type":"reference","isActive":true},{"text":"] to be the default for the whole lifecycle","type":"text"},{"type":"text","text":" "},{"text":"of the thread.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If you don’t have control over how the new thread was created (e.g.","type":"text"},{"text":" ","type":"text"},{"text":"in the new thread isn’t newly created, or if the thread life","type":"text"},{"text":" ","type":"text"},{"text":"cycle is managed by a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/ThreadPool","type":"reference"},{"text":"), it is always suggested to wrap","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the logic that needs to use the new [struct"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext"},{"type":"text","text":"] inside a"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"code":"GLib.MainContext.push_thread_default","type":"codeVoice"},{"text":"] \/","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GLib.MainContext.pop_thread_default"},{"type":"text","text":"] pair, otherwise threads that"},{"type":"text","text":" "},{"type":"text","text":"are re-used will end up never explicitly releasing the"},{"type":"text","text":" "},{"text":"[struct","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext"},{"type":"text","text":"] reference they hold."}]},{"type":"paragraph","inlineContent":[{"text":"In some cases you may want to schedule a single operation in a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"non-default context, or temporarily use a non-default context in"},{"text":" ","type":"text"},{"type":"text","text":"the main thread. In that case, you can wrap the call to the"},{"text":" ","type":"text"},{"text":"asynchronous operation inside a","type":"text"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.MainContext.push_thread_default"},{"text":"] \/","type":"text"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.MainContext.pop_thread_default"},{"text":"] pair, but it is up to you to","type":"text"},{"text":" ","type":"text"},{"text":"ensure that no other asynchronous operations accidentally get","type":"text"},{"type":"text","text":" "},{"text":"started while the non-default context is active.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Beware that libraries that predate this function may not correctly"},{"type":"text","text":" "},{"text":"handle being used from a thread with a thread-default context. For example,","type":"text"},{"type":"text","text":" "},{"text":"see ","type":"text"},{"code":"g_file_supports_thread_contexts()","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]}],"abstract":[{"type":"text","text":"Acquires "},{"code":"context","type":"codeVoice"},{"type":"text","text":" and sets it as the thread-default context for the"},{"text":" ","type":"text"},{"text":"current thread. This will cause certain asynchronous operations","type":"text"},{"text":" ","type":"text"},{"text":"(such as most ","type":"text"},{"isActive":true,"type":"reference","identifier":"..\/gio\/index.html"},{"type":"text","text":"-based I\/O) which are"},{"type":"text","text":" "},{"type":"text","text":"started in this thread to run under "},{"type":"codeVoice","code":"context"},{"type":"text","text":" and deliver their"},{"text":" ","type":"text"},{"type":"text","text":"results to its main loop, rather than running under the global"},{"type":"text","text":" "},{"text":"default main context in the main thread. Note that calling this function","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"changes the context returned by [func"},{"code":"GLib.MainContext.get_thread_default","type":"codeVoice"},{"text":"],","type":"text"},{"type":"text","text":" "},{"text":"not the one returned by [func","type":"text"},{"type":"codeVoice","code":"GLib.MainContext.default"},{"text":"], so it does not","type":"text"},{"type":"text","text":" "},{"type":"text","text":"affect the context used by functions like [func"},{"code":"GLib.idle_add","type":"codeVoice"},{"text":"].","type":"text"}],"references":{"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"../gio/index.html":{"identifier":"..\/gio\/index.html","title":"Gio","titleInlineContent":[{"text":"Gio","type":"text"}],"url":"..\/gio\/index.html","type":"link"},"doc://GLib/documentation/GLib/MainLoop":{"abstract":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"GMainLoop"},{"type":"text","text":" struct is an opaque data type"},{"text":" ","type":"text"},{"text":"representing the main event loop of a GLib or GTK application.","type":"text"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"MainLoop","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainLoop","type":"topic","navigatorTitle":[{"kind":"identifier","text":"MainLoop"}],"title":"MainLoop","role":"symbol","url":"\/documentation\/glib\/mainloop"},"doc://GLib/documentation/GLib/MainContext/pushThreadDefault()":{"url":"\/documentation\/glib\/maincontext\/pushthreaddefault()","abstract":[{"type":"text","text":"Acquires "},{"code":"context","type":"codeVoice"},{"type":"text","text":" and sets it as the thread-default context for the"},{"text":" ","type":"text"},{"text":"current thread. This will cause certain asynchronous operations","type":"text"},{"type":"text","text":" "},{"text":"(such as most ","type":"text"},{"type":"reference","isActive":true,"identifier":"..\/gio\/index.html"},{"type":"text","text":"-based I\/O) which are"},{"text":" ","type":"text"},{"text":"started in this thread to run under ","type":"text"},{"type":"codeVoice","code":"context"},{"text":" and deliver their","type":"text"},{"text":" ","type":"text"},{"text":"results to its main loop, rather than running under the global","type":"text"},{"type":"text","text":" "},{"text":"default main context in the main thread. Note that calling this function","type":"text"},{"text":" ","type":"text"},{"text":"changes the context returned by [func","type":"text"},{"type":"codeVoice","code":"GLib.MainContext.get_thread_default"},{"text":"],","type":"text"},{"text":" ","type":"text"},{"text":"not the one returned by [func","type":"text"},{"code":"GLib.MainContext.default","type":"codeVoice"},{"type":"text","text":"], so it does not"},{"text":" ","type":"text"},{"type":"text","text":"affect the context used by functions like [func"},{"type":"codeVoice","code":"GLib.idle_add"},{"text":"].","type":"text"}],"type":"topic","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"pushThreadDefault","kind":"identifier"},{"text":"()","kind":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext\/pushThreadDefault()","kind":"symbol","role":"symbol","title":"pushThreadDefault()"},"doc://GLib/documentation/GLib/MainContext/MainContextProtocol-Implementations":{"role":"collectionGroup","url":"\/documentation\/glib\/maincontext\/maincontextprotocol-implementations","abstract":[],"type":"topic","title":"MainContextProtocol Implementations","kind":"article","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext\/MainContextProtocol-Implementations"},"doc://GLib/documentation/GLib/MainContext":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MainContext"}],"url":"\/documentation\/glib\/maincontext","kind":"symbol","abstract":[{"type":"text","text":"The "},{"code":"GMainContext","type":"codeVoice"},{"type":"text","text":" struct is an opaque data"},{"text":" ","type":"text"},{"text":"type representing a set of sources to be handled in a main loop.","type":"text"}],"title":"MainContext","role":"symbol","navigatorTitle":[{"text":"MainContext","kind":"identifier"}]},"doc://GLib/documentation/GLib/ThreadPool":{"abstract":[{"type":"text","text":"The "},{"code":"GThreadPool","type":"codeVoice"},{"type":"text","text":" struct represents a thread pool."}],"role":"symbol","url":"\/documentation\/glib\/threadpool","identifier":"doc:\/\/GLib\/documentation\/GLib\/ThreadPool","title":"ThreadPool","kind":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ThreadPool"}],"navigatorTitle":[{"kind":"identifier","text":"ThreadPool"}]}}}