{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/spawnCheck(waitStatus:)","interfaceLanguage":"swift"},"kind":"symbol","primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"spawnCheck","kind":"identifier"},{"text":"(","kind":"text"},{"text":"waitStatus","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"text":") ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}]}],"kind":"declarations"},{"content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"g_spawn_sync()"},{"type":"text","text":" and "},{"code":"g_child_watch_add()","type":"codeVoice"},{"type":"text","text":" family of APIs return the"},{"type":"text","text":" "},{"text":"status of subprocesses encoded in a platform-specific way.","type":"text"},{"type":"text","text":" "},{"text":"On Unix, this is guaranteed to be in the same format ","type":"text"},{"type":"codeVoice","code":"waitpid()"},{"type":"text","text":" returns,"},{"type":"text","text":" "},{"type":"text","text":"and on Windows it is guaranteed to be the result of "},{"code":"GetExitCodeProcess()","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Prior to the introduction of this function in GLib 2.34, interpreting"},{"text":" ","type":"text"},{"type":"codeVoice","code":"waitStatus"},{"type":"text","text":" required use of platform-specific APIs, which is problematic"},{"type":"text","text":" "},{"text":"for software using GLib as a cross-platform layer.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Additionally, many programs simply want to determine whether or not","type":"text"},{"type":"text","text":" "},{"text":"the child exited successfully, and either propagate a ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/GLibError","isActive":true},{"type":"text","text":" or"},{"text":" ","type":"text"},{"text":"print a message to standard error. In that common case, this function","type":"text"},{"text":" ","type":"text"},{"text":"can be used. Note that the error message in ","type":"text"},{"code":"error","type":"codeVoice"},{"type":"text","text":" will contain"},{"type":"text","text":" "},{"type":"text","text":"human-readable information about the wait status."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"domain"},{"type":"text","text":" and "},{"code":"code","type":"codeVoice"},{"type":"text","text":" of "},{"code":"error","type":"codeVoice"},{"type":"text","text":" have special semantics in the case"},{"type":"text","text":" "},{"type":"text","text":"where the process has an “exit code”, as opposed to being killed by"},{"type":"text","text":" "},{"text":"a signal. On Unix, this happens if ","type":"text"},{"type":"codeVoice","code":"WIFEXITED()"},{"type":"text","text":" would be true of"},{"text":" ","type":"text"},{"type":"codeVoice","code":"waitStatus"},{"text":". On Windows, it is always the case.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The special semantics are that the actual exit code will be the"},{"text":" ","type":"text"},{"type":"text","text":"code set in "},{"code":"error","type":"codeVoice"},{"text":", and the domain will be ","type":"text"},{"type":"codeVoice","code":"G_SPAWN_EXIT_ERROR"},{"type":"text","text":"."},{"text":" ","type":"text"},{"type":"text","text":"This allows you to differentiate between different exit codes."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the process was terminated by some means other than an exit"},{"type":"text","text":" "},{"type":"text","text":"status (for example if it was killed by a signal), the domain will be"},{"text":" ","type":"text"},{"code":"G_SPAWN_ERROR","type":"codeVoice"},{"type":"text","text":" and the code will be "},{"type":"codeVoice","code":"failed"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function just offers convenience; you can of course also check"},{"type":"text","text":" "},{"type":"text","text":"the available platform via a macro such as "},{"type":"codeVoice","code":"G_OS_UNIX"},{"type":"text","text":", and use"},{"type":"text","text":" "},{"type":"codeVoice","code":"WIFEXITED()"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"WEXITSTATUS()"},{"type":"text","text":" on "},{"type":"codeVoice","code":"waitStatus"},{"type":"text","text":" directly. Do not attempt"},{"text":" ","type":"text"},{"text":"to scan or parse the error message string; it may be translated and\/or","type":"text"},{"type":"text","text":" "},{"type":"text","text":"change in future versions of GLib."}]},{"inlineContent":[{"type":"text","text":"Prior to version 2.70, "},{"type":"codeVoice","code":"g_spawn_check_exit_status()"},{"text":" provides the same","type":"text"},{"type":"text","text":" "},{"type":"text","text":"functionality, although under a misleading name."}],"type":"paragraph"}],"kind":"content"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/spawncheck(waitstatus:)"]}],"metadata":{"role":"symbol","title":"spawnCheck(waitStatus:)","externalID":"s:4GLib10spawnCheck10waitStatusSbSi_tKF","roleHeading":"Function","symbolKind":"func","modules":[{"name":"GLib"}],"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"spawnCheck","kind":"identifier"},{"text":"(","kind":"text"},{"text":"waitStatus","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":") "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}]},"sections":[],"abstract":[{"text":"Set ","type":"text"},{"code":"error","type":"codeVoice"},{"type":"text","text":" if "},{"type":"codeVoice","code":"waitStatus"},{"type":"text","text":" indicates the child exited abnormally"},{"text":" ","type":"text"},{"text":"(e.g. with a nonzero exit code, or via a fatal signal).","type":"text"}],"references":{"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/spawnCheck(waitStatus:)":{"abstract":[{"type":"text","text":"Set "},{"code":"error","type":"codeVoice"},{"text":" if ","type":"text"},{"code":"waitStatus","type":"codeVoice"},{"type":"text","text":" indicates the child exited abnormally"},{"text":" ","type":"text"},{"type":"text","text":"(e.g. with a nonzero exit code, or via a fatal signal)."}],"title":"spawnCheck(waitStatus:)","identifier":"doc:\/\/GLib\/documentation\/GLib\/spawnCheck(waitStatus:)","url":"\/documentation\/glib\/spawncheck(waitstatus:)","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"spawnCheck","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"waitStatus"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"kind":"symbol","type":"topic"},"doc://GLib/documentation/GLib/GLibError":{"title":"GLibError","identifier":"doc:\/\/GLib\/documentation\/GLib\/GLibError","navigatorTitle":[{"text":"GLibError","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/glib\/gliberror","abstract":[{"text":"The ","type":"text"},{"code":"GError","type":"codeVoice"},{"text":" structure contains information about","type":"text"},{"type":"text","text":" "},{"text":"an error that has occurred.","type":"text"}],"type":"topic","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"GLibError","kind":"identifier"}]}}}