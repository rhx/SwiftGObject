{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"pathIsAbsolute"},{"text":"(","kind":"text"},{"text":"fileName","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">!) -> ","kind":"text"},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"On POSIX systems, an absolute file name is well-defined. It always"},{"text":" ","type":"text"},{"type":"text","text":"starts from the single root directory. For example “\/usr\/local”."}]},{"type":"paragraph","inlineContent":[{"text":"On Windows, the concepts of current drive and drive-specific","type":"text"},{"type":"text","text":" "},{"text":"current directory introduce vagueness. This function interprets as","type":"text"},{"type":"text","text":" "},{"text":"an absolute file name one that either begins with a directory","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"separator such as “\\Users\\tml” or begins with the root on a drive,"},{"text":" ","type":"text"},{"text":"for example “C:\\Windows”. The first case also includes UNC paths","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"such as “\\\\myserver\\docs\\foo”. In all cases, either slashes or"},{"type":"text","text":" "},{"type":"text","text":"backslashes are accepted."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that a file name relative to the current drive root does not"},{"type":"text","text":" "},{"type":"text","text":"truly specify a file uniquely over time and across processes, as"},{"text":" ","type":"text"},{"type":"text","text":"the current drive is a per-process value and can be changed."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"File names relative the current directory on some specific drive,"},{"type":"text","text":" "},{"text":"such as “D:foo\/bar”, are not interpreted as absolute by this","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"function, but they obviously are not relative to the normal current"},{"text":" ","type":"text"},{"type":"text","text":"directory as returned by "},{"code":"getcwd()","type":"codeVoice"},{"type":"text","text":" or "},{"type":"codeVoice","code":"g_get_current_dir()"},{"type":"text","text":" "},{"type":"text","text":"either. Such paths should be avoided, or need to be handled using"},{"text":" ","type":"text"},{"text":"Windows-specific code.","type":"text"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/pathisabsolute(filename:)"]}],"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"Returns "},{"code":"true","type":"codeVoice"},{"type":"text","text":" if the given "},{"code":"fileName","type":"codeVoice"},{"text":" is an absolute file name.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Note that this is a somewhat vague concept on Windows."}],"metadata":{"role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"pathIsAbsolute"},{"kind":"text","text":"("},{"text":"fileName","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier","text":"gchar"},{"text":">!) -> ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"symbolKind":"func","externalID":"s:4GLib14pathIsAbsolute8fileNameSbSPys4Int8VGSg_tF","modules":[{"name":"GLib"}],"roleHeading":"Function","title":"pathIsAbsolute(fileName:)"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/pathIsAbsolute(fileName:)"},"references":{"doc://GLib/documentation/GLib/pathIsAbsolute(fileName:)":{"abstract":[{"type":"text","text":"Returns "},{"type":"codeVoice","code":"true"},{"type":"text","text":" if the given "},{"code":"fileName","type":"codeVoice"},{"text":" is an absolute file name.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Note that this is a somewhat vague concept on Windows."}],"url":"\/documentation\/glib\/pathisabsolute(filename:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"pathIsAbsolute"},{"text":"(","kind":"text"},{"text":"fileName","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"kind":"text","text":">!) -> "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/pathIsAbsolute(fileName:)","title":"pathIsAbsolute(fileName:)","kind":"symbol","type":"topic"},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"}}}