","type":"text"},{"code":"mayBlock","type":"codeVoice"},{"text":" is true, waiting","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"for a source to become ready, then dispatching the highest priority"},{"type":"text","text":" "},{"text":"events sources that are ready. Otherwise, if ","type":"text"},{"type":"codeVoice","code":"mayBlock"},{"type":"text","text":" is false,"},{"type":"text","text":" "},{"type":"text","text":"this function does not wait for sources to become ready, and only the highest"},{"text":" ","type":"text"},{"type":"text","text":"priority sources which are already ready (if any) will be dispatched."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that even when "},{"code":"mayBlock","type":"codeVoice"},{"type":"text","text":" is true, it is still possible for"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.MainContext.iteration"},{"text":"] to return false, since the wait may","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"be interrupted for other reasons than an event source becoming ready."}]}]}],"references":{"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/MainContextProtocol/iteration(mayBlock:)":{"kind":"symbol","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"iteration","kind":"identifier"},{"kind":"text","text":"("},{"text":"mayBlock","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"type":"topic","title":"iteration(mayBlock:)","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContextProtocol\/iteration(mayBlock:)","url":"\/document