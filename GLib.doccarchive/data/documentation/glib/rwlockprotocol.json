{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/rwlockprotocol"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"RWLockProtocol","kind":"identifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:4GLib14PointerWrapperP","identifier":"doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","text":"PointerWrapper","kind":"typeIdentifier"}],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Overview","anchor":"overview","type":"heading","level":2},{"inlineContent":[{"text":"The difference to a mutex is that a reader-writer lock discriminates","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"between read-only (‘reader’) and full (‘writer’) access. While only"},{"type":"text","text":" "},{"text":"one thread at a time is allowed write access (by holding the ‘writer’","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"lock via "},{"type":"codeVoice","code":"g_rw_lock_writer_lock()"},{"type":"text","text":"), multiple threads can gain"},{"text":" ","type":"text"},{"type":"text","text":"simultaneous read-only access (by holding the ‘reader’ lock via"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_rw_lock_reader_lock()"},{"text":").","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is unspecified whether readers or writers have priority in acquiring the"},{"type":"text","text":" "},{"text":"lock when a reader already holds the lock and a writer is queued to acquire","type":"text"},{"type":"text","text":" "},{"text":"it.","type":"text"}]},{"inlineContent":[{"text":"Here is an example for an array with access functions:","type":"text"},{"type":"text","text":" "},{"text":"(C Language Example):","type":"text"}],"type":"paragraph"},{"code":["  GRWLock lock;","  GPtrArray *array;","","  gpointer","  my_array_get (guint index)","  {","    gpointer retval = NULL;","","    if (!array)","      return NULL;","","    g_rw_lock_reader_lock (&lock);","    if (index < array->len)","      retval = g_ptr_array_index (array, index);","    g_rw_lock_reader_unlock (&lock);","","    return retval;","  }","","  void","  my_array_set (guint index, gpointer data)","  {","    g_rw_lock_writer_lock (&lock);","","    if (!array)","      array = g_ptr_array_new ();","","    if (index >= array->len)","      g_ptr_array_set_size (array, index+1);","    g_ptr_array_index (array, index) = data;","","    g_rw_lock_writer_unlock (&lock);","  }"," "],"type":"codeListing","syntax":"C"},{"type":"paragraph","inlineContent":[{"text":"This example shows an array which can be accessed by many readers","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(the "},{"type":"codeVoice","code":"my_array_get()"},{"type":"text","text":" function) simultaneously, whereas the writers"},{"type":"text","text":" "},{"type":"text","text":"(the "},{"type":"codeVoice","code":"my_array_set()"},{"text":" function) will only be allowed one at a time","type":"text"},{"type":"text","text":" "},{"text":"and only if no readers currently access the array. This is because","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of the potentially dangerous resizing of the array. Using these"},{"text":" ","type":"text"},{"text":"functions is fully multi-thread safe now.","type":"text"}]},{"inlineContent":[{"text":"If a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLock"},{"type":"text","text":" is allocated in static storage then it can be used"},{"text":" ","type":"text"},{"type":"text","text":"without initialisation.  Otherwise, you should call"},{"type":"text","text":" "},{"code":"g_rw_lock_init()","type":"codeVoice"},{"type":"text","text":" on it and "},{"code":"g_rw_lock_clear()","type":"codeVoice"},{"text":" when done.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A GRWLock should only be accessed with the g_rw_lock_ functions."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol","type":"reference"},{"text":" protocol exposes the methods and properties of an underlying ","type":"text"},{"type":"codeVoice","code":"GRWLock"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"text":"The default implementation of these can be found in the protocol extension below.","type":"text"},{"text":" ","type":"text"},{"text":"For a concrete class that implements these methods and properties, see ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLock"},{"type":"text","text":"."},{"text":" ","type":"text"},{"type":"text","text":"Alternatively, use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockRef"},{"type":"text","text":" as a lighweight, "},{"type":"codeVoice","code":"unowned"},{"type":"text","text":" reference if you already have an instance you just want to use."}]}]}],"relationshipsSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper"],"kind":"relationships","title":"Inherits From","type":"inheritsFrom"},{"kind":"relationships","identifiers":["doc:\/\/GLib\/documentation\/GLib\/RWLock","doc:\/\/GLib\/documentation\/GLib\/RWLockRef"],"type":"conformingTypes","title":"Conforming Types"}],"abstract":[{"type":"text","text":"The GRWLock struct is an opaque data structure to represent a"},{"type":"text","text":" "},{"type":"text","text":"reader-writer lock. It is similar to a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex"},{"text":" in that it allows","type":"text"},{"type":"text","text":" "},{"text":"multiple threads to coordinate access to a shared resource.","type":"text"}],"sections":[],"kind":"s