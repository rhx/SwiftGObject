{"sections":[],"abstract":[{"type":"text","text":"The GRWLock struct is an opaque data structure to represent a"},{"type":"text","text":" "},{"text":"reader-writer lock. It is similar to a ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","isActive":true},{"text":" in that it allows","type":"text"},{"type":"text","text":" "},{"type":"text","text":"multiple threads to coordinate access to a shared resource."}],"variants":[{"paths":["\/documentation\/glib\/rwlockprotocol"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol"},"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"title":"RWLockProtocol","navigatorTitle":[{"kind":"identifier","text":"RWLockProtocol"}],"modules":[{"name":"GLib"}],"externalID":"s:4GLib14RWLockProtocolP","symbolKind":"protocol","role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"text":"RWLockProtocol","kind":"identifier"}],"roleHeading":"Protocol"},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RWLockProtocol","kind":"identifier"},{"kind":"text","text":" : "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","text":"PointerWrapper","preciseIdentifier":"s:4GLib14PointerWrapperP","kind":"typeIdentifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"type":"heading","anchor":"overview","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"The difference to a mutex is that a reader-writer lock discriminates","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"between read-only (‘reader’) and full (‘writer’) access. While only"},{"type":"text","text":" "},{"type":"text","text":"one thread at a time is allowed write access (by holding the ‘writer’"},{"text":" ","type":"text"},{"type":"text","text":"lock via "},{"type":"codeVoice","code":"g_rw_lock_writer_lock()"},{"type":"text","text":"), multiple threads can gain"},{"type":"text","text":" "},{"type":"text","text":"simultaneous read-only access (by holding the ‘reader’ lock via"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_rw_lock_reader_lock()"},{"type":"text","text":")."}]},{"type":"paragraph","inlineContent":[{"text":"It is unspecified whether readers or writers have priority in acquiring the","type":"text"},{"text":" ","type":"text"},{"text":"lock when a reader already holds the lock and a writer is queued to acquire","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"it."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Here is an example for an array with access functions:"},{"text":" ","type":"text"},{"type":"text","text":"(C Language Example):"}]},{"syntax":"C","type":"codeListing","code":["  GRWLock lock;","  GPtrArray *array;","","  gpointer","  my_array_get (guint index)","  {","    gpointer retval = NULL;","","    if (!array)","      return NULL;","","    g_rw_lock_reader_lock (&lock);","    if (index < array->len)","      retval = g_ptr_array_index (array, index);","    g_rw_lock_reader_unlock (&lock);","","    return retval;","  }","","  void","  my_array_set (guint index, gpointer data)","  {","    g_rw_lock_writer_lock (&lock);","","    if (!array)","      array = g_ptr_array_new ();","","    if (index >= array->len)","      g_ptr_array_set_size (array, index+1);","    g_ptr_array_index (array, index) = data;","","    g_rw_lock_writer_unlock (&lock);","  }"," "]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This example shows an array which can be accessed by many readers"},{"text":" ","type":"text"},{"text":"(the ","type":"text"},{"type":"codeVoice","code":"my_array_get()"},{"type":"text","text":" function) simultaneously, whereas the writers"},{"type":"text","text":" "},{"type":"text","text":"(the "},{"type":"codeVoice","code":"my_array_set()"},{"type":"text","text":" function) will only be allowed one at a time"},{"text":" ","type":"text"},{"text":"and only if no readers currently access the array. This is because","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of the potentially dangerous resizing of the array. Using these"},{"type":"text","text":" "},{"type":"text","text":"functions is fully multi-thread safe now."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If a "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLock","type":"reference"},{"text":" is allocated in static storage then it can be used","type":"text"},{"type":"text","text":" "},{"type":"text","text":"without initialisation.  Otherwise, you should call"},{"text":" ","type":"text"},{"code":"g_rw_lock_init()","type":"codeVoice"},{"type":"text","text":" on it and "},{"type":"codeVoice","code":"g_rw_lock_clear()"},{"type":"text","text":" when done."}]},{"inlineContent":[{"type":"text","text":"A GRWLock should only be accessed with the g_rw_lock_ functions."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol","isActive":true},{"text":" protocol exposes the methods and properties of an underlying ","type":"text"},{"code":"GRWLock","type":"codeVoice"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"The default implementation of these can be found in the protocol extension below."},{"text":" ","type":"text"},{"type":"text","text":"For a concrete class that implements these methods and properties, see "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLock","type":"reference"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Alternatively, use ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockRef"},{"type":"text","text":" as a lighweight, "},{"type":"codeVoice","code":"unowned"},{"type":"text","text":" reference if you already have an instance you just want to use."}]}],"kind":"content"}],"relationshipsSections":[{"kind":"relationships","type":"inheritsFrom","title":"Inherits From","identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper"]},{"type":"conformingTypes","kind":"relationships","identifiers":["doc:\/\/GLib\/documentation\/GLib\/RWLock","doc:\/\/GLib\/documentation\/GLib\/RWLockRef"],"title":"Conforming Types"}],"topicSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol\/clear()","doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol\/init_()","doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol\/readerLock()","doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol\/readerTrylock()","doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol\/readerUnlock()","doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol\/writerLock()","doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol\/writerTrylock()","doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol\/writerUnlock()"],"anchor":"Instance-Methods","generated":true,"title":"Instance Methods"}],"references":{"doc://GLib/documentation/GLib/RWLockProtocol/readerLock()":{"title":"readerLock()","abstract":[{"type":"text","text":"Obtain a read lock on "},{"type":"codeVoice","code":"rwLock"},{"type":"text","text":". If another thread currently holds"},{"type":"text","text":" "},{"type":"text","text":"the write lock on "},{"type":"codeVoice","code":"rwLock"},{"text":", the current thread will block until the","type":"text"},{"text":" ","type":"text"},{"text":"write lock was (held and) released. If another thread does not hold","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the write lock, but is waiting for it, it is implementation defined"},{"text":" ","type":"text"},{"type":"text","text":"whether the reader or writer will block. Read locks can be taken"},{"type":"text","text":" "},{"type":"text","text":"recursively."}],"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol\/readerLock()","type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"readerLock"},{"text":"()","kind":"text"}],"url":"\/documentation\/glib\/rwlockprotocol\/readerlock()"},"doc://GLib/documentation/GLib/RWLockProtocol/init_()":{"title":"init_()","abstract":[{"type":"text","text":"Initializes a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLock"},{"text":" so that it can be used.","type":"text"}],"url":"\/documentation\/glib\/rwlockprotocol\/init_()","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"init_"},{"text":"()","kind":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol\/init_()","type":"topic","role":"symbol"},"doc://GLib/documentation/GLib/RWLockProtocol/writerTrylock()":{"kind":"symbol","title":"writerTrylock()","abstract":[{"type":"text","text":"Tries to obtain a write lock on "},{"type":"codeVoice","code":"rwLock"},{"type":"text","text":". If another thread"},{"text":" ","type":"text"},{"text":"currently holds a read or write lock on ","type":"text"},{"type":"codeVoice","code":"rwLock"},{"text":", it immediately","type":"text"},{"text":" ","type":"text"},{"text":"returns ","type":"text"},{"type":"codeVoice","code":"false"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Otherwise it locks "},{"type":"codeVoice","code":"rwLock"},{"text":" and returns ","type":"text"},{"code":"true","type":"codeVoice"},{"text":".","type":"text"}],"role":"symbol","type":"topic","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"writerTrylock","kind":"identifier"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol\/writerTrylock()","url":"\/documentation\/glib\/rwlockprotocol\/writertrylock()"},"doc://GLib/documentation/GLib/RWLockProtocol/readerUnlock()":{"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"readerUnlock"},{"text":"()","kind":"text"}],"title":"readerUnlock()","url":"\/documentation\/glib\/rwlockprotocol\/readerunlock()","abstract":[{"text":"Release a read lock on ","type":"text"},{"type":"codeVoice","code":"rwLock"},{"type":"text","text":"."}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol\/readerUnlock()","kind":"symbol","type":"topic","role":"symbol"},"doc://GLib/documentation/GLib/PointerWrapper":{"fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"PointerWrapper"}],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","url":"\/documentation\/glib\/pointerwrapper","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"PointerWrapper"}],"kind":"symbol","title":"PointerWrapper","abstract":[{"type":"text","text":"Protocol for GLib types that wrap pointers."}]},"doc://GLib/documentation/GLib/RWLock":{"kind":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"RWLock","kind":"identifier"}],"abstract":[{"type":"text","text":"The GRWLock struct is an opaque data structure to represent a"},{"type":"text","text":" "},{"text":"reader-writer lock. It is similar to a ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","isActive":true},{"type":"text","text":" in that it allows"},{"text":" ","type":"text"},{"type":"text","text":"multiple threads to coordinate access to a shared resource."}],"type":"topic","title":"RWLock","url":"\/documentation\/glib\/rwlock","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"RWLock"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLock"},"doc://GLib/documentation/GLib/RWLockRef":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockRef","kind":"symbol","abstract":[{"text":"The GRWLock struct is an opaque data structure to represent a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"reader-writer lock. It is similar to a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex"},{"text":" in that it allows","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"multiple threads to coordinate access to a shared resource."}],"role":"symbol","navigatorTitle":[{"text":"RWLockRef","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"RWLockRef"}],"type":"topic","url":"\/documentation\/glib\/rwlockref","title":"RWLockRef"},"doc://GLib/documentation/GLib/RWLockProtocol/readerTrylock()":{"url":"\/documentation\/glib\/rwlockprotocol\/readertrylock()","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"readerTrylock","kind":"identifier"},{"kind":"text","text":"() -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"role":"symbol","title":"readerTrylock()","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol\/readerTrylock()","type":"topic","abstract":[{"text":"Tries to obtain a read lock on ","type":"text"},{"type":"codeVoice","code":"rwLock"},{"type":"text","text":" and returns "},{"type":"codeVoice","code":"true"},{"text":" if","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the read lock was successfully obtained. Otherwise it"},{"text":" ","type":"text"},{"type":"text","text":"returns "},{"code":"false","type":"codeVoice"},{"type":"text","text":"."}]},"doc://GLib/documentation/GLib/Mutex":{"kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","role":"symbol","abstract":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","type":"reference","isActive":true},{"text":" struct is an opaque data structure to represent a mutex","type":"text"},{"type":"text","text":" "},{"text":"(mutual exclusion). It can be used to protect data against shared","type":"text"},{"type":"text","text":" "},{"text":"access.","type":"text"}],"type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"Mutex","kind":"identifier"}],"title":"Mutex","navigatorTitle":[{"kind":"identifier","text":"Mutex"}],"url":"\/documentation\/glib\/mutex"},"doc://GLib/documentation/GLib/RWLockProtocol/writerLock()":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"writerLock","kind":"identifier"},{"text":"()","kind":"text"}],"title":"writerLock()","url":"\/documentation\/glib\/rwlockprotocol\/writerlock()","abstract":[{"type":"text","text":"Obtain a write lock on "},{"code":"rwLock","type":"codeVoice"},{"type":"text","text":". If another thread currently holds"},{"text":" ","type":"text"},{"type":"text","text":"a read or write lock on "},{"code":"rwLock","type":"codeVoice"},{"text":", the current thread will block","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"until all other threads have dropped their locks on "},{"code":"rwLock","type":"codeVoice"},{"type":"text","text":"."}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol\/writerLock()","kind":"symbol","type":"topic","role":"symbol"},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/RWLockProtocol/writerUnlock()":{"title":"writerUnlock()","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"writerUnlock","kind":"identifier"},{"text":"()","kind":"text"}],"abstract":[{"text":"Release a write lock on ","type":"text"},{"type":"codeVoice","code":"rwLock"},{"type":"text","t