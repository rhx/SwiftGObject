torTitle":[{"kind":"identifier","text":"RWLockProtocol"}],"type":"topic","role":"symbol"},"doc://GLib/documentation/GLib/PointerWrapper":{"abstract":[{"text":"Protocol for GLib types that wrap pointers.","type":"text"}],"role":"symbol","url":"\/documentation\/glib\/pointerwrapper","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","title":"PointerWrapper","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"PointerWrapper"}],"type":"topic","navigatorTitle":[{"text":"PointerWrapper","kind":"identifier"}]},"doc://GLib/documentation/GLib/RWLockRef":{"url":"\/documentation\/glib\/rwlockref","navigatorTitle":[{"kind":"identifier","text":"RWLockRef"}],"title":"RWLockRef","identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockRef","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"RWLockRef"}],"role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"The GRWLock struct is an opaque data structure to represent a"},{"text":" ","type":"text"},{"type":"text","text":"reader-writer lock. It is similar to a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex"},{"type":"text","text":" in that it allows"},{"type":"text","text":" "},{"text":"multiple threads to coordinate access to a shared resource.","type":"text"}]},"doc://GLib/documentation/GLib/RWLockProtocol/clear()":{"title":"clear()","abstract":[{"type":"text","text":"Frees the resources allocated to a lock with "},{"type":"codeVoice","code":"g_rw_lock_init()"},{"type":"text","text":"."}],"kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"clear"},{"text":"()","kind":"text"}],"url":"\/documentation\/glib\/rwlockprotocol\/clear()","role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol\/clear()","type":"topic"},"doc://GLib/documentation/GLib/RWLockProtocol/writerTrylock()":{"title":"writerTrylock()","url":"\/documentation\/glib\/rwlockprotocol\/writertrylock()","kind":"symbol","abstract":[{"type":"text","text":"Tries to obtain a write lock on "},{"type":"codeVoice","code":"rwLock"},{"type":"text","text":". If another thread"},{"type":"text","text":" "},{"type":"text","text":"currently holds a read or write lock on "},{"type":"codeVoice","code":"rwLock"},{"type":"text","text":", it immediately"},{"text":" ","type":"text"},{"type":"text","text":"returns "},{"type":"codeVoice","code":"false"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Otherwise it locks ","type":"text"},{"type":"codeVoice","code":"rwLock"},{"type":"text","text":" and returns "},{"type":"codeVoice","code":"true"},{"text":".","type":"text"}],"role":"symbol","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol\/writerTrylock()","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"writerTrylock"},{"kind":"text","text":"() -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}]},"doc://GLib/documentation/GLib/RWLockProtocol/readerLock()":{"url":"\/documentation\/glib\/rwlockprotocol\/readerlock()","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"readerLock","kind":"identifier"},{"kind":"text","text":"()"}],"type":"topic","abstract":[{"type":"text","text":"Obtain a read lock on "},{"code":"rwLock","type":"codeVoice"},{"type":"text","text":". If another thread currently holds"},{"type":"text","text":" "},{"type":"text","text":"the write lock on "},{"code":"rwLock","type":"codeVoice"},{"type":"text","text":", the current thread will block until the"},{"type":"text","text":" "},{"type":"text","text":"write lock was (held and) released. If another thread does not hold"},{"type":"text","text":" "},{"text":"the write lock, but is waiting for it, it is implementation defined","type":"text"},{"type":"text","text":" "},{"type":"text","text":"whether the reader or writer will block. Read locks can be taken"},{"type":"text","text":" "},{"text":"recursively.","type":"text"}],"role":"symbol","kind":"symbol","title":"readerLock()","identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol\/readerLock()"},"doc://GLib/documentation/GLib/RWLock":{"url":"\/documentation\/glib\/rwlock","navigatorTitle":[{"text":"RWLock","kind":"identifier"}],"title":"RWLock","identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLock","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"RWLock"}],"role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"The GRWLock struct is an opaque data structure to represent a"},{"text":" ","type":"text"},{"text":"reader-writer lock. It is similar to a ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","type":"reference","isActive":true},{"text":" in that it allows","type":"text"},{"type":"text","text":" "},{"text":"multiple threads to coordinate access to a shared resource.","type":"text"}]},"doc://GLib/documentation/GLib/RWLockProtocol/init_()":{"type":"topic","title":"init_()","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"init_"},{"text":"()","kind":"text"}],"kind":"symbol","abstract":[{"type":"text","text":"Initializes a "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLock","type":"reference","isActive":true},{"type":"text","text":" so that it can be used."}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol\/init_()","url":"\/documentation\/glib\/rwlockprotocol\/init_()"},"doc://GLib/documentation/GLib/Mutex":{"title":"Mutex","type":"topic","abstract":[{"text":"The ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex"},{"text":" struct is an opaque data structure to represent a mutex","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(mutual exclusion). It can be used to protect data against shared"},{"text":" ","type":"text"},{"text":"access.","type":"text"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Mutex"}],"navigatorTitle":[{"kind":"identifier","text":"Mutex"}],"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","url":"\/documentation\/glib\/mutex","kind":"symbol"},"doc://GLib/documentation/GLib/RWLockProtocol/writerLock()":{"title":"writerLock()","abstract":[{"text":"Obtain a write lock on ","type":"text"},{"type":"codeVoice","code":"rwLock"},{"type":"text","text":". If another thread currently holds"},{"type":"text","text":" "},{"text":"a read or write lock on ","type":"text"},{"code":"rwLock","type":"codeVoice"},{"type":"text","text":", the current thread will block"},{"type":"text","text":" "},{"type":"text","text":"until all other threads have dropped their locks on "},{"code":"rwLock","type":"codeVoice"},{"text":".","type":"text"}],"kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"writerLock"},{"text":"()","kind":"text"}],"url":"\/documentation\/glib\/rwlockprotocol\/writerlock()","role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol\/writerLock()","type":"topic"},"doc://GLib/documentation/GLib/RWLockProtocol/readerUnlock()":{"abstract":[{"text":"Release a read lock on ","type":"text"},{"type":"codeVoice","code":"rwLock"},{"type":"text","text":"."}],"title":"readerUnlock()","role":"symbol","kind":"symbol","url":"\/documentation\/glib\/rwlockprotocol\/readerunlock()","identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol\/readerUnlock()","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"readerUnlock","kind":"identifier"},{"kind":"text","text":"()"}],"type":"topic"},"doc://GLib/documentation/GLib/RWLockProtocol/writerUnlock()":{"url":"\/do