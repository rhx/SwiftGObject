{"abstract":[{"text":"Obtain a read lock on ","type":"text"},{"type":"codeVoice","code":"rwLock"},{"text":". If another thread currently holds","type":"text"},{"type":"text","text":" "},{"text":"the write lock on ","type":"text"},{"type":"codeVoice","code":"rwLock"},{"text":", the current thread will block until the","type":"text"},{"type":"text","text":" "},{"text":"write lock was (held and) released. If another thread does not hold","type":"text"},{"type":"text","text":" "},{"text":"the write lock, but is waiting for it, it is implementation defined","type":"text"},{"text":" ","type":"text"},{"text":"whether the reader or writer will block. Read locks can be taken","type":"text"},{"type":"text","text":" "},{"text":"recursively.","type":"text"}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/RWLock\/readerLock()","interfaceLanguage":"swift"},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/rwlock\/readerlock()"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","metadata":{"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"readerLock"},{"kind":"text","text":"()"}],"externalID":"s:4GLib14RWLockProtocolPAAE10readerLockyyF::SYNTHESIZED::s:4GLib6RWLockC","role":"symbol","modules":[{"name":"GLib"}],"title":"readerLock()","extendedModule":"GLib","roleHeading":"Instance Method","symbolKind":"method"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/RWLock","doc:\/\/GLib\/documentation\/GLib\/RWLock\/RWLockProtocol-Implementations"]]},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"readerLock"},{"kind":"text","text":"()"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Calling "},{"type":"codeVoice","code":"g_rw_lock_reader_lock()"},{"type":"text","text":" while the current thread already"},{"type":"text","text":" "},{"type":"text","text":"owns a write lock leads to undefined behaviour. Read locks however"},{"text":" ","type":"text"},{"text":"can be taken recursively, in which case you need to make sure to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"call "},{"code":"g_rw_lock_reader_unlock()","type":"codeVoice"},{"type":"text","text":" the same amount of times."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is implementation-defined how many read locks are allowed to be"},{"text":" ","type":"text"},{"text":"held on the same lock simultaneously. If the limit is hit,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"or if a deadlock is detected, a critical warning will be emitted."}]}]}],"references":{"doc://GLib/documentation/GLib/RWLock/RWLockProtocol-Implementations":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLock\/RWLockProtocol-Implementations","type":"topic","kind":"article","title":"RWLockProtocol Implementations","url":"\/documentation\/glib\/rwlock\/rwlockprotocol-implementations","role":"collectionGroup","abstract":[]},"doc://GLib/documentation/GLib/Mutex":{"kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","role":"symbol","abstract":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","type":"reference","isActive":true},{"text":" struct is an opaque data structure to represent a mutex","type":"text"},{"type":"text","text":" "},{"text":"(mutual exclusion). It can be used to protect data against shared","type":"text"},{"type":"text","text":" "},{"text":"access.","type":"text"}],"type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"Mutex","kind":"identifier"}],"title":"Mutex","navigatorTitle":[{"kind":"identifier","text":