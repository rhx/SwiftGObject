{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/Variant","doc:\/\/GLib\/documentation\/GLib\/Variant\/VariantProtocol-Implementations"]]},"kind":"symbol","abstract":[{"text":"Reads a child item out of a container ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":" instance.  This","type":"text"},{"type":"text","text":" "},{"text":"includes variants, maybes, arrays, tuples and dictionary","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"entries.  It is an error to call this function on any other type of"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"type":"text","text":"."}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"getChildValue","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"index"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":") -> ","kind":"text"},{"text":"VariantRef","preciseIdentifier":"s:4GLib10VariantRefV","kind":"typeIdentifier","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef"},{"kind":"text","text":"!"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"inlineContent":[{"text":"It is an error if ","type":"text"},{"type":"codeVoice","code":"index"},{"type":"text","text":" is greater than the number of child items"},{"type":"text","text":" "},{"text":"in the container.  See ","type":"text"},{"code":"g_variant_n_children()","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The returned value is never floating.  You should free it with","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_va