{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/Variant","doc:\/\/GLib\/documentation\/GLib\/Variant\/VariantProtocol-Implementations"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/variant\/takeref()"]}],"kind":"symbol","abstract":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"value"},{"type":"text","text":" is floating, sink it.  Otherwise, do nothing."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"takeRef","kind":"identifier"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef","kind":"typeIdentifier","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef"},{"text":"!","kind":"text"}],"platforms":["macOS"]}]},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Typically you want to use "},{"type":"codeVoice","code":"g_variant_ref_sink()"},{"type":"text","text":" in order to"},{"text":" ","type":"text"},{"text":"automatically do the correct thing with respect to floating or","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"non-floating references, but there is one specific scenario where"},{"type":"text","text":" "},{"type":"text","text":"this function is helpful."}]},{"inlineContent":[{"type":"text","text":"The situation where this function is helpful is when creating an API"},{"type":"text","text":" "},{"type":"text","text":"that allows the user to provide a callback function that returns a"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"type":"text","text":".  We certainly want to allow the user the flexibility to"},{"text":" ","type":"text"},{"type":"text","text":"return a non-floating reference from this callback (for the case"},{"text":" ","type":"text"},{"text":"where the value that is being returned already exists).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"At the same time, the style of the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"type":"text","text":" API makes it likely that"},{"type":"text","text":" "},{"type":"text","text":"for newly-created "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference"},{"type":"text","text":" instances, the user can be saved some"},{"text":" ","type":"text"},{"type":"text","text":"typing if they are allowed to return a "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"type":"text","text":" with a floating"},{"type":"text","text":" "},{"type":"text","text":"reference."}]},{"type":"paragraph","inlineContent":[{"text":"Using this function on the return value of the user’s callback allows","type":"text"},{"text":" ","type":"text"},{"text":"the user to do whichever is more convenient for them.  The caller","type":"text"},{"type":"text","text":" "},{"type":"text","text":"will always receives exactly one full reference to the value: either"},{"text":" ","type":"text"},{"type":"text","text":"the one that was returned in the first place, or a floating reference"},{"text":" ","type":"text"},{"type":"text","text":"that has been converted to a full reference."}]},{"inlineContent":[{"type":"text","text":"This function has an odd interaction when combined with"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_variant_ref_sink()"},{"type":"text","text":" running at the same time in another thread on"},{"text":" ","type":"text"},{"text":"the same ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"type":"text","text":" instance.  If "},{"type":"codeVoice","code":"g_variant_ref_sink()"},{"type":"text","text":" runs first then"},{"type":"text","text":" "},{"type":"text","text":"the result will be that the floating reference is converted to a hard"},{"text":" ","type":"text"},{"type":"text","text":"reference.  If "},{"code":"g_variant_take_ref()","type":"codeVoice"},{"type":"text","text":" runs first then the result will"},{"text":" ","type":"text"},{"type":"text","text":"be that the floating reference is converted to a hard reference and"},{"type":"text","text":" "},{"text":"an additional reference on top of that one is added.  It is best to","type":"text"},{"text":" ","type":"text"},{"text":"avoid this situation.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"sections":[],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/Variant\/takeRef()","interfaceLanguage":"swift"},"metadata":{"modules":[{"name":"GLib"}],"extendedModule":"GLib","title":"takeRef()","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"takeRef","kind":"identifier"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef","kind":"typeIdentifier"},{"kind":"text","text":"!"}],"roleHeading":"Instance Method","externalID":"s:4GLib15VariantProtocolPAAE7takeRefAA0bE0VSgyF::SYNTHESIZED::s:4GLib7VariantC","symbolKind":"method"},"references":{"doc://GLib/documentation/GLib/Variant/VariantProtocol-Implementations":{"role":"collectionGroup","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant\/VariantProtocol-Implementations","type":"topic","title":"VariantProtocol Implementations","kind":"article","abstract":[],"url":"\/documentation\/glib\/variant\/variantprotocol-implementations"},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/VariantRef":{"role":"symbol","type":"topic","url":"\/documentation\/glib\/variantref","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef","abstract":[{"code":"GVariant","type":"codeVoice"},{"text":" is a variant datatype; it can contain one or more values","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"along with information about the type of the values."}],"kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"VariantRef","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"VariantRef"}],"title":"VariantRef"},"doc://GLib/documentation/GLib/Variant/takeRef()":{"title":"takeRef()","url":"\/documentation\/glib\/variant\/takeref()","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"takeRef"},{"text":"() -> ","kind":"text"},{"text":"VariantRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV"},{"text":"!","kind":"text"}],"type":"topic","abstract":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"value"},{"text":" is floating, sink it.  Otherwise, do nothing.","type":"text"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant\/takeRef()"},"doc://GLib/documentation/GLib/Variant":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Variant"}],"kind":"symbol","title":"Variant","role":"symbol","abstract":[{"type":"codeVoice","code":"GVariant"},{"type":"text","text":" is a variant datatype; it can contain one or more values"},{"text":" ","type":"text"},{"type":"text","text":"along with information about the type of the values."}],"url":"\/documentation\/glib\/variant","navigatorTitle":[{"text":"Variant","kind":"identifier"}]}}}