{"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"refSink"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef","preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef"},{"kind":"text","text":"!"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Calling "},{"type":"codeVoice","code":"g_variant_ref_sink()"},{"type":"text","text":" on a "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference"},{"type":"text","text":" with a floating reference"},{"type":"text","text":" "},{"text":"will convert the floating reference into a full reference.  Calling","type":"text"},{"type":"text","text":" "},{"code":"g_variant_ref_sink()","type":"codeVoice"},{"type":"text","text":" on a non-floating "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":" results in an","type":"text"},{"type":"text","text":" "},{"type":"text","text":"additional normal reference being added."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In other words, if the "},{"code":"value","type":"codeVoice"},{"type":"text","text":" is floating, then this call “assumes"},{"text":" ","type":"text"},{"type":"text","text":"ownership” of the floating reference, converting it to a normal"},{"type":"text","text":" "},{"text":"reference.  If the ","type":"text"},{"type":"codeVoice","code":"value"},{"text":" is not floating, then this call adds a","type":"text"},{"type":"text","text":" "},{"text":"new normal reference increasing the reference count by one.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"All calls that result in a "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true,"type":"reference"},{"type":"text","text":" instance being inserted into a"},{"text":" ","type":"text"},{"type":"text","text":"container will call "},{"code":"g_variant_ref_sink()","type":"codeVoice"},{"text":" on the instance.  This means","type":"text"},{"text":" ","type":"text"},{"text":"that if the value was just created (and has only its floating","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"reference) then the container will assume sole ownership of the value"},{"text":" ","type":"text"},{"type":"text","text":"at that point and the caller will not need to unreference it.  This"},{"text":" ","type":"text"},{"type":"text","text":"makes certain common styles of programming much easier while still"},{"text":" ","type":"text"},{"type":"text","text":"maintaining normal refcounting semantics in situations where values"},{"text":" ","type":"text"},{"text":"are not floating.","type":"text"}]}]}],"metadata":{"roleHeading":"Instance Method","extendedModule":"GLib","externalID":"s:4GLib15VariantProtocolPAAE7refSinkAA0B3RefVSgyF::SYNTHESIZED::s:4GLib7VariantC","title":"refSink()","symbolKind":"method","modules":[{"name":"GLib"}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"refSink","kind":"identifier"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef","kind":"typeIdentifier"},{"kind":"text","text":"!"}],"role":"symbol"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/Variant","doc:\/\/GLib\/documentation\/GLib\/Variant\/VariantProtocol-Implementations"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/Variant\/refSink()"},"kind":"symbol","abstract":[{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"type":"text","text":" uses a floating reference count system.  All functions with"},{"text":" ","type":"text"},{"type":"text","text":"names starting with "},{"code":"g_variant_new_","type":"codeVoice"},{"text":" return floating","type":"text"},{"type":"text","text":" "},{"type":"text","text":"references."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/variant\/refsink()"]}],"references":{"doc://GLib/documentation/GLib/VariantRef":{"abstract":[{"code":"GVariant","type":"codeVoice"},{"text":" is a variant datatype; it can contain one or more values","type":"text"},{"type":"text","text":" "},{"type":"text","text":"along with information about the type of the values."}],"type":"topic","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"VariantRef","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef","title":"VariantRef","url":"\/documentation\/glib\/variantref","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"VariantRef"}]},"doc://GLib/documentation/GLib/Variant/refSink()":{"kind":"symbol","type":"topic","url":"\/documentation\/glib\/variant\/refsink()","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant\/refSink()","abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":" uses a floating reference count system.  All functions with","type":"text"},{"type":"text","text":" "},{"text":"names starting with ","type":"text"},{"code":"g_variant_new_","type":"codeVoice"},{"text":" return floating","type":"text"},{"type":"text","text":" "},{"type":"text","text":"references."}],"title":"refSink()","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"refSink"},{"kind":"text","text":"() -> "},{"text":"VariantRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV"},{"text":"!","kind":"text"}]},"doc://GLib/documentation/GLib/Variant/V