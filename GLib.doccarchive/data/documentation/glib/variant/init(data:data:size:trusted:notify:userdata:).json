ill be constructed."},{"text":" ","type":"text"},{"type":"text","text":"The interpretation of "},{"type":"codeVoice","code":"data"},{"type":"text","text":" depends on knowing the type."}]},{"type":"paragraph","inlineContent":[{"code":"data","type":"codeVoice"},{"type":"text","text":" is not modified by this function and must remain valid with an"},{"type":"text","text":" "},{"type":"text","text":"unchanging value until such a time as "},{"type":"codeVoice","code":"notify"},{"type":"text","text":" is called with"},{"type":"text","text":" "},{"type":"codeVoice","code":"userData"},{"type":"text","text":".  If the contents of "},{"code":"data","type":"codeVoice"},{"text":" change before that time then","type":"text"},{"text":" ","type":"text"},{"text":"the result is undefined.","type":"text"}]},{"inlineContent":[{"text":"If ","type":"text"},{"code":"data","type":"codeVoice"},{"type":"text","text":" is trusted to be serialized data in normal form then"},{"type":"text","text":" "},{"type":"codeVoice","code":"trusted"},{"type":"text","text":" should be "},{"code":"true","type":"codeVoice"},{"text":".  This applies to serialized data created","type":"text"},{"type":"text","text":" "},{"text":"within this process or read from a trusted location on the disk (such","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"as a file installed in \/usr\/lib alongside your application).  You"},{"text":" ","type":"text"},{"type":"text","text":"should set trusted to "},{"type":"codeVoice","code":"false"},{"text":" if ","type":"text"},{"type":"codeVoice","code":"data"},{"type":"text","text":" is read from the network, a"},{"type":"text","text":" "},{"type":"text","text":"file in the user’s home directory, etc."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"data"},{"type":"text","text":" was not stored in this machine’s native endianness, any multi-byte"},{"type":"text","text":" "},{"type":"text","text":"numeric values in the returned variant will also be in non-native"},{"type":"text","text":" "},{"type":"text","text":"endianness. "},{"type":"codeVoice","code":"g_variant_byteswap()"},{"type":"text","text":" can be used to recover the original values."}]},{"type":"paragraph","inlineContent":[{"code":"notify","type":"codeVoice"},{"type":"text","text":" will be called with "},{"type":"codeVoice","code":"userData"},{"type":"text","text":" when "},{"type":"codeVoice","code":"data"},{"type":"text","text":" is no longer"},{"type":"text","text":" "},{"text":"needed.  The exact time of this call is unspecified and might even be","type":"text"},{"text":" ","type":"text"},{"text":"before this function returns.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Note: "},{"code":"data","type":"codeVoice"},{"text":" must be backed by memory that is aligned appropriately for the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"type"},{"text":" being loaded. Otherwise this function will internally create a copy of","type":"text"},{"text":" ","type":"text"},{"text":"the memory (since GLib 2.60) or (in older versions) fail and exit the","type":"text"},{"type":"text","text":" "},{"text":"process.","type":"text"}],"type":"paragraph"}]}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/Variant\/init(data:data:size:trusted:notify:userData:)"},"references":{"doc://GLib/documentation/GLib/VariantTypeProtocol":{"title":"VariantTypeProtocol","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantTypeProtocol","kind":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"VariantTypeProtocol","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"VariantTypeProtocol"}],"url":"\/documentation\/glib\/varianttypeprotocol","abstract":[{"text":"A type in the [type","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"refer