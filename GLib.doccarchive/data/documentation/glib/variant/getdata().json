{"sections":[],"abstract":[{"type":"text","text":"Returns a pointer to the serialized form of a "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"text":" instance.","type":"text"},{"type":"text","text":" "},{"text":"The returned data may not be in fully-normalised form if read from an","type":"text"},{"type":"text","text":" "},{"type":"text","text":"untrusted source.  The returned data must not be freed; it remains"},{"type":"text","text":" "},{"text":"valid for as long as ","type":"text"},{"code":"value","type":"codeVoice"},{"text":" exists.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/variant\/getdata()"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/Variant\/getData()"},"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/Variant","doc:\/\/GLib\/documentation\/GLib\/Variant\/VariantProtocol-Implementations"]]},"metadata":{"title":"getData()","modules":[{"name":"GLib"}],"role":"symbol","extendedModule":"GLib","externalID":"s:4GLib15VariantProtocolPAAE7getDataSVSgyF::SYNTHESIZED::s:4GLib7VariantC","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"getData"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"c:@T@gconstpointer","kind":"typeIdentifier","text":"gconstpointer"},{"kind":"text","text":"?"}],"roleHeading":"Instance Method","symbolKind":"method"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"getData"},{"kind":"text","text":"() -> "},{"text":"gconstpointer","preciseIdentifier":"c:@T@gconstpointer","kind":"typeIdentifier"},{"kind":"text","text":"?"}]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"value","type":"codeVoice"},{"text":" is a fixed-sized value that was deserialized from a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"corrupted serialized container then "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" may be returned.  In this"},{"text":" ","type":"text"},{"type":"text","text":"case, the proper thing to do is typically to use the appropriate"},{"text":" ","type":"text"},{"type":"text","text":"number of nul bytes in place of "},{"type":"codeVoice","code":"value"},{"type":"text","text":".  If "},{"code":"value","type":"codeVoice"},{"type":"text","text":" is not fixed-sized"},{"type":"text","text":" "},{"type":"text","text":"then "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" is never returned."}]},{"type":"paragraph","inlineContent":[{"text":"In the case that ","type":"text"},{"code":"value","type":"codeVoice"},{"type":"text","text":" is already in serialized form, this function"},{"text":" ","type":"text"},{"text":"is ","type":"text"},{"type":"codeVoice","code":"O(1)"},{"type":"text","text":".  If the value is not already in serialized form,"},{"type":"text","text":" "},{"text":"serialization occurs implicitly and is approximately ","type":"text"},{"code":"O(n)","type":"codeVoice"},{"text":" in the size","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of the result."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To deserialize the data returned by this function, in addition to the"},{"text":" ","type":"text"},{"text":"serialized data, you must know the type of the ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"type":"text","text":", and (if the"},{"text":" ","type":"text"},{"type":"text","text":"machine might be different) the endianness of the machine that stored"},{"text":" ","type":"text"},{"type":"text","text":"it. As a result, file formats or network messages that incorporate"},{"text":" ","type":"text"},{"type":"text","text":"serialized "},{"type":"codeVoice","code":"GVariants"},{"text":" must include this information either","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"implicitly (for instance “the file always contains a"},{"text":" ","type":"text"},{"type":"codeVoice","code":"G_VARIANT_TYPE_VARIANT"},{"text":" and it is always in little-endian order”) or","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"explicitly (by storing the type and\/or endianness in addition to the"},{"text":" ","type":"text"},{"text":"serialized data).","type":"text"}]}]}],"references":{"doc://GLib/documentation/GLib/Variant":{"abstract":[{"code":"GVariant","type":"codeVoice"},{"type":"text","text":" is a variant datatype; it can contain one or more values"},{"type":"text","text":" "},{"text":"along with information about the type of the values.","type":"text"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"Variant","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","navigatorTitle":[{"text":"Variant","kind":"identifier"}],"title":"Variant","role":"symbol","type":"topic","kind":"symbol","url":"\/documentation\/glib\/variant"},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/Variant/VariantProtocol-Implementations":{"abstract":[],"role":"collectionGroup","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant\/VariantProtocol-Implementations","type":"topic","title":"VariantProtocol Implementations","url":"\/documentation\/glib\/variant\/variantprotocol-implementations","kind":"article"},"doc://GLib/documentation/GLib/Variant/getData()":{"abstract":[{"type":"text","text":"Returns a