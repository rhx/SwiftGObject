ce","code":"value"},{"text":" is already trusted to be in normal form then a new","type":"text"},{"type":"text","text":" "},{"text":"reference to ","type":"text"},{"type":"codeVoice","code":"value"},{"type":"text","text":" is returned."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"value"},{"text":" is not already trusted, then it is scanned to check if it","type":"text"},{"text":" ","type":"text"},{"text":"is in normal form.  If it is found to be in normal form then it is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"marked as trusted and a new reference to it is returned."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"value","type":"codeVoice"},{"text":" is found not to be in normal form then a new trusted","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"type":"text","text":" is created with the same value as "},{"code":"value","type":"codeVoice"},{"type":"text","text":". The non-normal parts of"},{"type":"text","text":" "},{"code":"value","type":"codeVoice"},{"type":"text","text":" will be replaced with default values which are guaranteed to be in"},{"text":" ","type":"text"},{"type":"text","text":"normal form."}]},{"inlineContent":[{"type":"text","text":"It makes sense to call this function if you’ve received "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"type":"text","text":" "},{"type":"text","text":"data from untrusted sources and you want to ensure your serialized"},{"text":" ","type":"text"},{"type":"text","text":"output is definitely in normal form."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"value","type":"codeVoice"},{"type":"text","text":" is already in normal form, a new reference will be returned"},{"type":"text","text":" "},{"type":"text","text":"(which will be floating if "},{"code":"value","type":"codeVoice"},{"text":" is floating). If it is not in normal form,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the newly created "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference","isActive":true},{"text":" will be returned with a single non-floating","type":"text"},{"type":"text","text":" "},{"text":"reference. Typically, ","type":"text"},{"type":"codeVoice","code":"g_variant_take_ref()"},{"type":"text","text":" should be called on the return"},{"type":"text","text":" "},{"type":"text","text":"value from this function to guarantee ownership of a single non-floating"},{"text":" ","type":"text"},{"type":"text","text":"reference to it."}]}]}],"sections":[],"kind":"symbol","references":{"doc://GLib/documentation/GLib/Variant/normalForm":{"abstract":[{"type":"text","text":"Gets a "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"type":"text","text":" instance that has the same value as "},{"code":"value","type":"codeVoice"},{"type":"text","text":" and is"},{"type":"text","text":" "},{"type":"text","text":"trusted to be in normal form."}],"kind":"symbol","role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"normalForm"},{"kind":"text","text":": "},{"preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef","kind":"typeIdentifier"},{"kind":"text","text":"!"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant\/normalForm","url":"\/documentation\/glib\/variant\/normalform","title":"normalForm","type":"topic"},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/Variant/VariantProtocol-Implementations":{"abstract":[],"role":"collectionGroup","identifier":"doc:\/\/GLib\/documentation\/GLib\/V