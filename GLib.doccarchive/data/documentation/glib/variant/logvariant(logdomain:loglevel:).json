rnalParam","text":"logLevel"},{"kind":"text","text":": "},{"text":"LogLevelFlags","kind":"typeIdentifier","preciseIdentifier":"s:4GLib13LogLevelFlagsV","identifier":"doc:\/\/GLib\/documentation\/GLib\/LogLevelFlags"},{"text":")","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"This version is especially useful for use in other languages, via introspection.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The only mandatory item in the "},{"type":"codeVoice","code":"fields"},{"text":" dictionary is the ","type":"text"},{"type":"codeVoice","code":"\"MESSAGE\""},{"type":"text","text":" which must"},{"text":" ","type":"text"},{"type":"text","text":"contain the text shown to the user."}]},{"type":"paragraph","inlineContent":[{"text":"The values in the ","type":"text"},{"type":"codeVoice","code":"fields"},{"type":"text","text":" dictionary are likely to be of type "},{"code":"G_VARIANT_TYPE_STRING","type":"codeVoice"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Array of bytes ("},{"code":"G_VARIANT_TYPE_BYTESTRING","type":"codeVoice"},{"type":"text","text":") is also"},{"type":"text","text":" "},{"type":"text","text":"supported. In this case the message is handled as binary and will be forwarded"},{"text":" ","type":"text"},{"text":"to the log writer as such. The size of the array should not be higher than","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"G_MAXSSIZE"},{"type":"text","text":". Otherwise it will be truncated to this size. For other types"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GLib.Variant.print"},{"type":"text","text":"] will be used to convert the value into a string."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For more details on its usage and about the parameters, see [func"},{"type":"codeVoice","code":"GLib.log_structured"},{"type":"text","text":"]."}]}],"kind":"content"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/variant\/logvariant(logdomain:loglevel:)"]}],"references":{"doc://GLib/documentation/GLib/Variant/logVariant(logDomain:logLevel:)":{"type":"topic","role":"symbol","title":"logVariant(logDomain:logLevel:)","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant\/logVariant(logDomain:logLevel:)","kind":"symbol","url":"\/documentation\/glib\/variant\/logvariant(logdomain:loglevel:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"logVariant"},{"text":"(","kind":"text"},{"text":"logDomain","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">?, "},{"text":"logLevel","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib13LogLevelFlagsV","text":"LogLevelFlags"},{"text":")","kind":"text"}],"abstract":[{"type":"text","text":"Log a message with structured data, accepting the data within a [type"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference"},{"type":"text","text":"]."}]},"doc://GLib/documentation/GLib/Variant":{"abstract":[{"code":"GVariant","type":"codeVoice"},{"type":"text","text":" is a variant datatype; it can contain one or more values"},{"type":"text","text":" "},{"text":"along with information about the type of the values.","type":"text"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"Variant","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","navigatorTitle":[{"text":"Variant","kind":"identifier"}],"title":"