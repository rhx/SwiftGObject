k_buffer, &n_chunks);","for (gsize i = 0; i < n_chunks; i++)","  {","    \/\/ Do something with each chunk here, and then free them, since","    \/\/ `g_ptr_array_steal()` transfers ownership of all the elements and the","    \/\/ array to the caller.","    …","","    g_bytes_unref (chunks[i]);","  }","","g_free (chunks);","","\/\/ After calling `g_ptr_array_steal()`, the pointer array can be reused for the","\/\/ next set of chunks.","g_assert (chunk_buffer->len == 0);"]}],"kind":"content"}],"references":{"doc://GLib/documentation/GLib/DestroyNotify":{"title":"DestroyNotify","identifier":"doc:\/\/GLib\/documentation\/GLib\/DestroyNotify","kind":"symbol","type":"topic","url":"\/documentation\/glib\/destroynotify","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"DestroyNotify"}],"fragments":[{"kind":"keyword","text":"typealias"},{"text":" ","kind":"text"},{"kind":"identifier","text":"DestroyNotify"}],"abstract":[{"type":"text","text":"Specifies the type of function which is called when a data element"},{"type":"text","text":" "},{"type":"text","text":"is destroyed. It is passed the pointer to the data element and"},{"type":"text","text":" "},{"type":"text","text":"should free any memory and resources allocated for it."}]},"doc://GLib/documentation/GLib/PtrArray/steal(len:)":{"type":"topic","kind":"symbol","role":"symbol","title":"steal(len:)","url":"\/documentation\/glib\/ptrarray\/steal(len:)","identifier":"doc:\/\/GLib\/documentation\/GLib\/PtrArray\/steal(len:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"steal"},{"kind":"text","text":"("},{"text":"len","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gsize","text":"gsize"},{"text":">!) -> ","kind":"text"},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentif