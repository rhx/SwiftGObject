{"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","metadata":{"navigatorTitle":[{"text":"RWLockRef","kind":"identifier"}],"modules":[{"name":"GLib"}],"fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"RWLockRef"}],"symbolKind":"struct","role":"symbol","externalID":"s:4GLib9RWLockRefV","title":"RWLockRef","roleHeading":"Structure"},"sections":[],"variants":[{"paths":["\/documentation\/glib\/rwlockref"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"abstract":[{"type":"text","text":"The GRWLock struct is an opaque data structure to represent a"},{"type":"text","text":" "},{"text":"reader-writer lock. It is similar to a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex"},{"type":"text","text":" in that it allows"},{"text":" ","type":"text"},{"type":"text","text":"multiple threads to coordinate access to a shared resource."}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/RWLockRef","interfaceLanguage":"swift"},"relationshipsSections":[{"title":"Conforms To","type":"conformsTo","kind":"relationships","identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol"]}],"topicSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/RWLockRef\/init(_:)-3kjfl","doc:\/\/GLib\/documentation\/GLib\/RWLockRef\/init(_:)-4ny6y","doc:\/\/GLib\/documentation\/GLib\/RWLockRef\/init(_:)-6up5f","doc:\/\/GLib\/documentation\/GLib\/RWLockRef\/init(_:)-8ofb","doc:\/\/GLib\/documentation\/GLib\/RWLockRef\/init(_:)-8tf2d","doc:\/\/GLib\/documentation\/GLib\/RWLockRef\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/RWLockRef\/init(constPointer:)","doc:\/\/GLib\/documentation\/GLib\/RWLockRef\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/RWLockRef\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/RWLockRef\/init(mutating:)","doc:\/\/GLib\/documentation\/GLib\/RWLockRef\/init(opaquePointer:)"],"title":"Initializers","generated":true,"anchor":"Initializers"},{"generated":true,"title":"Instance Properties","identifiers":["doc:\/\/GLib\/documentation\/GLib\/RWLockRef\/ptr"],"anchor":"Instance-Properties"},{"generated":true,"anchor":"Default-Implementations","title":"Default Implementations","identifiers":["doc:\/\/GLib\/documentation\/GLib\/RWLockRef\/PointerWrapper-Implementations","doc:\/\/GLib\/documentation\/GLib\/RWLockRef\/RWLockProtocol-Implementations"]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"RWLockRef"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Overview","type":"heading","level":2,"anchor":"overview"},{"inlineContent":[{"text":"The difference to a mutex is that a reader-writer lock discriminates","type":"text"},{"type":"text","text":" "},{"text":"between read-only (‘reader’) and full (‘writer’) access. While only","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"one thread at a time is allowed write access (by holding the ‘writer’"},{"type":"text","text":" "},{"text":"lock via ","type":"text"},{"type":"codeVoice","code":"g_rw_lock_writer_lock()"},{"type":"text","text":"), multiple threads can gain"},{"type":"text","text":" "},{"text":"simultaneous read-only access (by holding the ‘reader’ lock via","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_rw_lock_reader_lock()"},{"text":").","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"It is unspecified whether readers or writers have priority in acquiring the"},{"text":" ","type":"text"},{"text":"lock when a reader already holds the lock and a writer is queued to acquire","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"it."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Here is an example for an array with access functions:"},{"type":"text","text":" "},{"text":"(C Language Example):","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"C","code":["  GRWLock lock;","  GPtrArray *array;","","  gpointer","  my_array_get (guint index)","  {","    gpointer retval = NULL;","","    if (!array)","      return NULL;","","    g_rw_lock_reader_lock (&lock);","    if (index < array->len)","      retval = g_ptr_array_index (array, index);","    g_rw_lock_reader_unlock (&lock);","","    return retval;","  }","","  void","  my_array_set (guint index, gpointer data)","  {","    g_rw_lock_writer_lock (&lock);","","    if (!array)","      array = g_ptr_array_new ();","","    if (index >= array->len)","      g_ptr_array_set_size (array, index+1);","    g_ptr_array_index (array, index) = data;","","    g_rw_lock_writer_unlock (&lock);","  }"," "]},{"inlineContent":[{"text":"This example shows an array which can be accessed by many readers","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(the "},{"code":"my_array_get()","type":"codeVoice"},{"text":" function) simultaneously, whereas the writers","type":"text"},{"text":" ","type":"text"},{"text":"(the ","type":"text"},{"code":"my_array_set()","type":"codeVoice"},{"text":" function) will only be allowed one at a time","type":"text"},{"type":"text","text":" "},{"text":"and only if no readers currently access the array. This is because","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of the potentially dangerous resizing of the array. Using these"},{"type":"text","text":" "},{"text":"functions is fully multi-thread safe now.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLock"},{"text":" is allocated in static storage then it can be used","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"without initialisation.  Otherwise, you should call"},{"text":" ","type":"text"},{"code":"g_rw_lock_init()","type":"codeVoice"},{"type":"text","text":" on it and "},{"type":"codeVoice","code":"g_rw_lock_clear()"},{"text":" when done.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A GRWLock should only be accessed with the g_rw_lock_ functions."}],"type":"paragraph"},{"inlineContent":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockRef","isActive":true},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"code":"GRWLock","type":"codeVoice"},{"text":" instance.","type":"text"},{"type":"text","text":" "},{"text":"It exposes methods that can operate on this data type through ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol","isActive":true,"type":"reference"},{"type":"text","text":" conformance."},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockRef","isActive":true},{"type":"text","text":" only as an "},{"type":"codeVoice","code":"unowned"},{"text":" reference to an existing ","type":"text"},{"code":"GRWLock","type":"codeVoice"},{"type":"text","text":" instance."}],"type":"paragraph"},{"style":"note","name":"Note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLock","isActive":true,"type":"reference"},{"type":"text","text":" (instead of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockRef"},{"type":"text","text":") if you want to use Automatic Reference Counting for memory management of the underlying "},{"code":"GRWLock","type":"codeVoice"},{"text":" instance.","type":"text"}]}]}],"kind":"content"}],"references":{"doc://GLib/documentation/GLib/RWLockRef/init(_:)-3kjfl":{"url":"\/documentation\/glib\/rwlockref\/init(_:)-3kjfl","type"