{"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"RWLockRef"}],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"overview","type":"heading","level":2,"text":"Overview"},{"inlineContent":[{"type":"text","text":"The difference to a mutex is that a reader-writer lock discriminates"},{"text":" ","type":"text"},{"type":"text","text":"between read-only (‘reader’) and full (‘writer’) access. While only"},{"type":"text","text":" "},{"type":"text","text":"one thread at a time is allowed write access (by holding the ‘writer’"},{"text":" ","type":"text"},{"type":"text","text":"lock via "},{"type":"codeVoice","code":"g_rw_lock_writer_lock()"},{"type":"text","text":"), multiple threads can gain"},{"text":" ","type":"text"},{"text":"simultaneous read-only access (by holding the ‘reader’ lock via","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_rw_lock_reader_lock()"},{"type":"text","text":")."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"It is unspecified whether readers or writers have priority in acquiring the"},{"text":" ","type":"text"},{"type":"text","text":"lock when a reader already holds the lock and a writer is queued to acquire"},{"type":"text","text":" "},{"type":"text","text":"it."}],"type":"paragraph"},{"inlineContent":[{"text":"Here is an example for an array with access functions:","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"code":["  GRWLock lock;","  GPtrArray *array;","","  gpointer","  my_array_get (guint index)","  {","    gpointer retval = NULL;","","    if (!array)","      return NULL;","","    g_rw_lock_reader_lock (&lock);","    if (index < array->len)","      retval = g_ptr_array_index (array, index);","    g_rw_lock_reader_unlock (&lock);","","    return retval;","  }","","  void","  my_array_set (guint index, gpointer data)","  {","    g_rw_lock_writer_lock (&lock);","","    if (!array)","      array = g_ptr_array_new ();","","    if (index >= array->len)","      g_ptr_array_set_size (array, index+1);","    g_ptr_array_index (array, index) = data;","","    g_rw_lock_writer_unlock (&lock);","  }"," "],"type":"codeListing","syntax":"C"},{"inlineContent":[{"type":"text","text":"This example shows an array which can be accessed by many readers"},{"type":"text","text":" "},{"type":"text","text":"(the "},{"code":"my_array_get()","type":"codeVoice"},{"text":" function) simultaneously, whereas the writers","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(the "},{"type":"codeVoice","code":"my_array_set()"},{"type":"text","text":" function) will only be allowed one at a time"},{"text":" ","type":"text"},{"type":"text","text":"and only if no readers currently access the array. This is because"},{"text":" ","type":"text"},{"type":"text","text":"of the potentially dangerous resizing of the array. Using these"},{"type":"text","text":" "},{"type":"text","text":"functions is fully multi-thread safe now."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If a "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLock","type":"reference"},{"text":" is allocated in static storage then it can be used","type":"text"},{"type":"text","text":" "},{"type":"text","text":"without initialisation.  Otherwise, you should call"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_rw_lock_init()"},{"text":" on it and ","type":"text"},{"code":"g_rw_lock_clear()","type":"codeVoice"},{"text":" when done.","type":"text"}]},{"inlineContent":[{"type":"text","text":"A GRWLock should only be accessed with the g_rw_lock_ functions."}],"type":"paragraph"},{"inlineContent":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockRef","isActive":true},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GRWLock"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol"},{"text":" conformance.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Use "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockRef","type":"reference","isActive":true},{"text":" only as an ","type":"text"},{"code":"unowned","type":"codeVoice"},{"type":"text","text":" reference to an existing "},{"code":"GRWLock","type":"codeVoice"},{"text":" instance.","type":"text"}],"type":"paragraph"},{"name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLock","isActive":true,"type":"reference"},{"text":" (instead of ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockRef","type":"reference","isActive":true},{"text":") if you want to use Automatic Reference Counting for memory management of the underlying ","type":"text"},{"code":"GRWLock","type":"codeVoice"},{"type":"text","text":" instance."}]}],"type":"aside"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/rwlockref"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/RWLockRef"},"relationshipsSections":[{"kind":"relationships","title":"Conforms To","type":"conformsTo","identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol"]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"abstract":[{"text":"The GRWLock struct is an opaque data structure to represent a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"reader-writer lock. It is similar to a "},{"identifier":"doc:\/