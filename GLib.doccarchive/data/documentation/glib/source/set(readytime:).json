{"variants":[{"paths":["\/documentation\/glib\/source\/set(readytime:)"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"abstract":[{"text":"Sets a source to be dispatched when the given monotonic time is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"reached (or passed)."}],"metadata":{"symbolKind":"method","modules":[{"name":"GLib"}],"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"set","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"readyTime"},{"text":": ","kind":"text"},{"text":"gint64","kind":"typeIdentifier","preciseIdentifier":"c:@T@gint64"},{"text":")","kind":"text"}],"roleHeading":"Instance Method","extendedModule":"GLib","title":"set(readyTime:)","role":"symbol","externalID":"s:4GLib14SourceProtocolPAAE3set9readyTimeys5Int64V_tF::SYNTHESIZED::s:4GLib6SourceC"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/Source","doc:\/\/GLib\/documentation\/GLib\/Source\/SourceProtocol-Implementations"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"set","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"readyTime"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@gint64","text":"gint64","kind":"typeIdentifier"},{"text":")","kind":"text"}],"platforms":["macOS"]}]},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"If the monotonic time is in the past (as it","type":"text"},{"type":"text","text":" "},{"type":"text","text":"always will be if "},{"type":"codeVoice","code":"readyTime"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"0"},{"text":") then the source will be","type":"text"},{"text":" ","type":"text"},{"text":"dispatched immediately.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"readyTime","type":"codeVoice"},{"type":"text","text":" is "},{"code":"-1","type":"codeVoice"},{"text":" then the source is never woken up on the basis","type":"text"},{"type":"text","text":" "},{"text":"of the passage of time.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Dispatching the source does not reset the ready time.  You should do"},{"type":"text","text":" "},{"type":"text","text":"so yourself, from the source dispatch function."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that if you have a pair of sources where the ready time of one"},{"type":"text","text":" "},{"type":"text","text":"suggests that it will be delivered first but the priority for the"},{"type":"text","text":" "},{"type":"text","text":"other suggests that it would be delivered first, and the ready time"},{"type":"text","text":" "},{"type":"text","text":"for both sources is reached during the same main context iteration,"},{"type":"text","text":" "},{"text":"then the order of dispatch is undefined.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"It is a no-op to call this function on a [struct","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","isActive":true},{"type":"text","text":"] which has"},{"text":" ","type":"text"},{"type":"text","text":"already been destroyed with [method"},{"type":"codeVoice","code":"GLib.Source.destroy"},{"text":"].","type":"text"}]},{"inlineContent":[{"text":"This API is only intended to be used by implementations of [struct","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Source"},{"type":"text","text":"]."},{"text":" ","type":"text"},{"text":"Do not call this API on a [struct","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","type":"reference","isActive":true},{"type":"text","text":"] that you did not create."}],"type":"paragraph"}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/Source\/set(readyTime:)"},"kind":"symbol","references":{"doc://GLib/documentation/GLib/Source/set(readyTime:)":{"abstract":[{"text":"Sets a source to be dispatched when the given monotonic time is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"reached (or passed)."}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"set"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"readyTime"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@gint64","text":"gint64","kind":"typeIdentifier"},{"kind":"text","text":")"}],"title":"set(readyTime:)","type":"topic","role":"symbol","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/Source\/set(readyTime:)","url":"\/documentation\/glib\/source\/set(readytime:)"},"doc://GLib/documentation/GLib/Source":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","kind":"symbol","abstract":[{"type":"text","text":"The "},{"code":"GSource","type":"codeVoice"},{"type":"text","text":" struct is an opaque data type"},{"text":" ","type":"text"},{"text":"representing an event source.","type":"text"}],"type":"topic","navigatorTitle":[{"text":"Source","kind":"identifier"}],"url":"\/documentation\/glib\/source","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"Source"}],"title":"Source","role":"symbol"},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/Source/SourceProtocol-Implementations":{"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/Source\/SourceProtocol-Implementations","url":"\/documentation\/glib\/source\/sourceprotocol-implementations","abstract":[],"kind