{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/Source","doc:\/\/GLib\/documentation\/GLib\/Source\/SourceProtocol-Implementations"]]},"abstract":[{"text":"Set ","type":"text"},{"code":"dispose","type":"codeVoice"},{"type":"text","text":" as dispose function on "},{"type":"codeVoice","code":"source"},{"text":".","type":"text"}],"kind":"symbol","sections":[],"metadata":{"role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"setDisposeFunction","kind":"identifier"},{"text":"(","kind":"text"},{"text":"dispose","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@GSourceDisposeFunc","text":"GSourceDisposeFunc","kind":"typeIdentifier"},{"text":"?)","kind":"text"}],"symbolKind":"method","modules":[{"name":"GLib"}],"extendedModule":"GLib","roleHeading":"Instance Method","externalID":"s:4GLib14SourceProtocolPAAE18setDisposeFunction7disposeyySpySo8_GSourceVGSgXCSg_tF::SYNTHESIZED::s:4GLib6SourceC","title":"setDisposeFunction(dispose:)"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/source\/setdisposefunction(dispose:)"]}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/Source\/setDisposeFunction(dispose:)","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"setDisposeFunction","kind":"identifier"},{"text":"(","kind":"text"},{"text":"dispose","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"GSourceDisposeFunc","kind":"typeIdentifier","preciseIdentifier":"c:@T@GSourceDisposeFunc"},{"kind":"text","text":"?)"}],"platforms":["macOS"]}]},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"The "},{"code":"dispose","type":"codeVoice"},{"type":"text","text":" function will be called once the reference count of "},{"type":"codeVoice","code":"source"},{"type":"text","text":" "},{"text":"reaches zero but before any of the state of the source is freed, especially","type":"text"},{"type":"text","text":" "},{"type":"text","text":"before the finalize function (set as part of the [type"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncs","type":"reference","isActive":true},{"text":"]) is","type":"text"},{"type":"text","text":" "},{"text":"called.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This means that at this point "},{"code":"source","type":"codeVoice"},{"text":" is still a valid [struct","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","isActive":true},{"type":"text","text":"]"},{"type":"text","text":" "},{"type":"text","text":"and it is allow for the reference count to increase again until "},{"type":"codeVoice","code":"dispose"},{"type":"text","text":" "},{"text":"returns.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The dispose function can be used to clear any ‘weak’ references to"},{"type":"text","text":" "},{"type":"text","text":"the "},{"type":"codeVoice","code":"source"},{"type":"text","text":" in other data structures in a thread-safe way where it is"},{"type":"text","text":" "},{"text":"possible for another thread to increase the reference count of ","type":"text"},{"type":"codeVoice","code":"source"},{"text":" again","type":"text"},{"type":"text","text":" "},{"text":"while it is being freed.","type":"text"}]},{"inlineContent":[{"type":"text","text":"The finalize function can not be used for this purpose as at that"},{"type":"text","text":" "},{"type":"text","text":"point "},{"type":"codeVoice","code":"source"},{"text":" is already partially freed and not valid any more.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This should only ever be called from [struct","type":"text"}