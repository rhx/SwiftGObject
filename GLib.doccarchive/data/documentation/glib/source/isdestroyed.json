{"sections":[],"metadata":{"extendedModule":"GLib","role":"symbol","roleHeading":"Instance Property","modules":[{"name":"GLib"}],"title":"isDestroyed","externalID":"s:4GLib14SourceProtocolPAAE11isDestroyedSbvp::SYNTHESIZED::s:4GLib6SourceC","symbolKind":"property","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"isDestroyed"},{"text":": ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/Source\/isDestroyed"},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"text":"isDestroyed","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"inlineContent":[{"text":"This is important when you operate upon your objects","type":"text"},{"type":"text","text":" "},{"text":"from within idle handlers, but may have freed the object","type":"text"},{"text":" ","type":"text"},{"text":"before the dispatch of your idle handler.","type":"text"}],"type":"paragraph"},{"syntax":"c","type":"codeListing","code":["static gboolean","idle_callback (gpointer data)","{","  SomeWidget *self = data;","   ","  g_mutex_lock (&self->idle_id_mutex);","  \/\/ do stuff with self","  self->idle_id = 0;","  g_mutex_unlock (&self->idle_id_mutex);","   ","  return G_SOURCE_REMOVE;","}"," ","static void","some_widget_do_stuff_later (SomeWidget *self)","{","  g_mutex_lock (&self->idle_id_mutex);","  self->idle_id = g_idle_add (idle_callback, self);","  g_mutex_unlock (&self->idle_id_mutex);","}"," ","static void","some_widget_init (SomeWidget *self)","{","  g_mutex_init (&self->idle_id_mutex);","","  \/\/ ...","}","","static void","some_widget_finalize (GObject *object)","{","  SomeWidget *self = SOME_WIDGET (object);","   ","  if (self->idle_id)","    g_source_remove (self->idle_id);","   ","  g_mutex_clear (&self->idle_id_mutex);","","  G_OBJECT_CLASS (parent_class)->finalize (object);","}"]},{"type":"paragraph","inlineContent":[{"text":"This will fail in a multi-threaded application if the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"widget is destroyed before the idle handler fires due"},{"type":"text","text":" "},{"type":"text","text":"to the use after free in the callback. A solution, to"},{"text":" ","type":"text"},{"type":"text","text":"this particular problem, is to check to if the source"},{"text":" ","type":"text"},{"type":"text","text":"has already been destroy within the callback."}]},{"code":["static gboolean","idle_callback (gpointer data)","{","  SomeWidget *self = data;","  ","  g_mutex_lock (&self->idle_id_mutex);","  if (!g_source_is_destroyed (g_main_current_source ()))","    {","      \/\/ do stuff with self","    }","  g_mutex_unlock (&self->idle_id_mutex);","  ","  return FALSE;","}"],"syntax":"c","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Calls to this function from a thread other than the one acquired by the"},{"type":"text","text":" "},{"text":"[struct","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","type":"reference"},{"type":"text","text":"] the [struct"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","isActive":true},{"text":"] is attached to are typically","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"redundant, as the source could be destroyed immediately after this function"},{"text":" ","type":"text"},{"text":"returns. However, once a source is destroyed it cannot be un-destroyed, so","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this function can be used for opportunistic checks from any thread."}]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/Source","doc:\/\/GLib\/documentation\/GLib\/Source\/SourceProtocol-Implementations"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/source\/isdestroyed"]}],"abstract":[{"text":"Returns whether ","type":"text"},{"type":"codeVoice","code":"source"},{"text":" has been destroyed.","type":"text"}],"references":{"doc://GLib/documentation/GLib/Source/SourceProtocol-Implementations":{"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/Source\/SourceProtocol-Implementations","url":"\/documentation\/glib\/source\/sourceprotocol-implementations","abstract":[],"kind":"article","title":"SourceProtocol Implementations","role":"collectionGroup"},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/Source/isDestroyed":{"type":"topic","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"isDestroyed"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"role":"symbol","title":"isDestroyed","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/Source\/isDestroyed","url":"\/documentation\/glib\/source\/isdestroyed","abstract":[{"text":"Returns whether ","type":"text"},{"type":"codeVoice","code":"source"},{"text":" has been destroyed.","type":"text"}]},"doc://GLib/documentation/GLib/MainContext":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","role":"symbol","type":"topic","navigatorTitle":[{"text":"MainContext","kind":"identifier"}],"abstract":[{"type":"text","text":"The "},{"code":"GMainContext","type":"codeVo