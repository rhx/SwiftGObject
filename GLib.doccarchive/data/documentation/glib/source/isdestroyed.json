{"abstract":[{"type":"text","text":"Returns whether "},{"type":"codeVoice","code":"source"},{"type":"text","text":" has been destroyed."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/Source\/isDestroyed"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"isDestroyed","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"inlineContent":[{"type":"text","text":"This is important when you operate upon your objects"},{"type":"text","text":" "},{"type":"text","text":"from within idle handlers, but may have freed the object"},{"text":" ","type":"text"},{"type":"text","text":"before the dispatch of your idle handler."}],"type":"paragraph"},{"type":"codeListing","syntax":"c","code":["static gboolean","idle_callback (gpointer data)","{","  SomeWidget *self = data;","   ","  g_mutex_lock (&self->idle_id_mutex);","  \/\/ do stuff with self","  self->idle_id = 0;","  g_mutex_unlock (&self->idle_id_mutex);","   ","  return G_SOURCE_REMOVE;","}"," ","static void","some_widget_do_stuff_later (SomeWidget *self)","{","  g_mutex_lock (&self->idle_id_mutex);","  self->idle_id = g_idle_add (idle_callback, self);","  g_mutex_unlock (&self->idle_id_mutex);","}"," ","static void","some_widget_init (SomeWidget *self)","{","  g_mutex_init (&self->idle_id_mutex);","","  \/\/ ...","}","","static void","some_widget_finalize (GObject *object)","{","  SomeWidget *self = SOME_WIDGET (object);","   ","  if (self->idle_id)","    g_source_remove (self->idle_id);","   ","  g_mutex_clear (&self->idle_id_mutex);","","  G_OBJECT_CLASS (parent_class)->finalize (object);","}"]},{"inlineContent":[{"text":"This will fail in a multi-threaded application if the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"widget is destroyed before the idle handler fires due"},{"text":" ","type":"text"},{"text":"to the use after free in the callback. A solution, to","type":"text"},{"type":"text","text":" "},{"text":"this particular problem, is to check to if the source","type":"text"},{"text":" ","type":"text"},{"text":"has already been destroy within the callback.","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["static gboolean","idle_callback (gpointer data)","{","  SomeWidget *self = data;","  ","  g_mutex_lock (&self->idle_id_mutex);","  if (!g_source_is_destroyed (g_main_current_source ()))","    {","      \/\/ do stuff with self","    }","  g_mutex_unlock (&self->idle_id_mutex);","  ","  return FALSE;","}"],"syntax":"c"},{"inlineContent":[{"text":"Calls to this function from a thread other than the one acquired by the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[struct"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","type":"reference"},{"type":"text","text":"] the [struct"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","isActive":true,"type":"reference"},{"type":"text","text":"] is attached to are typically"},{"text":" ","type":"text"},{"text":"redundant, as the source could be destroyed immediately after this function","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"returns. However, once a source is destroyed it cannot be un-destroyed, so"},{"text":" ","type":"text"},{"text":"this function can be used for opportunistic checks from any thread.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"sections":[],"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"externalID":"s:4GLib14SourceProtocolPAAE11isDestroyedSbvp::SYNTHESIZED::s:4GLib6SourceC","symbolKind":"property","role":"symbol","modules":[{"name":"GLib"}],"roleH