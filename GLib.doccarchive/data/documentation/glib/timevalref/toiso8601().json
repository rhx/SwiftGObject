{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/TimeValRef","doc:\/\/GLib\/documentation\/GLib\/TimeValRef\/TimeValProtocol-Implementations"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/TimeValRef\/toIso8601()","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/glib\/timevalref\/toiso8601()"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"Converts ","type":"text"},{"type":"codeVoice","code":"time"},{"text":" into an RFC 3339 encoded string, relative to the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Coordinated Universal Time (UTC). This is one of the many formats"},{"text":" ","type":"text"},{"type":"text","text":"allowed by ISO 8601."}],"kind":"symbol","primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"toIso8601","kind":"identifier"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"text":"!","kind":"text"}]}],"kind":"declarations"},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"inlineContent":[{"type":"text","text":"ISO 8601 allows a large number of date\/time formats, with or without"},{"type":"text","text":" "},{"type":"text","text":"punctuation and optional elements. The format returned by this function"},{"text":" ","type":"text"},{"type":"text","text":"is a complete date and time, with optional punctuation included, the"},{"type":"text","text":" "},{"type":"text","text":"UTC time zone represented as “Z”, and the "},{"code":"tv_usec","type":"codeVoice"},{"text":" part included if","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and only if it is nonzero, i.e. either"},{"type":"text","text":" "},{"text":"“YYYY-MM-DDTHH:MM:SSZ” or “YYYY-MM-DDTHH:MM:SS.fffffZ”.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This corresponds to the Internet date\/time format defined by","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"https:\/\/www.ietf.org\/rfc\/rfc3339.txt","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"and to either of the two most-precise formats defined by"},{"text":" ","type":"text"},{"type":"text","text":"the W3C Note"},{"text":" ","type":"text"},{"identifier":"http:\/\/www.w3.org\/TR\/NOTE-datetime-19980827","isActive":true,"type":"reference"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Both of these documents are profiles of ISO 8601."}]},{"inlineContent":[{"text":"Use ","type":"text"},{"type":"codeVoice","code":"g_date_time_format()"},{"type":"text","text":" or "},{"type":"codeVoice","code":"g_strdup_printf()"},{"text":" if a different","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"variation of ISO 8601 format is required."}],"type":"paragraph"},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"time"},{"type":"text","text":" represents a date which is too large to fit into a "},{"type":"codeVoice","code":"struct tm"},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" will be returned. This is platform dependent. Note also that since","type":"text"},{"text":" ","type":"text"},{"code":"GTimeVal","type":"codeVoice"},{"type":"text","text":" stores the number of seconds as a "},{"type":"codeVoice","code":"glong"},{"type":"text","text":", on 32-bit systems it"},{"type":"text","text":" "},{"text":"is subject to the year 2038 problem. Accordingly, since GLib 2.62, this","type":"text"},{"text":" ","type":"text"},{"text":"function has been deprecated. Equivalent functionality is available using:","type":"text"}],"type":"paragraph"},{"syntax":null,"type":"codeListing","code":["GDateTime *dt = g_date_time_new_from_unix_utc (time_val);","iso8601_string = g_date_time_format_iso8601 (dt);","g_date_time_unref (dt);"]},{"type":"paragraph","inlineContent":[{"text":"The return value of ","type":"text"},{"code":"g_time_val_to_iso8601()","type":"codeVoice"},{"text":" has been nullable since GLib","type":"text"},{"type":"text","text":" "},{"type":"text","text":"2.54; before then, GLib would crash under the same conditions."}]},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"to_iso8601 is deprecated:"}]},{"type":"text","text":" "},{"text":"#GTimeVal is not year-2038-safe. Use","type":"text"},{"type":"text","text":" "},{"type":"text","text":"g_date_time_format_iso8601(dt) instead."}],"type":"paragraph"}],"kind":"content"}],"sections":[],"metadata":{"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"toIso8601"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"text":"!","kind":"text"}],"title":"toIso8601()","platforms":[],"roleHeading":"Instance Method","role":"symbol","externalID":"s:4GLib15TimeValProtocolPAAE9toIso8601SSSgyF::SYNTHESIZED::s:4GLib10TimeValRefV","modules":[{"name":"GLib"}],"extendedModule":"GLib","symbolKind":"method"},"references":{"doc://GLib/documentation/GLib/TimeValRef/toIso8601()":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeValRef\/toIso8601()","type":"topic","deprecated":true,"abstract":[{"text":"Converts ","type":"text"},{"type":"codeVoice","code":"time"},{"type":"text","text":" into an RFC 3339 encoded string, relative to the"},{"type":"text","text":" "},{"text":"Coordinated Universal Time (UTC). This is one of the many formats","type":"text"},{"type":"text","text":" "},{"type":"text","text":"allowed by ISO 8601."}],"kind":"symbol","title":"toIso8601()","url":"\/documentation\/glib\/timevalref\/toiso8601()","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"toIso8601"},{"text":"() -> ","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":"!","kind":"text"}]},"doc://GLib/documentation/GLib/TimeValRef/TimeValProtocol-Implementations":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeValRef\/TimeValProtocol-Implementations","type":"topic","abstract":[],"title":"TimeValProtocol Implementations","kind":"article","role":"collectionGroup","url":"\/documentation\/glib\/timevalref\/timevalprotocol-implementations"},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/TimeValRef":{"title":"TimeValRef","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeValRef","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"TimeValRef","kind":"identifier"}],"abstract":[{"text":"Represents a precise time, with seconds and microseconds.","type":"text"}],"kind":"symbol","url":"\/documentation\/glib\/timevalref","navigatorTitle":[{"kind":"identifier","text":"TimeValRef"}],"type":"topic","role":"symbol"},"http://www.w3.org/TR/NOTE-datetime-19980827":{"url":"http:\/\/www.w3.org\/TR\/NOTE-datetime-19980827","type":"link","titleInlineContent":[{"text":"Date and Time Formats","type":"text"}],"identifier":"http:\/\/www.w3.org\/TR\/NOTE-datetime-19980827","title":"Date and Time Formats"},"https://www.ietf.org/rfc/rfc3339.txt":{"url":"https:\/\/www.ietf.org\/rfc\/rfc3339.txt","type":"link","titleInlineContent":[{"text":"RFC 3339","type":"text"}],"identifier":"https:\/\/www.ietf.org\/rfc\/rfc3339.txt","title":"RFC 3339"}}}