{"abstract":[{"type":"text","text":"Matches a string against a compiled pattern."}],"metadata":{"extendedModule":"GLib","role":"symbol","title":"patternMatch(stringLength:string:stringReversed:)","modules":[{"name":"GLib"}],"externalID":"s:4GLib19PatternSpecProtocolPAAE12patternMatch12stringLength0G00G8ReversedSbSi_SPys4Int8VGSgAKtF::SYNTHESIZED::s:4GLib11PatternSpecC","symbolKind":"method","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"patternMatch"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"stringLength"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"string","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"stringReversed"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">?) -> "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"platforms":[]},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/PatternSpec","doc:\/\/GLib\/documentation\/GLib\/PatternSpec\/PatternSpecProtocol-Implementations"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"patternMatch"},{"kind":"text","text":"("},{"text":"stringLength","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"string"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">!, "},{"text":"stringReversed","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">? = nil) -> "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Passing the correct"},{"text":" ","type":"text"},{"text":"length of the string given is mandatory. The reversed string can be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"omitted by passing "},{"code":"NULL","type":"codeVoice"},{"text":", this is more efficient if the reversed","type":"text"},{"type":"text","text":" "},{"text":"version of the string to be matched is not at hand, as","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_pattern_match()"},{"type":"text","text":" will only construct it if the compiled pattern"},{"type":"text","text":" "},{"type":"text","text":"requires reverse matches."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that, if the user code will (possibly) match a string against a"},{"text":" ","type":"text"},{"type":"text","text":"multitude of patterns containing wildcards, chances are high that"},{"text":" ","type":"text"},{"type":"text","text":"some patterns will require a reversed string. In this case, it’s"},{"type":"text","text":" "},{"type":"text","text":"more efficient to provide the reversed string to avoid multiple"},{"text":" ","type":"text"},{"text":"constructions thereof in the various calls to ","type":"text"},{"type":"codeVoice","code":"g_pattern_match()"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note also that the reverse of a UTF-8 encoded string can in general"},{"type":"text","text":" "},{"type":"text","text":"not be obtained by [func"},{"type":"codeVoice","code":"GLib.strreverse"},{"type":"text","text":"]. This works only if the string"},{"type":"text","text":" "},{"type":"text","text":"does not contain any multibyte characters. GLib offers the"},{"text":" ","type":"text"},{"type":"text","text":"[func"},{"code":"GLib.utf8_strreverse","type":"codeVoice"},{"type":"text","text":"] function to reverse UTF-8 encoded strings."}]},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"pattern_match is deprecated:","type":"text"}]},{"text":" ","type":"text"},{"type":"text","text":"Use [method@GLib.PatternSpec.match] instead"}],"type":"paragraph"}],"kind":"content"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/PatternSpec\/patternMatch(stringLength:string:stringReversed:)","interfaceLanguage":"swift"},"sections":[],"kind":"symbol","variants":[{"paths":["\/documentation\/glib\/patternspec\/patternmatch(stringlength:string:stringreversed:)"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GLib/documentation/GLib/PatternSpec/patternMatch(stringLength:string:stringReversed:)":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/PatternSpec\/patternMatch(stringLength:string:stringReversed:)","abstract":[{"text":"Matches a string against a compiled pattern.","type":"text"}],"type":"topic","title":"patternMatch(stringLength:string:stringReversed:)","role":"symbol","deprecated":true,"url":"\/documentation\/glib\/patternspec\/patternmatch(stringlength:string:stringreversed:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"patternMatch","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","