{"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/PatternSpec\/patternMatch(stringLength:string:stringReversed:)","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"patternMatch"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"stringLength"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"string"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"stringReversed"},{"kind":"text","text":": "},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">? = nil) -> ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Passing the correct"},{"type":"text","text":" "},{"type":"text","text":"length of the string given is mandatory. The reversed string can be"},{"type":"text","text":" "},{"text":"omitted by passing ","type":"text"},{"type":"codeVoice","code":"NULL"},{"text":", this is more efficient if the reversed","type":"text"},{"text":" ","type":"text"},{"text":"version of the string to be matched is not at hand, as","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_pattern_match()"},{"text":" will only construct it if the compiled pattern","type":"text"},{"type":"text","text":" "},{"text":"requires reverse matches.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Note that, if the user code will (possibly) match a string against a"},{"text":" ","type":"text"},{"type":"text","text":"multitude of patterns containing wildcards, chances are high that"},{"type":"text","text":" "},{"text":"some patterns will require a reversed string. In this case, it’s","type":"text"},{"text":" ","type":"text"},{"text":"more efficient to provide the reversed string to avoid multiple","type":"text"},{"type":"text","text":" "},{"type":"text","text":"constructions thereof in the various calls to "},{"type":"codeVoice","code":"g_pattern_match()"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note also that the reverse of a UTF-8 encoded string can in general"},{"text":" ","type":"text"},{"type":"text","text":"not be obtained by [func"},{"type":"codeVoice","code":"GLib.strreverse"},{"type":"text","text":"]. This works only if the string"},{"text":" ","type":"text"},{"type":"text","text":"does not contain any multibyte characters. GLib offers the"},{"text":" ","type":"text"},{"type":"text","text":"[func"},{"code":"GLib.utf8_strreverse","type":"codeVoice"},{"text":"] function to reverse UTF-8 encoded strings.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"pattern_match is deprecated:","type":"text"}]},{"text":" ","type":"text"},{"text":"Use [method@GLib.PatternSpec.match] instead","type":"text"}]}],"kind":"content"}],"metadata":{"roleHeading":"Instance Method","role":"symbol","symbolKind":"method","externalID":"s:4GLib19PatternSpecProtocolPAAE12patternMatch12stringLength0G00G8ReversedSbSi_SPys4Int8VGSgAKtF::SYNTHESIZED::s:4GLib11PatternSpecC","platforms":[],"title":"patternMatch(stringLength:string:stringReversed:)","extendedModule":"GLib","modules":[{"name":"GLib"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"iden