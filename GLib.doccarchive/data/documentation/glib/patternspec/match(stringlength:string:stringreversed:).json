{"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"title":"match(stringLength:string:stringReversed:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"match"},{"kind":"text","text":"("},{"text":"stringLength","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"string"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"stringReversed"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">?) -> "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"modules":[{"name":"GLib"}],"role":"symbol","symbolKind":"method","extendedModule":"GLib","externalID":"s:4GLib19PatternSpecProtocolPAAE5match12stringLength0F00F8ReversedSbSi_SPys4Int8VGSgAKtF::SYNTHESIZED::s:4GLib11PatternSpecC","roleHeading":"Instance Method"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/PatternSpec","doc:\/\/GLib\/documentation\/GLib\/PatternSpec\/PatternSpecProtocol-Implementations"]]},"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/PatternSpec\/match(stringLength:string:stringReversed:)"},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/patternspec\/match(stringlength:string:stringreversed:)"]}],"abstract":[{"type":"text","text":"Matches a string against a compiled pattern."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"match","kind":"identifier"},{"kind":"text","text":"("},{"text":"stringLength","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":", "},{"kind":"externalParam","text":"string"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"stringReversed"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">? = nil) -> "},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Passing the correct"},{"type":"text","text":" "},{"text":"length of the string given is mandatory. The reversed string can be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"omitted by passing "},{"code":"NULL","type":"codeVoice"},{"type":"text","text":", this is more efficient if the reversed"},{"text":" ","type":"text"},{"type":"text","text":"version of the string to be matched is not at hand, as"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"code":"GLib.PatternSpec.match","type":"codeVoice"},{"type":"text","text":"] will only construct it if the compiled pattern"},{"text":" ","type":"text"},{"type":"text","text":"requires reverse matches."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Note that, if the user code will (possibly) match a string against a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"multitude of patterns containing wildcards, chances are high that"},{"text":" ","type":"text"},{"text":"some patterns will require a reversed string. In this case, it’s","type":"text"},{"type":"text","text":" "},{"type":"text","text":"more efficient to provide the reversed string to avoid multiple"},{"type":"text","text":" "},{"text":"constructions thereof in the various calls to [method","type":"text"},{"code":"GLib.PatternSpec.match","type":"codeVoice"},{"text":"].","type":"text"}]},{"inlineContent":[{"type":"text","text":"Note also that the reverse of a UTF-8 encoded string can in general"},{"type":"text","text":" "},{"text":"not be obtained by [func","type":"text"},{"code":"GLib.strreverse","type":"codeVoice"},{"type":"text","text":"]. This works only if the string"},{"text":" ","type":"text"},{"type":"text","text":"does not contain any multibyte characters. GLib offers the"},{"text":" ","type":"text"},{"text":"[func","type":"text"},{"code":"GLib.utf8_strreverse","type":"codeVoice"},{"type":"text","text":"] function to reverse UTF-8 encoded strings."}],"type":"paragraph"}]}],"references":{"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/PatternSpec":{"url":"\/documentation\/glib\/patternspec","type":"topic","title":"PatternSpec","navigatorTitle":[{"kind":"identifier","text":"PatternSpec"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/PatternSpec","role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"PatternSpec","kind":"identifier"}],"kind":"symbol","abstract":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"GPatternSpec"},{"text":" struct is the ‘compiled’ form of a glob-style pattern.","type":"text"}]},"doc://GLib/documentation/GLib/PatternSpec/PatternSpecProtocol-Implementations":{"abstract":[],"title":"PatternSpecProtocol Implementations","type":"topic","kind":"article","url":"\/documentation\/glib\/patternspec\/patternspecprotocol-implementations","role":"collectionGroup","identifier":"doc:\/\/GLib\/documentation\/GLib\/PatternSpec\/PatternSpecProtocol-Implementations"},"doc://GLib/documentation/GLib/PatternSpec/match(stringLength:string:stringReversed:)":{"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"match","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"stringLength"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"string","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"stringReversed"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">?) -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/PatternSpec\/match(stringLength:string:stringReversed:)","type":"topic","abstract":[{"text":"Matches a string against a compiled pattern.","type":"text"}],"title":"match(stringLength:string:stringReversed:)","role":"symbol","kind":"symbol","url":"\/documentation\/glib\/patternspec\/match(stringlength:string:stringreversed:)"}}}