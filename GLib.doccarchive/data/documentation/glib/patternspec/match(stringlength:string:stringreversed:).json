{"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"match","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"stringLength"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"string","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">!, ","kind":"text"},{"text":"stringReversed","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"kind":"text","text":">? = nil) -> "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"text":"Passing the correct","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"length of the string given is mandatory. The reversed string can be"},{"text":" ","type":"text"},{"type":"text","text":"omitted by passing "},{"type":"codeVoice","code":"NULL"},{"text":", this is more efficient if the reversed","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"version of the string to be matched is not at hand, as"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GLib.PatternSpec.match"},{"text":"] will only construct it if the compiled pattern","type":"text"},{"type":"text","text":" "},{"text":"requires reverse matches.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Note that, if the user code will (possibly) match a string against a","type":"text"},{"type":"text","text":" "},{"text":"multitude of patterns containing wildcards, chances are high that","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"some patterns will require a reversed string. In this case, it’s"},{"type":"text","text":" "},{"type":"text","text":"more efficient to provide the reversed string to avoid multiple"},{"type":"text","text":" "},{"text":"constructions thereof in the various calls to [method","type":"text"},{"type":"codeVoice","code":"GLib.PatternSpec.match"},{"type":"text","text":"]."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note also that the reverse of a UTF-8 encoded string can in general"},{"text":" ","type":"text"},{"text":"not be obtained by [func","type":"text"},{"type":"codeVoice","code":"GLib.strreverse"},{"type":"text","text":"]. This works only if the string"},{"text":" ","type":"text"},{"text":"does not contain any multibyte characters. GLib offers the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.utf8_strreverse"},{"text":"] function to reverse UTF-8 encoded strings.","type":"text"}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/PatternSpec","doc:\/\/GLib\/documentation\/GLib\/PatternSpec\/PatternSpecProtocol-Implementations"]]},"metadata":{"roleHeading":"Instance Method","extendedModule":"GLib","externalID":"s:4GLib19PatternSpecProtocolPAAE5match12stringLength0F00F8ReversedSbSi_SPys4Int8VGSgAKtF::SYNTHESIZED::s:4GLib11PatternSpecC","title":"match(stringLength:string:stringReversed:)","symbolKind":"method","modules":[{"name":"GLib"}],"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"match"},{"kind":"text","text":"("},{"kind":"externalParam","text":"stringLength"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdent