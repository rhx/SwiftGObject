yword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"PointerWrapper"}],"type":"topic","navigatorTitle":[{"text":"PointerWrapper","kind":"identifier"}]},"doc://GLib/documentation/GLib/CondProtocol/wait(mutex:)":{"url":"\/documentation\/glib\/condprotocol\/wait(mutex:)","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"wait"},{"text":"<","kind":"text"},{"text":"MutexT","kind":"genericParameter"},{"kind":"text","text":">("},{"text":"mutex","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"MutexT"},{"text":")","kind":"text"}],"abstract":[{"type":"text","text":"Atomically releases "},{"type":"codeVoice","code":"mutex"},{"type":"text","text":" and waits until "},{"code":"cond","type":"codeVoice"},{"text":" is signalled.","type":"text"},{"type":"text","text":" "},{"text":"When this function returns, ","type":"text"},{"code":"mutex","type":"codeVoice"},{"type":"text","text":" is locked again and owned by the"},{"type":"text","text":" "},{"type":"text","text":"calling thread."}],"title":"wait(mutex:)","type":"topic","role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/CondProtocol\/wait(mutex:)"},"doc://GLib/documentation/GLib/CondProtocol/broadcast()":{"title":"broadcast()","abstract":[{"type":"text","text":"If threads are waiting for "},{"type":"codeVoice","code":"cond"},{"text":", all of them are unblocked.","type":"text"},{"text":" ","type":"text"},{"text":"If no threads are waiting for ","type":"text"},{"type":"codeVoice","code":"cond"},{"type":"text","text":", this function has no effect."},{"text":" ","type":"text"},{"text":"It is good practice to lock the same mutex as the waiting threads","type":"text"},{"type":"text","text":" "},{"text":"while calling this function, though not required.","type":"text"}],"kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"broadcast"},{"text":"()","kind":"text"}],"url":"\/documentation\/glib\/condprotocol\/broadcast()","role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/CondProtocol\/broadcast()","type":"topic"},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/CondProtocol/init_()":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"init_"},{"text":"()","kind":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/CondProtocol\/init_()","type":"topic","abstract":[{"text":"Initialises a ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","type":"reference","isActive":true},{"text":" so that it can be used.","type":"text"}],"title":"init_()","role":"symbol","kind":"symbol","url":"\/documentation\/glib\/condprotocol\/init_()"},"doc://GLib/documentation/GLib/Cond":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","type":"topic","abstract":[{"text":"The ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond"},{"text":" struct is an opaque data structure that represents a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"condition. Threads can block on a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond"},{"text":" if they find a certain","type":"text"},{"type":"text","text":" "},{"text":"condition to be false. If other threads change the state of this","type":"text"},{"type":"text","text":" "},{"text":"condition they signal the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","type":"reference"},{"text":", and that causes the waiting","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"threads to be woken up."}],"title":"Cond","navigatorTitle":[{"kind":"identifier","text":"Cond"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Cond"}],"url":"\/documentation\/glib\/cond","kind":"symbol","role":"symbol"},"doc://GLib/documentation/GLib/CondProtocol/signal()":{"abstract":[{"type":"text","text":"If threads are waiting for "},{"code":"cond","type":"codeVoice"},{"type":"text","text":", at least one of them is unblocked."},{"type":"text","text":" "},{"type":"text","text":"If no threads are waiting for "},{"type":"codeVoice","code":"cond"},{"type":"text","text":", this function has no effect."},{"text":" ","type":"text"},{"text":"It is good practice to hold the same lock as the waiting thread","type":"text"},{"type":"text","text":" "},{"text":"while calling this function, though not required.","type":"text"}],"url":"\/documentation\/glib\/condprotocol\/signal()","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"signal","kind":"identifier"},{"kind":"text","text":"()"}],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/CondProtocol\/signal()","role":"symbol","title":"signal()"},"doc://GLib/documentation/GLib/CondProtocol/timedWait(mutex:absTime:)":{"kind":"symbol","abstract":[{"text":"Waits until this thread is woken up on ","type":"text"},{"type":"codeVoice","code":"cond"},{"text":", but not longer than","type":"text"},{"type":"text","text":" "},{"type":"text","text":"until the time specified by "},{"code":"absTime","type":"codeVoice"},{"type":"text","text":". The "},{"code":"mutex","type":"codeVoice"},{"text":" is unlocked before","type":"text"},{"text":" ","type":"text"},{"text":"falling asleep and locked again before resuming.","type":"text"}],"deprecated":true,"type":"topic","url":"\/documentation\/glib\/condprotocol\/timedwait(mutex:abstime:)","identifier":"doc:\/\/GLib\/documentation\/GLib\/CondProtocol\/timedWait(mutex:absTime:)","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"timedWai