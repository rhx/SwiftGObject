{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/condprotocol"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"CondProtocol"},{"text":" : ","kind":"text"},{"text":"PointerWrapper","preciseIdentifier":"s:4GLib14PointerWrapperP","kind":"typeIdentifier","identifier":"doc:\/\/GLib\/documentation\/GLib\/PointerWrapper"}],"languages":["swift"]}]},{"content":[{"level":2,"anchor":"overview","type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Consider the following example of a shared variable.  One or more","type":"text"},{"type":"text","text":" "},{"text":"threads can wait for data to be published to the variable and when","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"another thread publishes the data, it can signal one of the waiting"},{"type":"text","text":" "},{"type":"text","text":"threads to wake up to collect the data."}]},{"inlineContent":[{"type":"text","text":"Here is an example for using GCond to block a thread until a condition"},{"type":"text","text":" "},{"type":"text","text":"is satisfied:"},{"type":"text","text":" "},{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"type":"codeListing","syntax":"C","code":["  gpointer current_data = NULL;","  GMutex data_mutex;","  GCond data_cond;","","  void","  push_data (gpointer data)","  {","    g_mutex_lock (&data_mutex);","    current_data = data;","    g_cond_signal (&data_cond);","    g_mutex_unlock (&data_mutex);","  }","","  gpointer","  pop_data (void)","  {","    gpointer data;","","    g_mutex_lock (&data_mutex);","    while (!current_data)","      g_cond_wait (&data_cond, &data_mutex);","    data = current_data;","    current_data = NULL;","    g_mutex_unlock (&data_mutex);","","    return data;","  }"]},{"inlineContent":[{"type":"text","text":"Whenever a thread calls "},{"type":"codeVoice","code":"pop_data()"},{"type":"text","text":" now, it will wait until"},{"type":"text","text":" "},{"text":"current_data is non-","type":"text"},{"type":"codeVoice","code":"nil"},{"text":", i.e. until some other thread","type":"text"},{"type":"text","text":" "},{"text":"has called ","type":"text"},{"code":"push_data()","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"The example shows that use of a condition variable must always be","type":"text"},{"text":" ","type":"text"},{"text":"paired with a mutex.  Without the use of a mutex, there would be a","type":"text"},{"text":" ","type":"text"},{"text":"race between the check of ","type":"text"},{"code":"current_data","type":"codeVoice"},{"type":"text","text":" by the while loop in"},{"text":" ","type":"text"},{"type":"codeVoice","code":"pop_data()"},{"type":"text","text":" and waiting. Specifically, another thread could set"},{"type":"text","text":" "},{"code":"current_data","type":"codeVoice"},{"type":"text","text":" after the check, and signal the cond (with nobody"},{"text":" ","type":"text"},{"type":"text","text":"waiting on it) before the first thread goes to sleep. "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond"},{"text":" is","type":"text"},{"type":"text","text":" "},{"text":"specifically useful for its ability to release the mutex and go","type":"text"},{"type":"text","text":" "},{"text":"to sleep atomically.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"It is also important to use the ","type":"text"},{"type":"codeVoice","code":"g_cond_wait()"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"g_cond_wait_until()"},{"type":"text","text":" "},{"text":"functions only inside a loop which checks for the condition to be","type":"text"},{"type":"text","text":" "},{"text":"true.  See ","type":"text"},{"type":"codeVoice","code":"g_cond_wait()"},{"text":" for an explanation of why the condition may","type":"text"},{"text":" ","type":"text"},{"text":"not be true even after it returns.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond"},{"type":"text","text":" is allocated in static storage then it can be used"},{"type":"text","text":" "},{"type":"text","text":"without initialisation.  Otherwise, you should call "},{"type":"codeVoice","code":"g_cond_init()"},{"type":"text","text":" "},{"type":"text","text":"on it and "},{"code":"g_cond_clear()","type":"codeVoice"},{"type":"text","text":" when done."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond"},{"type":"text","text":" should only be accessed via the g_cond_ functions."}]},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/CondProtocol","isActive":true,"type":"reference"},{"type":"text","text":" protocol exposes the methods and properties of an underlying "},{"code":"GCond","type":"codeVoice"},{"text":" instance.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"The default implementation of these can be found in the protocol extension below."},{"type":"text","text":" "},{"text":"For a concrete class that implements these methods and properties, see ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Alternatively, use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/CondRef"},{"text":" as a lighweight, ","type":"text"},{"type":"codeVoice","code":"unowned"},{"text":" reference if you already have an instance you just want to use.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"relationshipsSections":[{"kind":"relationships","type":"inheritsFrom","identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper"],"title":"Inherits From"},{"kind":"relationships","identifiers":["doc:\/\/GLib\/documentation\/GLib\/Cond","doc:\/\/GLib\/documentation\/GLib\/CondRef"],"type":"conformingTypes","title":"Conforming Types"}],"abstract":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond"},{"text":" struct is an opaque data structure that represents a","type":"text"},{"type":"text","text":" "},{"text":"condition. Threads can block on a ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","isActive":true,"type":"reference"},{"type":"text","text":" if they find a certain"},{"text":" ","type":"text"},{"type":"text","text":"condition to be false. If other threads change the state of this"},{"text":" ","type":"text"},{"text":"condition they signal the ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","isActive":true,"type":"reference"},{"type":"text","text":", and that causes the waiting"},{"type":"text","text":" "},{"text":"threads to be woken up.","type":"text"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","sections":[],"metadata":{"modules":[{"name":"GLib"}],"fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"CondProtocol"}],"symbolKind":"protocol","title":"CondProtocol","roleHeading":"Protocol","navigatorTitle":[{"text":"CondProtocol","kind":"identifier"}],"externalID":"s:4GLib12CondProtocolP","role":"symbol"},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/CondProtocol","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"topicSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/CondProtocol\/broadcast()","doc:\/\/GLib\/documentation\/GLib\/CondProtocol\/clear()","doc:\/\/GLib\/documentation\/GLib\/CondProtocol\/free()","doc