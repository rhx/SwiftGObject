{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"The memory at ","type":"text"},{"code":"limit","type":"codeVoice"},{"type":"text","text":" will never be accessed and the parser behaves as"},{"text":" ","type":"text"},{"text":"if the character at ","type":"text"},{"type":"codeVoice","code":"limit"},{"text":" is the nul terminator.  This has the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"effect of bounding "},{"type":"codeVoice","code":"text"},{"text":".","type":"text"}]},{"inlineContent":[{"text":"If ","type":"text"},{"code":"endptr","type":"codeVoice"},{"text":" is non-","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":" then "},{"code":"text","type":"codeVoice"},{"text":" is permitted to contain data","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"following the value that this function parses and "},{"type":"codeVoice","code":"endptr"},{"text":" will be","type":"text"},{"text":" ","type":"text"},{"text":"updated to point to the first character past the end of the text","type":"text"},{"type":"text","text":" "},{"type":"text","text":"parsed by this function.  If "},{"type":"codeVoice","code":"endptr"},{"type":"text","text":" is "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" and there is extra data"},{"type":"text","text":" "},{"type":"text","text":"then an error is returned."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"type"},{"text":" is non-","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" then the value will be parsed to have that","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"type.  This may result in additional parse errors (in the case that"},{"type":"text","text":" "},{"type":"text","text":"the parsed value doesn’t fit the type) but may also result in fewer"},{"type":"text","text":" "},{"text":"errors (in the case that the type would have been ambiguous, such as","type":"text"},{"type":"text","text":" "},{"type":"text","text":"with empty arrays)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the event that the parsing is successful, the resulting "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"type":"text","text":" "},{"type":"text","text":"is returned. It is never floating, and must be freed with"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"code":"GLib.Variant.unref","type":"codeVoice"},{"type":"text","text":"]."}]},{"inlineContent":[{"text":"In case of any error, ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" will be returned.  If ","type":"text"},{"type":"codeVoice","code":"error"},{"text":" is non-","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" ","type":"text"},{"text":"then it will be set to reflect the error that occurred.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Officially, the language understood by the parser is “any string","type":"text"},{"type":"text","text":" "},{"text":"produced by [method","type":"text"},{"type":"codeVoice","code":"GLib.Variant.print"},{"text":"]”. This explicitly includes","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_variant_print()"},{"text":"’s annotated types like ","type":"text"},{"type":"codeVoice","code":"int64 -1000"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"There may be implementation specific restrictions on deeply nested values,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"which would result in a "},{"type":"codeVoice","code":"recursion"},{"type":"text","text":" error. "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true,"type":"reference"},{"text":" is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"guaranteed to handle nesting up to at least 64 levels."}]}]}],"identifier":{"url":"doc:\/\/GLib\