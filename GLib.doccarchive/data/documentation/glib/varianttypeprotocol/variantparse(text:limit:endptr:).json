ext:limit:endptr:)"},"sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"variantParse"},{"kind":"text","text":"("},{"text":"text","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"kind":"text","text":">!, "},{"text":"limit","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"text":">? = nil, ","kind":"text"},{"kind":"externalParam","text":"endptr"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sp","kind":"typeIdentifier","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">?>? = nil) "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:4GLib10VariantRefV","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef","text":"VariantRef","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A single "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference"},{"type":"text","text":" is parsed from the content of "},{"type":"codeVoice","code":"text"},{"type":"text","text":"."}]},{"inlineContent":[{"text":"The format is described ","type":"text"},{"type":"reference","isActive":true,"identifier":"gvariant-text-format.html"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The memory at "},{"type":"codeVoice","code":"limit"},{"type":"text","text":" will never be accessed and the parser behaves as"},{"text":" ","type":"text"},{"text":"if the character at ","type":"text"},{"type":"codeVoice","code":"limit"},{"text":" is the nul terminator.  This has the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"effect of bounding "},{"type":"codeVoice","code":"text"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"endptr"},{"type":"text","text":" is non-"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" then "},{"type":"codeVoice","code":"text"},{"type":"text","text":" is permitted to contain data"},{"text":" ","type":"text"},{"type":"text","text":"following the value that this function parses and "},{"code":"endptr","type":"codeVoice"},{"type":"text","text":" will be"},{"text":" ","type":"text"},{"type":"text","text":"updated to point to the first character past the end of the text"},{"type":"text","text":" "},{"text":"parsed by this function.  If ","type":"text"},{"code":"endptr","type":"codeVoice"},{"type":"text","text":" is "},{"type":"codeVoice","code":"nil"},{"text":" and there is extra data","type":"text"},{"type":"text","text":" "},{"text":"then an error is returned.","type":"text"}]},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"type"},{"text":" is non-","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" then the value will be parsed to have that"},{"type":"text","text":" "},{"type":"text","text":"type.  This may result in additional parse errors (in the case that"},{"type":"text","text":" "},{"type":"text","text":"the parsed value doesn’t fit the type) but may also result in fewer"},{"text":" ","type":"text"},{"text":"errors (in the case that the type would have been ambiguous, such as","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"with empty arrays)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"In the event that the parsing is successful, the resulting ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"text":" ","type":"text"},{"type":"text","text":"is returned. It is never floating, and must be freed with"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.Variant.unref"},{"type":"text","text":"]."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In case of any error, "},{"type":"codeVoice","code":"nil"},{"text":" will be returned.  If ","type":"text"},{"type":"codeVoice","code":"error"},{"type":"text","text":" is non-"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" "},{"type":"text","text":"then it will be set to reflect the error that occurred."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Officially, the language understood by the parser is “any string"},{"type":"text","text":" "},{"type":"text","text":"produced by [method"},{"code":"GLib.Variant.print","type":"codeVoice"},{"type":"text","text":"]”. This explicitly includes"},{"text":" ","type":"text"},{"code":"g_variant_print()","type":"codeVoice"},{"type":"text","text":"’s annotated types like "},{"code":"int64 -1000","type":"codeVoice"},{"type":"text","text":"."}]},{"inlineContent":[{"text":"There may be implementation specific restrictions on deeply nested values,","type":"text"},{"type":"text","text":" "},{"text":"which would result in a ","type":"text"},{"type":"codeVoice","code":"recursion"},{"text":" error. ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true,"type":"reference"},{"text":" is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"guaranteed to handle nesting up to at least 64 levels."}],"type":"paragraph"}],"kind":"content"}],