{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/spawnchildsetupfunc"]}],"sections":[],"abstract":[{"text":"Specifies the type of the setup function passed to ","type":"text"},{"type":"codeVoice","code":"g_spawn_async()"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"codeVoice","code":"g_spawn_sync()"},{"text":" and ","type":"text"},{"code":"g_spawn_async_with_pipes()","type":"codeVoice"},{"text":", which can, in very","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"limited ways, be used to affect the child’s execution."}],"metadata":{"symbolKind":"typealias","modules":[{"name":"GLib"}],"fragments":[{"kind":"keyword","text":"typealias"},{"text":" ","kind":"text"},{"kind":"identifier","text":"SpawnChildSetupFunc"}],"roleHeading":"Type Alias","title":"SpawnChildSetupFunc","navigatorTitle":[{"text":"SpawnChildSetupFunc","kind":"identifier"}],"role":"symbol","externalID":"s:4GLib19SpawnChildSetupFunca"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"typealias","kind":"keyword"},{"kind":"text","text":" "},{"text":"SpawnChildSetupFunc","kind":"identifier"},{"text":" = ","kind":"text"},{"text":"GSpawnChildSetupFunc","kind":"typeIdentifier","preciseIdentifier":"c:@T@GSpawnChildSetupFunc"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"inlineContent":[{"type":"text","text":"On POSIX platforms, the function is called in the child after GLib"},{"type":"text","text":" "},{"type":"text","text":"has performed all the setup it plans to perform, but before calling"},{"type":"text","text":" "},{"type":"codeVoice","code":"exec()"},{"type":"text","text":". Actions taken in this function will only affect the child,"},{"type":"text","text":" "},{"text":"not the parent.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"On Windows, the function is called in the parent. Its usefulness on","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Windows is thus questionable. In many cases executing the child setup"},{"type":"text","text":" "},{"type":"text","text":"function in the parent can have ill effects, and you should be very"},{"text":" ","type":"text"},{"type":"text","text":"careful when porting software to Windows that uses child setup"},{"text":" ","type":"text"},{"type":"text","text":"functions."}]},{"inlineContent":[{"type":"text","text":"However, even on POSIX, you are extremely limited in what you can"},{"text":" ","type":"text"},{"type":"text","text":"safely do from a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/SpawnChildSetupFunc"},{"text":", because any mutexes that were","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"held by other threads in the parent process at the time of the "},{"type":"codeVoice","code":"fork()"},{"type":"text","text":" "},{"text":"will still be locked in the child process, and they will never be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"unlocked (since the threads that held them don’t exist in the child)."},{"type":"text","text":" "},{"text":"POSIX allows only async-signal-safe functions (see ","type":"text"},{"code":"signal(7)","type":"codeVoice"},{"type":"text","text":") to be"},{"text":" ","type":"text"},{"type":"text","text":"called in the child between "},{"type":"codeVoice","code":"fork()"},{"type":"text","text":" and "},{"type":"codeVoice","code":"exec()"},{"text":", which drastically limits","type":"text"},{"type":"text","text":" "},{"text":"the usefulness of child setup functions.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In particular, it is not safe to call any function which may"},{"text":" ","type":"text"},{"text":"call ","type":"text"},{"code":"malloc()","type":"codeVoice"},{"text":", which includes POSIX functions such as ","type":"text"},{"type":"codeVoice","code":"setenv()"},{"type":"text","text":"."},{"text":" ","type":"text"},{"type":"text","text":"If you need to set up the child environment differently from"},{"type":"text","text":" "},{"text":"the parent, you should use ","type":"text"},{"type":"codeVoice","code":"g_get_environ()"},{"type":"text","text":", "},{"code":"g_environ_setenv()","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"text":"and ","type":"text"},{"type":"codeVoice","code":"g_environ_unsetenv()"},{"text":", and then pass the complete environment","type":"text"},{"text":" ","type":"text"},{"text":"list to the ","type":"text"},{"type":"codeVoice","code":"g_spawn..."},{"type":"text","text":" function."}]}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/SpawnChildSetupFunc"},"kind":"symbol","references":{"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/SpawnChildSetupFunc":{"abstract":[{"text":"Specifies the type of the setup function passed to ","type":"text"},{"type":"codeVoice","code":"g_spawn_async()"},{"type":"text","text":","},{"text":" ","type":"text"},{"code":"g_spawn_sync()","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"g_spawn_async_with_pipes()","type":"codeVoice"},{"text":", which can, in very","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"limited ways, be used to affect the child’s execution."}],"fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"SpawnChildSetupFunc"}],"title":"SpawnChildSetupFunc","type":"topic","navigatorTitle":[{"text":"SpawnChildSetupFunc","kind":"identifier"}],"role":"symbol","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/SpawnChildSetupFunc","url":"\/documentation\/glib\/spawnchildsetupfunc"}}}