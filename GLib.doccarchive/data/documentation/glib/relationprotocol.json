{"metadata":{"title":"RelationProtocol","externalID":"s:4GLib16RelationProtocolP","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"RelationProtocol"}],"role":"symbol","symbolKind":"protocol","modules":[{"name":"GLib"}],"navigatorTitle":[{"text":"RelationProtocol","kind":"identifier"}],"roleHeading":"Protocol"},"abstract":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"GRelation"},{"type":"text","text":" is a table of data which can be indexed on any number"},{"text":" ","type":"text"},{"type":"text","text":"of fields, rather like simple database tables. A "},{"code":"GRelation","type":"codeVoice"},{"type":"text","text":" contains"},{"type":"text","text":" "},{"type":"text","text":"a number of records, called tuples. Each record contains a number of"},{"type":"text","text":" "},{"text":"fields. Records are not ordered, so it is not possible to find the","type":"text"},{"text":" ","type":"text"},{"text":"record at a particular index.","type":"text"}],"kind":"symbol","sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/relationprotocol"]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/RelationProtocol","interfaceLanguage":"swift"},"relationshipsSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper"],"title":"Inherits From","kind":"relationships","type":"inheritsFrom"},{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/Relation","doc:\/\/GLib\/documentation\/GLib\/RelationRef"],"kind":"relationships","title":"Conforming Types","type":"conformingTypes"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"topicSections":[{"generated":true,"title":"Instance Methods","identifiers":["doc:\/\/GLib\/documentation\/GLib\/RelationProtocol\/count(key:field:)","doc:\/\/GLib\/documentation\/GLib\/RelationProtocol\/delete(key:field:)","doc:\/\/GLib\/documentation\/GLib\/Relatio