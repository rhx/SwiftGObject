{"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"article","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/tutorial"]}],"sections":[],"metadata":{"title":"Using GLib with Swift","roleHeading":"Article","role":"article","modules":[{"name":"GLib"}]},"primaryContentSections":[{"content":[{"level":2,"anchor":"What-is-GLib","text":"What is GLib?","type":"heading"},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/docs.gtk.org\/glib\/","isActive":true,"type":"reference"},{"type":"text","text":" is a low-level,"},{"type":"text","text":" "},{"type":"text","text":"general-purpose software library that provides a set of"},{"type":"text","text":" "},{"type":"text","text":"useful data types, string utilities, filesystem abstractions,"},{"type":"text","text":" "},{"text":"a mainloop abstraction, and similar tools for developing","type":"text"},{"type":"text","text":" "},{"type":"text","text":"libraries and applications in different programming languages."},{"type":"text","text":" "},{"text":"GLIb is mainly used for creating and interacting with","type":"text"},{"type":"text","text":" "},{"type":"text","text":"low-level data structures and supports features such as"},{"type":"text","text":" "},{"type":"text","text":"event-driven programming, memory management, and data"},{"type":"text","text":" "},{"type":"text","text":"type management."},{"text":" ","type":"text"},{"type":"text","text":"GLib is part of the GNOME project, but works with different"},{"type":"text","text":" "},{"text":"Operating Systems, including Linux and macOS.","type":"text"}]},{"text":"Swift Bindings","level":2,"type":"heading","anchor":"Swift-Bindings"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Swift language bindings have been generated using"},{"type":"text","text":" "},{"type":"text","text":"the "},{"code":".gir","type":"codeVoice"},{"type":"text","text":" files from"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/gi.readthedocs.io\/en\/latest\/"},{"text":",","type":"text"},{"type":"text","text":" "},{"type":"text","text":"allowing a more “swifty” use of the library than using it"},{"type":"text","text":" "},{"type":"text","text":"through the low-level C interface."},{"text":" ","type":"text"},{"text":"Particularly the collection interfaces, such as","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"https:\/\/rhx.github.io\/SwiftGLib\/GLib\/documentation\/glib\/typedslist","isActive":true},{"type":"text","text":" and"},{"type":"text","text":" "},{"identifier":"https:\/\/rhx.github.io\/SwiftGLib\/GLib\/documentation\/glib\/typedlist","isActive":true,"type":"reference"},{"type":"text","text":" "},{"type":"text","text":"allow to use templated Swift data types rather than raw"},{"type":"text","text":" "},{"type":"text","text":"pointers."}]},{"type":"heading","level":2,"text":"Prerequisites","anchor":"Prerequisites"},{"type":"paragraph","inlineContent":[{"text":"To get the most out of this tutorial, you should be","type":"text"},{"text":" ","type":"text"},{"text":"generally familiar with Linux, macOS, or other UNIX-like","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"environments and know how to use a command-line shell"},{"type":"text","text":" "},{"type":"text","text":"such as "},{"identifier":"https:\/\/www.gnu.org\/software\/bash\/","isActive":true,"type":"reference"},{"type":"text","text":" or"},{"text":" ","type":"text"},{"identifier":"https:\/\/www.zsh.org\/","type":"reference","isActive":true},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You will need a"},{"type":"text","text":" "},{"identifier":"https:\/\/www.swift.org\/getting-started\/cli-swiftpm\/","type":"reference","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"either by"},{"type":"text","text":" "},{"isActive":true,"identifier":"https:\/\/developer.apple.com\/support\/xcode\/","type":"reference"},{"type":"text","text":" "},{"text":"if you are running macOS, or","type":"text"},{"type":"text","text":" "},{"type":"text","text":"by "},{"identifier":"https:\/\/www.swift.org\/install\/","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"directly for your Operating System.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"You also need to install the GLib development libraries","type":"text"},{"text":" ","type":"text"},{"text":"for your system.","type":"text"}]},{"type":"heading","anchor":"Installing-GLib-on-Linux","level":3,"text":"Installing GLib on Linux"},{"type":"paragraph","inlineContent":[{"text":"Most modern Linux distributions come with the GLib runtime","type":"text"},{"type":"text","text":" "},{"type":"text","text":"preinstalled, but you will need to install the headers"},{"text":" ","type":"text"},{"text":"necessary for development.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This can be done using the package manager for your system."},{"text":" ","type":"text"},{"text":"For example, on Ubuntu or other Debian-based systems,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"you can use the "},{"isActive":true,"type":"reference","identifier":"https:\/\/wiki.debian.org\/Apt"},{"text":" package","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"manager using the following commands:"}]},{"syntax":null,"type":"codeListing","code":["sudo apt update","sudo apt install libglib2.0-dev glib-networking gobject-introspection libgirepository1.0-dev libxml2-dev jq"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Depending on your Linux distributions, the names of the"},{"type":"text","text":" "},{"type":"text","text":"packages and package management tools will vary."},{"type":"text","text":" "},{"type":"text","text":"You should be able to find this in the documentation for"},{"text":" ","type":"text"},{"type":"text","text":"your Linux distribution."}]},{"name":"Tip","style":"tip","content":[{"type":"paragraph","inlineContent":[{"text":"Some more examples can also be found in the","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/github.com\/rhx\/SwiftGLib\/blob\/main\/README.md","type":"reference","isActive":true},{"text":".","type":"text"}]}],"type":"aside"},{"text":"Installing GLib on macOS","anchor":"Installing-GLib-on-macOS","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"For macOS, there are multiple package management tools"},{"text":" ","type":"text"},{"type":"text","text":"that you can use."},{"text":" ","type":"text"},{"identifier":"http:\/\/brew.sh\/","isActive":true,"type":"reference"},{"type":"text","text":" is one example."},{"text":" ","type":"text"},{"text":"After you have installed HomeBrew, you can install","type":"text"},{"type":"text","text":" "},{"type":"text","text":"GLib using:"}]},{"type":"codeListing","syntax":null,"code":["brew update","brew install glib glib-networking gobject-introspection pkg-config jq"]},{"level":2,"type":"heading","text":"Compiling SwiftGLib programs","anchor":"Compiling-SwiftGLib-programs"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The easiest way to compile programs and libraries using"},{"type":"text","text":" "},{"type":"text","text":"SwiftGLib is through projects using the"},{"type":"text","text":" "},{"identifier":"https:\/\/swift.org\/package-manager\/","isActive":true,"type":"reference"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Here is an example for a simple program that uses a"},{"text":" ","type":"text"},{"overridingTitle":"type list","isActive":true,"identifier":"https:\/\/rhx.github.io\/SwiftGLib\/GLib\/documentation\/glib\/typedlist","type":"reference","overridingTitleInlineContent":[{"type":"text","text":"type list"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"First, create a directory (folder) for your project, then"},{"type":"text","text":" "},{"type":"text","text":"create the project inside the folder:"}]},{"code":["mkdir swift-glist","cd swift-glist","swift package init --type=executable"],"syntax":null,"type":"codeListing"},{"inlineContent":[{"text":"This will create a simple “Hello World” executable that","type":"text"},{"type":"text","text":" "},{"text":"you can test using ","type":"text"},{"type":"codeVoice","code":"swift run"},{"text":" – the program will run","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and print “Hello world”."},{"text":" ","type":"text"},{"text":"If you look at the files generated by ","type":"text"},{"type":"codeVoice","code":"swift package init"},{"type":"text","text":","},{"text":" ","type":"text"},{"text":"you will find a file named ","type":"text"},{"type":"codeVoice","code":"Package.swift"},{"type":"text","text":" that represents"},{"text":" ","type":"text"},{"type":"text","text":"the project and its compilation targets."},{"type":"text","text":" "},{"type":"text","text":"Overall, if you run"}],"type":"paragraph"},{"syntax":null,"code":["find * -type f"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"you should see two files, the aforementioned "},{"code":"Package.swift","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"and a "},{"code":"main.swift","type":"codeVoice"},{"text":" in ","type":"text"},{"type":"codeVoice","code":"Sources\/swift-glist"},{"type":"text","text":":"}]},{"syntax":null,"type":"codeListing","code":["Package.swift","Sources\/swift-glist\/main.swift"]},{"type":"aside","style":"warning","content":[{"inlineContent":[{"type":"text","text":"Some versions of the Swift Package manager create"},{"text":" ","type":"text"},{"text":"a flat structure when using ","type":"text"},{"type":"codeVoice","code":"swift package init"},{"type":"text","text":" that puts"},{"type":"text","text":" "},{"text":"the ","type":"text"},{"type":"codeVoice","code":"main.swift"},{"text":" directly in the ","type":"text"},{"type":"codeVoice","code":"Sources"},{"text":" folder.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"This will cause the Swift compiler to exit with an error if"},{"text":" ","type":"text"},{"text":"you try to use ","type":"text"},{"code":"swift run","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"name":"Warning"},{"inlineContent":[{"text":"Such a faulty structure that places your ","type":"text"},{"type":"codeVoice","code":"main.swift"},{"text":" ","type":"text"},{"type":"text","text":"directly in the "},{"type":"codeVoice","code":"Sources"},{"type":"text","text":" folder would look like this:"}],"type":"paragraph"},{"code":["Package.swift","Sources\/main.swift"],"type":"codeListing","syntax":null},{"type":"paragraph","inlineContent":[{"type":"text","text":"In this case, your program won’t compile or run."},{"type":"text","text":" "},{"type":"text","text":"To fix this, you need to move the "},{"type":"codeVoice","code":"main.swift"},{"type":"text","text":" file"},{"text":" ","type":"text"},{"text":"into a ","type":"text"},{"code":"swift-glist","type":"codeVoice"},{"text":" subfolder:","type":"text"}]},{"code":["mkdir Sources\/swift-glist","mv Sources\/main.swift Sources\/swift-glist\/"],"type":"codeListing","syntax":null},{"type":"paragraph","inlineContent":[{"type":"text","text":"Now you should be able to build your project."}]},{"type":"paragraph","inlineContent":[{"text":"Let us now change the ","type":"text"},{"type":"codeVoice","code":"Package.swift"},{"type":"text","text":" file so that it"},{"text":" ","type":"text"},{"text":"reads:","type":"text"}]},{"code":["\/\/ swift-tools-version: 5.7","","import PackageDescription","","let package = Package(","    name: \"swift-glist\",","    dependencies: [","        .package(url: \"https:\/\/github.com\/rhx\/gir2swift.git\", branch: \"main\"),","        .package(url: \"https:\/\/github.com\/rhx\/SwiftGLib.git\", branch: \"main\"),","    ],","    targets: [","        .executableTarget(","            name: \"swift-glist\",","            dependencies: [","                .product(name: \"GLib\", package: \"SwiftGLib\"),","            ]","        ),","    ]",")"],"syntax":"Swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"This will add the relevant dependencies for SwiftGLib"},{"type":"text","text":" "},{"text":"to the project.  We can now change the code in our","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"Sources\/swift-glist\/main.swift"},{"text":" so that it reads:","type":"text"}],"type":"paragraph"},{"syntax":"Swift","code":["import GLib","","let list: TypedList = [\"Hello\", \"world\"]","","print(list.length())  \/\/ Prints: 2","","list.forEach { element in","    print(element)    \/\/ Prints: \"hello\" and \"world\"","}"],"type":"codeListing"},{"inlineContent":[{"text":"Compile and run the code using:","type":"text"}],"type":"paragraph"},{"syntax":null,"type":"codeListing","code":["swift run"]},{"type":"paragraph","inlineContent":[{"text":"After some compiler output (and potentially","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"some warnings that you can ignore), you should get the"},{"type":"text","text":" "},{"text":"following output:","type":"text"}]},{"syntax":null,"code":["2","Hello","world"],"type":"codeListing"}],"kind":"content"}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/Tutorial","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"This tutorial shows how to use GLib with Swift."},{"type":"text","text":" "},{"text":"This is particularly useful if you want to interact","type":"text"},{"type":"text","text":" "},{"text":"with libraries written in C or other languages that use GLib.","type":"text"}],"references":{"https://www.swift.org/install/":{"title":"installing Swift","type":"link","url":"https:\/\