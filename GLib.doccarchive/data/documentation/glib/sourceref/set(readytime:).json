{"sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"set"},{"text":"(","kind":"text"},{"text":"readyTime","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gint64","text":"gint64"},{"text":")","kind":"text"}],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"If the monotonic time is in the past (as it","type":"text"},{"type":"text","text":" "},{"type":"text","text":"always will be if "},{"type":"codeVoice","code":"readyTime"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"0"},{"type":"text","text":") then the source will be"},{"text":" ","type":"text"},{"text":"dispatched immediately.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"readyTime"},{"type":"text","text":" is "},{"type":"codeVoice","code":"-1"},{"type":"text","text":" then the source is never woken up on the basis"},{"text":" ","type":"text"},{"type":"text","text":"of the passage of time."}]},{"inlineContent":[{"text":"Dispatching the source does not reset the ready time.  You should do","type":"text"},{"text":" ","type":"text"},{"text":"so yourself, from the source dispatch function.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that if you have a pair of sources where the ready time of one"},{"type":"text","text":" "},{"text":"suggests that it will be delivered first but the priority for the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"other suggests that it would be delivered first, and the ready time"},{"type":"text","text":" "},{"type":"text","text":"for both sources is reached during the same main context iteration,"},{"type":"text","text":" "},{"type":"text","text":"then the order of dispatch is undefined."}]},{"inlineContent":[{"text":"It is a no-op to call this function on a [struct","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Source"},{"type":"text","text":"] which has"},{"type":"text","text":" "},{"text":"already been destroyed with [method","type":"text"},{"code":"GLib.Source.destroy","type":"codeVoice"},{"type":"text","text":"]."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This API is only intended to be used by implementations of [struct"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","type":"reference","isActive":true},{"type":"text","text":"]."},{"text":" ","type":"text"},{"type":"text","text":"Do not call this API on a [struct"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Source"},{"text":"] that you did not create.","type":"text"}],"type":"paragraph"}]}],"metadata":{"roleHeading":"Instance Method","externalID":"s:4GLib14SourceProtocolPAAE3set9readyTimeys5Int64V_tF::SYNTHESIZED::s:4GLib9SourceRefV","extendedModule":"GLib","title":"set(readyTime:)","symbolKind":"method","modules":[{"name":"GLib"}],"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"set"},{"kind":"text","text":"("},{"kind":"externalParam","text":"readyTime"},{"text":": ","kind":"text"},{"text":"gint64","kind":"typeIdentifier","preciseIdentifier":"c:@T@gint64"},{"kind":"text","text":")"}],"role":"symbol"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/SourceRef","doc:\/\/GLib\/documentation\/GLib\/SourceRef\/SourceProtocol-Implementations"]]},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/SourceRef\/set(readyTime:)","interfaceLanguage":"swift"},"kind":"symbol","abstract":[{"type":"text","text":"Sets a source to be dispatched when the given monotonic time is"},{"type":"text","text":" "},{"type":"text","text":"reached (or passed)."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/sourceref\/set(readytime:)"]}],"references":{"doc://GLib/documentation/GLib/SourceRef":{"url":"\/documentation\/glib\/sourceref","title":"SourceRef","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"SourceRef"}],"type":"topic","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceRef","abstract":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"GSource"},{"text":" struct is an opaque data type","type":"text"},{"type":"text","text":" "},{"type":"text","text":"representing an event source."}],"navigatorTitle":[{"kind":"identifier","text":"SourceRef"}]},"doc://GLib/documentation/GLib/SourceRef/SourceProtocol-Implementations":{"url":"\/documentation\/glib\/sourceref\/sourceprotocol-implementations","title":"SourceProtocol Implementations","abstract":[],"kind":"article","type":"topic","role":"collectionGroup","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceRef\/SourceProtocol-Implementations"},"doc://GLib/documentation/GLib/Source":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","kind":"symbol","abstract":[{"type":"text","text":"The "},{"code":"GSource","type":"codeVoice"},{"type":"text","text":" struct is an opaque data type"},{"text":" ","type":"text"},{"text":"representing an event source.","type":"text"}],"type":"topic","navigatorTitle":[{"text":"Source","kind":"identifier"}],"url":"\/documentation\/glib\/source","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"Source"}],"title":"Source","role":"symbol"},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/Sou