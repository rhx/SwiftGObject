{"abstract":[{"type":"text","text":"Sets a source to be dispatched when the given monotonic time is"},{"text":" ","type":"text"},{"text":"reached (or passed).","type":"text"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"extendedModule":"GLib","roleHeading":"Instance Method","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"set"},{"kind":"text","text":"("},{"kind":"externalParam","text":"readyTime"},{"kind":"text","text":": "},{"text":"gint64","kind":"typeIdentifier","preciseIdentifier":"c:@T@gint64"},{"text":")","kind":"text"}],"title":"set(readyTime:)","symbolKind":"method","modules":[{"name":"GLib"}],"externalID":"s:4GLib14SourceProtocolPAAE3set9readyTimeys5Int64V_tF::SYNTHESIZED::s:4GLib9SourceRefV"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"set","kind":"identifier"},{"kind":"text","text":"("},{"text":"readyTime","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@gint64","kind":"typeIdentifier","text":"gint64"},{"text":")","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"inlineContent":[{"text":"If the monotonic time is in the past (as it","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"always will be if "},{"type":"codeVoice","code":"readyTime"},{"type":"text","text":" is "},{"code":"0","type":"codeVoice"},{"text":") then the source will be","type":"text"},{"type":"text","text":" "},{"text":"dispatched immediately.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"code":"readyTime","type":"codeVoice"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"-1"},{"type":"text","text":" then the source is never woken up on the basis"},{"text":" ","type":"text"},{"text":"of the passage of time.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Dispatching the source does not reset the ready time.  You should do","type":"text"},{"text":" ","type":"text"},{"text":"so yourself, from the source dispatch function.","type":"text"}]},{"inlineContent":[{"text":"Note that if you have a pair of sources where the ready time of one","type":"text"},{"text":" ","type":"text"},{"text":"suggests that it will be delivered first but the priority for the","type":"text"},{"type":"text","text":" "},{"text":"other suggests that it would be delivered first, and the ready time","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for both sources is reached during the same main context iteration,"},{"text":" ","type":"text"},{"text":"then the order of dispatch is undefined.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"It is a no-op to call this function on a [struct","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","isActive":true,"type":"reference"},{"type":"text","text":"] which has"},{"type":"text","text":" "},{"text":"already been destroyed with [method","type":"text"},{"code":"GLib.Source.destroy","type":"codeVoice"},{"type":"text","text":"]."}]},{"inlineContent":[{"text":"This API is only intended to be used by implementations of [struct","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","isActive":true,"type":"reference"},{"text":"].","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Do not call this API on a [struct"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","isActive":true,"type":"reference"},{"type":"text","text":"] that you did not create."}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/sourceref\/set(readytime:)"]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/SourceRef","doc:\/\/GLib\/documentation\/GLib\/SourceRef\/SourceProtocol-Implementations"]]},"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/SourceRef\/set(readyTime:)"},"references":{"doc://GLib/documentation/GLib/SourceRef/set(readyTime:)":{"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"set"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"readyTime"},{"kind":"text","text":": "},{"text":"gint64","preciseIdentifier":"c:@T@gint64","kind":"typeIdentifier"},{"kind":"text","text":")"}],"abstract":[{"text":"Sets a source to be dispatched when the given monotonic time is","type":"text"},{"text":" ","type":"text"},{"text":"reached (or passed).","type":"text"}],"url":"\/documentation\/glib\/sourceref\/set(readytime:)","role":"symbol","kind":"symbol","title":"set(readyTime:)","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceRef\/set(readyTime:)"},"doc://GLib/documentation/GLib/Source":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","role":"symbol","title":"Source","url":"\/documentation\/glib\/source","type":"topic","navigatorTitle":[{"text":"Source","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"Source","kind":"identifier"}],"abstract":[{"type":"text","text":"The "},{"code":"GSource","type":"codeVoice"},{"text":" struct is an opaque data type","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"representing an event source."}],"kind":"symbol"},"doc://GLib/documentation/GLib/SourceRef/SourceProtocol-Implementations":{"title":"SourceProtocol Implementations","role":"collectionGroup","abstract":[],"url":"\/documentation\/glib\/sourceref\/sourceprotocol-implementations","type":"topic","kind":"article","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceRef\/SourceProtocol-Implementations"},"doc://GLib/documentation/GLib/SourceRef":{"identifier":"doc:\/\/GLib\/documentat