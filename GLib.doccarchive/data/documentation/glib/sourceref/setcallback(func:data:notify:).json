{"abstract":[{"text":"Sets the callback function for a source. The callback for a source is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"called from the source’s dispatch function."}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"setCallback","kind":"identifier"},{"kind":"text","text":"("},{"text":"func","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GSourceFunc","text":"GSourceFunc"},{"text":"?, ","kind":"text"},{"text":"data","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"kind":"text","text":"? = nil, "},{"text":"notify","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@T@GDestroyNotify","text":"GDestroyNotify","kind":"typeIdentifier"},{"kind":"text","text":"? = nil)"}]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"inlineContent":[{"type":"text","text":"The exact type of "},{"type":"codeVoice","code":"func"},{"text":" depends on the type of source; ie. you","type":"text"},{"type":"text","text":" "},{"text":"should not count on ","type":"text"},{"type":"codeVoice","code":"func"},{"text":" being called with ","type":"text"},{"code":"data","type":"codeVoice"},{"text":" as its first","type":"text"},{"type":"text","text":" "},{"type":"text","text":"parameter. Cast "},{"type":"codeVoice","code":"func"},{"type":"text","text":" with [func"},{"type":"codeVoice","code":"GLib.SOURCE_FUNC"},{"type":"text","text":"] to avoid warnings about"},{"type":"text","text":" "},{"text":"incompatible function types.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"isActive":true,"identifier":"main-loop.html#memory-management-of-sources","type":"r