{"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/SourceRef\/isDestroyed","interfaceLanguage":"swift"},"abstract":[{"text":"Returns whether ","type":"text"},{"type":"codeVoice","code":"source"},{"text":" has been destroyed.","type":"text"}],"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/SourceRef","doc:\/\/GLib\/documentation\/GLib\/SourceRef\/SourceProtocol-Implementations"]]},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/sourceref\/isdestroyed"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"isDestroyed"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"This is important when you operate upon your objects","type":"text"},{"type":"text","text":" "},{"type":"text","text":"from within idle handlers, but may have freed the object"},{"text":" ","type":"text"},{"type":"text","text":"before the dispatch of your idle handler."}]},{"syntax":"c","code":["static gboolean","idle_callback (gpointer data)","{","  SomeWidget *self = data;","   ","  g_mutex_lock (&self->idle_id_mutex);","  \/\/ do stuff with self","  self->idle_id = 0;","  g_mutex_unlock (&self->idle_id_mutex);","   ","  return G_SOURCE_REMOVE;","}"," ","static void","some_widget_do_stuff_later (SomeWidget *self)","{","  g_mutex_lock (&self->idle_id_mutex);","  self->idle_id = g_idle_add (idle_callback, self);","  g_mutex_unlock (&self->idle_id_mutex);","}"," ","static void","some_widget_init (SomeWidget *self)","{","  g_mutex_init (&self->idle_id_mutex);","","  \/\/ ...","}","","static void","some_widget_finalize (GObject *object)","{","  SomeWidget *self = SOME_WIDGET (object);","   ","  if (self->idle_id)","    g_source_remove (self->idle_id);","   ","  g_mutex_clear (&self->idle_id_mutex);","","  G_OBJECT_CLASS (parent_class)->finalize (object);","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This will fail in a multi-threaded application if the"},{"text":" ","type":"text"},{"text":"widget is destroyed before the idle handler fires due","type":"text"},{"type":"text","text":" "},{"text":"to the use after free in the callback. A solution, to","type":"text"},{"type":"text","text":" "},{"text":"this particular problem, is to check to if the source","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"has already been destroy within the callback."}]},{"syntax":"c","code":["static gboolean","idle_callback (gpointer data)","{","  SomeWidget *self = data;","  ","  g_mutex_lock (&self->idle_id_mutex);","  if (!g_source_is_destroyed (g_main_current_source ()))","    {","      \/\/ do stuff with self","    }","  g_mutex_unlock (&self->idle_id_mutex);","  ","  return FALSE;","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Calls to this function from a thread other than the one acquired by the"},{"type":"text","text":" "},{"type":"text","text":"[struct"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","type":"reference","isActive":true},{"type":"text","text":"] the [struct"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","type":"reference","isActive":true},{"type":"text","text":"] is attached to are typically"},{"type":"text","text":" "},{"type":"text","text":"redundant, as the source could be destroyed immediately after this function"},{"text":" ","type":"text"},{"type":"text","text":"returns. However, once a source is destroyed it cannot be un-destroyed, so"},{"type":"text","text":" "},{"text":"this function can be used for opportunistic checks from any thread.","type":"text"}]}]}],"metadata":{"role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"isDestroyed"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"symbolKind":"property","modules":[{"name":"GLib"}],"extendedModule":"GLib","roleHeading":"Instance Property","externalID":"s:4GLib14SourceProtocolPAAE11isDestroyedSbvp::SYNTHESIZED::s:4GLib9SourceRefV","title":"isDestroyed"},"schemaVersion":{"major":0,"patch":0,"minor":3},"references":{"doc://GLib/documentation/GLib/MainContext":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MainContext"}],"url":"\/documentation\/glib\/maincontext","kind":"symbol","abstract":[{"type":"text","text":"The "},{"code":"GMainContext","type":"codeVoice"},{"type":"text","text":" struct is an opaque data"},{"text":" ","type":"text"},{"text":"type representing a set of sources to be handled in a main loop.","type":"text"}],"title":"MainContext","role":"symbol","navigatorTitle":[{"text":"MainContext","kind":"identifier"}]},"doc://GLib/documentation/GLib/SourceRef/isDestroyed":{"title":"isDestroyed","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"isDestroyed","kind":"identifier"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"type":"topic","url":"\/documentation\/glib\/sourceref\/isdestroyed","abstract":[{"type":"text","text":"Returns whether "},{"code":"source","type":"codeVoice"},{"text":" has been destroyed.","type":"text"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceRef\/isDestroyed"},"doc://GLib/documentation/GLib/SourceRef/SourceProtocol-Implementations":{"title":"SourceProtocol Implementations","role":"collectionGrou