{"schemaVersion":{"minor":3,"patch":0,"major":0},"relationshipsSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper"],"type":"inheritsFrom","kind":"relationships","title":"Inherits From"},{"type":"conformingTypes","identifiers":["doc:\/\/GLib\/documentation\/GLib\/ThreadPool","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef"],"title":"Conforming Types","kind":"relationships"}],"metadata":{"title":"ThreadPoolProtocol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"ThreadPoolProtocol","kind":"identifier"}],"modules":[{"name":"GLib"}],"role":"symbol","symbolKind":"protocol","navigatorTitle":[{"text":"ThreadPoolProtocol","kind":"identifier"}],"externalID":"s:4GLib18ThreadPoolProtocolP","roleHeading":"Protocol"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"kind":"symbol","topicSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/exclusive","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/func","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/maxThreads","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/numThreads","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/userData"],"anchor":"Instance-Properties","generated":true,"title":"Instance Properties"},{"title":"Instance Methods","anchor":"Instance-Methods","identifiers":["doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/free(immediate:wait:)","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/getMaxThreads()","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/getNumThreads()","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/moveToFront(data:)","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/push(data:)","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/set(maxThreads:)","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/setSortFunction(func:userData:)","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/unprocessed()"],"generated":true}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol","interfaceLanguage":"swift"},"sections":[],"variants":[{"paths":["\/documentation\/glib\/threadpoolprotocol"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"GThreadPool"},{"type":"text","text":" struct represents a thread pool."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"text":"ThreadPoolProtocol","kind":"identifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:4GLib14PointerWrapperP","kind":"typeIdentifier","identifier":"doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","text":"PointerWrapper"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"inlineContent":[{"type":"text","text":"A thread pool is useful when you wish to asynchronously fork out the execution of work"},{"type":"text","text":" "},{"type":"text","text":"and continue working in your own thread. If that will happen often, the overhead of starting"},{"type":"text","text":" "},{"text":"and destroying a thread each time might be too high. In such cases reusing already started","type":"text"},{"text":" ","type":"text"},{"text":"threads seems like a good idea. And it indeed is, but implementing this can be tedious","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and error-prone."}],"type":"paragraph"},{"inlineContent":[{"text":"Therefore GLib provides thread pools for your convenience. An added advantage is, that the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"threads can be shared between the different subsystems of your program, when they are using GLib."}],"type":"paragraph"},{"inlineContent":[{"text":"To create a new thread pool, you use [func","type":"text"},{"code":"GLib.ThreadPool.new","type":"codeVoice"},{"text":"].","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It is destroyed by [method"},{"type":"codeVoice","code":"GLib.ThreadPool.free"},{"type":"text","text":"]."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you want to execute a certain task within a thread pool, use [method"},{"code":"GLib.ThreadPool.push","type":"codeVoice"},{"text":"].","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To get the current number of running threads you call [method"},{"code":"GLib.ThreadPool.get_num_threads","type":"codeVoice"},{"text":"].","type":"text"},{"text":" ","type":"text"},{"text":"To get the number of still unprocessed tasks you call [method","type":"text"},{"type":"codeVoice","code":"GLib.ThreadPool.unprocessed"},{"type":"text","text":"]."},{"type":"text","text":" "},{"type":"text","text":"To control the maximum number of threads for a thread pool, you use"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"code":"GLib.ThreadPool.get_max_threads","type":"codeVoice"},{"text":"]. and [method","type":"text"},{"type":"codeVoice","code":"GLib.ThreadPool.set_max_threads"},{"type":"text","text":"]."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Finally you can control the number of unused threads, that are kept alive by GLib for future use."},{"type":"text","text":" "},{"type":"text","text":"The current number can be fetched with [func"},{"type":"codeVoice","code":"GLib.ThreadPool.get_num_unused_threads"},{"type":"text","text":"]."},{"type":"text","text":" "},{"type":"text","text":"The maximum number can be controlled by [func"},{"type":"codeVoice","code":"GLib.ThreadPool.get_max_unused_threads"},{"text":"] and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[func"},{"code":"GLib.ThreadPool.set_max_unused_threads","type":"codeVoice"},{"text":"]. All currently unused threads","type":"text"},{"type":"text","text":" "},{"type":"text","text":"can be stopped by calling [func"},{"code":"GLib.ThreadPool.stop_unused_threads","type":"codeVoice"},{"type":"text","text":"]."}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol","type":"reference","isActive":true},{"text":" protocol exposes the methods and properties of an underlying ","type":"text"},{"code":"GThreadPool","type":"codeVoice"},{"text":" instance.","type":"text"},{"type":"text","text":" "},{"text":"The default implementation of these can be found in the protocol extension below.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"For a concrete class that implements these methods and properties, see "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/ThreadPool"},{"text":".","type":"text"},{"type":"text","text":" "},{"text":"Alternatively, use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef","type":"reference"},{"text":" as a lighweight, ","type":"text"},{"code":"unowned","type":"codeVoice"},{"type":"text","text":" reference if you already have an instance you just want to use."}]}]}],"references":{"doc://GLib/documentation/GLib/ThreadPoolProtocol/maxThreads":{"title":"maxThreads","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"text":"maxThreads","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Returns the maximal number of threads for "},{"type":"codeVoice","code":"pool"},{"type":"text","text":"."}],"url":"\/documentation\/glib\/threadpoolprotocol\/maxthreads","role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/maxThreads"},"doc://GLib/documentation/GLib/ThreadPoolRef":{"url":"\/documentation\/glib\/threadpoolref","navigatorTitle":[{"text":"ThreadPoolRef","kind":"identifier"}],"title":"ThreadPoolRef","identifier":"doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef","type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"ThreadPoolRef","kind":"identifier"}],"role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"The "},{"code":"GThreadPool","type":"codeVoice"},{"text":" struct represents a thread pool.","type":"text"}]},"doc://GLib/documentation/GLib/ThreadPoolProtocol/set(maxThreads:)":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"set"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"maxThreads"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"role":"symbol","abstract":[{"type":"text","text":"Sets the maximal allowed number of threads for "},{"type":"codeVoice","code":"pool"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"A value of -1 means that the maximal number of threads"},{"type":"text","text":" "},{"type":"text","text":"is unlimited. If "},{"code":"pool","type":"codeVoice"},{"text":" is an exclusive thread pool, setting","type":"text"},{"text":" ","type":"text"},{"text":"the maximal number of threads to -1 is not allowed.","type":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/set(maxThreads:)","type":"topic","kind":"symbol","title":"set(maxThreads:)","url":"\/documentation\/glib\/threadpoolprotocol\/set(maxthreads:)"},"doc://GLib/documentation/GLib/ThreadPoolProtocol/unprocessed()":{"abstract":[{"text":"Returns the number of tasks still unprocessed in ","type":"text"},{"type":"codeVoice","code":"pool"},{"text":".","type":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/unprocessed()","fragments":[{"kind":"keyword","text":"func"},{"kind":"tex