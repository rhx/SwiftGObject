"type":"codeVoice","code":"queue"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"It should return 0 if they are equal, a negative value if the"},{"type":"text","text":" "},{"text":"first element should be higher in the ","type":"text"},{"type":"codeVoice","code":"queue"},{"type":"text","text":" or a positive value"},{"text":" ","type":"text"},{"text":"if the first element should be lower in the ","type":"text"},{"code":"queue","type":"codeVoice"},{"type":"text","text":" than the second"},{"text":" ","type":"text"},{"type":"text","text":"element."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This function will lock ","type":"text"},{"type":"codeVoice","code":"queue"},{"type":"text","text":" before it sorts the queue and unlock"},{"type":"text","text":" "},{"type":"text","text":"it when it is finished."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you were sorting a list of priority numbers to make sure the"},{"text":" ","type":"text"},{"type":"text","text":"lowest priority would be at the top of the queue, you could use:"},{"type":"text","text":" "},{"type":"text","text":"(C Language Example):"}]},{"syntax":"C","code":[" gint32 id1;"," gint32 id2;",""," id1 = GPOINTER_TO_INT (element1);"," id2 = GPOINTER_TO_INT (element2);",""," return (id1 > id2 ? +1 : id1 == id2 ? 0 : -1);"],"type":"codeListing"}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/AsyncQueueRef","doc:\/\/GLib\/documentation\/GLib\/AsyncQueueRef\/AsyncQueueProtocol-Implementations"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/asyncqueueref\/sort(func:userdata:)"]}],"references":{"doc://GLib/documentation/GLib/AsyncQueueRef/AsyncQueueProtocol-Implementations":{"title":"AsyncQueueProtocol Implementations","kind":"article","identifier":"doc:\/\/GLib\/documentation\/GLib\/Async