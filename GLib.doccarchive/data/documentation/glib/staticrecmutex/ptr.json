"},{"text":" ","type":"text"},{"text":"unlock it n times again to let other threads lock it. An exception","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is the function "},{"code":"g_static_rec_mutex_unlock_full()","type":"codeVoice"},{"text":": that allows you to","type":"text"},{"text":" ","type":"text"},{"text":"unlock a ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","isActive":true},{"type":"text","text":" completely returning the depth, (i.e. the"},{"text":" ","type":"text"},{"type":"text","text":"number of times this mutex was locked). The depth can later be used"},{"text":" ","type":"text"},{"text":"to restore the state of the ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","isActive":true,"type":"reference"},{"type":"text","text":" by calling"},{"text":" ","type":"text"},{"code":"g_static_rec_mutex_lock_full()","type":"codeVoice"},{"type":"text","text":". In GLib 2.32, "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","isActive":true,"type":"reference"},{"text":" has","type":"text"},{"type":"text","text":" "},{"type":"text","text":"been deprecated in favor of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex"},{"text":".","type":"text"}],"kind":"symbol","role":"symbol","url":"\/documentation\/glib\/staticrecmutex","title":"StaticRecMutex","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex"},"doc://GLib/documentation/GLib/RecMutex":{"title":"RecMutex","type":"topic","abstract":[{"type":"text","text":"The GRecMutex struct is an opaque data structure to represent a"},{"text":" ","type":"text"},{"text":"recursive mutex. It is similar to a ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","type":"reference","isActive":true},{"type":"text","text":" with the difference"},{"type":"text","text":" "},{"text":"that it is possible to lock a GRecMutex multiple times in the same","type":"text"},{"text":" ","type":"text"},{"text":"thread without deadlock. When doing so, care has to be taken to","type":"text"},{"type":"text","text":" "},{"text":"unlock the recursive mutex as often as it has been locked.","type":"text"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"RecMutex","kind":"identifier"}],"navigatorTitle":[{"text":"RecMutex","kind":"identifier"}],"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex","url":"\/documentation\/glib\/recmutex","kind":"symbol"}}}