"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex"},{"text":" instance.","type":"text"}],"url":"\/documentation\/glib\/staticrecmutex\/init(_:)-6kdxl","role":"symbol"},"doc://GLib/documentation/GLib/RecMutex":{"title":"RecMutex","type":"topic","abstract":[{"type":"text","text":"The GRecMutex struct is an opaque data structure to represent a"},{"text":" ","type":"text"},{"text":"recursive mutex. It is similar to a ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","type":"reference","isActive":true},{"type":"text","text":" with the difference"},{"type":"text","text":" "},{"text":"that it is possible to lock a GRecMutex multiple times in the same","type":"text"},{"text":" ","type":"text"},{"text":"thread without deadlock. When doing so, care has to be taken to","type":"text"},{"type":"text","text":" "},{"text":"unlock the recursive mutex as often as it has been locked.","type":"text"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"RecMutex","kind":"identifier"}],"navigatorTitle":[{"text":"RecMutex","kind":"identifier"}],"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex","url":"\/documentation\/glib\/recmutex","kind":"symbol"}}}