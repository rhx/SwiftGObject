t"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"StaticMutex"}]},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/StaticRecMutex":{"navigatorTitle":[{"text":"StaticRecMutex","kind":"identifier"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"StaticRecMutex"}],"abstract":[{"text":"A ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","isActive":true,"type":"reference"},{"text":" works like a ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex","type":"reference","isActive":true},{"type":"text","text":", but it can be locked"},{"text":" ","type":"text"},{"text":"multiple times by one thread. If you enter it n times, you have to","type":"text"},{"text":" ","type":"text"},{"text":"unlock it n times again to let other threads lock it. An exception","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is the function "},{"code":"g_static_rec_mutex_unlock_full()","type":"codeVoice"},{"text":": that allows you to","type":"text"},{"text":" ","type":"text"},{"text":"unlock a ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","isActive":true},{"type":"text","text":" completely returning the depth, (i.e. the"},{"text":" ","type":"text"},{"type":"text","text":"number of times this mutex was locked). The depth can later be used"},{"text":" ","type":"text"},{"text":"to restore the state of the ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","isActive":true,"type":"reference"},{"type":"text","text":" by calling"},{"text":" ","type":"text"},{"code":"g_static_rec_mutex_lock_full()","type":"codeVoice"},{"type":"text","text":". In GLib 2.32, "},{"