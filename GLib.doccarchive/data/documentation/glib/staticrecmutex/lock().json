{"abstract":[{"text":"Locks ","type":"text"},{"code":"mutex","type":"codeVoice"},{"type":"text","text":". If "},{"code":"mutex","type":"codeVoice"},{"type":"text","text":" is already locked by another thread, the"},{"text":" ","type":"text"},{"type":"text","text":"current thread will block until "},{"code":"mutex","type":"codeVoice"},{"type":"text","text":" is unlocked by the other"},{"type":"text","text":" "},{"type":"text","text":"thread. If "},{"code":"mutex","type":"codeVoice"},{"type":"text","text":" is already locked by the calling thread, this"},{"text":" ","type":"text"},{"type":"text","text":"functions increases the depth of "},{"type":"codeVoice","code":"mutex"},{"type":"text","text":" and returns immediately."}],"sections":[],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"lock","kind":"identifier"},{"kind":"text","text":"()"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Lock is deprecated:","type":"text"}]},{"type":"text","text":" "},{"type":"text","text":"Use g_rec_mutex_lock()"}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/staticrecmutex\/lock()"]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex\/StaticRecMutexProtocol-Implementations"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","metadata":{"symbolKind":"method","extendedModule":"GLib","platforms":[],"title":"lock()","modules":[{"name":"GLib"}],"roleHeading":"Instance Method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"lock","kind":"identifier"},{"kind":"text","text":"()"}],"externalID":"s:4GLib22StaticRecMut