ction","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/StaticMutex":{"kind":"symbol","role":"symbol","title":"StaticMutex","url":"\/documentation\/glib\/staticmutex","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex","navigatorTitle":[{"kind":"identifier","text":"StaticMutex"}],"type":"topic","abstract":[{"type":"text","text":"A "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex"},{"text":" works like a ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","isActive":true,"type":"reference"},{"text":".","type":"text"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"StaticMutex"}]},"doc://GLib/documentation/GLib/StaticRecMutex/init_()":{"url":"\/documentation\/glib\/staticrecmutex\/init_()","type":"topic","role":"symbol","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"init_","kind":"identifier"},{"kind":"text","text":"()"}],"deprecated":true,"abstract":[{"text":"A ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","isActive":true},{"type":"text","text":" must be initialized with this function before it"},{"type":"text","text":" "},{"text":"can be used. Alternatively you can initialize it with","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"G_STATIC_REC_MUTEX_INIT"},{"type":"text","text":"."}],"title":"init_()","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex\/init_()"},"doc://GLib/documentation/GLib/StaticRecMutex/StaticRecMutexProtocol-Implementations":{"kind":"article","role":"collectionGroup","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex\/StaticRecMutexProtocol-Implementations","type":"topic","abstract":[],"url":"\/documentation\/glib\/staticrecmutex\/staticrecmutexprotocol-implementations","title":"StaticRecMutexProtocol Implementations"},"doc://GLib/documentation/GLib/StaticRecMutex":{"navigatorTitle":[{"text":"StaticRecMutex","kind":"identifier"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"StaticRecMutex"}],"abstract":[{"text":"A ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","isActive":true,"type":"reference"},{"text":" works like a ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex","type":"reference","isActive":true},{"type":"text","text":", but it can be locked"},{"text":" ","type":"text"},{"text":"multiple times by one thread. If you enter it n times, you have to","type":"text"},{"text":" ","type":"text"},{"text":"unlock it n times again to let other threads lock it. An exception","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is the function "},{"code":"g_static_rec_mutex_unlock_full()","type":"codeVoice"},{"text":": that allows you to","type":"text"},{"text":" ","type":"text"},{"text":"unlock a ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","isActive":true},{"type":"text","text":" completely returning the depth, (i.e. the"},{"text":" ","type":"text"},{"type":"text","text":"number of times this mutex was locked). The depth can later be used"},{"text":" ","type":"text"},{"text":"to restore the state of the ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","isActive":true,"type":"reference"},{"type":"text","text":" by calling"},{"text":" ","type":"text"},{"code":"g_static_rec_mutex_lock_full()","type":"codeVoice"},{"type":"text","text":". In GLib 2.32, "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","isActive":true,"type":"reference"},{"text":" has","type":"text"},{"type":"text","text":" "},{"type":"text","text":"been deprecated in favor of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex"},{"text":".","type":"text"}],"kind":"symbol","role":"symbol","url":"\/documentation\/glib\/staticrecmutex","title":"StaticRecMutex","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex"},"doc://GLib/documentation/GLib/RecMutex":{"title":"RecMutex","type":"topic","abstract":[{"type":"text","text":"The GRecMutex struct is an opaque data structure to represent a"},{"text":" ","type":"text"},{"text":"recursive mutex. It is similar to a ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","type":"reference","isActive":true},{"type":"text","text":" with the difference"},{"type":"text","text":" "},{"text":"that it is possible to lock a GRecMutex multiple times in the same","type":"text"},{"text":" ","type":"text"},{"text":"thread without deadlock. When doing so, care has to be taken to","type":"text"},{"type":"text","text":" "},{"text":"unlock the recursive mutex as often as it has been locked.","type":"text"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"RecMutex","kind":"identifier"}],"navigatorTitle":[{"text":"RecMutex","kind":"identifier"}],"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex","url":"\/documentation\/glib\/recmutex","kind":"symbol"}}}