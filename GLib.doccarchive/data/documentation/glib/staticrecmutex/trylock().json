ely returns "},{"code":"false","type":"codeVoice"},{"type":"text","text":". Otherwise it locks "},{"type":"codeVoice","code":"mutex"},{"type":"text","text":" and returns"},{"text":" ","type":"text"},{"type":"codeVoice","code":"true"},{"text":". If ","type":"text"},{"type":"codeVoice","code":"mutex"},{"text":" is already locked by the calling thread, this","type":"text"},{"type":"text","text":" "},{"type":"text","text":"functions increases the depth of "},{"code":"mutex","type":"codeVoice"},{"text":" and immediately returns","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"true"},{"type":"text","text":"."}],"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"trylock","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}]},"doc://GLib/documentation/GLib/StaticRecMutex":{"navigatorTitle":[{"text":"StaticRecMutex","kind":"identifier"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"StaticRecMutex"}],"abstract":[{"text":"A ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","isActive":true,"type":"reference"},{"text":" works like a ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex","type":"reference","isActive":true},{"type":"text","text":", but it can be locked"},{"text":" ","type":"text"},{"text":"multiple times by one thread. If you enter it n times, you have to","type":"text"},{"text":" ","type":"text"},{"text":"unlock it n times again to let other threads lock it. An exception","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is the function "},{"code":"g_static_rec_mutex_unlock_full()","type":"codeVoice"},{"text":": that allows you to","type":"text"},{"text":" ","type":"text"},{"text":"unlock a ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","isActive":true},{"type":"