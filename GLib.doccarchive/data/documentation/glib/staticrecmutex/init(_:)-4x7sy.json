s":{"doc://GLib/documentation/GLib/RecMutex":{"abstract":[{"text":"The GRecMutex struct is an opaque data structure to represent a","type":"text"},{"type":"text","text":" "},{"text":"recursive mutex. It is similar to a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex"},{"text":" with the difference","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"that it is possible to lock a GRecMutex multiple times in the same"},{"type":"text","text":" "},{"type":"text","text":"thread without deadlock. When doing so, care has to be taken to"},{"text":" ","type":"text"},{"type":"text","text":"unlock the recursive mutex as often as it has been locked."}],"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex","navigatorTitle":[{"text":"RecMutex","kind":"identifier"}],"url":"\/documentation\/glib\/recmutex","type":"topic","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RecMutex","kind":"identifier"}],"kind":"symbol","title":"RecMutex"},"doc://GLib/documentation/GLib/StaticRecMutex":{"abstract":[{"text":"A ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","isActive":true},{"type":"text","text":" works like a "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex","isActive":true},{"type":"text","text":", but it can be locked"},{"text":" ","type":"text"},{"type":"text","text":"multiple times by one thread. If you enter it n times, you have to"},{"type":"text","text":" "},{"type":"text","text":"unlock it n times again to let other threads lock it. An exception"},{"text":" ","type":"text"},{"text":"is the function ","type":"text"},{"code":"g_static_rec_mutex_unlock_full()","type":"codeVoice"},{"text":": that allows you to","type":"text"},{"type":"text","text":" "},{"text":"unlock a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex"},{"type":"text","text":" completely returning the depth, (i.e. the"},{"type":"text","text":" "},{"type":"text","text":"number of times this mutex was locked). The depth can later be used"},{"text":" ","type":"text"},{"text":"to restore the state of the ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","isActive":true,"type":"reference"},{"type":"text","text":" by calling"},{"type":"text","text":" "},{"code":"g_static_rec_mutex_lock_full()","type":"codeVoice"},{"type":"text","text":". In GLib 2.32, "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex"},{"type":"text","text":" has"},{"type":"text","text":" "},{"text":"been deprecated in favor of ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex","isActive":true},{"text":".","type":"text"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"StaticRecMutex"}],"kind":"symbol","title":"StaticRecMutex","navigatorTitle":[{"kind":"identifier","text":"StaticRecMutex"}],"type":"topic","url":"\/documentation\/glib\/staticrecmutex","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","role":"symbol"},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/StaticRecMutex/init(_:)-4x7sy":{"url":"\/documentation\/glib\/staticrecmutex\/init(_:)-4x7sy","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"text":"GStaticRecMutex","kind":"typeIdentifier"},{"kind":"text","text":">)"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex\/init(_:)-4x7sy","abstract":[{"type":"text","text":"Designated initialiser from the unde