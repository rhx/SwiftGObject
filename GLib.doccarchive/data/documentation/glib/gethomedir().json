{"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"getHomeDir","kind":"identifier"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"kind":"text","text":"!"}]}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"inlineContent":[{"text":"As with most UNIX tools, this function will return the value of the","type":"text"},{"text":" ","type":"text"},{"code":"HOME","type":"codeVoice"},{"type":"text","text":" environment variable if it is set to an existing absolute path"},{"text":" ","type":"text"},{"text":"name, falling back to the ","type":"text"},{"type":"codeVoice","code":"passwd"},{"type":"text","text":" file in the case that it is unset."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the path given in "},{"code":"HOME","type":"codeVoice"},{"type":"text","text":" is non-absolute, does not exist, or is"},{"type":"text","text":" "},{"type":"text","text":"not a directory, the result is undefined."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Before version 2.36 this function would ignore the "},{"code":"HOME","type":"codeVoice"},{"type":"text","text":" environment"},{"text":" ","type":"text"},{"type":"text","text":"variable, taking the value from the "},{"code":"passwd","type":"codeVoice"},{"type":"text","text":" database instead. This was"},{"type":"text","text":" "},{"type":"text","text":"changed to increase the compatibility of GLib with other programs (and"},{"text":" ","type":"text"},{"text":"the XDG basedir specification) and to increase testability of programs","type":"text"},{"text":" ","type":"text"},{"text":"based on GLib (by making it easier to run them from test frameworks).","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If your program has a strong requirement for either the new or the"},{"text":" ","type":"text"},{"text":"old behaviour (and if you don’t wish to increase your GLib","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"dependency to ensure that the new behaviour is in effect) then you"},{"type":"text","text":" "},{"type":"text","text":"should either directly check the "},{"code":"HOME","type":"codeVoice"},{"type":"text","text":" environment variable yourself"},{"text":" ","type":"text"},{"type":"text","text":"or unset it before calling any functions in GLib."}]}]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/gethomedir()"]}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/getHomeDir()"},"abstract":[{"type":"text","text":"Gets the current user’s home directory."}],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"symbolKind":"func","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"getHomeDir"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"},{"text":"!","kind":"text"}],"title":"getHomeDir()","modules":[{"name":"GLib"}],"roleHeading":"Function","externalID":"s:4GLib10getHomeDirSSSgyF"},"references":{"doc://GLib/documentation/GLib/getHomeDir()":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/getHomeDir()","url":"\/documentation\/glib\/gethomedir()","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"getHomeDir"},{"text":"() -> ","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"abstract":[{"type":"text","text":"Gets the current user’s home directory."}],"type":"topic","title":"getHomeDir()"},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"}}}