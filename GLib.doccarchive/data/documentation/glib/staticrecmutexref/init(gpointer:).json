s lock it. An exception","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is the function "},{"code":"g_static_rec_mutex_unlock_full()","type":"codeVoice"},{"text":": that allows you to","type":"text"},{"text":" ","type":"text"},{"text":"unlock a ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","isActive":true},{"type":"text","text":" completely returning the depth, (i.e. the"},{"text":" ","type":"text"},{"type":"text","text":"number of times this mutex was locked). The depth can later be used"},{"text":" ","type":"text"},{"text":"to restore the state of the ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","isActive":true,"type":"reference"},{"type":"text","text":" by calling"},{"text":" ","type":"text"},{"code":"g_static_rec_mutex_lock_full()","type":"codeVoice"},{"type":"text","text":". In GLib 2.32, "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","isActive":true,"type":"reference"},{"text":" has","type":"text"},{"type":"text","text":" "},{"type":"text","text":"been deprecated in favor of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex"},{"text":".","type":"text"}],"kind":"symbol","role":"symbol","url":"\/documentation\/glib\/staticrecmutex","title":"StaticRecMutex","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex"},"doc://GLib/documentation/GLib/StaticRecMutexRef/init(gpointer:)":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutexRef\/init(gpointer:)","url":"\/documentation\/glib\/staticrecmutexref\/init(gpointer:)","title":"init(gpointer:)","type":"topic","abstract":[{"text":"Conditional initialiser from an optional ","type":"text"},{"type":"codeVoice","code":"gpointer"}],"role":"symbol","fragments":[{"kind":"identifier","text":"init"},{"text":"!(","kind":"text"},{"kind":"externalParam","text":"gpointer"},{"kind":"text","text":": "},{"preciseIdentifi