{"abstract":[{"type":"text","text":"Invokes a function in such a way that "},{"type":"codeVoice","code":"context"},{"type":"text","text":" is owned during the"},{"text":" ","type":"text"},{"text":"invocation of ","type":"text"},{"type":"codeVoice","code":"function"},{"type":"text","text":"."}],"variants":[{"paths":["\/documentation\/glib\/maincontextref\/invoke(function:data:)"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/MainContextRef\/invoke(function:data:)"},"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"externalID":"s:4GLib19MainContextProtocolPAAE6invoke8function4datays5Int32VSvSgXCSg_AItF::SYNTHESIZED::s:4GLib14MainContextRefV","role":"symbol","extendedModule":"GLib","title":"invoke(function:data:)","roleHeading":"Instance Method","symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"invoke","kind":"identifier"},{"text":"(","kind":"text"},{"text":"function","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GSourceFunc","text":"GSourceFunc"},{"text":"?, ","kind":"text"},{"text":"data","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gpointer","text":"gpointer"},{"text":"?)","kind":"text"}],"modules":[{"name":"GLib"}]},"kind":"symbol","sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"invoke"},{"kind":"text","text":"("},{"kind":"externalParam","text":"function"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GSourceFunc","text":"GSourceFunc"},{"text":"?, ","kind":"text"},{"text":"data","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"gpointer","preciseIdentifier":"c:@T@gpointer","kind":"typeIdentifier"},{"kind":"text","text":"? = nil)"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"context"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"NULL"},{"type":"text","text":" then the global-default main context — as"},{"text":" ","type":"text"},{"type":"text","text":"returned by [func"},{"type":"codeVoice","code":"GLib.MainContext.default"},{"type":"text","text":"] — is used."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"code":"context","type":"codeVoice"},{"type":"text","text":" is owned by the current thread, "},{"type":"codeVoice","code":"function"},{"text":" is called","type":"text"},{"type":"text","text":" "},{"type":"text","text":"directly.  Otherwise, if "},{"code":"context","type":"codeVoice"},{"type":"text","text":" is the thread-default main context"},{"type":"text","text":" "},{"type":"text","text":"of the current thread and [method"},{"type":"codeVoice","code":"GLib.MainContext.acquire"},{"text":"] succeeds,","type":"text"},{"type":"text","text":" "},{"text":"then ","type":"text"},{"type":"codeVoice","code":"function"},{"text":" is called and [method","type":"text"},{"type":"codeVoice","code":"GLib.MainContext.release"},{"text":"] is called","type":"text"},{"type":"text","text":" "},{"type":"text","text":"afterwards."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"In any other case, an idle source is created to call ","type":"text"},{"type":"codeVoice","code":"function"},{"type":"text","text":" and"},{"type":"text","text":" "},{"text":"that source is attached to ","type":"text"},{"type":"codeVoice","code":"context"},{"text":" (presumably to be run in another","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"thread).  The idle source is attached with [const"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/priorityDefault","isActive":true,"type":"reference"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"type":"text","text":"priority.  If you want a different priority, use"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"code":"GLib.MainContext.invoke_full","type":"codeVoice"},{"text":"].","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that, as with normal idle functions, "},{"code":"function","type":"codeVoice"},{"type":"text","text":" should probably return"},{"type":"text","text":" "},{"type":"text","text":"[const"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/sourceRemove","isActive":true},{"type":"text","text":"].  If it returns [const"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/sourceContinue","isActive":true,"type":"reference"},{"text":"], it","type":"text"},{"type":"text","text":" "},{"text":"will be continuously run in a loop (and may prevent this call from returning).","type":"text"}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/MainContextRef","doc:\/\/GLib\/documentation\/GLib\/MainContextRef\/MainContextProtocol-Implementations"]]},"references":{"doc://GLib/documentation/GLib/priorityDefault":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/priorityDefault","fragments":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"text":"priorityDefault","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:s5Int32V","text":"Int32","kind":"typeIdentifier"}],"role":"symbol","url":"\/documentation\/glib\/prioritydefault","kind":"symbol","title":"priorityDefault","type":"topic","abstract":[{"type":"text","text":"Use this for default priority event sources."}]},"doc://GLib/documentation/GLib/MainContextRef/invoke(function:data:)":{"kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContextRef\/invoke(function:data:)","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","