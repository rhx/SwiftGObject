{"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/MainContextRef\/pushThreadDefault()"},"abstract":[{"type":"text","text":"Acquires "},{"type":"codeVoice","code":"context"},{"type":"text","text":" and sets it as the thread-default context for the"},{"type":"text","text":" "},{"type":"text","text":"current thread. This will cause certain asynchronous operations"},{"text":" ","type":"text"},{"type":"text","text":"(such as most "},{"type":"reference","isActive":true,"identifier":"..\/gio\/index.html"},{"type":"text","text":"-based I\/O) which are"},{"text":" ","type":"text"},{"text":"started in this thread to run under ","type":"text"},{"type":"codeVoice","code":"context"},{"type":"text","text":" and deliver their"},{"type":"text","text":" "},{"text":"results to its main loop, rather than running under the global","type":"text"},{"type":"text","text":" "},{"text":"default main context in the main thread. Note that calling this function","type":"text"},{"type":"text","text":" "},{"type":"text","text":"changes the context returned by [func"},{"type":"codeVoice","code":"GLib.MainContext.get_thread_default"},{"text":"],","type":"text"},{"type":"text","text":" "},{"type":"text","text":"not the one returned by [func"},{"code":"GLib.MainContext.default","type":"codeVoice"},{"type":"text","text":"], so it does not"},{"type":"text","text":" "},{"type":"text","text":"affect the context used by functions like [func"},{"type":"codeVoice","code":"GLib.idle_add"},{"type":"text","text":"]."}],"variants":[{"paths":["\/documentation\/glib\/maincontextref\/pushthreaddefault()"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/MainContextRef","doc:\/\/GLib\/documentation\/GLib\/MainContextRef\/MainContextProtocol-Implementations"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"modules":[{"name":"GLib"}],"role":"symbol","extendedModule":"GLib","externalID":"s:4GLib19MainContextProtocolPAAE17pushThreadDefaultyyF::SYNTHESIZED::s:4GLib14MainContextRefV","title":"pushThreadDefault()","roleHeading":"Instance Method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"pushThreadDefault"},{"text":"()","kind":"text"}],"symbolKind":"method"},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"pushThreadDefault"},{"text":"()","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"Normally you would call this function shortly after creating a new","type":"text"},{"type":"text","text":" "},{"text":"thread, passing it a [struct","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext"},{"type":"text","text":"] which will be run by a"},{"text":" ","type":"text"},{"text":"[struct","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainLoop"},{"text":"] in that thread, to set a new default context for all","type":"text"},{"text":" ","type":"text"},{"text":"async operations in that thread. In this case you may not need to","type":"text"},{"type":"text","text":" "},{"text":"ever call [method","type":"text"},{"type":"codeVoice","code":"GLib.MainContext.pop_thread_default"},{"type":"text","text":"], assuming you want"},{"type":"text","text":" "},{"type":"text","text":"the new [struct"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext"},{"type":"text","text":"] to be the default for the whole lifecycle"},{"type":"text","text":" "},{"text":"of the thread.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If you don’t have control over how the new thread was created (e.g.","type":"text"},{"type":"text","text":" "},{"text":"in the new thread isn’t newly created, or if the thread life","type":"text"},{"type":"text","text":" "},{"text":"cycle is managed by a ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/ThreadPool","isActive":true,"type":"reference"},{"text":"), it is always suggested to wrap","type":"text"},{"text":" ","type":"text"},{"text":"the logic that needs to use the new [struct","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","type":"reference","isActive":true},{"type":"text","text":"] inside a"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GLib.MainContext.push_thread_default"},{"type":"text","text":"] \/"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GLib.MainContext.pop_thread_default"},{"type":"text","text":"] pair, otherwise threads that"},{"type":"text","text":" "},{"text":"are re-used will end up never explicitly releasing the","type":"text"},{"type":"text","text":" "},{"text":"[struct","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext"},{"text":"] reference they hold.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"In some cases you may want to schedule a single operation in a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"non-default context, or temporarily use a non-default context in"},{"text":" ","type":"text"},{"text":"the main thread. In that case, you can wrap the call to the","type":"text"},{"type":"text","text":" "},{"text":"asynchronous operation inside a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"code":"GLib.MainContext.push_thread_default","type":"codeVoice"},{"type":"text","text":"] \/"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.MainContext.pop_thread_default"},{"text":"] pair, but it is up to you to","type":"text"},{"text":" ","type":"text"},{"text":"ensure that no other asynchronous operations accidentally get","type":"text"},{"type":"text","text":" "},{"type":"text","text":"started while the non-default context is active."}]},{"type":"paragraph","inlineContent":[{"text":"Beware that libraries that predate this function may not correctly","type":"text"},{"type":"text","text":" "},{"text":"handle being used from a thread with a thread-default context. For example,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"see "},{"type":"codeVoice","code":"g_file_supports_thread_contexts()"},{"type":"text","text":"."}]}]}],"references":{"doc://GLib/documentation/GLib/ThreadPool":{"kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/ThreadPool","role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"ThreadPool","kind":"identifier"}],"navigatorTitle":[{"text":"ThreadPool","kind":"identifier"}],"abstract":[{"type":"text","text":"The "},{"code":"GThreadPool","type":"codeVoice"},{"text":" struct represents a thread pool.","type":"text"}],"url":"\/documentation\/glib\/threadpool","title":"ThreadPool","type":"topic"},"doc://GLib/documentation/GLib/MainContextRef/MainContextProtocol-Implementations":{"kind":"article","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContextRef\/MainContextProtocol-Implementations","role":"collectionGroup","title":"MainContextProtocol Implementations","abstract":[],"url":"\/documentation\/glib\/maincontextref\/maincontextprotocol-implementations","type":"topic"},"doc://GLib/documentation/GLib/MainLoop":{"abstract":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"GMainLoop"},{"type":"text","text":" struct is an opaque data type"},{"type":"text","text":" "},{"type":"text","text":"representing the main event loop of a GLib or GTK application."}],"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainLoop","navigatorTitle":[{"text":"MainLoop","kind":"identifier"}],"title":"MainLoop","type":"topic","kind":"symbol","url":"\/documentation\/glib\/mainloop","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"MainLoop","kind":"identifier"}]},"../gio/index.html":{"type":"link","identifier":"..\/gio\/index.html","titleInlineContent":[{"text":"Gio","type":"text"}],"url":"..\/gio\/index.html","title":"Gio"},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/MainContextRef":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"MainContextRef","kind":"identifier"}],"abstract":[{"text":"The ","type":"text"},{"code":"GMainContext","type":"codeVoice"},{"type":"text","text":" struct is an opaque data"},{"text":" ","type":"text"},{"type":"text","text":"type representing a set of sources to be handled in a main loop."}],"role":"symbol","title":"MainContextRef","navigatorTitle":[{"text":"MainContextRef","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContextRef","url":"\/documentation\/glib\/maincontextref","type":"topic"},"doc://GLib/documentation/GLib/MainContext":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","role":"symbol","type":"topic","navigatorTitle":[{"text":"MainContext","kind":"identifier"}],"abstract":[{"type":"text","text":"The "},{"code":"GMainContext","type":"codeVoice"},{"text":" struct is an opaque data","type":"text"},{"type":"text","text":" "},{"text":"type representing a set of sources to be handled in a main loop.","type":"text"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"MainContext","kind":"identifier"}],"url":"\/documentation\/glib\/maincontext","title":"MainContext","kind":"symbol"},"doc://GLib/documentation/GLib/MainContextRef/pushThreadDefault()":{"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"pushThreadDefault"},{"text":"()","kind":"text"}],"abstract":[{"type":"text","text":"Acquires "},{"type":"codeVoice","code":"context"},{"type":"text","text":" and sets it as the thread-default context for the"},{"text":" ","type":"text"},{"type":"text","text":"current thread. This will cause certain asynchronous operations"},{"type":"text","text":" "},{"type":"text","text":"(such as most "},{"type":"reference","identifier":"..\/gio\/index.html","isActive":true},{"type":"text","text":"-based I\/O) which are"},{"type":"text","text":" "},{"text":"started in this thread to run under ","type":"text"},{"code":"context","type":"codeVoice"},{"text":" and deliver their","type":"text"},{"type":"text","text":" "},{"type":"text","text":"results to its main loop, rather than running under the global"},{"type":"text","text":" "},{"type":"text","text":"default main context in the main thread. Note that calling this function"},{"type":"text","text":" "},{"text":"changes the context returned by [func","type":"text"},{"type":"codeVoice","code":"GLib.MainContext.get_thread_default"},{"text":"],","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"not the one returned by [func"},{"code":"GLib.MainContext.default","type":"codeVoice"},{"type":"text","text":"], so it does not"},{"type":"text","text":" "},{"type":"text","text":"affect the context used by functions like [func"},{"type":"codeVoice","code":"GLib.idle_add"},{"text":"].","type":"text"}],"url":"\/documentation\/glib\/maincontextref\/pushthreaddefault()","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContextRef\/pushThreadDefault()","kind":"symbol","title":"pushThreadDefault()","role":"symbol","type":"topic"}}}