"type":"text","text":" "},{"type":"text","text":"started in this thread to run under "},{"code":"context","type":"codeVoice"},{"text":" and deliver their","type":"text"},{"type":"text","text":" "},{"type":"text","text":"results to its main loop, rather than running under the global"},{"type":"text","text":" "},{"text":"default main context in the main thread. Note that calling this function","type":"text"},{"type":"text","text":" "},{"type":"text","text":"changes the context returned by [func"},{"code":"GLib.MainContext.get_thread_default","type":"codeVoice"},{"text":"],","type":"text"},{"type":"text","text":" "},{"text":"not the one returned by [func","type":"text"},{"type":"codeVoice","code":"GLib.MainContext.default"},{"text":"], so it does not","type":"text"},{"text":" ","type":"text"},{"text":"affect the context used by functions like [func","type":"text"},{"type":"codeVoice","code":"GLib.idle_add"},{"type":"text","text":"]."}],"type":"topic","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"pushThreadDefault","kind":"identifier"},{"text":"()","kind":"text"}],"kind":"symbol","title":"pushThreadDefault()","role":"symbol","url":"\/documentation\/glib\/maincontextref\/pushthreaddefault()"},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/ThreadPool":{"abstract":[{"type":"text","text":"The "},{"code":"GThreadPool","type":"codeVoice"},{"type":"text","text":" struct represents a thread pool."}],"role":"symbol","url":"\/documentation\/glib\/threadpool","identifier":"doc:\/\/GLib\/documentation\/GLib\/ThreadPool","title":"ThreadPool","kind":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ThreadPool"}],"navigatorTitle":[{"kind":"identifier","text":"ThreadPool"}]},"../gio/index.html":{"type