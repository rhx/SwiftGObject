{"metadata":{"extendedModule":"GLib","roleHeading":"Instance Method","externalID":"s:4GLib16PtrArrayProtocolPAAE5steal3lenSpySvSgGSgSpySuGSg_tF","modules":[{"name":"GLib"}],"symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"steal","kind":"identifier"},{"text":"(","kind":"text"},{"text":"len","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"gsize","preciseIdentifier":"c:@T@gsize"},{"text":">!) -> ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"kind":"text","text":"?>!"}],"role":"symbol","title":"steal(len:)"},"abstract":[{"type":"text","text":"Frees the data in the array and resets the size to zero, while"},{"text":" ","type":"text"},{"text":"the underlying array is preserved for use elsewhere and returned","type":"text"},{"text":" ","type":"text"},{"text":"to the caller.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/PtrArrayProtocol"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"steal","kind":"identifier"},{"text":"(","kind":"text"},{"text":"len","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"gsize","preciseIdentifier":"c:@T@gsize","kind":"typeIdentifier"},{"kind":"text","text":">! = nil) -> "},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"text":"?>!","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that if the array is "},{"type":"codeVoice","code":"NULL"},{"type":"text","text":" terminated this may still return"},{"type":"text","text":" "},{"type":"codeVoice","code":"NULL"},{"type":"text","text":" if the length of the array was zero and pdata was not yet"},{"type":"text","text":" "},{"text":"allocated.","type":"text"}]},{"inlineContent":[{"text":"Even if set, the [callback","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/DestroyNotify"},{"type":"text","text":"] function will never be called"},{"type":"text","text":" "},{"text":"on the current contents of the array and the caller is","type":"text"},{"text":" ","type":"text"},{"text":"responsible for freeing the array elements.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"An example of use:"}],"type":"paragraph"},{"code":["`g_autoptr(GPtrArray)` chunk_buffer = g_ptr_array_new_with_free_func (g_bytes_unref);","","\/\/ Some part of your application appends a number of chunks to the pointer array.","g_ptr_array_add (chunk_buffer, g_bytes_new_static (\"hello\", 5));","g_ptr_array_add (chunk_buffer, g_bytes_new_static (\"world\", 5));","","…","","\/\/ Periodically, the chunks need to be sent as an array-and-length to some","\/\/ other part of the program.","GBytes **chunks;","gsize n_chunks;","","chunks = g_ptr_array_steal (chunk_buffer, &n_chunks);","for (gsize i = 0; i < n_chunks; i++)","  {","    \/\/ Do something with each chunk here, and then free them, since","    \/\/ `g_ptr_array_steal()` transfers ownership of all the elements and the","    \/\/ array to the caller.","    …","","    g_bytes_unref (chunks[i]);","  }","","g_free (chunks);","","\/\/ After calling `g_ptr_array_steal()`, the pointer array can be reused for the","\/\/ next set of chunks.","g_assert (chunk_buffer->len == 0);"],"type":"codeListing","syntax":"c"}]}],"sections":[],"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/PtrArrayProtocol\/steal(len:)"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/ptrarrayprotocol\/steal(len:)"]}],"references":{"doc://GLib/documentation/GLib/DestroyNotify":{"url":"\/documentation\/glib\/destroynotify","title":"DestroyNotify","role":"symbol","fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"DestroyNotify"}],"type":"topic","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/DestroyNotify","abstract":[{"text":"Specifies the type of function which is called when a data element","type":"text"},{"type":"text","text":" "},{"text":"is destroyed. It is passed the pointer to the data element and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"should free any memory and resources allocated for it."}],"navigatorTitle":[{"text":"DestroyNotify","kind":"identifier"}]},"doc://GLib/documentation/GLib/PtrArrayProtocol":{"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/PtrArrayProtocol","abstract":[{"text":"Contains the public fields of a ","type":"text"},{"type":"codeVoice","code":"GPtrArray"},{"text":".","type":"text"}],"navigatorTitle":[{"text":"PtrArrayProtocol","kind":"identifier"}],"title":"PtrArrayProtocol","url":"\/documentation\/glib\/ptrarrayprotocol","type":"topic","kind":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"PtrArrayProtocol"}]},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/PtrArrayProtocol/steal(len:)":{"fragme