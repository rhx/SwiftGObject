{"metadata":{"roleHeading":"Instance Method","externalID":"s:4GLib16PtrArrayProtocolPAAE5steal3lenSpySvSgGSgSpySuGSg_tF","modules":[{"name":"GLib"}],"role":"symbol","symbolKind":"method","extendedModule":"GLib","title":"steal(len:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"steal"},{"kind":"text","text":"("},{"kind":"externalParam","text":"len"},{"kind":"text","text":": "},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gsize","preciseIdentifier":"c:@T@gsize"},{"text":">!) -> ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:@T@gpointer"},{"kind":"text","text":"?>!"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"steal","kind":"identifier"},{"text":"(","kind":"text"},{"text":"len","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gsize","text":"gsize","kind":"typeIdentifier"},{"text":">! = nil) -> ","kind":"text"},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"text":"?>!","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that if the array is "},{"type":"codeVoice","code":"NULL"},{"text":" terminated this may still return","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"NULL"},{"type":"text","text":" if the length of the array was zero and pdata was not yet"},{"type":"text","text":" "},{"text":"allocated.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Even if set, the [callback","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/DestroyNotify"},{"type":"text","text":"] function will never be called"},{"type":"text","text":" "},{"text":"on the current contents of the array and the caller is","type":"text"},{"type":"text","text":" "},{"text":"responsible for freeing the array elements.","type":"text"}]},{"inlineContent":[{"type":"text","text":"An example of use:"}],"type":"paragraph"},{"type":"codeListing","syntax":"c","code":["`g_autoptr(GPtrArray)` chunk_buffer = g_ptr_array_new_with_free_func (g_bytes_unref);","","\/\/ Some part of your application appends a number of chunks to the pointer array.","g_ptr_array_add (chunk_buffer, g_bytes_new_static (\"hello\", 5));","g_ptr_array_add (chunk_buffer, g_bytes_new_static (\"world\", 5));","","…","","\/\/ Periodically, the chunks need to be sent as an array-and-length to some","\/\/ other part of the program.","GBytes **chunks;","gsize n_chunks;","","chunks = g_ptr_array_steal (chunk_buffer, &n_chunks);","for (gsize i = 0; i < n_chunks; i++)","  {","    \/\/ Do something with each chunk here, and then free them, since","    \/\/ `g_ptr_array_steal()` transfers ownership of all the elements and the","    \/\/ array to the caller.","    …","","    g_bytes_unref (chunks[i]);","  }","","g_free (chunks);","","\/\/ After calling `g_ptr_array_steal()`, the pointer array can be reused for the","\/\/ next set of chunks.","g_assert (chunk_buffer->len == 0);"]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/PtrArrayProtocol"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"text":"Frees the data in the array and resets the size to zero, while","type":"text"},{"text":" ","type":"text"},{"text":"the underlying array is preserved for use elsewhere and returned","type":"text"},{"text":" ","type":"text"},{"text":"to the caller.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/PtrArrayProtocol\/steal(len:)"},"variants":[{"paths":["\/documentation\/glib\/ptrarrayprotocol\/steal(len:)"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"kind":"symbol","references":{"doc://GLib/documentation/GLib/PtrArrayProtocol/steal(len:)":{"kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/PtrArrayProtocol\/steal(len:)","abstract":[{"text":"Frees the data in the array and resets the size to zero, while","type":"text"},{"type":"text","text":" "},{"text":"the underlying array is preserved for use elsewhere and returned","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to the caller."}],"role":"symbol","title":"steal(len:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"steal"},{"text":"(","kind":"text"},{"text":"len","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"text":"gsize","kind":"typeIdentifier","preciseIdentifier":"c:@T@gsize"},{"text":">!) -> ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:@T@gpointer"},{"text":"?>!","kind":"text"}],"type":"topic","url":"\/documentation\/glib\/ptrarrayprotocol\/steal(len:)"},"doc://GLib/documentation/GLib/DestroyNotify":{"title":"DestroyNotify","identifier":"doc:\/\/GLib\/documentation\/GLib\/DestroyNotify","kind":"symbol","type":"topic","url":"\/documentation\/glib\/destroynotify","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"DestroyNotify"}],"fragments":[{"kind":"keyword","text":"typealias"},{"text":" ","kind":"text"},{"kind":"identifier","text":"DestroyNotify"}],"abstract":[{"type":"text","text":"Specifies the type of function which is called when a data element"},{"type":"text","text":" "},{"type":"text","text":"is destroyed. It is passed the pointer to the data element and"},{"type":"text","text":" "},{"type":"text","text":"should free any memory and resources allocated for it."}]},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/PtrArrayProtocol":{"abstract":[{"text":"Contains the public fields of a ","type":"text"},{"code":"GPtrArray","type":"codeVoice"},{"type":"text","text":"."}],"title":"PtrArrayProtocol","url":"\/documentation\/glib\/ptrarrayprotocol","type":"topic","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"PtrArrayProtocol"}],"role":"symbol","kind":"symbol","navigatorTitle":[{"text":"PtrArrayProtocol","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/PtrArrayProtocol"}}}