{"kind":"symbol","sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/timezoneref\/new(identifier:)"]}],"abstract":[{"text":"Creates a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone","type":"reference"},{"type":"text","text":" corresponding to "},{"type":"codeVoice","code":"identifier"},{"text":". If ","type":"text"},{"code":"identifier","type":"codeVoice"},{"text":" cannot be","type":"text"},{"type":"text","text":" "},{"text":"parsed or loaded, ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" is returned.","type":"text"}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"new"},{"kind":"text","text":"("},{"text":"identifier","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier","text":"gchar"},{"text":">? = nil) -> ","kind":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef","kind":"typeIdentifier","text":"TimeZoneRef","preciseIdentifier":"s:4GLib11TimeZoneRefV"},{"kind":"text","text":"!"}]}],"kind":"declarations"},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"identifier"},{"type":"text","text":" can either be an RFC3339\/ISO 8601 time offset or"},{"type":"text","text":" "},{"text":"something that would pass as a valid value for the ","type":"text"},{"type":"codeVoice","code":"TZ"},{"text":" environment","type":"text"},{"type":"text","text":" "},{"text":"variable (including ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":").","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"In Windows, ","type":"text"},{"code":"identifier","type":"codeVoice"},{"type":"text","text":" can also be the unlocalized name of a time"},{"type":"text","text":" "},{"type":"text","text":"zone for standard time, for example “Pacific Standard Time”."}]},{"type":"paragraph","inlineContent":[{"text":"Valid RFC3339 time offsets are ","type":"text"},{"type":"codeVoice","code":"\"Z\""},{"type":"text","text":" (for UTC) or"},{"text":" ","type":"text"},{"code":"\"±hh:mm\"","type":"codeVoice"},{"type":"text","text":".  ISO 8601 additionally specifies"},{"type":"text","text":" "},{"type":"codeVoice","code":"\"±hhmm\""},{"text":" and ","type":"text"},{"code":"\"±hh\"","type":"codeVoice"},{"type":"text","text":".  Offsets are"},{"type":"text","text":" "},{"type":"text","text":"time values to be added to Coordinated Universal Time (UTC) to get"},{"type":"text","text":" "},{"type":"text","text":"the local time."}]},{"inlineContent":[{"type":"text","text":"In UNIX, the "},{"type":"codeVoice","code":"TZ"},{"type":"text","text":" environment variable typically corresponds"},{"type":"text","text":" "},{"type":"text","text":"to the name of a file in the zoneinfo database, an absolute path to a file"},{"type":"text","text":" "},{"text":"somewhere else, or a string in","type":"text"},{"type":"text","text":" "},{"text":"“std offset [dst [offset],start[\/time],end[\/time]]” (POSIX) format.","type":"text"},{"type":"text","text":" "},{"text":"There  are  no spaces in the specification. The name of standard","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and daylight savings time zone must be three or more alphabetic"},{"text":" ","type":"text"},{"text":"characters. Offsets are time values to be added to local time to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"get Coordinated Universal Time (UTC) and should be"},{"type":"text","text":" "},{"type":"codeVoice","code":"\"[±]hh[[:]mm[:ss]]\""},{"text":".  Dates are either","type":"text"},{"text":" ","type":"text"},{"code":"\"Jn\"","type":"codeVoice"},{"type":"text","text":" (Julian day with n between 1 and 365, leap"},{"text":" ","type":"text"},{"text":"years not counted), ","type":"text"},{"type":"codeVoice","code":"\"n\""},{"type":"text","text":" (zero-based Julian day"},{"type":"text","text":" "},{"text":"with n between 0 and 365) or ","type":"text"},{"type":"codeVoice","code":"\"Mm.w.d\""},{"text":" (day d","type":"text"},{"type":"text","text":" "},{"text":"(0 <= d <= 6) of week w (1 <= w <= 5) of month m (1 <= m <= 12), day","type":"text"},{"text":" ","type":"text"},{"text":"0 is a Sunday).  Times are in local wall clock time, the default is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"02:00:00."}],"type":"paragraph"},{"inlineContent":[{"text":"In Windows, the “tzn[+|–]hh","type":"text"},{"identifier":"#dzn","isActive":true,"type":"reference"},{"text":"” format is used, but also","type":"text"},{"type":"text","text":" "},{"text":"accepts POSIX format.  The Windows format uses US rules for all time","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"zones; daylight savings time is 60 minutes behind the standard time"},{"type":"text","text":" "},{"text":"with date and time of change taken from Pacific Standard Time.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Offsets are time values to be added to the local time to get"},{"type":"text","text":" "},{"type":"text","text":"Coordinated Universal Time (UTC)."}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"g_time_zone_new_local()"},{"text":" calls this function with the value of the","type":"text"},{"type":"text","text":" "},{"code":"TZ","type":"codeVoice"},{"text":" environment variable. This function itself is independent of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the value of "},{"type":"codeVoice","code":"TZ"},{"type":"text","text":", but if "},{"code":"identifier","type":"codeVoice"},{"type":"text","text":" is "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" then "},{"type":"codeVoice","code":"\/etc\/localtime"},{"text":" ","type":"text"},{"type":"text","text":"will be consulted to discover the correct time zone on UNIX and the"},{"type":"text","text":" "},{"type":"text","text":"registry will be consulted or "},{"type":"codeVoice","code":"GetTimeZoneInformation()"},{"type":"text","text":" will be used"},{"text":" ","type":"text"},{"type":"text","text":"to get the local time zone on Windows."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If intervals are not available, only time zone rules from ","type":"text"},{"type":"codeVoice","code":"TZ"},{"text":" ","type":"text"},{"type":"text","text":"environment variable or other means, then they will be computed"},{"type":"text","text":" "},{"text":"from year 1900 to 2037.  If the maximum year for the rules is","type":"text"},{"text":" ","type":"text"},{"text":"available and it is greater than 2037, then it will followed","type":"text"},{"type":"text","text":" "},{"type":"text","text":"instead."}]},{"inlineContent":[{"text":"See","type":"text"},{"type":"text","text":" "},{"type":"reference","identifier":"http:\/\/tools.ietf.org\/html\/rfc3339#section-5.6","isActive":true},{"type":"text","text":" "},{"type":"text","text":"for a precise definition of valid RFC3339 time offsets"},{"text":" ","type":"text"},{"type":"text","text":"(the "},{"code":"time-offset","type":"codeVoice"},{"text":" expansion) and ISO 8601 for the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"full list of valid time offsets.  See"},{"type":"text","text":" "},{"type":"reference","identifier":"http:\/\/www.gnu.org\/s\/libc\/manual\/html_node\/TZ-Variable.html","isActive":true},{"text":" ","type":"text"},{"type":"text","text":"for an explanation of the possible"},{"type":"text","text":" "},{"text":"values of the ","type":"text"},{"code":"TZ","type":"codeVoice"},{"text":" environment variable. See","type":"text"},{"text":" ","type":"text"},{"identifier":"http:\/\/msdn.microsoft.com\/en-us\/library\/ms912391%28v=winembedded.11%29.aspx","isActive":true,"type":"reference"},{"type":"text","text":" "},{"text":"for the list of time zones on Windows.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"You should release the return value by calling ","type":"text"},{"code":"g_time_zone_unref()","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"when you are done with it."}]}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef\/new(identifier:)"},"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"roleHeading":"Type Method","role":"symbol","modules":[{"name":"GLib"}],"externalID":"s:4GLib11TimeZoneRefV3new10identifierACSgSPys4Int8VGSg_tFZ","symbolKind":"method","extendedModule":"GLib","title":"new(identifier:)","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"new","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"identifier"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"text":">?) -> ","kind":"text"},{"text":"TimeZoneRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib11TimeZoneRefV"},{"text":"!","kind":"text"}]},"references":{"#dzn":{"titleInlineContent":[{"type":"text","text":":mm[:ss]"}],"title":":mm[:ss]","type":"link","identifier":"#dzn","url":"#dzn"},"doc://GLib/documentation/GLib/TimeZoneRef":{"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TimeZoneRef"}],"navigatorTitle":[{"text":"