{"metadata":{"roleHeading":"Type Method","title":"new(identifier:)","modules":[{"name":"GLib"}],"symbolKind":"method","role":"symbol","extendedModule":"GLib","fragments":[{"kind":"keyword","text":"static"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"new","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">?) -> "},{"kind":"typeIdentifier","text":"TimeZoneRef","preciseIdentifier":"s:4GLib11TimeZoneRefV"},{"text":"!","kind":"text"}],"externalID":"s:4GLib11TimeZoneRefV3new10identifierACSgSPys4Int8VGSg_tFZ"},"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef\/new(identifier:)"},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"new"},{"kind":"text","text":"("},{"kind":"externalParam","text":"identifier"},{"kind":"text","text":": "},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">? = nil) -> "},{"kind":"typeIdentifier","text":"TimeZoneRef","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef","preciseIdentifier":"s:4GLib11TimeZoneRefV"},{"kind":"text","text":"!"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"identifier"},{"text":" can either be an RFC3339\/ISO 8601 time offset or","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"something that would pass as a valid value for the "},{"type":"codeVoice","code":"TZ"},{"text":" environment","type":"text"},{"text":" ","type":"text"},{"text":"variable (including ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":")."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In Windows, "},{"code":"identifier","type":"codeVoice"},{"type":"text","text":" can also be the unlocalized name of a time"},{"text":" ","type":"text"},{"text":"zone for standard time, for example “Pacific Standard Time”.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Valid RFC3339 time offsets are "},{"code":"\"Z\"","type":"codeVoice"},{"text":" (for UTC) or","type":"text"},{"text":" ","type":"text"},{"code":"\"±hh:mm\"","type":"codeVoice"},{"text":".  ISO 8601 additionally specifies","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"\"±hhmm\""},{"text":" and ","type":"text"},{"code":"\"±hh\"","type":"codeVoice"},{"text":".  Offsets are","type":"text"},{"type":"text","text":" "},{"type":"text","text":"time values to be added to Coordinated Universal Time (UTC) to get"},{"type":"text","text":" "},{"text":"the local time.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In UNIX, the "},{"code":"TZ","type":"codeVoice"},{"type":"text","text":" environment variable typically corresponds"},{"text":" ","type":"text"},{"type":"text","text":"to the name of a file in the zoneinfo database, an absolute path to a file"},{"text":" ","type":"text"},{"type":"text","text":"somewhere else, or a string in"},{"text":" ","type":"text"},{"text":"“std offset [dst [offset],start[\/time],end[\/time]]” (POSIX) format.","type":"text"},{"type":"text","text":" "},{"text":"There  are  no spaces in the specification. The name of standard","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and daylight savings time zone must be three or more alphabetic"},{"type":"text","text":" "},{"type":"text","text":"characters. Offsets are time values to be added to local time to"},{"text":" ","type":"text"},{"text":"get Coordinated Universal Time (UTC) and should be","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"\"[±]hh[[:]mm[:ss]]\""},{"type":"text","text":".  Dates are either"},{"type":"text","text":" "},{"code":"\"Jn\"","type":"codeVoice"},{"type":"text","text":" (Julian day with n between 1 and 365, leap"},{"type":"text","text":" "},{"type":"text","text":"years not counted), "},{"type":"codeVoice","code":"\"n\""},{"text":" (zero-based Julian day","type":"text"},{"type":"text","text":" "},{"type":"text","text":"with n between 0 and 365) or "},{"type":"codeVoice","code":"\"Mm.w.d\""},{"type":"text","text":" (day d"},{"type":"text","text":" "},{"type":"text","text":"(0 <= d <= 6) of week w (1 <= w <= 5) of month m (1 <= m <= 12), day"},{"type":"text","text":" "},{"text":"0 is a Sunday).  Times are in local wall clock time, the default is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"02:00:00."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"In Windows, the “tzn[+|–]hh","type":"text"},{"type":"reference","identifier":"#dzn","isActive":true},{"type":"text","text":"” format is used, but also"},{"text":" ","type":"text"},{"type":"text","text":"accepts POSIX format.  The Windows format uses US rules for all time"},{"text":" ","type":"text"},{"text":"zones; daylight savings time is 60 minutes behind the standard time","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"with date and time of change taken from Pacific Standard Time."},{"type":"text","text":" "},{"type":"text","text":"Offsets are time values to be added to the local time to get"},{"type":"text","text":" "},{"type":"text","text":"Coordinated Universal Time (UTC)."}]},{"inlineContent":[{"type":"codeVoice","code":"g_time_zone_new_local()"},{"type":"text","text":" calls this function with the value of the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"TZ"},{"text":" environment variable. This function itself is independent of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the value of "},{"code":"TZ","type":"codeVoice"},{"text":", but if ","type":"text"},{"code":"identifier","type":"codeVoice"},{"type":"text","text":" is "},{"code":"nil","type":"codeVoice"},{"text":" then ","type":"text"},{"code":"\/etc\/localtime","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"will be consulted to discover the correct time zone on UNIX and the"},{"type":"text","text":" "},{"type":"text","text":"registry will be consulted or "},{"type":"codeVoice","code":"GetTimeZoneInformation()"},{"type":"text","text":" will be used"},{"type":"text","text":" "},{"type":"text","text":"to get the local time zone on Windows."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If intervals are not available, only time zone rules from ","type":"text"},{"type":"codeVoice","code":"TZ"},{"text":" ","type":"text"},{"type":"text","text":"environment variable or other means, then they will be computed"},{"text":" ","type":"text"},{"text":"from year 1900 to 2037.  If the maximum year for the rules is","type":"text"},{"type":"text","text":" "},{"text":"available and it is greater than 2037, then it will followed","type":"text"},{"type":"text","text":" "},{"text":"instead.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"See","type":"text"},{"type":"text","text":" "},{"identifier":"http:\/\/tools.ietf.org\/html\/rfc3339#section-5.6","type":"reference","isActive":true},{"text":" ","type":"text"},{"text":"for a precise definition of valid RFC3339 time offsets","type":"text"},{"text":" ","type":"text"},{"text":"(the ","type":"text"},{"code":"time-offset","type":"codeVoice"},{"type":"text","text":" expansion) and ISO 8601 for the"},{"type":"text","text":" "},{"type":"text","text":"full list of valid time offsets.  See"},{"text":" ","type":"text"},{"identifier":"http:\/\/www.gnu.org\/s\/libc\/manual\/html_node\/TZ-Variable.html","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"type":"text","text":"for an explanation of the possible"},{"text":" ","type":"text"},{"text":"values of the ","type":"text"},{"type":"codeVoice","code":"TZ"},{"type":"text","text":" environment variable. See"},{"text":" ","type":"text"},{"identifier":"http:\/\/msdn.microsoft.com\/en-us\/library\/ms912391%28v=winembedded.11%29.aspx","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"for the list of time zones on Windows."}]},{"inlineContent":[{"text":"You should release the return value by calling ","type":"text"},{"code":"g_time_zone_unref()","type":"codeVoice"},{"type":"text","text":" "},{"text":"when you are done with it.","type":"text"}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef"]]},"abstract":[{"text":"Creates a ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone","isActive":true,"type":"reference"},{"text":" corresponding to ","type":"text"},{"type":"codeVoice","code":"identifier"},{"type":"text","text":". If "},{"code":"identifier","type":"codeVoice"},{"text":" cannot be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"parsed or loaded, "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" is returned."}],"variants":[{"paths":["\/documentation\/glib\/timezoneref\/new(identifier:)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","references":{"doc://GLib/documentation/GLib/TimeZone":{"title":"TimeZone","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TimeZone"}],"abstract":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"GTimeZone"},{"text":" represents a time zone, at no particular point in time.","type":"text"}],"kind":"symbol","url":"\/documentation\/glib\/timezone","navigatorTitle":[{"kind":"identifier","text":"TimeZone"}],"type":"topic","role":"symbol"},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"#dzn":{"url":"#dzn","type":"link","title":":mm[:ss]","identifier":"#dzn","titleInlineContent":[{"type":"text","text":":mm[:ss]"}]},"doc://GLib/documentation/GLib/TimeZoneRef/new(identifier:)":{"type":"topic","abstract":[{"type":"text","text":"Creates a "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone","isActive":true,"type":"reference"},{"type":"text","text":" corresponding to "},{"code":"identifier","type":"codeVoice"},{"type":"text","text":". If "},{"code":"identifier","type":"codeVoice"},{"text":" cannot be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"parsed or loaded, "},{"type":"codeVoice","code":"nil"},{"text":" is returned.","type":"text"}],"fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"new","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">?) -> "},{"preciseIdentifier":"s:4GLib11TimeZoneRefV","text":"TimeZoneRef","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"url":"\/documentation\/glib\/timezoneref\/new(identifier:)","title":"new(identifier:)","kind":"symbol","role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef\/new(identifier:)"},"http://msdn.microsoft.com/en-us/library/ms912391%28v=winembedded.11%29.aspx":{"url":"http:\/\/msdn.microsoft.