{"metadata":{"role":"symbol","modules":[{"name":"GLib"}],"title":"init(identifier:)","externalID":"s:4GLib11TimeZoneRefV10identifierACSPys4Int8VGSg_tcfc","roleHeading":"Initializer","symbolKind":"init","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"identifier","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"text":">?)","kind":"text"}],"extendedModule":"GLib"},"kind":"symbol","schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef\/init(identifier:)","interfaceLanguage":"swift"},"abstract":[{"text":"Creates a ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone","isActive":true,"type":"reference"},{"text":" corresponding to ","type":"text"},{"type":"codeVoice","code":"identifier"},{"type":"text","text":". If "},{"type":"codeVoice","code":"identifier"},{"type":"text","text":" cannot be"},{"type":"text","text":" "},{"text":"parsed or loaded, ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" is returned.","type":"text"}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"init","kind":"keyword"},{"text":"(","kind":"text"},{"text":"identifier","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"gchar","preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier"},{"text":">? = nil)","kind":"text"}]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"identifier"},{"text":" can either be an RFC3339\/ISO 8601 time offset or","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"something that would pass as a valid value for the "},{"type":"codeVoice","code":"TZ"},{"text":" environment","type":"text"},{"type":"text","text":" "},{"text":"variable (including ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":")."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In Windows, "},{"type":"codeVoice","code":"identifier"},{"text":" can also be the unlocalized name of a time","type":"text"},{"text":" ","type":"text"},{"text":"zone for standard time, for example “Pacific Standard Time”.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Valid RFC3339 time offsets are ","type":"text"},{"code":"\"Z\"","type":"codeVoice"},{"text":" (for UTC) or","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"\"±hh:mm\""},{"type":"text","text":".  ISO 8601 additionally specifies"},{"type":"text","text":" "},{"type":"codeVoice","code":"\"±hhmm\""},{"type":"text","text":" and "},{"code":"\"±hh\"","type":"codeVoice"},{"text":".  Offsets are","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"time values to be added to Coordinated Universal Time (UTC) to get"},{"text":" ","type":"text"},{"type":"text","text":"the local time."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In UNIX, the "},{"type":"codeVoice","code":"TZ"},{"text":" environment variable typically corresponds","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to the name of a file in the zoneinfo database, an absolute path to a file"},{"text":" ","type":"text"},{"text":"somewhere else, or a string in","type":"text"},{"text":" ","type":"text"},{"text":"“std offset [dst [offset],start[\/time],end[\/time]]” (POSIX) format.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"There  are  no spaces in the specification. The name of standard"},{"text":" ","type":"text"},{"type":"text","text":"and daylight savings time zone must be three or more alphabetic"},{"type":"text","text":" "},{"text":"characters. Offsets are time values to be added to local time to","type":"text"},{"text":" ","type":"text"},{"text":"get Coordinated Universal Time (UTC) and should be","type":"text"},{"type":"text","text":" "},{"code":"\"[±]hh[[:]mm[:ss]]\"","type":"codeVoice"},{"type":"text","text":".  Dates are either"},{"type":"text","text":" "},{"type":"codeVoice","code":"\"Jn\""},{"text":" (Julian day with n between 1 and 365, leap","type":"text"},{"type":"text","text":" "},{"text":"years not counted), ","type":"text"},{"code":"\"n\"","type":"codeVoice"},{"text":" (zero-based Julian day","type":"text"},{"type":"text","text":" "},{"text":"with n between 0 and 365) or ","type":"text"},{"code":"\"Mm.w.d\"","type":"codeVoice"},{"type":"text","text":" (day d"},{"text":" ","type":"text"},{"type":"text","text":"(0 <= d <= 6) of week w (1 <= w <= 5) of month m (1 <= m <= 12), day"},{"type":"text","text":" "},{"type":"text","text":"0 is a Sunday).  Times are in local wall clock time, the default is"},{"type":"text","text":" "},{"text":"02:00:00.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"In Windows, the “tzn[+|–]hh","type":"text"},{"type":"reference","isActive":true,"identifier":"#dzn"},{"type":"text","text":"” format is used, but also"},{"type":"text","text":" "},{"text":"accepts POSIX format.  The Windows format uses US rules for all time","type":"text"},{"type":"text","text":" "},{"type":"text","text":"zones; daylight savings time is 60 minutes behind the standard time"},{"type":"text","text":" "},{"text":"with date and time of change taken from Pacific Standard Time.","type":"text"},{"type":"text","text":" "},{"text":"Offsets are time values to be added to the local time to get","type":"text"},{"text":" ","type":"text"},{"text":"Coordinated Universal Time (UTC).","type":"text"}]},{"type":"paragraph","inlineContent":[{"code":"g_time_zone_new_local()","type":"codeVoice"},{"type":"text","text":" calls this function with the value of the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"TZ"},{"text":" environment variable. This function itself is independent of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the value of "},{"type":"codeVoice","code":"TZ"},{"type":"text","text":", but if "},{"code":"identifier","type":"codeVoice"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" then "},{"code":"\/etc\/localtime","type":"codeVoice"},{"text":" ","type":"text"},{"text":"will be consulted to discover the correct time zone on UNIX and the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"registry will be consulted or "},{"code":"GetTimeZoneInformation()","type":"codeVoice"},{"type":"text","text":" will be used"},{"text":" ","type":"text"},{"type":"text","text":"to get the local time zone on Windows."}]},{"type":"paragraph","inlineContent":[{"text":"If intervals are not available, only time zone rules from ","type":"text"},{"type":"codeVoice","code":"TZ"},{"type":"text","text":" "},{"type":"text","text":"environment variable or other means, then they will be computed"},{"type":"text","text":" "},{"text":"from year 1900 to 2037.  If the maximum year for the rules is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"available and it is greater than 2037, then it will followed"},{"type":"text","text":" "},{"type":"text","text":"instead."}]},{"inlineContent":[{"text":"See","type":"text"},{"type":"text","text":" "},{"type":"reference","identifier":"http:\/\/tools.ietf.org\/html\/rfc3339#section-5.6","isActive":true},{"type":"text","text":" "},{"type":"text","text":"for a precise definition of valid RFC3339 time offsets"},{"type":"text","text":" "},{"text":"(the ","type":"text"},{"code":"time-offset","type":"codeVoice"},{"type":"text","text":" expansion) and ISO 8601 for the"},{"type":"text","text":" "},{"text":"full list of valid time offsets.  See","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"http:\/\/www.gnu.org\/s\/libc\/manual\/html_node\/TZ-Variable.html"},{"text":" ","type":"text"},{"type":"text","text":"for an explanation of the possible"},{"text":" ","type":"text"},{"type":"text","text":"values of the "},{"type":"codeVoice","code":"TZ"},{"type":"text","text":" environment variable. See"},{"type":"text","text":" "},{"isActive":true,"identifier":"http:\/\/msdn.microsoft.com\/en-us\/library\/ms912391%28v=winembedded.11%29.aspx","type":"reference"},{"text":" ","type":"text"},{"type":"text","text":"for the list of time zones on Windows."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"You should release the return value by calling ","type":"text"},{"type":"codeVoice","code":"g_time_zone_unref()"},{"type":"text","text":" "},{"type":"text","text":"when you are done with it."}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/glib\/timezoneref\/init(identifier:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef"]]},"sections":[],"references":{"http://tools.ietf.org/html/rfc3339#section-5.6":{"url":"http:\/\/tools.ietf.org\/html\/rfc3339#section-5.6","identifier":"http:\/\/tools.ietf.org\/html\/rfc3339#section-5.6","type":"link","titleInlineContent":[{"text":"RFC3339 §5.6","type":"text"}],"title":"RFC3339 §5.6"},"doc://GLib/documentation/GLib/TimeZoneRef/init(identifier:)":{"abstract":[{"type":"text","text":"Creates a "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone","type":"reference"},{"text":" corresponding to ","type":"text"},{"type":"codeVoice","code":"identifier"},{"text":". If ","type":"text"},{"code":"identifier","type":"codeVoice"},{"type":"text","text":" cannot be"},{"type":"text","text":" "},{"type":"text","text":"parsed or loaded, "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" is returned."}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef\/init(identifier:)","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"identifier","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"text":">?)","kind":"text"}],"role":"symbol","url":"\/documentation\/glib\/timezoneref\/init(identifier:)","kind":"symbol","type":"topic","title":"init(identifier:)"},"#dzn":{"url":"#dzn","identifier":"#dzn","type":"link","titleInlineContent":[{"text":":mm[:ss]","type":"text"}],"title":":mm[:ss]"},"http://www.gnu.org/s/libc/manual/html_node/TZ-Variable.html":{"url":"http:\/\/www.gnu.org\/s\/libc\/manual\/html_node\/TZ-Variable.html","identifier":"http:\/\/www.gnu.org\/s\/libc\/manual\/html_node\/TZ-Variable.html","type":"link","titleInlineContent":[{"text":"The GNU C Library manual","type":"text"}],"title":"The GNU C Library manual"},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/TimeZone":{"title":"TimeZone","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TimeZone"}],"abstract":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"GTimeZone"},{"text":" represents a time zone, at no particular point in time.","type":"text"}],"kind":"symbol","url":"\/documentation\/glib\/timezone","navigatorTitle":[{"kind":"identifier","text":"TimeZone"}],"type":"topic","role":"symbol"},"http://msdn.microsoft.com/en-us/library/ms912391%28v=winembedded.11%29.aspx":{"url":"http:\/\/msdn.microsoft.com\/en-us\/library\/ms912391%28v=winembedded.11%29.aspx","identifier":"http:\/\/msdn.microsoft.com\/en-us\/library\/ms912391%28v=winembedded.11%29.aspx","type":"link","titleInlineContent":[{"text":"Microsoft Time Zone Index Values","type":"text"}],"title":"Microsoft Time Zone Index Values"},"doc://GLib/documentation/GLib/TimeZoneRef":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef","type":"topic","abstract":[{"text":"A ","type":"text"},{"code":"GTimeZone","type":"codeVoice"},{"text":" represents a time zone, at no particular point in time.","type":"text"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TimeZoneRef"}],"title":"TimeZoneRef","kind":"symbol","navigatorTitle":[{"text":"TimeZoneRef","kind":"identifier"}],"role":"symbol","url":"\/documentation\/glib\/timezoneref"}}}