{"metadata":{"symbolKind":"init","modules":[{"name":"GLib"}],"fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"identifier"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"text":"gchar","preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier"},{"text":">?)","kind":"text"}],"extendedModule":"GLib","roleHeading":"Initializer","title":"init(identifier:)","role":"symbol","externalID":"s:4GLib11TimeZoneRefV10identifierACSPys4Int8VGSg_tcfc"},"variants":[{"paths":["\/documentation\/glib\/timezoneref\/init(identifier:)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"init","kind":"keyword"},{"kind":"text","text":"("},{"text":"identifier","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">? = nil)","kind":"text"}]}]},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"identifier"},{"text":" can either be an RFC3339\/ISO 8601 time offset or","type":"text"},{"type":"text","text":" "},{"type":"text","text":"something that would pass as a valid value for the "},{"type":"codeVoice","code":"TZ"},{"text":" environment","type":"text"},{"text":" ","type":"text"},{"text":"variable (including ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":")."}]},{"type":"paragraph","inlineContent":[{"text":"In Windows, ","type":"text"},{"code":"identifier","type":"codeVoice"},{"type":"text","text":" can also be the unlocalized name of a time"},{"type":"text","text":" "},{"type":"text","text":"zone for standard time, for example “Pacific Standard Time”."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Valid RFC3339 time offsets are "},{"type":"codeVoice","code":"\"Z\""},{"type":"text","text":" (for UTC) or"},{"type":"text","text":" "},{"code":"\"±hh:mm\"","type":"codeVoice"},{"text":".  ISO 8601 additionally specifies","type":"text"},{"text":" ","type":"text"},{"code":"\"±hhmm\"","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"\"±hh\""},{"text":".  Offsets are","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"time values to be added to Coordinated Universal Time (UTC) to get"},{"text":" ","type":"text"},{"text":"the local time.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"In UNIX, the ","type":"text"},{"type":"codeVoice","code":"TZ"},{"type":"text","text":" environment variable typically corresponds"},{"type":"text","text":" "},{"text":"to the name of a file in the zoneinfo database, an absolute path to a file","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"somewhere else, or a string in"},{"text":" ","type":"text"},{"type":"text","text":"“std offset [dst [offset],start[\/time],end[\/time]]” (POSIX) format."},{"type":"text","text":" "},{"text":"There  are  no spaces in the specification. The name of standard","type":"text"},{"type":"text","text":" "},{"text":"and daylight savings time zone must be three or more alphabetic","type":"text"},{"text":" ","type":"text"},{"text":"characters. Offsets are time values to be added to local time to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"get Coordinated Universal Time (UTC) and should be"},{"text":" ","type":"text"},{"type":"codeVoice","code":"\"[±]hh[[:]mm[:ss]]\""},{"text":".  Dates are either","type":"text"},{"type":"text","text":" "},{"code":"\"Jn\"","type":"codeVoice"},{"type":"text","text":" (Julian day with n between 1 and 365, leap"},{"text":" ","type":"text"},{"type":"text","text":"years not counted), "},{"code":"\"n\"","type":"codeVoice"},{"type":"text","text":" (zero-based Julian day"},{"type":"text","text":" "},{"text":"with n between 0 and 365) or ","type":"text"},{"code":"\"Mm.w.d\"","type":"codeVoice"},{"type":"text","text":" (day d"},{"text":" ","type":"text"},{"text":"(0 <= d <= 6) of week w (1 <= w <= 5) of month m (1 <= m <= 12), day","type":"text"},{"type":"text","text":" "},{"type":"text","text":"0 is a Sunday).  Times are in local wall clock time, the default is"},{"type":"text","text":" "},{"type":"text","text":"02:00:00."}]},{"inlineContent":[{"type":"text","text":"In Windows, the “tzn[+|–]hh"},{"isActive":true,"type":"reference","identifier":"#dzn"},{"text":"” format is used, but also","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"accepts POSIX format.  The Windows format uses US rules for all time"},{"type":"text","text":" "},{"type":"text","text":"zones; daylight savings time is 60 minutes behind the standard time"},{"type":"text","text":" "},{"text":"with date and time of change taken from Pacific Standard Time.","type":"text"},{"type":"text","text":" "},{"text":"Offsets are time values to be added to the local time to get","type":"text"},{"text":" ","type":"text"},{"text":"Coordinated Universal Time (UTC).","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"g_time_zone_new_local()"},{"type":"text","text":" calls this function with the value of the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"TZ"},{"text":" environment variable. This function itself is independent of","type":"text"},{"text":" ","type":"text"},{"text":"the value of ","type":"text"},{"type":"codeVoice","code":"TZ"},{"text":", but if ","type":"text"},{"type":"codeVoice","code":"identifier"},{"text":" is ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" then ","type":"text"},{"type":"codeVoice","code":"\/etc\/localtime"},{"text":" ","type":"text"},{"type":"text","text":"will be consulted to discover the correct time zone on UNIX and the"},{"type":"text","text":" "},{"text":"registry will be consulted or ","type":"text"},{"type":"codeVoice","code":"GetTimeZoneInformation()"},{"type":"text","text":" will be used"},{"text":" ","type":"text"},{"text":"to get the local time zone on Windows.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If intervals are not available, only time zone rules from ","type":"text"},{"type":"codeVoice","code":"TZ"},{"text":" ","type":"text"},{"text":"environment variable or other means, then they will be computed","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"from year 1900 to 2037.  If the maximum year for the rules is"},{"text":" ","type":"text"},{"type":"text","text":"available and it is greater than 2037, then it will followed"},{"type":"text","text":" "},{"text":"instead.","type":"text"}]},{"inlineContent":[{"type":"text","text":"See"},{"text":" ","type":"text"},{"type":"reference","identifier":"http:\/\/tools.ietf.org\/html\/rfc3339#section-5.6","isActive":true},{"type":"text","text":" "},{"type":"text","text":"for a precise definition of valid RFC3339 time offsets"},{"type":"text","text":" "},{"type":"text","text":"(the "},{"code":"time-offset","type":"codeVoice"},{"text":" expansion) and ISO 8601 for the","type":"text"},{"type":"text","text":" "},{"text":"full list of valid time offsets.  See","type":"text"},{"type":"text","text":" "},{"identifier":"http:\/\/www.gnu.org\/s\/libc\/manual\/html_node\/TZ-Variable.html","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"for an explanation of the possible","type":"text"},{"text":" ","type":"text"},{"text":"values of the ","type":"text"},{"code":"TZ","type":"codeVoice"},{"type":"text","text":" environment variable. See"},{"text":" ","type":"text"},{"identifier":"http:\/\/msdn.microsoft.com\/en-us\/library\/ms912391%28v=winembedded.11%29.aspx","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"for the list of time zones on Windows.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"You should release the return value by calling ","type":"text"},{"type":"codeVoice","code":"g_time_zone_unref()"},{"type":"text","text":" "},{"text":"when you are done with it.","type":"text"}]}],"kind":"content"}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef\/init(identifier:)","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef"]]},"abstract":[{"type":"text","text":"Creates a "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone","isActive":true},{"type":"text","text":" corresponding to "},{"code":"identifier","type":"codeVoice"},{"type":"text","text":". If "},{"type":"codeVoice","code":"identifier"},{"text":" cannot be","type":"text"},{"type":"text","text":" "},{"text":"parsed or loaded, ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" is returned.","type":"text"}],"references":{"http://www.gnu.org/s/libc/manual/html_node/TZ-Variable.html":{"title":"The GNU C Library manual","type":"link","url":"http:\/\/www.gnu.org\/s\/libc\/manual\/html_node\/TZ-Variable.html","identifier":"http:\/\/www.gnu.org\/s\/libc\/manual\/html_node\/TZ-Variable.html","titleInlineContent":[{"text":"The GNU C Library manual","type":"text"}]},"http://tools.ietf.org/html/rfc3339#section-5.6":{"title":"RFC3339 §5.6","type":"link","url":"http:\/\/tools.ietf.org\/html\/rfc3339#section-5.6","identifier":"http:\/\/tools.ietf.org\/html\/rfc3339#section-5.6","titleInlineContent":[{"text":"RFC3339 §5.6","type":"text"}]},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/TimeZone":{"url":"\/documentation\/glib\/timezone","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"TimeZone","kind":"identifier"}],"type":"topic","title":"TimeZone","navigatorTitle":[{"text":"TimeZone","kind":"identifier"}],"abstract":[{"type":"text","text":"A "},{"type":"codeVoice","code":"GTimeZone"},{"text":" represents a time zone, at no particular point in time.","type":"text"}]},"doc://GLib/documentation/GLib/TimeZoneRef/init(identifier:)":{"role":"symbol","type":"topic","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef\/init(identifier:)","url":"\/documentation\/glib\/timezoneref\/init(identifier:)","abstract":[{"text":"Creates a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone"},{"text":" corresponding to ","type":"text"},{"code":"identifier","type":"codeVoice"},{"type":"text","text":". If "},{"code":"identifier","type":"codeVoice"},{"text":" cannot be","type":"text"},{"text":" ","type":"text"},{"text":"parsed or loaded, ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" is returned.","type":"text"}],"fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"identifier","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">?)","kind":"text"}],"title":"init(identifier:)"},"http://msdn.microsoft.com/en-us/library/ms912391%28v=winembedded.11%29.aspx":{"title":"Microsoft Time Zone Index Values","type":"link","url":"http:\/\/msdn.microsoft.com\/en-us\/library\/ms912391%28v=winembedded.11%29.aspx","identifier":"http:\/\/msdn.microsoft.com\/en-us\/library\/ms912391%28v=winembedded.11%29.aspx","titleInlineContent":[{"text":"Microsoft Time Zone Index Values","type":"text"}]},"doc://GLib/documentation/GLib/TimeZoneRef":{"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TimeZoneRef"}],"navigatorTitle":[{"text":"TimeZoneRef","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef","abstract":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"GTimeZone"},{"type":"text","text":" represents a time zone, at no particular point in time."}],"kind":"symbol","url":"\/documentation\/glib\/timezoneref","type":"topic","title":"TimeZoneRef"},"#dzn":{"title":":mm[:ss]","type":"link","url":"#dzn","identifier":"#dzn","titleInlineContent":[{"type":"text","text":":mm[:ss]"}]}}}