{"abstract":[{"text":"A ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex","isActive":true,"type":"reference"},{"text":" works like a ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","isActive":true,"type":"reference"},{"type":"text","text":"."}],"metadata":{"externalID":"s:4GLib19StaticMutexProtocolP","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"text":"StaticMutexProtocol","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"StaticMutexProtocol"}],"title":"StaticMutexProtocol","role":"symbol","symbolKind":"protocol","modules":[{"name":"GLib"}],"roleHeading":"Protocol"},"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/StaticMutexProtocol"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"topicSections":[{"anchor":"Instance-Properties","generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/StaticMutexProtocol\/mutex","doc:\/\/GLib\/documentation\/GLib\/StaticMutexProtocol\/mutexImpl"],"title":"Instance Properties"},{"generated":true,"title":"Instance Methods","anchor":"Instance-Methods","identifiers":["doc:\/\/GLib\/documentation\/GLib\/StaticMutexProtocol\/free()","doc:\/\/GLib\/documentation\/GLib\/StaticMutexProtocol\/getMutexImpl()","doc:\/\/GLib\/documentation\/GLib\/StaticMutexProtocol\/init_()"]}],"relationshipsSections":[{"kind":"relationships","identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper"],"title":"Inherits From","type":"inheritsFrom"},{"title":"Conforming Types","type":"conformingTypes","kind":"relationships","identifiers":["doc:\/\/GLib\/documentation\/GLib\/StaticMutex","doc:\/\/GLib\/documentation\/GLib\/StaticMutexRef"]}],"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/glib\/staticmutexprotocol"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"StaticMutexProtocol"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:4GLib14PointerWrapperP","text":"PointerWrapper","kind":"typeIdentifier","identifier":"doc:\/\/GLib\/documentation\/GLib\/PointerWrapper"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"overview","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Prior to GLib 2.32, GStaticMutex had the significant advantage"},{"text":" ","type":"text"},{"text":"that it doesn’t need to be created at run-time, but can be defined","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"at compile-time. Since 2.32, "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","isActive":true},{"text":" can be statically allocated","type":"text"},{"type":"text","text":" "},{"text":"as well, and GStaticMutex has been deprecated.","type":"text"}]},{"inlineContent":[{"text":"Here is a version of our ","type":"text"},{"code":"give_me_next_number()","type":"codeVoice"},{"text":" example using","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a GStaticMutex:"}],"type":"paragraph"},{"type":"codeListing","syntax":null,"code":["  int","  give_me_next_number (void)","  {","    static int current_number = 0;","    int ret_val;","    static GStaticMutex mutex = G_STATIC_MUTEX_INIT;","","    g_static_mutex_lock (&mutex);","    ret_val = current_number = calc_next_number (current_number);","    g_static_mutex_unlock (&mutex);","","    return ret_val;","  }"]},{"inlineContent":[{"text":"Sometimes you would like to dynamically create a mutex. If you don’t","type":"text"},{"type":"text","text":" "},{"type":"text","text":"want to require prior calling to "},{"code":"g_thread_init()","type":"codeVoice"},{"type":"text","text":", because your code"},{"type":"text","text":" "},{"text":"should also be usable in non-threaded programs, you are not able to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"use "},{"type":"codeVoice","code":"g_mutex_new()"},{"type":"text","text":" and thus "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","isActive":true},{"text":", as that requires a prior call to","type":"text"},{"text":" ","type":"text"},{"code":"g_thread_init()","type":"codeVoice"},{"type":"text","text":". In these cases you can also use a "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex","type":"reference"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It must be initialized with "},{"code":"g_static_mutex_init()","type":"codeVoice"},{"text":" before using it","type":"text"},{"type":"text","text":" "},{"text":"and freed with with ","type":"text"},{"type":"codeVoice","code":"g_static_mutex_free()"},{"type":"text","text":" when not needed anymore to"},{"type":"text","text":" "},{"type":"text","text":"free up any allocated resources."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Even though "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex","isActive":true},{"type":"text","text":" is not opaque, it should only be used with"},{"type":"text","text":" "},{"type":"text","text":"the following functions, as it is defined differently on different"},{"type":"text","text":" "},{"text":"platforms.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"All of the g_static_mutex_* functions apart from","type":"text"},{"text":" ","type":"text"},{"code":"g_static_mutex_get_mutex()","type":"codeVoice"},{"text":" can also be used even if ","type":"text"},{"code":"g_thread_init()","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"has not yet been called. Then they do nothing, apart from"},{"type":"text","text":" "},{"code":"g_static_mutex_trylock()","type":"codeVoice"},{"text":" which does nothing but returning ","type":"text"},{"code":"true","type":"codeVoice"},{"text":".","type":"text"}]},{"inlineContent":[{"type":"text","text":"All of the g_static_mutex_* functions are actually macros. Apart from"},{"type":"text","text":" "},{"type":"text","text":"taking their addresses, you can however use them as if they were"},{"text":" ","type":"text"},{"text":"functions.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutexProtocol","isActive":true},{"type":"text","text":" protocol exposes the methods and properties of an underlying "},{"code":"GStaticMutex","type":"codeVoice"},{"text":" instance.","type":"text"},{"type":"text","text":" "},{"text":"The default implementation of these can be found in the protocol extension below.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"For a concrete class that implements these methods and properties, see "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex","isActive":true,"type":"reference"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Alternatively, use "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutexRef","type":"reference","isActive":true},{"type":"text","text":" as a lighweight, "},{"type":"codeVoice","code":"unowned"},{"type":"text","text":" reference if you already have an instance you just want to use."}],"type":"paragraph"}]}],"references":{"doc://GLib/documentation/GLib/StaticMutexProtocol/mutexImpl":{"abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutexProtocol\/mutexImpl","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"mutexImpl","kind":"identifier"},{"kind":"text","text":": "},{"preciseIdentifier":"s:4GLib8MutexRefV","kind":"typeIdentifier","text":"MutexRef"},{"kind":"text","text":"!"}],"role":"symbol","kind":"symbol","url":"\/documentation\/glib\/staticmutexprotocol\/muteximpl","type":"topic","title":"mutexImpl"},"doc://GLib/documentation/GLib/StaticMutexRef":{"navigatorTitle":[{"text":"StaticMutexRef","kind":"identifier"}],"role":"symbol","title":"StaticMutexRef","url":"\/documentation\/glib\/staticmutexref","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutexRef","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"StaticMutexRef"}],"abstract":[{"text":"A ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex"},{"text":" works like a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex"},{"text":".","type":"text"}],"kind":"symbol"},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/Mutex":{"title":"Mutex","type":"topic","abstract":[{"text":"The ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex"},{"text":" struct is an opaque data structure to represent a mutex","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(mutual exclusion). It can be used to protect data against shared"},{"text":" ","type":"text"},{"text":"access.","type":"text"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Mutex"}],"navigatorTitle":[{"kind":"identifier","text":"Mutex"}],"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","url":"\/documentation\/glib\/mutex","kind":"symbol"},"doc://GLib/documentation/GLib/PointerWrapper":{"abstract":[{"text":"Protocol for GLib types that wrap pointers.","type":"text"}],"role":"symbol","url":"\/documentation\/glib\/pointerwrapper","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/Pointe