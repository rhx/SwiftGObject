"type":"codeVoice","code":"text"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The format is described ","type":"text"},{"isActive":true,"type":"reference","identifier":"gvariant-text-format.html"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"The memory at ","type":"text"},{"type":"codeVoice","code":"limit"},{"type":"text","text":" will never be accessed and the parser behaves as"},{"text":" ","type":"text"},{"type":"text","text":"if the character at "},{"type":"codeVoice","code":"limit"},{"type":"text","text":" is the nul terminator.  This has the"},{"type":"text","text":" "},{"text":"effect of bounding ","type":"text"},{"type":"codeVoice","code":"text"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"endptr"},{"text":" is non-","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":" then "},{"code":"text","type":"codeVoice"},{"text":" is permitted to contain data","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"following the value that this function parses and "},{"code":"endptr","type":"codeVoice"},{"type":"text","text":" will be"},{"type":"text","text":" "},{"type":"text","text":"updated to point to the first character past the end of the text"},{"type":"text","text":" "},{"type":"text","text":"parsed by this function.  If "},{"type":"codeVoice","code":"endptr"},{"text":" is ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":" and there is extra data"},{"text":" ","type":"text"},{"type":"text","text":"then an error is returned."}]},{"inlineContent":[{"text":"If ","type":"text"},{"code":"type","type":"codeVoice"},{"type":"text","text":" is non-"},{"type":"codeVoice","code":"nil"},{"text":" then the value will be parsed to have that","type":"text"},{"text":" ","type":"text"},{"text":"type.  This may result in additional parse errors (in the case that","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the parsed value doesn’t fit the type) but may also result in fewer"},{"text":" ","type":"text"},{"type":"text","text":"errors (in the case that the type would have been ambiguous, such as"},{"type":"text","text":" "},{"type":"text","text":"with empty arrays)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"In the event that the parsing is successful, the resulting ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"is returned. It is never floating, and must be freed with"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GLib.Variant.unref"},{"type":"text","text":"]."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In case of any error, "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" will be returned.  If "},{"type":"codeVoice","code":"error"},{"type":"text","text":" is non-"},{"code":"nil","type":"codeVoice"},{"text":" ","type":"text"},{"text":"then it will be set to reflect the error that occurred.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Officially, the language understood by the parser is “any string","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"produced by [method"},{"type":"codeVoice","code":"GLib.Variant.print"},{"text":"]”. This explicitly includes","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_variant_print()"},{"text":"’s annotated types like ","type":"text"},{"type":"codeVoice","code":"int64 -1000"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"There may be implementation specific restrictions on deeply nested values,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"which would result in a "},{"type":"codeVoice","code":"recursion"},{"type":"text","text":" error. "},{"isActive":true,"type"