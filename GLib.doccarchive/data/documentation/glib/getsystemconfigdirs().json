{"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"abstract":[{"text":"Returns an ordered list of base directories in which to access","type":"text"},{"text":" ","type":"text"},{"text":"system-wide configuration information.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"getSystemConfigDirs","kind":"identifier"},{"kind":"text","text":"() -> "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">?>!","kind":"text"}]}]},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"On UNIX platforms this is determined using the mechanisms described"},{"type":"text","text":" "},{"text":"in the","type":"text"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"http:\/\/www.freedesktop.org\/Standards\/basedir-spec"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"In this case the list of directories retrieved will be "},{"type":"codeVoice","code":"XDG_CONFIG_DIRS"},{"text":".","type":"text"}]},{"inlineContent":[{"text":"On Windows it follows XDG Base Directory Specification if ","type":"text"},{"code":"XDG_CONFIG_DIRS","type":"codeVoice"},{"text":" is defined.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"If "},{"code":"XDG_CONFIG_DIRS","type":"codeVoice"},{"type":"text","text":" is undefined, the directory that contains application"},{"type":"text","text":" "},{"type":"text","text":"data for all users is used instead. A typical path is"},{"type":"text","text":" "},{"code":"C:\\Documents and Settings\\All Users\\Application Data","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"This folder is used for application data"},{"type":"text","text":" "},{"text":"that is not user specific. For example, an application can store","type":"text"},{"type":"text","text":" "},{"text":"a spell-check dictionary, a database of clip art, or a log file in the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"FOLDERID_ProgramData folder. This information will not roam and is available"},{"type":"text","text":" "},{"text":"to anyone using the computer.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The return value is cached and modifying it at runtime is not supported, as"},{"text":" ","type":"text"},{"type":"text","text":"it’s not thread-safe to modify environment variables at runtime."}]}],"kind":"content"}],"sections":[],"schemaVersion":{"patch":0,"minor":3,"major":0},"variants":[{"paths":["\/documentation\/glib\/getsystemconfigdirs()"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/getSystemConfigDirs()"},"metadata":{"symbolKind":"func","modules":[{"name":"GLib"}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"getSystemConfigDirs","kind":"identifier"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"text":">?>!","kind":"text"}],"roleHeading":"Function","title":"getSystemConfigDirs()","role":"symbol","externalID":"s:4GLib19getSystemConfigDirsSPySPys4Int8VGSgGSgyF"},"references":{"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"to