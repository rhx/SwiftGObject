{"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"set","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"strictPosix"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":")","kind":"text"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default, this mode is disabled."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In strict POSIX mode, the first non-argument parameter encountered"},{"type":"text","text":" "},{"type":"text","text":"(eg: filename) terminates argument processing.  Remaining arguments"},{"type":"text","text":" "},{"text":"are treated as non-options and are not attempted to be parsed.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If strict POSIX mode is disabled then parsing is done in the GNU way"},{"type":"text","text":" "},{"text":"where option arguments can be freely mixed with non-options.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"As an example, consider “ls foo -l”.  With GNU style parsing, this"},{"type":"text","text":" "},{"text":"will list “foo” in long mode.  In strict POSIX style, this will list","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the files named “foo” and “-l”."}]},{"type":"paragraph","inlineContent":[{"text":"It may be useful to force strict POSIX mode when creating “verb","type":"text"},{"text":" ","type":"text"},{"text":"style” command line tools.  For example, the “gsettings” command line","type":"text"},{"type":"text","text":" "},{"type":"text","text":"tool supports the global option “–schemadir” as well as many"},{"type":"text","text":" "},{"type":"text","text":"subcommands (“get”, “set”, etc.) which each have their own set of"},{"text":" ","type":"text"},{"text":"arguments.  Using strict POSIX mode will allow parsing the global","type":"text"},{"type":"text","text":" "},{"type":"text","text":"options up to the verb name while leaving the remaining options to be"},{"text":" ","type":"text"},{"type":"text","text":"parsed by the relevant subcommand (which can be determined by"},{"type":"text","text":" "},{"text":"examining the verb name, which should be present in argv[1] after","type":"text"},{"type":"text","text":" "},{"type":"text","text":"parsing)."}]}],"kind":"content"}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/optioncontextref\/set(strictposix:)"]}],"metadata":{"role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"set"},{"text":"(","kind":"text"},{"text":"strictPosix","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"},{"kind":"text","text":")"}],"symbolKind":"method","modules":[{"name":"GLib"}],"extendedModule":"GLib","roleHeading":"Instance Method","externalID":"s:4GLib21OptionContextProtocolPAAE3set11strictPosixySb_tF::SYNTHESIZED::s:4GLib16OptionContextRefV","title":"set(strictPosix:)"},"abstract":[{"text":"Sets strict POSIX mode.","type":"text"}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/OptionContextRef\/set(strictPosix:)","interfaceLanguage":"swift"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/OptionContextRef","doc:\/\/GLib\/documentation\/GLib\/OptionContextRef\/OptionContextProtocol-Implementations"]]},"references":{"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/OptionContextRef/set(strictPosix:)":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/OptionContextRef\/set(strictPosix:)","role":"symbol","url":"\/documentation\/glib\/optioncontextref\/set(strictposix:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"set"},{"kind":"text","text":"("},{"text":"strictPosix","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"text":")","kind":"text"}],"type":"topic","abstract":[{"text":"Sets strict POSIX mode.","type":"text"}],"title":"set(strictPosix:)","kind":"symbol"},"doc://GLib/documentation/GLib/OptionContextRef/OptionContextProtocol-Implementations":{"url":"\/documentation\/glib\/optioncontextref\/optioncontextprotocol-implementations","identifier":"doc:\/\/GLib\/documentation\/GLib\/OptionContextRef\/OptionContextProtocol-Implementations","abstract":[],"type":"topic","title":"OptionContextProtocol Implementations","role":"collectionGroup","kind":"article"},"doc://GLib/documentation/GLib/OptionContextRef":{"url":"\/documentation\/glib\/optioncontextref","identifier":"doc:\/\/GLib\/documentation\/GLib\/OptionContextRef","abstract":[{"type":"text","text":"A "},{"code":"GOptionContext","type":"codeVoice"},{"text":" struct defines which options","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"are accepted by the commandline option parser. The struct has only private"},{"text":" ","type":"text"},{"text":"fields and should not be directly accessed.","type":"text"}],"type":"topic","title":"OptionContextRef","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OptionContextRef","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"OptionContextRef"}]}}}