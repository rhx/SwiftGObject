{"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/OptionContextRef\/set(strictPosix:)","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"paths":["\/documentation\/glib\/optioncontextref\/set(strictposix:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/OptionContextRef","doc:\/\/GLib\/documentation\/GLib\/OptionContextRef\/OptionContextProtocol-Implementations"]]},"abstract":[{"type":"text","text":"Sets strict POSIX mode."}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"set","kind":"identifier"},{"text":"(","kind":"text"},{"text":"strictPosix","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":")","kind":"text"}]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"By default, this mode is disabled.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"In strict POSIX mode, the first non-argument parameter encountered","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(eg: filename) terminates argument processing.  Remaining arguments"},{"text":" ","type":"text"},{"text":"are treated as non-options and are not attempted to be parsed.","type":"text"}]},{"inlineContent":[{"text":"If strict POSIX mode is disabled then parsing is done in the GNU way","type":"text"},{"type":"text","text":" "},{"type":"text","text":"where option arguments can be freely mixed with non-options."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"As an example, consider “ls foo -l”.  With GNU style parsing, this"},{"type":"text","text":" "},{"type":"text","text":"will list “foo” in long mode.  In strict POSIX style, this will list"},{"text":" ","type":"text"},{"text":"the files named “foo” and “-l”.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"It may be useful to force strict POSIX mode when creating “verb","type":"text"},{"text":" ","type":"text"},{"text":"style” command line tools.  For example, the “gsettings” command line","type":"text"},{"type":"text","text":" "},{"type":"text","text":"tool supports the global option “–schemadir” as well as many"},{"text":" ","type":"text"},{"text":"subcommands (“get”, “set”, etc.) which each have their own set of","type":"text"},{"text":" ","type":"text"},{"text":"arguments.  Using strict POSIX mode will allow parsing the global","type":"text"},{"text":" ","type":"text"},{"text":"options up to the verb name while leaving the remaining options to be","type":"text"},{"text":" ","type":"text"},{"text":"parsed by the relevant subcommand (which can be determined by","type":"text"},{"type":"text","text":" "},{"type":"text","text":"examining the verb name, which should be present in argv[1] after"},{"type":"text","text":" "},{"type":"text","text":"parsing)."}],"type":"paragraph"}]}],"kind":"symbol","metadata":{"roleHeading":"Instance Method","title":"set(strictPosix:)","modules":[{"name":"GLib"}],"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"set"},{"kind":"text","text":"("},{"kind":"externalParam","text":"strictPosix"},{"kind":"text","text":": "},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"},{"text":")","kind":"text"}],"role":"symbol","extendedModule":"GLib","externalID":"s:4GLib21OptionContextProtocolPAAE3set11strictPosixySb_tF::SYNTHESIZED::s:4GLib16OptionContextRefV","symbolKind":"method"},"sections":[],"references":{"doc://GLib/documentation/GLib/OptionContextRef/set(strictPosix:)":{"url":"\/documentation\/glib\/optioncontextref\/set(strictposix:)","type":"topic","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"set","kind":"identifier"},{"text":"(","kind":"text"},{"text":"strictPosix","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"kind":"text","text":")"}],"abstract":[{"text":"Sets strict POSIX mode.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/OptionContextRef\/set(strictPosix:)","role":"symbol","title":"set(strictPosix:)"},"doc://GLib/documentation/GLib/OptionContextRef/OptionContextProtocol-Implementations":{"type":"topic","url":"\/documentation\/glib\/optioncontextref\/optioncontextprotocol-implementations","title":"OptionContextProtocol Implementations","identifier":"doc:\/\/GLib\/documentation\/GLib\/OptionContextRef\/OptionContextProtocol-Implementations","role":"collectionGroup","kind":"article","abstract":[]},"doc://GLib/documentation/GLib/OptionContextRef":{"fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"OptionContextRef","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"OptionContextRef","kind":"identifier"}],"type":"topic","title":"OptionContextRef","abstract":[{"type":"text","text":"A "},{"type":"codeVoice","code":"GOptionContext"},{"type":"text","text":" struct defines which options"},{"text":" ","type":"text"},{"type":"text","text":"are accepted by the commandline option parser. The struct has only private"},{"type":"text","text":" "},{"text":"fields and should not be directly accessed.","type":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/OptionContextRef","role":"symbol","url":"\/documentation\/glib\/optioncontextref"},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"}}}