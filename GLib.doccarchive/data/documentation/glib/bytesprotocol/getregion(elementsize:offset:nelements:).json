{"abstract":[{"text":"Gets a pointer to a region in ","type":"text"},{"code":"bytes","type":"codeVoice"},{"text":".","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/BytesProtocol"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/BytesProtocol\/getRegion(elementSize:offset:nElements:)"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"getRegion","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"elementSize"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"offset","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"nElements"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"gconstpointer","preciseIdentifier":"c:@T@gconstpointer","kind":"typeIdentifier"},{"kind":"text","text":"?"}],"platforms":["macOS"]}]},{"content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"The region starts at "},{"type":"codeVoice","code":"offset"},{"type":"text","text":" many bytes from the start of the data"},{"type":"text","text":" "},{"type":"text","text":"and contains "},{"type":"codeVoice","code":"nElements"},{"text":" many elements of ","type":"text"},{"type":"codeVoice","code":"elementSize"},{"type":"text","text":" size."}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"nElements"},{"type":"text","text":" may be zero, but "},{"type":"codeVoice","code":"elementSize"},{"type":"text","text":" must always be non-zero."},{"text":" ","type":"text"},{"text":"IDeally, ","type":"text"},{"type":"codeVoice","code":"elementSize"},{"type":"text","text":" is a static constant (eg: "},{"code":"sizeof","type":"codeVoice"},{"type":"text","text":" a struct)."}],"type":"paragraph"},{"inlineContent":[{"text":"This function does careful bounds checking (including checking for","type":"text"},{"type":"text","text":" "},{"type":"text","text":"arithmetic overflows) and returns a non-"},{"code":"NULL","type":"codeVoice"},{"text":" pointer if the","type":"text"},{"text":" ","type":"text"},{"text":"specified region lies entirely within the ","type":"text"},{"code":"bytes","type":"codeVoice"},{"text":". If the region is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"in some way out of range, or if an overflow has occurred, then "},{"type":"codeVoice","code":"NULL"},{"type":"text","text":" "},{"text":"is returned.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Note: it is possible to have a valid zero-size region. In this case,"},{"type":"text","text":" "},{"type":"text","text":"the returned pointer will be equal to the base pointer of the data of"},{"type":"text","text":" "},{"code":"bytes","type":"codeVoice"},{"type":"text","text":", plus "},{"type":"codeVoice","code":"offset"},{"text":".  This will be non-","type":"text"},{"code":"NULL","type":"codeVoice"},{"type":"text","text":" except for the case"},{"type":"text","text":" "},{"text":"where ","type":"text"},{"type":"codeVoice","code":"bytes"},{"type":"text","text":" itself was a zero-sized region.  Since it is unlikely"},{"text":" ","type":"text"},{"type":"text","text":"that you will be using this function to check for a zero-sized region"},{"text":" ","type":"text"},{"type":"text","text":"in a zero-sized "},{"code":"bytes","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"NULL"},{"text":" effectively always means ‘error’.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"sections":[],"kind":"symbol","schemaVersion":{"maj