{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/OptionContext","doc:\/\/GLib\/documentation\/GLib\/OptionContext\/OptionContextProtocol-Implementations"]]},"variants":[{"paths":["\/documentation\/glib\/optioncontext\/set(strictposix:)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","abstract":[{"text":"Sets strict POSIX mode.","type":"text"}],"schemaVersion":{"patch":0,"minor":3,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"set"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"strictPosix"},{"kind":"text","text":": "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"kind":"text","text":")"}]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"By default, this mode is disabled.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"In strict POSIX mode, the first non-argument parameter encountered","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(eg: filename) terminates argument processing.  Remaining arguments"},{"type":"text","text":" "},{"type":"text","text":"are treated as non-options and are not attempted to be parsed."}]},{"inlineContent":[{"type":"text","text":"If strict POSIX mode is disabled then parsing is done in the GNU way"},{"text":" ","type":"text"},{"text":"where option arguments can be freely mixed with non-options.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"As an example, consider “ls foo -l”.  With GNU style parsing, this"},{"type":"text","text":" "},{"type":"text","text":"will list “foo” in long mode.  In strict POSIX style, this will list"},{"type":"text","text":" "},{"type":"text","text":"the files named “foo” and “-l”."}]},{"inlineContent":[{"type":"text","text":"It may be useful to force strict POSIX mode when creating “verb"},{"type":"text","text":" "},{"text":"style” command line tools.  For example, the “gsettings” command line","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"tool supports the global option “–schemadir” as well as many"},{"text":" ","type":"text"},{"type":"text","text":"subcommands (“get”, “set”, etc.) which each have their own set of"},{"text":" ","type":"text"},{"text":"arguments.  Using strict POSIX mode will allow parsing the global","type":"text"},{"text":" ","type":"text"},{"text":"options up to the verb name while leaving the remaining options to be","type":"text"},{"type":"text","text":" "},{"text":"parsed by the relevant subcommand (which can be determined by","type":"text"},{"text":" ","type":"text"},{"text":"examining the verb name, which should be present in argv[1] after","type":"text"},{"type":"text","text":" "},{"type":"text","text":"parsing)."}],"type":"paragraph"}]}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/OptionContext\/set(strictPosix:)"},"metadata":{"symbolKind":"method","extendedModule":"GLib","title":"set(strictPosix:)","modules":[{"name":"GLib"}],"roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"set","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"strictPosix"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"},{"kind":"text","text":")"}],"externalID":"s:4GLib21OptionContextProtocolPAAE3set11strictPosixySb_tF::SYNTHESIZED::s:4GLib13OptionContextC","role":"symbol"},"references":{"doc://GLib/documentation/GLib/OptionContext/OptionContextProtocol-Implementations":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/OptionContext\/OptionContextProtocol-Implementations","title":"OptionContextProtocol Implementations","abstract":[],"type":"topic","role":"collectionGroup","kind":"article","url":"\/documentation\/glib\/optioncontext\/optioncontextprotocol-implementations"},"doc://GLib/documentation/GLib/OptionContext":{"url":"\/documentation\/glib\/optioncontext","navigatorTitle":[{"kind":"identifier","text":"OptionContext"}],"title":"OptionContext","identifier":"doc:\/\/GLib\/documentation\/GLib\/OptionContext","type":"topic","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"OptionContext","kind":"identifier"}],"role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"A "},{"code":"GOptionContext","type":"codeVoice"},{"text":" struct defines which options","type":"text"},{"type":"text","text":" "},{"type":"text","text":"are accepted by the commandline option parser. The struct has only private"},{"text":" ","type":"text"},{"type":"text","text":"fields and should not be directly accessed."}]},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/OptionContext/set(strictPosix:)":{"url":"\/documentation\/glib\/optioncontext\/set(strictposix:)","abstract":[{"type":"text","text":"Sets strict POSIX mode."}],"type":"topic","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"set","kind":"identifier"},{"kind":"text","text":"("},{"text":"strictPosix","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"text":")","kind":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/OptionContext\/set(strictPosix:)","kind":"symbol","role":"symbol","title":"set(strictPosix:)"}}}