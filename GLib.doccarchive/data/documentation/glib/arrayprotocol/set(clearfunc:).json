ent"},{"type":"text","text":" "},{"type":"text","text":"is destroyed. It is passed the pointer to the data element and"},{"type":"text","text":" "},{"type":"text","text":"should free any memory and resources allocated for it."}]},"doc://GLib/documentation/GLib/ArrayProtocol/set(clearFunc:)":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/ArrayProtocol\/set(clearFunc:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"set"},{"text":"(","kind":"text"},{"text":"clearFunc","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"GDestroyNotify","preciseIdentifier":"c:@T@GDestroyNotify","kind":"typeIdentifier"},{"kind":"text","text":"?)"}],"title":"set(clearFunc:)","url":"\/documentation\/glib\/arrayprotocol\/set(clearfunc:)","abstract":[{"text":"Sets a function to clear an element of ","type":"text"},{"type":"codeVoice","code":"array"},{"text":".","type":"text"}],"type":"topic","role":"symbol","kind":"symbol"},"doc://GLib/documentation/GLib/ArrayProtocol":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/ArrayProtocol","type":"topic","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ArrayProtocol"}],"kind":"symbol","title":"ArrayProtocol","role":"symbol","abstract":[{"text":"Contains the public fields of a ","type":"text"},{"type":"codeVoice","code":"GArray"},{"text":".","type":"text"}],"url":"\/documentation\/glib\/arrayprotocol","navigatorTitle":[{"text":"ArrayProtocol","kind":"identifier"}]}}}