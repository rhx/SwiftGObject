{"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/spawnasyncwithpipesandfds(workingdirectory:argv:envp:flags:childsetup:userdata:stdinfd:stdoutfd:stderrfd:sourcefds:targetfds:nfds:childpidout:stdinpipeout:stdoutpipeout:stderrpipeout:)"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/spawnAsyncWithPipesAndFds(workingDirectory:argv:envp:flags:childSetup:userData:stdinFd:stdoutFd:stderrFd:sourceFds:targetFds:nFds:childPidOut:stdinPipeOut:stdoutPipeOut:stderrPipeOut:)"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"metadata":{"title":"spawnAsyncWithPipesAndFds(workingDirectory:argv:envp:flags:childSetup:userData:stdinFd:stdoutFd:stderrFd:sourceFds:targetFds:nFds:childPidOut:stdinPipeOut:stdoutPipeOut:stderrPipeOut:)","role":"symbol","externalID":"s:4GLib25spawnAsyncWithPipesAndFds16workingDirectory4argv4envp5flags10childSetup8userData7stdinFd06stdoutR006stderrR006sourceG006targetG001nG00M6PidOut0q4PipeX00syX00tyX0SbSPys4Int8VGSg_SPyAVGSgAxA10SpawnFlagsVySvSgXCSgA_S3iSPys5Int32VGSgA4_SiSpyA2_GSgA6_A6_A6_tKF","symbolKind":"func","roleHeading":"Function","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"spawnAsyncWithPipesAndFds"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"workingDirectory"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"kind":"text","text":">?, "},{"text":"argv","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">?>!, ","kind":"text"},{"text":"envp","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier","text":"gchar"},{"text":">?>!, ","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib10SpawnFlagsV","text":"SpawnFlags"},{"kind":"text","text":", "},{"text":"childSetup","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@GSpawnChildSetupFunc","text":"GSpawnChildSetupFunc","kind":"typeIdentifier"},{"kind":"text","text":"?, "},{"text":"userData","kind":"externalParam"},{"kind":"text","text":": "},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:@T@gpointer"},{"text":"?, ","kind":"text"},{"text":"stdinFd","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"stdoutFd"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"stderrFd","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"sourceFds"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"gint","kind":"typeIdentifier","preciseIdentifier":"c:@T@gint"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"targetFds"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gint","kind":"typeIdentifier","text":"gint"},{"kind":"text","text":">!, "},{"text":"nFds","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"childPidOut","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sp","kind":"typeIdentifier","text":"UnsafeMutablePointer"},{"text":"<","kind":"text"},{"text":"GPid","kind":"typeIdentifier","preciseIdentifier":"c:@T@GPid"},{"text":">!, ","kind":"text"},{"text":"stdinPipeOut","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"text":"gint","kind":"typeIdentifier","preciseIdentifier":"c:@T@gint"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"stdoutPipeOut"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gint","kind":"typeIdentifier","text":"gint"},{"kind":"text","text":">!, "},{"text":"stderrPipeOut","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gint","text":"gint"},{"text":">!) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"modules":[{"name":"GLib"}]},"abstract":[{"text":"Executes a child program asynchronously (your program will not","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"block waiting for the child to exit)."}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"spawnAsyncWithPipesAndFds","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"workingDirectory"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">? = nil, "},{"kind":"externalParam","text":"argv"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"kind":"text","text":">?>!, "},{"text":"envp","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"text":">?>! = nil, ","kind":"text"},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/SpawnFlags","text":"SpawnFlags","kind":"typeIdentifier","preciseIdentifier":"s:4GLib10SpawnFlagsV"},{"text":", ","kind":"text"},{"text":"childSetup","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GSpawnChildSetupFunc","text":"GSpawnChildSetupFunc"},{"kind":"text","text":"? = nil, "},{"kind":"externalParam","text":"userData"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gpointer","text":"gpointer"},{"text":"? = nil, ","kind":"text"},{"text":"stdinFd","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"kind":"externalParam","text":"stdoutFd"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"stderrFd","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"sourceFds","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gint","preciseIdentifier":"c:@T@gint"},{"kind":"text","text":">! = nil, "},{"text":"targetFds","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gint","preciseIdentifier":"c:@T@gint"},{"kind":"text","text":">! = nil, "},{"kind":"externalParam","text":"nFds"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"text":"childPidOut","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"GPid","preciseIdentifier":"c:@T@GPid","kind":"typeIdentifier"},{"text":">! = nil, ","kind":"text"},{"kind":"externalParam","text":"stdinPipeOut"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gint","text":"gint"},{"kind":"text","text":">! = nil, "},{"text":"stdoutPipeOut","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"text":"<","kind":"text"},{"text":"gint","kind":"typeIdentifier","preciseIdentifier":"c:@T@gint"},{"text":">! = nil, ","kind":"text"},{"kind":"externalParam","text":"stderrPipeOut"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gint","text":"gint"},{"kind":"text","text":">! = nil) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The child program is specified by the only argument that must be"},{"type":"text","text":" "},{"text":"provided, ","type":"text"},{"code":"argv","type":"codeVoice"},{"type":"text","text":". "},{"code":"argv","type":"codeVoice"},{"type":"text","text":" should be a "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"-terminated array of strings,"},{"type":"text","text":" "},{"type":"text","text":"to be passed as the argument vector for the child. The first string"},{"text":" ","type":"text"},{"type":"text","text":"in "},{"code":"argv","type":"codeVoice"},{"type":"text","text":" is of course the name of the program to execute. By default,"},{"type":"text","text":" "},{"text":"the name of the program must be a full path. If ","type":"text"},{"code":"flags","type":"codeVoice"},{"type":"text","text":" contains the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"searchPath"},{"type":"text","text":" flag, the "},{"code":"PATH","type":"codeVoice"},{"text":" environment variable is used to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"search for the executable. If "},{"type":"codeVoice","code":"flags"},{"text":" contains the","type":"text"},{"type":"text","text":" "},{"code":"searchPathFromEnvp","type":"codeVoice"},{"type":"text","text":" flag, the "},{"code":"PATH","type":"codeVoice"},{"text":" variable from ","type":"text"},{"code":"envp","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"is used to search for the executable. If both the"},{"text":" ","type":"text"},{"code":"searchPath","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"searchPathFromEnvp"},{"type":"text","text":" flags are"},{"type":"text","text":" "},{"text":"set, the ","type":"text"},{"code":"PATH","type":"codeVoice"},{"type":"text","text":" variable from "},{"type":"codeVoice","code":"envp"},{"type":"text","text":" takes precedence over the"},{"text":" ","type":"text"},{"type":"text","text":"environment variable."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the program name is not a full path and "},{"type":"codeVoice","code":"searchPath"},{"type":"text","text":" flag"},{"text":" ","type":"text"},{"type":"text","text":"is not used, then the program will be run from the current directory"},{"type":"text","text":" "},{"type":"text","text":"(or "},{"type":"codeVoice","code":"workingDirectory"},{"type":"text","text":", if specified); this might be unexpected or even"},{"type":"text","text":" "},{"text":"dangerous in some cases when the current directory is world-writable.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On Windows, note that all the string or string vector arguments to"},{"text":" ","type":"text"},{"type":"text","text":"this function and the other "},{"type":"codeVoice","code":"g_spawn*()"},{"type":"text","text":" functions are in UTF-8, the"},{"type":"text","text":" "},{"text":"GLib file name encoding. Unicode characters that are not part of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the system codepage passed in these arguments will be correctly"},{"text":" ","type":"text"},{"text":"available in the spawned program only if it uses wide character API","type":"text"},{"type":"text","text":" "},{"text":"to retrieve its command line. For C programs built with Microsoft’s","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"tools it is enough to make the program have a "},{"type":"codeVoice","code":"wmain()"},{"type":"text","text":" instead of"},{"type":"text","text":" "},{"code":"main()","type":"codeVoice"},{"text":". ","type":"text"},{"type":"codeVoice","code":"wmain()"},{"text":" has a wide character argument vector as parameter.","type":"text"}]},{"inlineContent":[{"text":"At least currently, mingw doesn’t support ","type":"text"},{"code":"wmain()","type":"codeVoice"},{"type":"text","text":", so if you use"},{"type":"text","text":" "},{"type":"text","text":"mingw to develop the spawned program, it should call"},{"text":" ","type":"text"},{"code":"g_win32_get_command_line()","type":"codeVoice"},{"text":" to get arguments in UTF-8.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"On Windows the low-level child process creation API "},{"type":"codeVoice","code":"CreateProcess()"},{"text":" ","type":"text"},{"type":"text","text":"doesn’t use argument vectors, but a command line. The C runtime"},{"text":" ","type":"text"},{"text":"library’s ","type":"text"},{"code":"spawn*()","type":"codeVoice"},{"type":"text","text":" family of functions (which "},{"type":"codeVoice","code":"g_spawn_async_with_pipes()"},{"type":"text","text":" "},{"type":"text","text":"eventually calls) paste the argument vector elements together into"},{"text":" ","type":"text"},{"text":"a command line, and the C runtime startup code does a corresponding","type":"text"},{"type":"text","text":" "},{"type":"text","text":"reconstruction of an argument vector from the command line, to be"},{"text":" ","type":"text"},{"type":"text","text":"passed to "},{"code":"main()","type":"codeVoice"},{"type":"text","text":". Complications arise when you have argument vector"},{"text":" ","type":"text"},{"text":"elements that contain spaces or double quotes. The ","type":"text"},{"type":"codeVoice","code":"spawn*()"},{"type":"text","text":" functions"},{"type":"text","text":" "},{"type":"text","text":"don’t do any quoting or escaping, but on the other hand the startup"},{"text":" ","type":"text"},{"type":"text","text":"code does do unquoting and unescaping in order to enable receiving"},{"type":"text","text":" "},{"text":"arguments with embedded spaces or double quotes. To work around this","type":"text"},{"type":"text","text":" "},{"text":"asymmetry, ","type":"text"},{"type":"codeVoice","code":"g_spawn_async_with_pipes()"},{"type":"text","text":" will do quoting and escaping on"},{"type":"text","text":" "},{"type":"text","text":"argument vector elements that need it before calling the C runtime"},{"text":" ","type":"text"},{"type":"codeVoice","code":"spawn()"},{"type":"text","text":" function."}]},{"inlineContent":[{"type":"text","text":"The returned "},{"type":"codeVoice","code":"child_pid"},{"text":" on Windows is a handle to the child","type":"text"},{"type":"text","text":" "},{"type":"text","text":"process, not its identifier. Process handles and process"},{"type":"text","text":" "},{"text":"identifiers are different concepts on Windows.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"envp"},{"text":" is a ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":"-terminated array of strings, where each string"},{"type":"text","text":" "},{"type":"text","text":"has the form "},{"code":"KEY=VALUE","type":"codeVoice"},{"text":". This will become the child’s environment.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"If "},{"type":"codeVoice","code":"envp"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":", the child inherits its parent’s environment."}]},{"type":"paragraph","inlineContent":[{"code":"flags","type":"codeVoice"},{"type":"text","text":" should be the bitwise OR of any flags you want to affect the"},{"type":"text","text":" "},{"text":"function’s behaviour. The ","type":"text"},{"type":"codeVoice","code":"doNotReapChild"},{"text":" means that the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"child will not automatically be reaped; you must use a child watch"},{"type":"text","text":" "},{"text":"(","type":"text"},{"type":"codeVoice","code":"g_child_watch_add()"},{"text":") to be notified about the death of the child process,","type":"text"},{"type":"text","text":" "},{"text":"otherwise it will stay around as a zombie process until this process exits.","type":"text"},{"type":"text","text":" "},{"text":"Eventually you must call ","type":"text"},{"type":"codeVoice","code":"g_spawn_close_pid()"},{"text":" on the ","type":"text"},{"code":"child_pid","type":"codeVoice"},{"type":"text","text":", in order to"},{"type":"text","text":" "},{"type":"text","text":"free resources which may be associated with the child process. (On Unix,"},{"text":" ","type":"text"},{"text":"using a child watch is equivalent to calling ","type":"text"},{"type":"codeVoice","code":"waitpid()"},{"type":"text","text":" or handling"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"type":"codeVoice","code":"SIGCHLD"},{"type":"text","text":" signal manually. On Windows, calling "},{"type":"codeVoice","code":"g_spawn_close_pid()"},{"text":" ","type":"text"},{"type":"text","text":"is equivalent to calling "},{"code":"CloseHandle()","type":"codeVoice"},{"text":" on the process handle returned","type":"text"},{"text":" ","type":"text"},{"text":"in ","type":"text"},{"type":"codeVoice","code":"child_pid"},{"type":"text","text":"). See "},{"code":"g_child_watch_add()","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Open UNIX file descriptors marked as "},{"code":"FD_CLOEXEC","type":"codeVoice"},{"type":"text","text":" will be automatically"},{"type":"text","text":" "},{"type":"text","text":"closed in the child process. "},{"type":"codeVoice","code":"leaveDescriptorsOpen"},{"type":"text","text":" means that"},{"type":"text","text":" "},{"type":"text","text":"other open file descriptors will be inherited by the child; otherwise all"},{"text":" ","type":"text"},{"type":"text","text":"descriptors except stdin\/stdout\/stderr will be closed before calling "},{"type":"codeVoice","code":"exec()"},{"text":" ","type":"text"},{"type":"text","text":"in the child. "},{"code":"searchPath","type":"codeVoice"},{"type":"text","text":" means that "},{"code":"argv","type":"codeVoice"},{"text":"[0] need not be an","type":"text"},{"text":" ","type":"text"},{"text":"absolute path, it will be looked for in the ","type":"text"},{"type":"codeVoice","code":"PATH"},{"type":"text","text":" environment"},{"type":"text","text":" "},{"type":"text","text":"variable. "},{"type":"codeVoice","code":"searchPathFromEnvp"},{"type":"text","text":" means need not be an"},{"text":" ","type":"text"},{"text":"absolute path, it will be looked for in the ","type":"text"},{"code":"PATH","type":"codeVoice"},{"type":"text","text":" variable from"},{"type":"text","text":" "},{"code":"envp","type":"codeVoice"},{"type":"text","text":". If both "},{"type":"codeVoice","code":"searchPath"},{"type":"text","text":" and "},{"code":"searchPathFromEnvp","type":"codeVoice"},{"type":"text","text":" "},{"text":"are used, the value from ","type":"text"},{"type":"codeVoice","code":"envp"},{"type":"text","text":" takes precedence over the environment."}]},{"type":"paragraph","inlineContent":[{"code":"childInheritsStdin","type":"codeVoice"},{"type":"text","text":" means that the child will inherit the parent’s"},{"type":"text","text":" "},{"text":"standard input (by default, the child’s standard input is attached to","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"\/dev\/null"},{"type":"text","text":"). "},{"code":"stdinFromDevNull","type":"codeVoice"},{"type":"text","text":" explicitly imposes the default"},{"type":"text","text":" "},{"type":"text","text":"behavior. Both flags cannot be enabled at the same time and, in both cases,"},{"type":"text","text":" "},{"text":"the ","type":"text"},{"code":"stdinPipeOut","type":"codeVoice"},{"type":"text","text":" argument is ignored."}]},{"type":"paragraph","inlineContent":[{"code":"stdoutToDevNull","type":"codeVoice"},{"type":"text","text":" means that the child’s standard output"},{"text":" ","type":"text"},{"type":"text","text":"will be discarded (by default, it goes to the same location as the parent’s"},{"type":"text","text":" "},{"text":"standard output). ","type":"text"},{"type":"codeVoice","code":"childInheritsStdout"},{"text":" explicitly imposes the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"default behavior. Both flags cannot be enabled at the same time and, in"},{"type":"text","text":" "},{"type":"text","text":"both cases, the "},{"code":"stdoutPipeOut","type":"codeVoice"},{"type":"text","text":" argument is ignored."}]},{"type":"paragraph","inlineContent":[{"code":"stderrToDevNull","type":"codeVoice"},{"type":"text","text":" means that the child’s standard error"},{"text":" ","type":"text"},{"text":"will be discarded (by default, it goes to the same location as the parent’s","type":"text"},{"text":" ","type":"text"},{"text":"standard error). ","type":"text"},{"code":"childInheritsStderr","type":"codeVoice"},{"type":"text","text":" explicitly imposes the"},{"type":"text","text":" "},{"text":"default behavior. Both flags cannot be enabled at the same time and, in","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"both cases, the "},{"code":"stderrPipeOut","type":"codeVoice"},{"text":" argument is ignored.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is valid to pass the same FD in multiple parameters (e.g. you can pass"},{"type":"text","text":" "},{"type":"text","text":"a single FD for both "},{"code":"stdoutFd","type":"codeVoice"},{"type":"text","text":" and "},{"code":"stderrFd","type":"codeVoice"},{"type":"text","text":", and include it in"},{"text":" ","type":"text"},{"type":"codeVoice","code":"sourceFds"},{"text":" too).","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"sourceFds"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"targetFds"},{"text":" allow zero or more FDs from this process to be","type":"text"},{"text":" ","type":"text"},{"text":"remapped to different FDs in the spawned process. If ","type":"text"},{"code":"nFds","type":"codeVoice"},{"type":"text","text":" is greater than"},{"type":"text","text":" "},{"type":"text","text":"zero, "},{"type":"codeVoice","code":"sourceFds"},{"text":" and ","type":"text"},{"code":"targetFds","type":"codeVoice"},{"type":"text","text":" must both be non-"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" and the same length."},{"text":" ","type":"text"},{"text":"Each FD in ","type":"text"},{"type":"codeVoice","code":"sourceFds"},{"type":"text","text":" is remapped to the FD number at the same index in"},{"type":"text","text":" "},{"code":"targetFds","type":"codeVoice"},{"type":"text","text":". The source and target FD may be equal to simply propagate an FD"},{"type":"text","text":" "},{"type":"text","text":"to the spawned process. FD remappings are processed after standard FDs, so"},{"type":"text","text":" "},{"text":"any target FDs which equal ","type":"text"},{"code":"stdinFd","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"stdoutFd"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"stderrFd"},{"type":"text","text":" will overwrite"},{"type":"text","text":" "},{"type":"text","text":"them in the spawned process."}]},{"inlineContent":[{"code":"sourceFds","type":"codeVoice"},{"text":" is supported on Windows since 2.72.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"code":"fileAndArgvZero","type":"codeVoice"},{"text":" means that the first element of ","type":"text"},{"type":"codeVoice","code":"argv"},{"text":" is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the file to execute, while the remaining elements are the actual"},{"type":"text","text":" "},{"text":"argument vector to pass to the file. Normally ","type":"text"},{"code":"g_spawn_async_with_pipes()","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"uses "},{"code":"argv","type":"codeVoice"},{"text":"[0] as the file to execute, and passes all of ","type":"text"},{"code":"argv","type":"codeVoice"},{"text":" to the child.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"childSetup"},{"type":"text","text":" and "},{"code":"userData","type":"codeVoice"},{"text":" are a function and user data. On POSIX","type":"text"},{"text":" ","type":"text"},{"text":"platforms, the function is called in the child after GLib has","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"performed all the setup it plans to perform (including creating"},{"type":"text","text":" "},{"type":"text","text":"pipes, closing file descriptors, etc.) but before calling "},{"type":"codeVoice","code":"exec()"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"That is, "},{"type":"codeVoice","code":"childSetup"},{"type":"text","text":" is called just before calling "},{"code":"exec()","type":"codeVoice"},{"text":" in the","type":"text"},{"text":" ","type":"text"},{"text":"child. Obviously actions taken in this function will only affect","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the child, not the parent."}]},{"type":"paragraph","inlineContent":[{"text":"On Windows, there is no separate ","type":"text"},{"type":"codeVoice","code":"fork()"},{"type":"text","text":" and "},{"code":"exec()","type":"codeVoice"},{"type":"text","text":" functionality."},{"text":" ","type":"text"},{"text":"Child processes are created and run with a single API call,","type":"text"},{"text":" ","type":"text"},{"code":"CreateProcess()","type":"codeVoice"},{"type":"text","text":". There is no sensible thing "},{"code":"childSetup","type":"codeVoice"},{"type":"text","text":" "},{"text":"could be used for on Windows so it is ignored and not called.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If non-"},{"type":"codeVoice","code":"nil"},{"type":"text","text":", "},{"code":"child_pid","type":"codeVoice"},{"text":" will on Unix be filled with the child’s","type":"text"},{"text":" ","type":"text"},{"text":"process ID. You can use the process ID to send signals to the child,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"or to use "},{"type":"codeVoice","code":"g_child_watch_add()"},{"text":" (or ","type":"text"},{"code":"waitpid()","type":"codeVoice"},{"type":"text","text":") if you specified the"},{"type":"text","text":" "},{"type":"codeVoice","code":"doNotReapChild"},{"type":"text","text":" flag. On Windows, "},{"type":"codeVoice","code":"child_pid"},{"text":" will be","type":"text"},{"text":" ","type":"text"},{"text":"filled with a handle to the child process only if you specified the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"doNotReapChild"},{"type":"text","text":" flag. You can then access the child"},{"text":" ","type":"text"},{"type":"text","text":"process using the Win32 API, for example wait for its termination"},{"text":" ","type":"text"},{"text":"with the ","type":"text"},{"code":"WaitFor*()","type":"codeVoice"},{"text":" functions, or examine its exit code with","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"GetExitCodeProcess()"},{"type":"text","text":". You should close the handle with "},{"code":"CloseHandle()","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"or "},{"code":"g_spawn_close_pid()","type":"codeVoice"},{"text":" when you no longer need it.","type":"text"}]},{"inlineContent":[{"type":"text","text":"If non-"},{"type":"codeVoice","code":"nil"},{"type":"text","text":", the "},{"code":"stdinPipeOut","type":"codeVoice"},{"type":"text","text":", "},{"code":"stdoutPipeOut","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"stderrPipeOut"},{"type":"text","text":" "},{"type":"text","text":"locations will be filled with file descriptors for writing to the child’s"},{"text":" ","type":"text"},{"type":"text","text":"standard input or reading from its standard output or standard error."},{"text":" ","type":"text"},{"text":"The caller of ","type":"text"},{"type":"codeVoice","code":"g_spawn_async_with_pipes()"},{"type":"text","text":" must close these file descriptors"},{"type":"text","text":" "},{"text":"when they are no longer in use. If these parameters are ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", the"},{"type":"text","text":" "},{"type":"text","text":"corresponding pipe won’t be created."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"stdinPipeOut"},{"type":"text","text":" is "},{"code":"nil","type":"codeVoice"},{"type":"text","text":", the child’s standard input is attached to"},{"type":"text","text":" "},{"type":"codeVoice","code":"\/dev\/null"},{"text":" unless ","type":"text"},{"type":"codeVoice","code":"childInheritsStdin"},{"type":"text","text":" is set."}]},{"inlineContent":[{"text":"If ","type":"text"},{"code":"stderrPipeOut","type":"codeVoice"},{"type":"text","text":" is NULL, the child’s standard error goes to the same"},{"type":"text","text":" "},{"type":"text","text":"location as the parent’s standard error unless "},{"code":"stderrToDevNull","type":"codeVoice"},{"type":"text","text":" "},{"text":"is set.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"stdoutPipeOut"},{"type":"text","text":" is NULL, the child’s standard output goes to the same"},{"text":" ","type":"text"},{"type":"text","text":"location as the parent’s standard output unless "},{"code":"stdoutToDevNull","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"is set."}],"type":"paragraph"},{"inlineContent":[{"code":"error","type":"codeVoice"},{"type":"text","text":" can be "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" to ignore errors, or non-"},{"code":"nil","type":"codeVoice"},{"text":" to report errors.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"If an error is set, the function returns "},{"type":"codeVoice","code":"false"},{"text":". Errors are reported","type":"text"},{"type":"text","text":" "},{"text":"even if they occur in the child (for example if the executable in","type":"text"},{"text":" ","type":"text"},{"text":"``argv","type":"text"},{"type":"codeVoice","code":"[0]"},{"type":"text","text":" is not found). Typically the `message` field of returned"},{"text":" ","type":"text"},{"text":"errors should be displayed to users. Possible errors are those from","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the `G_SPAWN_ERROR` domain."}],"type":"paragraph"},{"inlineContent":[{"text":"If an error occurs, ","type":"text"},{"code":"child_pid","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"stdinPipeOut"},{"type":"text","text":", "},{"code":"stdoutPipeOut","type":"codeVoice"},{"type":"text","text":","},{"text":" ","type":"text"},{"text":"and ","type":"text"},{"type":"codeVoice","code":"stderrPipeOut"},{"text":" will not be filled with valid values.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"child_pid"},{"text":" is not ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" and an error does not occur then the returned"},{"type":"text","text":" "},{"text":"process reference must be closed using ","type":"text"},{"type":"codeVoice","code":"g_spawn_close_pid()"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"On modern UNIX platforms, GLib can use an efficient process launching"},{"type":"text","text":" "},{"type":"text","text":"codepath driven internally by "},{"type":"codeVoice","code":"posix_spawn()"},{"type":"text","text":". This has the advantage of"},{"type":"text","text":" "},{"type":"text","text":"avoiding the fork-time performance costs of cloning the parent process"},{"text":" ","type":"text"},{"text":"address space, and avoiding associated memory overcommit checks that are","type":"text"},{"text":" ","type":"text"},{"text":"not relevant in the context of immediately executing a distinct process.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This optimized codepath will be used provided that the following conditions"},{"text":" ","type":"text"},{"text":"are met:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"code":"doNotReapChild","type":"codeVoice"},{"text":" is set","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"leaveDescriptorsOpen"},{"type":"text","text":" is set"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"searchPathFromEnvp","type":"codeVoice"},{"text":" is not set","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"workingDirectory"},{"text":" is ","type":"text"},{"code":"nil","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"childSetup"},{"type":"text","text":" is "},{"type":"codeVoice","code":"nil"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The program is of a recognised binary format, or has a shebang."},{"type":"text","text":" "},{"type":"text","text":"Otherwise, GLib will have to execute the program through the"},{"type":"text","text":" "},{"text":"shell, which is not done using the optimized codepath.","type":"text"}]}]}],"type":"orderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you are writing a GTK application, and the program you are spawning is a"},{"type":"text","text":" "},{"text":"graphical application too, then to ensure that the spawned program opens its","type":"text"},{"type":"text","text":" "},{"text":"windows on the right screen, you may want to use ","type":"text"},{"type":"codeVoice","code":"GdkAppLaunchContext"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"GAppLaunchContext","type":"codeVoice"},{"type":"text","text":", or set the "},{"type":"codeVoice","code":"DISPLAY"},{"text":" environment variable.","type":"text"}]}]}],"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/spawnAsyncWithPipesAndFds(workingDirectory:argv:envp:flags:childSetup:userData:stdinFd:stdoutFd:stderrFd:sourceFds:targetFds:nFds:childPidOut:stdinPipeOut:stdoutPipeOut:stderrPipeOut:)":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/spawnAsyncWithPipesAndFds(workingDirectory:argv:envp:flags:childSetup:userData:stdinFd:stdoutFd:stderrFd:sourceFds:targetFds:nFds:childPidOut:stdinPipeOut:stdoutPipeOut:stderrPipeOut:)","title":"spawnAsyncWithPipesAndFds(workingDirectory:argv:envp:flags:childSetup:userData:stdinFd:stdoutFd:stderrFd:sourceFds:targetFds:nFds:childPidOut:stdinPipeOut:stdoutPipeOut:stderrPipeOut:)","url":"\/documentation\/glib\/spawnasyncwithpipesandfds(workingdirectory:argv:envp:flags:childsetup:userdata:stdinfd:stdoutfd:stderrfd:sourcefds:targetfds:nfds:childpidout:stdinpipeout:stdoutpipeout:stderrpipeout:)","abstract":[{"type":"text","text":"Executes a child program asynchronously (your program will not"},{"text":" ","type":"text"},{"type":"text","text":"block waiting for the child to exit)."}],"role":"symbol","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"spawnAsyncWithPipesAndFds"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"workingDirectory"},{"kind":"text","text":": "},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"kind":"ty