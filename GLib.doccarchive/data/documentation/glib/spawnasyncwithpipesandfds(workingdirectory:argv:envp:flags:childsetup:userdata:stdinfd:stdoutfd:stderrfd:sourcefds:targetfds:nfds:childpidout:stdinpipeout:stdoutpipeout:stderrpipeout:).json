{"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/spawnAsyncWithPipesAndFds(workingDirectory:argv:envp:flags:childSetup:userData:stdinFd:stdoutFd:stderrFd:sourceFds:targetFds:nFds:childPidOut:stdinPipeOut:stdoutPipeOut:stderrPipeOut:)","interfaceLanguage":"swift"},"metadata":{"symbolKind":"func","roleHeading":"Function","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"spawnAsyncWithPipesAndFds"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"workingDirectory"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">?, ","kind":"text"},{"kind":"externalParam","text":"argv"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">?>!, ","kind":"text"},{"kind":"externalParam","text":"envp"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"gchar","preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier"},{"text":">?>!, ","kind":"text"},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:4GLib10SpawnFlagsV","kind":"typeIdentifier","text":"SpawnFlags"},{"kind":"text","text":", "},{"text":"childSetup","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"GSpawnChildSetupFunc","preciseIdentifier":"c:@T@GSpawnChildSetupFunc"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"userData"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"kind":"text","text":"?, "},{"text":"stdinFd","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"stdoutFd"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":", "},{"kind":"externalParam","text":"stderrFd"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"text":"sourceFds","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"gint","preciseIdentifier":"c:@T@gint"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"targetFds"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gint","text":"gint","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"text":"nFds","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"text":"childPidOut","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"GPid","preciseIdentifier":"c:@T@GPid"},{"text":">!, ","kind":"text"},{"text":"stdinPipeOut","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"text":"gint","kind":"typeIdentifier","preciseIdentifier":"c:@T@gint"},{"kind":"text","text":">!, "},{"text":"stdoutPipeOut","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sp","kind":"typeIdentifier","text":"UnsafeMutablePointer"},{"text":"<","kind":"text"},{"text":"gint","kind":"typeIdentifier","preciseIdentifier":"c:@T@gint"},{"text":">!, ","kind":"text"},{"text":"stderrPipeOut","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gint","text":"gint"},{"text":">!) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"externalID":"s:4GLib25spawnAsyncWithPipesAndFds16workingDirectory4argv4envp5flags10childSetup8userData7stdinFd06stdoutR006stderrR006sourceG006targetG001nG00M6PidOut0q4PipeX00syX00tyX0SbSPys4Int8VGSg_SPyAVGSgAxA10SpawnFlagsVySvSgXCSgA_S3iSPys5Int32VGSgA4_SiSpyA2_GSgA6_A6_A6_tKF","modules":[{"name":"GLib"}],"role":"symbol","title":"spawnAsyncWithPipesAndFds(workingDirectory:argv:envp:flags:childSetup:userData:stdinFd:stdoutFd:stderrFd:sourceFds:targetFds:nFds:childPidOut:stdinPipeOut:stdoutPipeOut:stderrPipeOut:)"},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"spawnAsyncWithPipesAndFds"},{"text":"(","kind":"text"},{"text":"workingDirectory","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"text":">? = nil, ","kind":"text"},{"text":"argv","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"kind":"text","text":">?>!, "},{"kind":"externalParam","text":"envp"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">?>! = nil, "},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"preciseIdentifier":"s:4GLib10SpawnFlagsV","text":"SpawnFlags","kind":"typeIdentifier","identifier":"doc:\/\/GLib\/documentation\/GLib\/SpawnFlags"},{"kind":"text","text":", "},{"kind":"externalParam","text":"childSetup"},{"kind":"text","text":": "},{"text":"GSpawnChildSetupFunc","kind":"typeIdentifier","preciseIdentifier":"c:@T@GSpawnChildSetupFunc"},{"kind":"text","text":"? = nil, "},{"kind":"externalParam","text":"userData"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"kind":"text","text":"? = nil, "},{"text":"stdinFd","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":", "},{"text":"stdoutFd","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"stderrFd","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"text":"sourceFds","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gint","text":"gint","kind":"typeIdentifier"},{"text":">! = nil, ","kind":"text"},{"text":"targetFds","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"gint","preciseIdentifier":"c:@T@gint","kind":"typeIdentifier"},{"text":">! = nil, ","kind":"text"},{"kind":"externalParam","text":"nFds"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"childPidOut"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"GPid","preciseIdentifier":"c:@T@GPid","kind":"typeIdentifier"},{"kind":"text","text":">! = nil, "},{"text":"stdinPipeOut","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gint","text":"gint","kind":"typeIdentifier"},{"kind":"text","text":">! = nil, "},{"text":"stdoutPipeOut","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sp","kind":"typeIdentifier","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"text":"gint","kind":"typeIdentifier","preciseIdentifier":"c:@T@gint"},{"kind":"text","text":">! = nil, "},{"kind":"externalParam","text":"stderrPipeOut"},{"kind":"text","text":": "},{"text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"gint","preciseIdentifier":"c:@T@gint"},{"kind":"text","text":">! = nil) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"text":"The child program is specified by the only argument that must be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"provided, "},{"code":"argv","type":"codeVoice"},{"type":"text","text":". "},{"code":"argv","type":"codeVoice"},{"type":"text","text":" should be a "},{"code":"nil","type":"codeVoice"},{"text":"-terminated array of strings,","type":"text"},{"type":"text","text":" "},{"text":"to be passed as the argument vector for the child. The first string","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"in "},{"type":"codeVoice","code":"argv"},{"text":" is of course the name of the program to execute. By default,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the name of the program must be a full path. If "},{"code":"flags","type":"codeVoice"},{"text":" contains the","type":"text"},{"text":" ","type":"text"},{"code":"searchPath","type":"codeVoice"},{"type":"text","text":" flag, the "},{"type":"codeVoice","code":"PATH"},{"type":"text","text":" environment variable is used to"},{"type":"text","text":" "},{"text":"search for the executable. If ","type":"text"},{"type":"codeVoice","code":"flags"},{"type":"text","text":" contains the"},{"type":"text","text":" "},{"code":"searchPathFromEnvp","type":"codeVoice"},{"type":"text","text":" flag, the "},{"type":"codeVoice","code":"PATH"},{"type":"text","text":" variable from "},{"code":"envp","type":"codeVoice"},{"text":" ","type":"text"},{"text":"is used to search for the executable. If both the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"searchPath"},{"type":"text","text":" and "},{"type":"codeVoice","code":"searchPathFromEnvp"},{"type":"text","text":" flags are"},{"type":"text","text":" "},{"text":"set, the ","type":"text"},{"code":"PATH","type":"codeVoice"},{"type":"text","text":" variable from "},{"type":"codeVoice","code":"envp"},{"text":" takes precedence over the","type":"text"},{"type":"text","text":" "},{"text":"environment variable.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If the program name is not a full path and ","type":"text"},{"code":"searchPath","type":"codeVoice"},{"text":" flag","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is not used, then the program will be run from the current directory"},{"type":"text","text":" "},{"type":"text","text":"(or "},{"type":"codeVoice","code":"workingDirectory"},{"type":"text","text":", if specified); this might be unexpected or even"},{"type":"text","text":" "},{"text":"dangerous in some cases when the current directory is world-writable.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"On Windows, note that all the string or string vector arguments to"},{"text":" ","type":"text"},{"text":"this function and the other ","type":"text"},{"code":"g_spawn*()","type":"codeVoice"},{"type":"text","text":" functions are in UTF-8, the"},{"text":" ","type":"text"},{"text":"GLib file name encoding. Unicode characters that are not part of","type":"text"},{"text":" ","type":"text"},{"text":"the system codepage passed in these arguments will be correctly","type":"text"},{"type":"text","text":" "},{"type":"text","text":"available in the spawned program only if it uses wide character API"},{"text":" ","type":"text"},{"type":"text","text":"to retrieve its command line. For C programs built with Microsoft’s"},{"type":"text","text":" "},{"type":"text","text":"tools it is enough to make the program have a "},{"code":"wmain()","type":"codeVoice"},{"text":" instead of","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"main()"},{"type":"text","text":". "},{"code":"wmain()","type":"codeVoice"},{"text":" has a wide character argument vector as parameter.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"At least currently, mingw doesn’t support "},{"type":"codeVoice","code":"wmain()"},{"type":"text","text":", so if you use"},{"text":" ","type":"text"},{"text":"mingw to develop the spawned program, it should call","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_win32_get_command_line()"},{"text":" to get arguments in UTF-8.","type":"text"}]},{"inlineContent":[{"type":"text","text":"On Windows the low-level child process creation API "},{"type":"codeVoice","code":"CreateProcess()"},{"type":"text","text":" "},{"text":"doesn’t use argument vectors, but a command line. The C runtime","type":"text"},{"type":"text","text":" "},{"type":"text","text":"library’s "},{"code":"spawn*()","type":"codeVoice"},{"type":"text","text":" family of functions (which "},{"code":"g_spawn_async_with_pipes()","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"eventually calls) paste the argument vector elements together into"},{"text":" ","type":"text"},{"type":"text","text":"a command line, and the C runtime startup code does a corresponding"},{"type":"text","text":" "},{"type":"text","text":"reconstruction of an argument vector from the command line, to be"},{"type":"text","text":" "},{"type":"text","text":"passed to "},{"type":"codeVoice","code":"main()"},{"text":". Complications arise when you have argument vector","type":"text"},{"type":"text","text":" "},{"type":"text","text":"elements that contain spaces or double quotes. The "},{"type":"codeVoice","code":"spawn*()"},{"text":" functions","type":"text"},{"text":" ","type":"text"},{"text":"don’t do any quoting or escaping, but on the other hand the startup","type":"text"},{"type":"text","text":" "},{"type":"text","text":"code does do unquoting and unescaping in order to enable receiving"},{"type":"text","text":" "},{"text":"arguments with embedded spaces or double quotes. To work around this","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"asymmetry, "},{"code":"g_spawn_async_with_pipes()","type":"codeVoice"},{"type":"text","text":" will do quoting and escaping on"},{"type":"text","text":" "},{"type":"text","text":"argument vector elements that need it before calling the C runtime"},{"type":"text","text":" "},{"type":"codeVoice","code":"spawn()"},{"type":"text","text":" function."}],"type":"paragraph"},{"inlineContent":[{"text":"The returned ","type":"text"},{"type":"codeVoice","code":"child_pid"},{"type":"text","text":" on Windows is a handle to the child"},{"text":" ","type":"text"},{"text":"process, not its identifier. Process handles and process","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"identifiers are different concepts on Windows."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"code":"envp","type":"codeVoice"},{"text":" is a ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":"-terminated array of strings, where each string"},{"type":"text","text":" "},{"type":"text","text":"has the form "},{"type":"codeVoice","code":"KEY=VALUE"},{"type":"text","text":". This will become the child’s environment."},{"type":"text","text":" "},{"text":"If ","type":"text"},{"type":"codeVoice","code":"envp"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":", the child inherits its parent’s environment.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"flags"},{"type":"text","text":" should be the bitwise OR of any flags you want to affect the"},{"type":"text","text":" "},{"type":"text","text":"function’s behaviour. The "},{"code":"doNotReapChild","type":"codeVoice"},{"text":" means that the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"child will not automatically be reaped; you must use a child watch"},{"type":"text","text":" "},{"type":"text","text":"("},{"type":"codeVoice","code":"g_child_watch_add()"},{"text":") to be notified about the death of the child process,","type":"text"},{"text":" ","type":"text"},{"text":"otherwise it will stay around as a zombie process until this process exits.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Eventually you must call "},{"type":"codeVoice","code":"g_spawn_close_pid()"},{"type":"text","text":" on the "},{"type":"codeVoice","code":"child_pid"},{"text":", in order to","type":"text"},{"text":" ","type":"text"},{"text":"free resources which may be associated with the child process. (On Unix,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"using a child watch is equivalent to calling "},{"code":"waitpid()","type":"codeVoice"},{"type":"text","text":" or handling"},{"text":" ","type":"text"},{"type":"text","text":"the "},{"code":"SIGCHLD","type":"codeVoice"},{"type":"text","text":" signal manually. On Windows, calling "},{"code":"g_spawn_close_pid()","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"is equivalent to calling "},{"code":"CloseHandle()","type":"codeVoice"},{"text":" on the process handle returned","type":"text"},{"type":"text","text":" "},{"text":"in ","type":"text"},{"code":"child_pid","type":"codeVoice"},{"text":"). See ","type":"text"},{"type":"codeVoice","code":"g_child_watch_add()"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"Open UNIX file descriptors marked as ","type":"text"},{"code":"FD_CLOEXEC","type":"codeVoice"},{"type":"text","text":" will be automatically"},{"type":"text","text":" "},{"type":"text","text":"closed in the child process. "},{"code":"leaveDescriptorsOpen","type":"codeVoice"},{"text":" means that","type":"text"},{"type":"text","text":" "},{"text":"other open file descriptors will be inherited by the child; otherwise all","type":"text"},{"type":"text","text":" "},{"type":"text","text":"descriptors except stdin\/stdout\/stderr will be closed before calling "},{"type":"codeVoice","code":"exec()"},{"text":" ","type":"text"},{"text":"in the child. ","type":"text"},{"type":"codeVoice","code":"searchPath"},{"text":" means that ","type":"text"},{"code":"argv","type":"codeVoice"},{"type":"text","text":"[0] need not be an"},{"type":"text","text":" "},{"text":"absolute path, it will be looked for in the ","type":"text"},{"type":"codeVoice","code":"PATH"},{"type":"text","text":" environment"},{"type":"text","text":" "},{"type":"text","text":"variable. "},{"type":"codeVoice","code":"searchPathFromEnvp"},{"text":" means need not be an","type":"text"},{"type":"text","text":" "},{"text":"absolute path, it will be looked for in the ","type":"text"},{"type":"codeVoice","code":"PATH"},{"text":" variable from","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"envp"},{"type":"text","text":". If both "},{"type":"codeVoice","code":"searchPath"},{"type":"text","text":" and "},{"code":"searchPathFromEnvp","type":"codeVoice"},{"type":"text","text":" "},{"text":"are used, the value from ","type":"text"},{"type":"codeVoice","code":"envp"},{"type":"text","text":" takes precedence over the environment."}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"childInheritsStdin"},{"text":" means that the child will inherit the parent’s","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"standard input (by default, the child’s standard input is attached to"},{"text":" ","type":"text"},{"type":"codeVoice","code":"\/dev\/null"},{"type":"text","text":"). "},{"code":"stdinFromDevNull","type":"codeVoice"},{"text":" explicitly imposes the default","type":"text"},{"type":"text","text":" "},{"type":"text","text":"behavior. Both flags cannot be enabled at the same time and, in both cases,"},{"type":"text","text":" "},{"type":"text","text":"the "},{"type":"codeVoice","code":"stdinPipeOut"},{"text":" argument is ignored.","type":"text"}]},{"type":"paragraph","inlineContent":[{"code":"stdoutToDevNull","type":"codeVoice"},{"text":" means that the child’s standard output","type":"text"},{"type":"text","text":" "},{"text":"will be discarded (by default, it goes to the same location as the parent’s","type":"text"},{"type":"text","text":" "},{"type":"text","text":"standard output). "},{"code":"childInheritsStdout","type":"codeVoice"},{"text":" explicitly imposes the","type":"text"},{"type":"text","text":" "},{"text":"default behavior. Both flags cannot be enabled at the same time and, in","type":"text"},{"text":" ","type":"text"},{"text":"both cases, the ","type":"text"},{"code":"stdoutPipeOut","type":"codeVoice"},{"type":"text","text":" argument is ignored."}]},{"inlineContent":[{"type":"codeVoice","code":"stderrToDevNull"},{"type":"text","text":" means that the child’s standard error"},{"text":" ","type":"text"},{"type":"text","text":"will be discarded (by default, it goes to the same location as the parent’s"},{"type":"text","text":" "},{"type":"text","text":"standard error). "},{"type":"codeVoice","code":"childInheritsStderr"},{"text":" explicitly imposes the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"default behavior. Both flags cannot be enabled at the same time and, in"},{"type":"text","text":" "},{"text":"both cases, the ","type":"text"},{"type":"codeVoice","code":"stderrPipeOut"},{"type":"text","text":" argument is ignored."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"It is valid to pass the same FD in multiple parameters (e.g. you can pass","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a single FD for both "},{"type":"codeVoice","code":"stdoutFd"},{"text":" and ","type":"text"},{"code":"stderrFd","type":"codeVoice"},{"type":"text","text":", and include it in"},{"text":" ","type":"text"},{"code":"sourceFds","type":"codeVoice"},{"text":" too).","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"sourceFds"},{"type":"text","text":" and "},{"code":"targetFds","type":"codeVoice"},{"text":" allow zero or more FDs from this process to be","type":"text"},{"text":" ","type":"text"},{"text":"remapped to different FDs in the spawned process. If ","type":"text"},{"type":"codeVoice","code":"nFds"},{"type":"text","text":" is greater than"},{"type":"text","text":" "},{"type":"text","text":"zero, "},{"type":"codeVoice","code":"sourceFds"},{"type":"text","text":" and "},{"type":"codeVoice","code":"targetFds"},{"text":" must both be non-","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" and the same length.","type":"text"},{"type":"text","text":" "},{"text":"Each FD in ","type":"text"},{"code":"sourceFds","type":"codeVoice"},{"text":" is remapped to the FD number at the same index in","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"targetFds"},{"type":"text","text":". The source and target FD may be equal to simply propagate an FD"},{"text":" ","type":"text"},{"type":"text","text":"to the spawned process. FD remappings are processed after standard FDs, so"},{"type":"text","text":" "},{"text":"any target FDs which equal ","type":"text"},{"type":"codeVoice","code":"stdinFd"},{"type":"text","text":", "},{"code":"stdoutFd","type":"codeVoice"},{"type":"text","text":" or "},{"type":"codeVoice","code":"stderrFd"},{"text":" will overwrite","type":"text"},{"text":" ","type":"text"},{"text":"them in the spawned process.","type":"text"}]},{"type":"paragraph","inlineContent":[{"code":"sourceFds","type":"codeVoice"},{"type":"text","text":" is supported on Windows since 2.72."}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"fileAndArgvZero"},{"text":" means that the first element of ","type":"text"},{"code":"argv","type":"codeVoice"},{"type":"text","text":" is"},{"text":" ","type":"text"},{"type":"text","text":"the file to execute, while the remaining elements are the actual"},{"type":"text","text":" "},{"type":"text","text":"argument vector to pass to the file. Normally "},{"code":"g_spawn_async_with_pipes()","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"uses "},{"type":"codeVoice","code":"argv"},{"text":"[0] as the file to execute, and passes all of ","type":"text"},{"type":"codeVoice","code":"argv"},{"text":" to the child.","type":"text"}]},{"inlineContent":[{"code":"childSetup","type":"codeVoice"},{"type":"text","text":" and "},{"code":"userData","type":"codeVoice"},{"text":" are a function and user data. On POSIX","type":"text"},{"text":" ","type":"text"},{"text":"platforms, the function is called in the child after GLib has","type":"text"},{"type":"text","text":" "},{"type":"text","text":"performed all the setup it plans to perform (including creating"},{"text":" ","type":"text"},{"text":"pipes, closing file descriptors, etc.) but before calling ","type":"text"},{"code":"exec()","type":"codeVoice"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"That is, "},{"type":"codeVoice","code":"childSetup"},{"type":"text","text":" is called just before calling "},{"type":"codeVoice","code":"exec()"},{"type":"text","text":" in the"},{"type":"text","text":" "},{"type":"text","text":"child. Obviously actions taken in this function will only affect"},{"text":" ","type":"text"},{"text":"the child, not the parent.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"On Windows, there is no separate ","type":"text"},{"type":"codeVoice","code":"fork()"},{"type":"text","text":" and "},{"type":"codeVoice","code":"exec()"},{"text":" functionality.","type":"text"},{"type":"text","text":" "},{"text":"Child processes are created and run with a single API call,","type":"text"},{"text":" ","type":"text"},{"code":"CreateProcess()","type":"codeVoice"},{"type":"text","text":". There is no sensible thing "},{"code":"childSetup","type":"codeVoice"},{"type":"text","text":" "},{"text":"could be used for on Windows so it is ignored and not called.","type":"text"}]},{"inlineContent":[{"type":"text","text":"If non-"},{"type":"codeVoice","code":"nil"},{"text":", ","type":"text"},{"code":"child_pid","type":"codeVoice"},{"type":"text","text":" will on Unix be filled with the child’s"},{"text":" ","type":"text"},{"type":"text","text":"process ID. You can use the process ID to send signals to the child,"},{"type":"text","text":" "},{"text":"or to use ","type":"text"},{"type":"codeVoice","code":"g_child_watch_add()"},{"text":" (or ","type":"text"},{"code":"waitpid()","type":"codeVoice"},{"text":") if you specified the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"doNotReapChild"},{"type":"text","text":" flag. On Windows, "},{"code":"child_pid","type":"codeVoice"},{"type":"text","text":" will be"},{"type":"text","text":" "},{"type":"text","text":"filled with a handle to the child process only if you specified the"},{"text":" ","type":"text"},{"code":"doNotReapChild","type":"codeVoice"},{"type":"text","text":" flag. You can then access the child"},{"type":"text","text":" "},{"type":"text","text":"process using the Win32 API, for example wait for its termination"},{"type":"text","text":" "},{"type":"text","text":"with the "},{"type":"codeVoice","code":"WaitFor*()"},{"text":" functions, or examine its exit code with","type":"text"},{"text":" ","type":"text"},{"code":"GetExitCodeProcess()","type":"codeVoice"},{"type":"text","text":". You should close the handle with "},{"type":"codeVoice","code":"CloseHandle()"},{"text":" ","type":"text"},{"type":"text","text":"or "},{"type":"codeVoice","code":"g_spawn_close_pid()"},{"type":"text","text":" when you no longer need it."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If non-"},{"code":"nil","type":"codeVoice"},{"text":", the ","type":"text"},{"code":"stdinPipeOut","type":"codeVoice"},{"text":", ","type":"text"},{"code":"stdoutPipeOut","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"stderrPipeOut"},{"text":" ","type":"text"},{"type":"text","text":"locations will be filled with file descriptors for writing to the child’s"},{"text":" ","type":"text"},{"text":"standard input or reading from its standard output or standard error.","type":"text"},{"type":"text","text":" "},{"text":"The caller of ","type":"text"},{"type":"codeVoice","code":"g_spawn_async_with_pipes()"},{"type":"text","text":" must close these file descriptors"},{"type":"text","text":" "},{"type":"text","text":"when they are no longer in use. If these parameters are "},{"type":"codeVoice","code":"nil"},{"text":", the","type":"text"},{"text":" ","type":"text"},{"text":"corresponding pipe won’t be created.","type":"text"}]},{"inlineContent":[{"text":"If ","type":"text"},{"code":"stdinPipeOut","type":"codeVoice"},{"type":"text","text":" is "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", the child’s standard input is attached to"},{"type":"text","text":" "},{"code":"\/dev\/null","type":"codeVoice"},{"type":"text","text":" unless "},{"code":"childInheritsStdin","type":"codeVoice"},{"text":" is set.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"stderrPipeOut","type":"codeVoice"},{"type":"text","text":" is NULL, the child’s standard error goes to the same"},{"text":" ","type":"text"},{"text":"location as the parent’s standard error unless ","type":"text"},{"type":"codeVoice","code":"stderrToDevNull"},{"type":"text","text":" "},{"type":"text","text":"is set."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"stdoutPipeOut","type":"codeVoice"},{"text":" is NULL, the child’s standard output goes to the same","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"location as the parent’s standard output unless "},{"type":"codeVoice","code":"stdoutToDevNull"},{"type":"text","text":" "},{"type":"text","text":"is set."}]},{"type":"paragraph","inlineContent":[{"code":"error","type":"codeVoice"},{"text":" can be ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" to ignore errors, or non-"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" to report errors."},{"text":" ","type":"text"},{"type":"text","text":"If an error is set, the function returns "},{"type":"codeVoice","code":"false"},{"text":". Errors are reported","type":"text"},{"type":"text","text":" "},{"text":"even if they occur in the child (for example if the executable in","type":"text"},{"type":"text","text":" "},{"text":"``argv","type":"text"},{"code":"[0]","type":"codeVoice"},{"type":"text","text":" is not found). Typically the `message` field of returned"},{"type":"text","text":" "},{"text":"errors should be displayed to users. Possible errors are those from","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the `G_SPAWN_ERROR` domain."}]},{"inlineContent":[{"type":"text","text":"If an error occurs, "},{"type":"codeVoice","code":"child_pid"},{"type":"text","text":", "},{"type":"codeVoice","code":"stdinPipeOut"},{"text":", ","type":"text"},{"type":"codeVoice","code":"stdoutPipeOut"},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"text","text":"and "},{"type":"codeVoice","code":"stderrPipeOut"},{"type":"text","text":" will not be filled with valid values."}],"type":"paragraph"},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"child_pid"},{"text":" is not ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":" and an error does not occur then the returned"},{"text":" ","type":"text"},{"type":"text","text":"process reference must be closed using "},{"type":"codeVoice","code":"g_spawn_close_pid()"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"On modern UNIX platforms, GLib can use an efficient process launching"},{"type":"text","text":" "},{"text":"codepath driven internally by ","type":"text"},{"code":"posix_spawn()","type":"codeVoice"},{"type":"text","text":". This has the advantage of"},{"text":" ","type":"text"},{"text":"avoiding the fork-time performance costs of cloning the parent process","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"address space, and avoiding associated memory overcommit checks that are"},{"text":" ","type":"text"},{"text":"not relevant in the context of immediately executing a distinct process.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This optimized codepath will be used provided that the following conditions"},{"text":" ","type":"text"},{"text":"are met:","type":"text"}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"doNotReapChild","type":"codeVoice"},{"text":" is set","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"leaveDescriptorsOpen"},{"type":"text","text":" is set"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"searchPathFromEnvp"},{"type":"text","text":" is not set"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"workingDirectory"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"nil"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"childSetup"},{"text":" is ","type":"text"},{"code":"nil","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"The program is of a recognised binary format, or has a shebang.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Otherwise, GLib will have to execute the program through the"},{"text":" ","type":"text"},{"type":"text","text":"shell, which is not done using the optimized codepath."}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you are writing a GTK application, and the program you are spawning is a"},{"text":" ","type":"text"},{"text":"graphical application too, then to ensure that the spawned program opens its","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"windows on the right screen, you may want to use "},{"code":"GdkAppLaunchContext","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"codeVoice","code":"GAppLaunchContext"},{"type":"text","text":", or set the "},{"type":"codeVoice","code":"DISPLAY"},{"type":"text","text":" environment variable."}]}]}],"abstract":[{"type":"text","text":"Executes a child program asynchronously (your program will not"},{"text":" ","type":"text"},{"text":"block waiting for the child to exit).","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/spawnasyncwithpipesandfds(workingdirectory:argv:envp:flags:childsetup:userdata:stdinfd:stdoutfd:stderrfd:sourcefds:targetfds:nfds:childpidout:stdinpipeout:stdoutpipeout:stderrpipeout:)"]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"kind":"symbol","schemaVersion":{"major":0,"patch":0,"minor":3},"references":{"doc://GLib/documentation/GLib/spawnAsyncWithPipesAndFds(workingDirectory:argv:envp:flags:childSetup:userData:stdinFd:stdoutFd:stderrFd:sourceFds:targetFds:nFds:childPidOut:stdinPipeOut:stdoutPipeOut:stderrPipeOut:)":{"role":"symbol","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/spawnAsyncWithPipesAndFds(workingDirectory:argv:envp:flags:childSetup:userData:stdinFd:stdoutFd:stderrFd:sourceFds:targetFds:nFds:childPidOut:stdinPipeOut:stdoutPipeOut:stderrPipeOut:)","abstract":[{"type":"text","text":"Executes a child program asynchronously (your program will not"},{"type":"text","text":" "},{"text":"block waiting for the child to exit).","type":"text"}],"url":"\/documentation\/glib\/spawnasyncwithpipesandfds(workingdirectory:argv:envp:flags:childsetup:userdata:stdinfd:stdoutfd:stderrfd:sourcefds:targetfds:nfds:childpidout:stdinpipeout:stdoutpipeout:stderrpipeout:)","kind":"symbol","title":"spawnAsyncWithPipesAndFds(workingDirectory:argv:envp:flags:childSetup:userData:stdinFd:stdoutFd:stderrFd:sourceFds:targetFds:nFds:childPidOut:stdinPipeOut:stdoutPipeOut:stderrPipeOut:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"spawnAsyncWithPipesAndFds"},{"text":"(","kind":"text"},{"text":"workingDirectory","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"text":">?, ","kind":"text"},{"kind":"externalParam","text":"argv"},{"kind":"text","text":": "},{"text":"UnsafePoi