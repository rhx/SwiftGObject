b\/spawnflags","role":"symbol","title":"SpawnFlags","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"SpawnFlags"}],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/SpawnFlags","navigatorTitle":[{"kind":"identifier","text":"SpawnFlags"}],"kind":"symbol","abstract":[{"type":"text","text":"Flags passed to "},{"code":"g_spawn_sync()","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"g_spawn_async()"},{"type":"text","text":" and "},{"type":"codeVoice","code":"g_spawn_async_with_pipes()"},{"text":".","type":"text"}]}}}