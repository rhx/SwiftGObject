{"sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"unsetenv","kind":"identifier"},{"kind":"text","text":"("},{"text":"variable","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"text":">!)","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"Note that on some systems, when variables are overwritten, the","type":"text"},{"type":"text","text":" "},{"text":"memory used for the previous variables and its value isn’t reclaimed.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You should be mindful of the fact that environment variable handling"},{"type":"text","text":" "},{"type":"text","text":"in UNIX is not thread-safe, and your program may crash if one thread"},{"text":" ","type":"text"},{"type":"text","text":"calls "},{"code":"g_unsetenv()","type":"codeVoice"},{"type":"text","text":" while another thread is calling "},{"type":"codeVoice","code":"getenv()"},{"text":". (And note","type":"text"},{"text":" ","type":"text"},{"text":"that many functions, such as ","type":"text"},{"code":"gettext()","type":"codeVoice"},{"text":", call ","type":"text"},{"code":"getenv()","type":"codeVoice"},{"type":"text","text":" internally.) This"},{"text":" ","type":"text"},{"type":"text","text":"function is only safe to use at the very start of your program, before"},{"text":" ","type":"text"},{"type":"text","text":"creating any other threads (or creating objects that create worker"},{"text":" ","type":"text"},{"type":"text","text":"threads of their own)."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need to set up the environment for a child process, you can"},{"type":"text","text":" "},{"type":"text","text":"use "},{"type":"codeVoice","code":"g_get_environ()"},{"text":" to get an environment array, modify that with","type":"text"},{"text":" ","type":"text"},{"code":"g_environ_setenv()","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"g_environ_unsetenv()","type":"codeVoice"},{"text":", and then pass that","type":"text"},{"type":"text","text":" "},{"text":"array directly to ","type":"text"},{"type":"codeVoice","code":"execvpe()"},{"text":", ","type":"text"},{"code":"g_spawn_async()","type":"codeVoice"},{"type":"text","text":", or the like."}]}],"kind":"content"}],"metadata":{"roleHeading":"Function","externalID":"s:4GLib8unsetenv8variableySPys4Int8VGSg_tF","title":"unsetenv(variable:)","symbolKind":"func","modules":[{"name":"GLib"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"unsetenv","kind":"identifier"},{"text":"(","kind":"text"},{"text":"variable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">!)","kind":"text"}],"role":"symbol"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/unsetenv(variable:)","interfaceLanguage":"swift"},"kind":"symbol","abstract":[{"type":"text","text":"Removes an environment variable from the environment."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/unsetenv(variable:)"]}],"references":{"doc://GLib/documentation/GLib/unsetenv(variable:)":{"role":"symbol","kind":"symbol","title":"unsetenv(variable:)","type":"topic","abstract":[{"text":"Removes an environment variable from the environment.","type":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/unsetenv(variable:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"unsetenv"},{"kind":"text","text":"("},{"text":"variable","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">!)","kind":"text"}],"url":"\/documentation\/glib\/unsetenv(variable:)"},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"}}}