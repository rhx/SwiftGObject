{"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/getsystemdatadirs()"]}],"sections":[],"metadata":{"externalID":"s:4GLib17getSystemDataDirsSPySPys4Int8VGSgGSgyF","modules":[{"name":"GLib"}],"title":"getSystemDataDirs()","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"getSystemDataDirs"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"gchar","preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier"},{"text":">?>!","kind":"text"}],"symbolKind":"func","roleHeading":"Function"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"getSystemDataDirs"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">?>!","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"On UNIX platforms this is determined using the mechanisms described"},{"type":"text","text":" "},{"type":"text","text":"in the"},{"type":"text","text":" "},{"type":"reference","identifier":"http:\/\/www.freedesktop.org\/Standards\/basedir-spec","isActive":true},{"type":"text","text":" "},{"type":"text","text":"In this case the list of directories retrieved will be "},{"code":"XDG_DATA_DIRS","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"On Windows it follows XDG Base Directory Specification if "},{"type":"codeVoice","code":"XDG_DATA_DIRS"},{"text":" is defined.","type":"text"},{"type":"text","text":" "},{"text":"If ","type":"text"},{"code":"XDG_DATA_DIRS","type":"codeVoice"},{"text":" is undefined,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the first elements in the list are the Application Data"},{"type":"text","text":" "},{"text":"and Documents folders for All Users. (These can be determined only","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"on Windows 2000 or later and are not present in the list on other"},{"type":"text","text":" "},{"type":"text","text":"Windows versions.) See documentation for FOLDERID_ProgramData and"},{"type":"text","text":" "},{"type":"text","text":"FOLDERID_PublicDocuments."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then follows the “share” subfolder in the installation folder for"},{"text":" ","type":"text"},{"type":"text","text":"the package containing the DLL that calls this function, if it can"},{"type":"text","text":" "},{"text":"be determined.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Finally the list contains the “share” subfolder in the installation"},{"type":"text","text":" "},{"type":"text","text":"folder for GLib, and in the installation folder for the package the"},{"type":"text","text":" "},{"text":"application’s .exe file belongs to.","type":"text"}]},{"inlineContent":[{"type":"text","text":"The installation folders above are determined by looking up the"},{"text":" ","type":"text"},{"type":"text","text":"folder where the module (DLL or EXE) in question is located. If the"},{"type":"text","text":" "},{"type":"text","text":"folder’s name is “bin”, its parent is used, otherwise the folder"},{"text":" ","type":"text"},{"type":"text","text":"itself."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Note that on Windows the returned list can vary depending on where"},{"type":"text","text":" "},{"type":"text","text":"this function is called."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The return value is cached and modifying it at runtime is not supported, as"},{"type":"text","text":" "},{"text":"it’s not thread-safe to modify environment variables at runtime.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/getSystemDataDirs()"},"abstract":[{"text":"Returns an ordered list of base directories in which to access","type":"text"},{"text":" ","type":"text"},{"text":"system-wide application data.","type":"text"}],"references":{"doc://GLib/documentation/GLib/getSystemDataDirs()":{"kind":"symbol","type":"topic","abstract":[{"text":"Returns an ordered list of base directories in which to access","type":"text"},{"type":"text","text":" "},{"text":"system-wide application data.","type":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/getSystemDataDirs()","url":"\/documentation\/glib\/getsystemdatadirs()","title":"getSystemDataDirs()","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"getSystemDataDirs","kind":"identifier"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">?>!"}]},"http://www.freedesktop.org/Standards/basedir-spec":{"titleInlineContent":[{"text":"XDG Base Directory Specification","type":"text"}],"type":"link","identifier":"http:\/\/www.freedesktop.org\/Standards\/basedir-spec","title":"XDG Base Directory Specification","url":"http:\/\/www.freedesktop.org\/Standards\/basedir-spec"},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"}}}