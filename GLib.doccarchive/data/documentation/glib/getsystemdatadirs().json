{"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"title":"getSystemDataDirs()","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"getSystemDataDirs","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"kind":"text","text":">?>!"}],"modules":[{"name":"GLib"}],"role":"symbol","symbolKind":"func","externalID":"s:4GLib17getSystemDataDirsSPySPys4Int8VGSgGSgyF","roleHeading":"Function"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"kind":"symbol","identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/getSystemDataDirs()","interfaceLanguage":"swift"},"sections":[],"variants":[{"paths":["\/documentation\/glib\/getsystemdatadirs()"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"Returns an ordered list of base directories in which to access"},{"type":"text","text":" "},{"type":"text","text":"system-wide application data."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"getSystemDataDirs","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"text":">?>!","kind":"text"}]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"On UNIX platforms this is determined using the mechanisms described","type":"text"},{"type":"text","text":" "},{"type":"text","text":"in the"},{"type":"text","text":" "},{"identifier":"http:\/\/www.freedesktop.org\/Standards\/basedir-spec","isActive":true,"type":"reference"},{"type":"text","text":" "},{"text":"In this case the list of directories retrieved will be ","type":"text"},{"code":"XDG_DATA_DIRS","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"On Windows it follows XDG Base Directory Specification if ","type":"text"},{"code":"XDG_DATA_DIRS","type":"codeVoice"},{"type":"text","text":" is defined."},{"text":" ","type":"text"},{"type":"text","text":"If "},{"code":"XDG_DATA_DIRS","type":"codeVoice"},{"type":"text","text":" is undefined,"},{"text":" ","type":"text"},{"type":"text","text":"the first elements in the list are the Application Data"},{"text":" ","type":"text"},{"type":"text","text":"and Documents folders for All Users. (These can be determined only"},{"text":" ","type":"text"},{"type":"text","text":"on Windows 2000 or later and are not present in the list on other"},{"type":"text","text":" "},{"type":"text","text":"Windows versions.) See documentation for FOLDERID_ProgramData and"},{"type":"text","text":" "},{"text":"FOLDERID_PublicDocuments.","type":"text"}]},{"inlineContent":[{"text":"Then follows the “share” subfolder in the installation folder for","type":"text"},{"type":"text","text":" "},{"text":"the package containing the DLL that calls this function, if it can","type":"text"},{"type":"text","text":" "},{"text":"be determined.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Finally the list contains the “share” subfolder in the installation","type":"text"},{"text":" ","type":"text"},{"text":"folder for GLib, and in the installation folder for the package the","type":"text"},{"type":"text","text":" "},{"text":"application’s .exe file belongs to.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The installation folders above are determined by looking up the"},{"text":" ","type":"text"},{"type":"text","text":"folder where the module (DLL or EXE) in question is located. If the"},{"type":"text","text":" "},{"type":"text","text":"folder’s name is “bin”, its parent is used, otherwise the folder"},{"type":"text","text":" "},{"text":"itself.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that on Windows the returned list can vary depending on where"},{"type":"text","text":" "},{"type":"text","text":"this function is called."}]},{"inlineContent":[{"type":"text","text":"The return value is cached and modifying it at runtime is not supported, as"},{"text":" ","type":"text"},{"type":"text","text":"it’s not thread-safe to modify environment variables at runtime."}],"type":"paragraph"}]}],"references":{"http://www.freedesktop.org/Standards/basedir-spec":{"url":"http:\/\/www.freedesktop.org\/Standards\/basedir-spec","type":"link","title":"XDG Base Directory Specification","titleInlineContent":[{"type":"text","text":"XDG Base Directory Specification"}],"identifier":"http:\/\/www.freedesktop.org\/Standards\/basedir-spec"},"doc://GLib/documentation/GLib/getSystemDataDirs()":{"title":"getSystemDataDirs()","type":"topic","abstract":[{"text":"Returns an ordered list of base directories in which to access","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"system-wide application data."}],"kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"getSystemDataDirs","kind":"identifier"},{"kind":"text","text":"() -> "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"kind":"text","text":">?>!"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/getSystemDataDirs()","url":"\/documentation\/glib\/getsystemdatadirs()"},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"}}}