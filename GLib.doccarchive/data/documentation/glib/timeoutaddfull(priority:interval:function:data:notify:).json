"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"timeoutAddFull","kind":"identifier"},{"kind":"text","text":"("},{"text":"priority","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"interval","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"function","kind":"externalParam"},{"kind":"text","text":": "},{"text":"GSourceFunc","preciseIdentifier":"c:@T@GSourceFunc","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"data"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gpointer","text":"gpointer"},{"kind":"text","text":"? = nil, "},{"text":"notify","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"GDestroyNotify","kind":"typeIdentifier","preciseIdentifier":"c:@T@GDestroyNotify"},{"text":"? = nil) -> ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}]}],"kind":"declarations"},{"content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"The function is called repeatedly until it returns","type":"text"},{"type":"text","text":" "},{"text":"[const","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/sourceRemove"},{"type":"text","text":"], at which point the timeout is automatically"},{"text":" ","type":"text"},{"type":"text","text":"destroyed and"},{"text":" ","type":"text"},{"type":"text","text":"the function will not be called again.  The "},{"type":"codeVoice","code":"notify"},{"type":"text","text":" function is"},{"type":"text","text":" "},{"text":"called when the timeout is destroyed.  The first call to the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"function will be at the end of the first "},{"type":"codeVoice","code":"interval"},{"text":".","type":"text"}]},{"inlineContent":[{"text":"Note that timeout functions may be delayed, due to the processing of other","type":"text"},{"text":" ","type":"text"},{"text":"event sources. Thus they should not be relied on for precise timing.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"After each call to the timeout function, the time of the next"},{"type":"text","text":" "},{"text":"timeout is recalculated based on the current time and the given interval","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(it does not try to ‘catch up’ time lost in delays)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"type":"reference","isActive":true,"identifier":"main-loop.html#memory-management-of-sources"},{"type":"text","text":" for details"},{"text":" ","type":"text"},{"text":"on how to handle the return value and memory management of ","type":"text"},{"code":"data","type":"codeVoice"},{"text":".","type":"text"}]},{"inlineContent":[{"type":"text","text":"This internally creates a main loop source using"},{"type":"text","text":" "},{"text":"[func","type":"text"},{"code":"GLib.timeout_source_new","type":"codeVoice"},{"text":"] and attaches it to the global","type":"text"},{"type":"text","text":" "},{"text":"[struct","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","isActive":true},{"type":"text","text":"] using [method"},{"type":"codeVoice","code":"GLib.Source.attach"},{"type":"text","text":"], so the callback"},{"type":"text","text":" "},{"text":"will be invoked in whichever thread is running that main context. You can do","type":"text"},{"type":"text","text":" "},{"text":"these steps manually if you need greater control or to use a custom main","type":"text"},{"type":"text","text":" "},{"type":"text","text":"context."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The interval given is in terms of monotonic time, not wall clock time.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"See [func"},{"code":"GLib.get_monotonic_time","type":"codeVoice"},{"text":"].","type":"text"}]}],"kind":"content"}],"references":{"doc://GLib/documentation/GLib/MainContext":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","role":"symbol","type":"topic","navigatorTitle":[{"text":"MainContext","kind":"identifier"}],"abstract":[{"type":"text","text":"The "},{"code":"GMainContext","type":"codeVoice"},{"text":" struct is an opaque data","type":"text"},{"type":"text","text":" "},{"text":"type representing a set of sources to be handled in a main loop.","type":"text"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"MainContext","kind":"identifier"}],"url":"\/documentation\/glib\/maincontext","title":"MainContext","kind":"symbol"},"main-loop.html#memory-management-of-sources":{"identifier":"main-loop.html#memory-management-of-sources","title":"main loop memory management","type":"link","url":"main-loop.html#memory-management-of-sources","titleInlineContent":[{"type":"text","text":"main loop memory management"}]},"doc://GLib/documentation/GLib/SourceFunc":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFunc","fragments":[{"text":"typealias","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"SourceFunc"}],"role":"symbol","url":"\/documentation\/glib\/sourcefunc","kind":"symbol","title":"SourceFunc","type":"topic","navigatorTitle":[{"kind":"identifier","text":"SourceFunc"}],"abstract":[{"type":"text","text":"Specifies the type of function passed to [func"},{"code":"GLib.timeout_add","type":"codeVoice"},{"type":"text","text":"],"},{"type":"text","text":" "},{"type":"text","text":"[func"},{"code":"GLib.timeout_add_full","type":"codeVoice"},{"type":"text","text":"], [func"},{"code":"GLib.idle_add","type":"codeVoice"