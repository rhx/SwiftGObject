{"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/MatchInfoRef\/isPartialMatch"},"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"isPartialMatch"},{"kind":"text","text":": "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":" { ","kind":"text"},{"kind":"keyword","text":"get"},{"text":" }","kind":"text"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Consider, for example, an application where a human is required to"},{"text":" ","type":"text"},{"type":"text","text":"type in data for a field with specific formatting requirements. An"},{"text":" ","type":"text"},{"text":"example might be a date in the form ddmmmyy, defined by the pattern","type":"text"},{"type":"text","text":" "},{"code":"\"^\\d?\\d(jan|feb|mar|apr|may|jun|jul|aug|sep|oct|nov|dec)","type":"codeVoice"},{"type":"text","text":"\\d\\d$”."},{"type":"text","text":" "},{"type":"text","text":"If the application sees the user’s keystrokes one by one, and can"},{"type":"text","text":" "},{"type":"text","text":"check that what has been typed so far is potentially valid, it is"},{"text":" ","type":"text"},{"type":"text","text":"able to raise an error as soon as a mistake is made."}]},{"type":"paragraph","inlineContent":[{"text":"GRegex supports the concept of partial matching by means of the","type":"text"},{"text":" ","type":"text"},{"code":"partialSoft","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"partialHard"},{"type":"text","text":" flags."},{"type":"text","text":" "},{"type":"text","text":"When they are used, the return code for"},{"type":"text","text":" "},{"code":"g_regex_match()","type":"codeVoice"},{"type":"text","text":" or "},{"code":"g_regex_match_full()","type":"codeVoice"},{"type":"text","text":" is, as usual, "},{"type":"codeVoice","code":"true"},{"type":"text","text":" "},{"text":"for a complete match, ","type":"text"},{"code":"false","type":"codeVoice"},{"text":" otherwise. But, when these functions","type":"text"},{"text":" ","type":"text"},{"text":"return ","type":"text"},{"code":"false","type":"codeVoice"},{"type":"text","text":", you can check if the match was partial calling"},{"type":"text","text":" "},{"code":"g_match_info_is_partial_match()","type":"codeVoice"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"The difference between "},{"type":"codeVoice","code":"partialSoft"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"partialHard"},{"text":" is that when a partial match is encountered","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"with "},{"code":"partialSoft","type":"codeVoice"},{"type":"text","text":", matching continues to search for a"},{"text":" ","type":"text"},{"text":"possible complete match, while with ","type":"text"},{"code":"partialHard","type":"codeVoice"},{"type":"text","text":" matching"},{"type":"text","text":" "},{"text":"stops at the partial match.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"When both "},{"code":"partialSoft","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"partialHard"},{"text":" ","type":"text"},{"type":"text","text":"are set, the latter takes precedence."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"There were formerly some restrictions on the pattern for partial matching."},{"type":"text","text":" "},{"type":"text","text":"The restrictions no longer apply."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"type":"codeVoice","code":"pcrepartial(3)"},{"text":" for more information on partial matching.","type":"text"}]}]}],"metadata":{"fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"isPartialMatch","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"extendedModule":"GLib","role":"symbol","externalID":"s:4GLib17MatchInfoProtocolPAAE09isPartialB0Sbvp::SYNTHESIZED::s:4GLib12MatchInfoRefV","roleHeading":"Instance Property","title":"isPartialMatch","symbolKind":"property","modules":[{"name":"GLib"}]},"variants":[{"paths":["\/documentation\/glib\/matchinforef\/ispartialmatch"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"Usually if the string passed to g_regex_match*() matches as far as","type":"text"},{"type":"text","text":" "},{"text":"it goes, but is too short to match the entire pattern, ","type":"text"},{"code":"false","type":"codeVoice"},{"text":" is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"returned. There are circumstances where it might be helpful to"},{"type":"text","text":" "},{"type":"text","text":"distinguish this case from other cases in which there is no match."}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/MatchInfoRef","doc:\/\/GLib\/documentation\/GLib\/MatchInfoRef\/MatchInfoProtocol-Implementations"]]},"references":{"doc://GLib/documentation/GLib/MatchInfoRef/MatchInfoProtocol-Implementations":{"role":"collectionGroup","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfoRef\/MatchInfoProtocol-Implementations","url":"\/documentation\/glib\/matchinforef\/matchinfoprotocol-implementations","abstract":[],"kind":"article","title":"MatchInfoProtocol Implementations"},"doc://GLib/documentation/GLib/MatchInfoRef":{"role":"symbol","navigatorTitle":[{"text":"MatchInfoRef","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"MatchInfoRef"}],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfoRef","url":"\/documentation\/glib\/matchinforef","abstract":[{"type":"text","text":"A GMatchInfo is an opaque struct used to return information about"},{"text":" ","type":"text"},{"text":"matches.","type":"text"}],"kind":"symbol","title":"MatchInfoRef"},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/MatchInfoRef/isPartialMatch":{"fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"isPartialMatch"},{"text":": ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfoRef\/isPartialMatch","type":"topic","abstract":[{"text":"Usually if the string passed to g_regex_match*() matches as far as","type":"text"},{"type":"text","text":" "},{"text":"it goes, but is too short to match the entire pattern, ","type":"text"},{"code":"false","type":"codeVoice"},{"type":"text","text":" is"},{"type":"text","text":" "},{"type":"text","text":"returned. There are circumstances where it might be helpful to"},{"type":"text","text":" "},{"type":"text","text":"distinguish this case from other cases in which there is no match."}],"role":"symbol","title":"isPartialMatch","url":"\/documentation\/glib\/matchinforef\/ispartialmatch","kind":"symbol"}}}