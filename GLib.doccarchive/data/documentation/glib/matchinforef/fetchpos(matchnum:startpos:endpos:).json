{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/MatchInfoRef","doc:\/\/GLib\/documentation\/GLib\/MatchInfoRef\/MatchInfoProtocol-Implementations"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/matchinforef\/fetchpos(matchnum:startpos:endpos:)"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/MatchInfoRef\/fetchPos(matchNum:startPos:endPos:)"},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"fetchPos"},{"text":"(","kind":"text"},{"text":"matchNum","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"startPos","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"text":"gint","kind":"typeIdentifier","preciseIdentifier":"c:@T@gint"},{"text":">! = nil, ","kind":"text"},{"text":"endPos","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"text":"gint","preciseIdentifier":"c:@T@gint","kind":"typeIdentifier"},{"text":">! = nil) -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Valid values for ","type":"text"},{"type":"codeVoice","code":"matchNum"},{"type":"text","text":" are "},{"code":"0","type":"codeVoice"},{"text":" for the full text of the match,","type":"text"},{"type":"text","text":" "},{"code":"1","type":"codeVoice"},{"text":" for the first paren set, ","type":"text"},{"type":"codeVoice","code":"2"},{"text":" for the second, and so on.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"As ","type":"text"},{"code":"endPos","type":"codeVoice"},{"text":" is set to the byte after the final byte of the match (on success),","type":"text"},{"text":" ","type":"text"},{"text":"the length of the match can be calculated as ","type":"text"},{"type":"codeVoice","code":"end_pos - start_pos"},{"text":".","type":"text"}]},{"inlineContent":[{"text":"As a best practice, initialize ","type":"text"},{"type":"codeVoice","code":"startPos"},{"type":"text","text":" and "},{"type":"codeVoice","code":"endPos"},{"type":"text","text":" to identifiable"},{"text":" ","type":"text"},{"type":"text","text":"values, such as "},{"code":"G_MAXINT","type":"codeVoice"},{"type":"text","text":", so that you can test if"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_match_info_fetch_pos()"},{"type":"text","text":" actually changed the value for a given"},{"type":"text","text":" "},{"type":"text","text":"capture parenthesis."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The parameter ","type":"text"},{"type":"codeVoice","code":"matchNum"},{"text":" corresponds to a matched capture parenthesis. The","type":"text"},{"type":"text","text":" "},{"type":"text","text":"actual value you use for "},{"type":"codeVoice","code":"matchNum"},{"text":" depends on the method used to generate","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"matchInfo"},{"text":". The following sections describe those methods.","type":"text"}]},{"type":"heading","anchor":"Methods-Using-Non-deterministic-Finite-Automata-Matching","level":2,"text":"Methods Using Non-deterministic Finite Automata Matching"},{"inlineContent":[{"text":"The methods [method","type":"text"},{"code":"GLib.Regex.match","type":"codeVoice"},{"type":"text","text":"] and [method"},{"type":"codeVoice","code":"GLib.Regex.match_full"},{"type":"text","text":"]"},{"type":"text","text":" "},{"type":"text","text":"return a [struct"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo","type":"reference","isActive":true},{"type":"text","text":"] using traditional (greedy) pattern"},{"text":" ","type":"text"},{"type":"text","text":"matching, also known as"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/en.wikipedia.org\/wiki\/Nondeterministic_finite_automaton","isActive":true},{"text":" ","type":"text"},{"text":"(NFA) matching. You pass the returned ","type":"text"},{"type":"codeVoice","code":"GMatchInfo"},{"type":"text","text":" from these methods to"},{"type":"text","text":" "},{"code":"g_match_info_fetch_pos()","type":"codeVoice"},{"type":"text","text":" to determine the start and end positions"},{"text":" ","type":"text"},{"type":"text","text":"of capture parentheses. The values for "},{"type":"codeVoice","code":"matchNum"},{"text":" correspond to the capture","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"parentheses in order, with "},{"type":"codeVoice","code":"0"},{"type":"text","text":" corresponding to the entire matched string."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"code":"matchNum","type":"codeVoice"},{"type":"text","text":" can refer to a capture parenthesis with no match. For example,"},{"text":" ","type":"text"},{"type":"text","text":"the string "},{"type":"codeVoice","code":"b"},{"text":" matches against the pattern ","type":"text"},{"type":"codeVoice","code":"(a)?b"},{"type":"text","text":", but the capture"},{"type":"text","text":" "},{"text":"parenthesis ","type":"text"},{"code":"(a)","type":"codeVoice"},{"text":" has no match. In this case, ","type":"text"},{"type":"codeVoice","code":"g_match_info_fetch_pos()"},{"text":" ","type":"text"},{"type":"text","text":"returns true and sets "},{"type":"codeVoice","code":"startPos"},{"type":"text","text":" and "},{"type":"codeVoice","code":"endPos"},{"type":"text","text":" to "},{"code":"-1","type":"codeVoice"},{"text":" when called with","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"match_num"},{"type":"text","text":" as "},{"type":"codeVoice","code":"1"},{"text":" (for ","type":"text"},{"type":"codeVoice","code":"(a)"},{"text":").","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For an expanded example, a regex pattern is "},{"code":"(a)?(.*?)the (.*)","type":"codeVoice"},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"text","text":"and a candidate string is "},{"type":"codeVoice","code":"glib regexes are the best"},{"type":"text","text":". In this scenario"},{"type":"text","text":" "},{"text":"there are four capture parentheses numbered 0–3: an implicit one","type":"text"},{"type":"text","text":" "},{"text":"for the entire string, and three explicitly declared in the regex pattern.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Given this example, the following table describes the return values"},{"text":" ","type":"text"},{"text":"from ","type":"text"},{"type":"codeVoice","code":"g_match_info_fetch_pos()"},{"type":"text","text":" for various values of "},{"code":"matchNum","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"type":"codeVoice","code":"match_num"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Contents","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Return value"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Returned "},{"code":"start_pos","type":"codeVoice"}]}],[{"inlineContent":[{"text":"Returned ","type":"text"},{"type":"codeVoice","code":"end_pos"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"0","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Matches entire string","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"True"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"0","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"25","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"1","type":"text"}]}],[{"inlineContent":[{"text":"Does not match first character","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"True","type":"text"}]}],[{"inlineContent":[{"text":"-1","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"-1","type":"text"}]}]],[[{"inlineContent":[{"text":"2","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"All text before ","type":"text"},{"code":"the ","type":"codeVoice"}]}],[{"inlineContent":[{"type":"text","text":"True"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"0","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"17"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"3"}]}],[{"inlineContent":[{"text":"All text after ","type":"text"},{"code":"the ","type":"codeVoice"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"True"}]}],[{"inlineContent":[{"type":"text","text":"21"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"25"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"4"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Capture paren out of range"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"False"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Unchanged"}]}],[{"type":"paragraph","inlineContent":[{"text":"Unchanged","type":"text"}]}]]]},{"inlineContent":[{"text":"The following code sample and output implements this example.","type":"text"}],"type":"paragraph"},{"code":["`include` <glib.h>","","int","main (int argc, char *argv[])","{","  `g_autoptr(GError)` local_error = NULL;","  const char *regex_pattern = \"(a)?(.*?)the (.*)\";","  const char *test_string = \"glib regexes are the best\";","  `g_autoptr(GRegex)` regex = NULL;","","  regex = g_regex_new (regex_pattern,","                       G_REGEX_DEFAULT,","                       G_REGEX_MATCH_DEFAULT,","                       &local_error);","  if (regex == NULL)","    {","      g_printerr (\"Error creating regex: `s`\\n\", local_error->message);","      return 1;","    }","","  `g_autoptr(GMatchInfo)` match_info = NULL;","  g_regex_match (regex, test_string, G_REGEX_MATCH_DEFAULT, &match_info);","","  int n_matched_strings = g_match_info_get_match_count (match_info);","","  \/\/ Print header line","  g_print (\"match_num Contents                  Return value returned start_pos returned end_pos\\n\");","","  \/\/ Iterate over each capture paren, including one that is out of range as a demonstration.","  for (int match_num = 0; match_num <= n_matched_strings; match_num++)","    {","      gboolean found_match;","      g_autofree char *paren_string = NULL;","      int start_pos = G_MAXINT;","      int end_pos = G_MAXINT;","","      found_match = g_match_info_fetch_pos (match_info,","                                            match_num,","                                            &start_pos,","                                            &end_pos);","","      \/\/ If no match, display N\/A as the found string.","      if (start_pos == G_MAXINT || start_pos == -1)","        paren_string = g_strdup (\"N\/A\");","      else","        paren_string = g_strndup (test_string + start_pos, end_pos - start_pos);","","      g_print (\"`-9d` `-25s` `-12d` `-18d` `d`\\n\", match_num, paren_string, found_match, start_pos, end_pos);","    }","","  return 0;","}"],"type":"codeListing","syntax":"{ .c }"},{"syntax":null,"type":"codeListing","code":["match_num Contents                  Return value returned start_pos returned end_pos","0         glib regexes are the best 1            0                  25","1         N\/A                       1            -1                 -1","2         glib regexes are          1            0                  17","3         best                      1            21                 25","4         N\/A                       0            2147483647         2147483647"]},{"level":2,"anchor":"Methods-Using-Deterministic-Finite-Automata-Matching","text":"Methods Using Deterministic Finite Automata Matching","type":"heading"},{"inlineContent":[{"text":"The methods [method","type":"text"},{"type":"codeVoice","code":"GLib.Regex.match_all"},{"text":"] and","type":"text"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.Regex.match_all_full"},{"text":"]","type":"text"},{"type":"text","text":" "},{"text":"return a ","type":"text"},{"code":"GMatchInfo","type":"codeVoice"},{"type":"text","text":" using"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"https:\/\/en.wikipedia.org\/wiki\/Deterministic_finite_automaton"},{"type":"text","text":" "},{"text":"(DFA) pattern matching. This algorithm detects overlapping matches. You pass","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the returned "},{"type":"codeVoice","code":"GMatchInfo"},{"type":"text","text":" from these methods to "},{"code":"g_match_info_fetch_pos()","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"to determine the start and end positions of each overlapping match. Use the"},{"text":" ","type":"text"},{"text":"method [method","type":"text"},{"code":"GLib.MatchInfo.get_match_count","type":"codeVoice"},{"text":"] to determine the number","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of overlapping matches."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"For example, a regex pattern is ","type":"text"},{"code":"<.*>","type":"codeVoice"},{"text":", and a candidate string is","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"<a> <b> <c>"},{"type":"text","text":". In this scenario there are three implicit capture"},{"text":" ","type":"text"},{"text":"parentheses: one for the entire string, one for ","type":"text"},{"type":"codeVoice","code":"<a> <b>"},{"text":", and one for ","type":"text"},{"code":"<a>","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Given this example, the following table describes the return values from"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_match_info_fetch_pos()"},{"text":" for various values of ","type":"text"},{"code":"matchNum","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"match_num"}]}],[{"inlineContent":[{"text":"Contents","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Return value"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Returned "},{"type":"codeVoice","code":"start_pos"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Returned "},{"type":"codeVoice","code":"end_pos"}]}]],[[{"inlineContent":[{"text":"0","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Matches entire string","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"True","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"0"}],"type":"paragraph"}],[{"inlineContent":[{"text":"11","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"1","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Matches "},{"type":"codeVoice","code":"<a> <b>"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"True"}]}],[{"inlineContent":[{"type":"text","text":"0"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"7"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"2"}]}],[{"inlineContent":[{"text":"Matches ","type":"text"},{"type":"codeVoice","code":"<a>"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"True"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"0"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"3"}]}]],[[{"inlineContent":[{"text":"3","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Capture paren out of range"}]}],[{"inlineContent":[{"text":"False","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Unchanged","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Unchanged","type":"text"}]}]]]},{"inlineContent":[{"text":"The following code sample and output implements this example.","type":"text"}],"type":"paragraph"},{"code":["`include` <glib.h>","","int","main (int argc, char *argv[])","{","  `g_autoptr(GError)` local_error = NULL;","  const char *regex_pattern = \"<.*>\";","  const char *test_string = \"<a> <b> <c>\";","  `g_autoptr(GRegex)` regex = NULL;","","  regex = g_regex_new (regex_pattern,","                       G_REGEX_DEFAULT,","                       G_REGEX_MATCH_DEFAULT,","                       &local_error);","  if (regex == NULL)","    {","      g_printerr (\"Error creating regex: `s`\\n\", local_error->message);","      return -1;","    }","","  `g_autoptr(GMatchInfo)` match_info = NULL;","  g_regex_match_all (regex, test_string, G_REGEX_MATCH_DEFAULT, &match_info);","","  int n_matched_strings = g_match_info_get_match_count (match_info);","","  \/\/ Print header line","  g_print (\"match_num Contents                  Return value returned start_pos returned end_pos\\n\");","","  \/\/ Iterate over each capture paren, including one that is out of range as a demonstration.","  for (int match_num = 0; match_num <= n_matched_strings; match_num++)","    {","      gboolean found_match;","      g_autofree char *paren_string = NULL;","      int start_pos = G_MAXINT;","      int end_pos = G_MAXINT;","","      found_match = g_match_info_fetch_pos (match_info, match_num, &start_pos, &end_pos);","","      \/\/ If no match, display N\/A as the found string.","      if (start_pos == G_MAXINT || start_pos == -1)","        paren_string = g_strdup (\"N\/A\");","      else","        paren_string = g_strndup (test_string + start_pos, end_pos - start_pos);","","      g_print (\"`-9d` `-25s` `-12d` `-18d` `d`\\n\", match_num, paren_string, found_match, start_pos, end_pos);","    }","","  return 0;","}"],"type":"codeListing","syntax":"{ .c }"},{"syntax":null,"code":["match_num Contents                  Return value returned start_pos returned end_pos","0         <a> <b> <c>               1            0                  11","1         <a> <b>                   1            0                  7","2         <a>                       1            0                  3","3         N\/A                       0            2147483647         2147483647"],"type":"codeListing"}],"kind":"content"}],"metadata":{"roleHeading":"Instance Method","externalID":"s:4GLib17MatchInfoProtocolPAAE8fetchPos8matchNum05startF003endF0SbSi_Spys5Int32VGSgAKtF::SYNTHESIZED::s:4GLib12MatchInfoRefV","modules":[{"name":"GLib"}],"role":"symbol","symbolKind":"method","extendedModule":"GLib","title":"fetchPos(matchNum:startPos:endPos:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"fetchPos"},{"text":"(","kind":"text"},{"text":"matchNum","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"startPos","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"gint","kind":"typeIdentifier","preciseIdentifier":"c:@T@gint"},{"text":">!, ","kind":"text"},{"text":"endPos","kind":"externalParam"},{"text":": ","kind":"text"},{"t