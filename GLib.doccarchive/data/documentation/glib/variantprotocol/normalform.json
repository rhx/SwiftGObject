new"},{"text":" ","type":"text"},{"type":"text","text":"reference to "},{"code":"value","type":"codeVoice"},{"text":" is returned.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If ","type":"text"},{"code":"value","type":"codeVoice"},{"type":"text","text":" is not already trusted, then it is scanned to check if it"},{"text":" ","type":"text"},{"type":"text","text":"is in normal form.  If it is found to be in normal form then it is"},{"type":"text","text":" "},{"type":"text","text":"marked as trusted and a new reference to it is returned."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"code":"value","type":"codeVoice"},{"type":"text","text":" is found not to be in normal form then a new trusted"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":" is created with the same value as ","type":"text"},{"type":"codeVoice","code":"value"},{"type":"text","text":". The non-normal parts of"},{"type":"text","text":" "},{"type":"codeVoice","code":"value"},{"text":" will be replaced with default values which are guaranteed to be in","type":"text"},{"text":" ","type":"text"},{"text":"normal form.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"It makes sense to call this function if you’ve received ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"type":"text","text":" "},{"type":"text","text":"data from untrusted sources and you want to ensure your serialized"},{"type":"text","text":" "},{"type":"text","text":"output is definitely in normal form."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"value","type":"codeVoice"},{"type":"text","text":" is already in normal form, a new reference will be returned"},{"type":"text","text":" "},{"type":"text","text":"(which will be floating if "},{"code":"value","type":"codeVoice"},{"type":"text"