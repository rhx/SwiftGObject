{"abstract":[{"text":"Returns a pointer to the serialized form of a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"type":"text","text":"The returned data may not be in fully-normalised form if read from an"},{"type":"text","text":" "},{"text":"untrusted source.  The returned data must not be freed; it remains","type":"text"},{"text":" ","type":"text"},{"text":"valid for as long as ","type":"text"},{"type":"codeVoice","code":"value"},{"type":"text","text":" exists."}],"sections":[],"metadata":{"roleHeading":"Instance Method","externalID":"s:4GLib15VariantProtocolPAAE7getDataSVSgyF","extendedModule":"GLib","title":"getData()","symbolKind":"method","modules":[{"name":"GLib"}],"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"getData","kind":"identifier"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"c:@T@gconstpointer","text":"gconstpointer","kind":"typeIdentifier"},{"kind":"text","text":"?"}],"role":"symbol"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/VariantProtocol"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/VariantProtocol\/getData()"},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"getData"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gconstpointer","text":"gconstpointer"},{"kind":"text","text":"?"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"value"},{"type":"text","text":" is a fixed-sized value that was deserialized from a"},{"type":"text","text":" "},{"type":"text","text":"corrupted serialized container then "},{"type":"codeVoice","code":"nil"},{"text":" may be returned.  In this","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"case, the proper thing to do is typically to use the appropriate"},{"text":" ","type":"text"},{"type":"text","text":"number of nul bytes in place of "},{"type":"codeVoice","code":"value"},{"text":".  If ","type":"text"},{"type":"codeVoice","code":"value"},{"type":"text","text":" is not fixed-sized"},{"type":"text","text":" "},{"type":"text","text":"then "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" is never returned."}]},{"type":"paragraph","inlineContent":[{"text":"In the case that ","type":"text"},{"type":"codeVoice","code":"value"},{"type":"text","text":" is already in serialized form, this function"},{"type":"text","text":" "},{"text":"is ","type":"text"},{"type":"codeVoice","code":"O(1)"},{"text":".  If the value is not already in serialized form,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"serialization occurs implicitly and is approximately "},{"type":"codeVoice","code":"O(n)"},{"text":" in the size","type":"text"},{"type":"text","text":" "},{"text":"of the result.","type":"text"}]},{"inlineContent":[{"type":"text","text":"To deserialize the data returned by this function, in addition to the"},{"text":" ","type":"text"},{"type":"text","text":"serialized data, you must know the type of the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"type":"text","text":", and (if the"},{"text":" ","type":"text"},{"text":"machine might be different) the endianness of the machine that stored","type":"text"},{"text":" ","type":"text"},{"text":"it. As a result, file formats or network messages that incorporate","type":"text"},{"text":" ","type":"text"},{"text":"serialized ","type":"text"},{"code":"GVariants","type":"codeVoice"},{"text":" must include this information either","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"implicitly (for instance “the file always contains a"},{"text":" ","type":"text"},{"type":"codeVoice","code":"G_VARIANT_TYPE_VARIANT"},{"type":"text","text":" and it is always in little-endian order”) or"},{"text":" ","type":"text"},{"type":"text","text":"explicitly (by storing the type and\/or endianness in addition to the"},{"text":" ","type":"text"},{"type":"text","text":"serialized data)."}],"type":"paragraph"}],"kind":"content"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/variantprotocol\/getdata()"]}],"references":{"doc://GLib/documentation/GLib/VariantProtocol":{"abstract":[{"code":"GVariant","type":"codeVoice"},{"text":" is a variant datatype; it can contain one or more values","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"along with information about the type of the values."}],"type":"topic","role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"VariantProtocol","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantProtocol","title":"VariantProtocol","url":"\/documentation\/glib\/variantprotocol","kind":"symbol","navigatorTitle":[{"text":"VariantProtocol","kind":"identifier"}]},"doc://GLib/documentation/GLib/Variant":{"abstract":[{"code":"GVariant","type":"codeVoice"},{"type":"text","text":" is a variant datatype; it can contain one or more values"},{"type":"text","text":" "},{"text":"along with information about the type of the values.","type":"text"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"Variant","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","navigatorTitle":[{"text":"Variant","kind":"identifier"}],"title":"Variant","role":"symbol","type":"topic","kind":"symbol","url":"\/documentation\/glib\/variant"},"doc://GLib/documentation/GLib/VariantProtocol/getData()