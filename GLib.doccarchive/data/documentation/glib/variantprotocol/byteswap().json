{"abstract":[{"type":"text","text":"Performs a byteswapping operation on the contents of "},{"code":"value","type":"codeVoice"},{"text":".  The","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"result is that all multi-byte numeric data contained in "},{"type":"codeVoice","code":"value"},{"text":" is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"byteswapped.  That includes 16, 32, and 64bit signed and unsigned"},{"text":" ","type":"text"},{"text":"integers as well as file handles and double precision floating point","type":"text"},{"text":" ","type":"text"},{"text":"values.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/VariantProtocol"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/variantprotocol\/byteswap()"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/VariantProtocol\/byteswap()"},"sections":[],"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"roleHeading":"Instance Method","extendedModule":"GLib","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"byteswap","kind":"identifier"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef"},{"kind":"text","text":"!"}],"modules":[{"name":"GLib"}],"externalID":"s:4GLib15VariantProtocolPAAE8byteswapAA0B3RefVSgyF","title":"byteswap()","role":"symbol","symbolKind":"method"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"byteswap","kind":"identifier"},{"kind":"text","text":"() -> "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef","kind":"typeIdentifier","text":"VariantRef","preciseIdentifier":"s:4GLib10VariantRefV"},{"text":"!","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"This function is an identity mapping on any value that does not","type":"text"},{"type":"text","text":" "},{"type":"text","text":"contain multi-byte numeric data.  That include strings, booleans,"},{"type":"text","text":" "},{"type":"text","text":"bytes and containers containing only these things (recursively)."}]},{"type":"paragraph","inlineContent":[{"text":"While this function can safely handle untrusted, non-normal data, it is","type":"text"},{"type":"text","text":" "},{"text":"recommended to check whether the input is in normal form beforehand, using","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_variant_is_normal_form()"},{"text":", and to reject non-normal inputs if your","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"application can be strict about what inputs it rejects."}]},{"type":"paragraph","inlineContent":[{"text":"The returned value is always in normal form and is marked as trusted.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"A full, not floating, reference is returned."}]}]}],"references":{"doc://GLib/documentation/GLib/VariantProtocol":{"abstract":[{"code":"GVariant","type":"codeVoice"},{"text":" is a variant datatype; it can contain one or more values","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"along with information about the type of the values."}],"type":"topic","role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"VariantProtocol","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantProtocol","title":"VariantProtocol","url":"\/documentation\/glib\/variantprotocol","kind":"symbol","navigatorTitle":[{"text":"VariantProtocol","kind":"identifier"}]},"doc://GLib/documentation/GLib/VariantProtocol/byteswap()":{"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","t