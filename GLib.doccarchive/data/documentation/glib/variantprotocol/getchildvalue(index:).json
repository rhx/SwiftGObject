{"abstract":[{"text":"Reads a child item out of a container ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference"},{"type":"text","text":" instance.  This"},{"type":"text","text":" "},{"type":"text","text":"includes variants, maybes, arrays, tuples and dictionary"},{"type":"text","text":" "},{"type":"text","text":"entries.  It is an error to call this function on any other type of"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"type":"text","text":"."}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/VariantProtocol"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/VariantProtocol\/getChildValue(index:)"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"getChildValue"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"index"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"VariantRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef"},{"text":"!","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"inlineContent":[{"text":"It is an error if ","type":"text"},{"type":"codeVoice","code":"index"},{"type":"text","text":" is greater than the number of child items"},{"type":"text","text":" "},{"type":"text","text":"in the container.  See "},{"code":"g_variant_n_children()","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The returned value is never floating.  You should free it with"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_variant_unref()"},{"type":"text","text":" when you’re done with it."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Note that values borrowed from the returned child are not guaranteed to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"still be valid after the child is freed even if you still hold a reference"},{"type":"text","text":" "},{"type":"text","text":"to "},{"type":"codeVoice","code":"value"},{"type":"text","text":", if "},{"code":"value","type":"codeVoice"},{"type":"text","text":" has not been serialized at the time this function is"},{"text":" ","type":"text"},{"type":"text","text":"called. To avoid this, you can serialize "},{"type":"codeVoice","code":"value"},{"text":" by calling","type":"text"},{"type":"text","text":" "},{"code":"g_variant_get_data()","type":"codeVoice"},{"text":" and optionally ignoring the return value.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"There may be implementation specific restrictions on deeply nested values,"},{"type":"text","text":" "},{"text":"which would result in the unit tuple being returned as the child value,","type":"text"},{"type":"text","text":" "},{"text":"instead of further nested children. ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true,"type":"reference"},{"text":" is guaranteed to handle","type":"text"},{"type":"text","text":" "},{"type":"text","text":"nesting up to at least 64 levels."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function is "},{"code":"O(1)","type":"codeVoice"},{"text":".","type":"text"}]}],"kind":"content"}],"sections":[],"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"roleHeading":"Instance Method","title":"getChildValue(index:)","modules":[{"name":"GLib"}],"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"getChildValue"},{"text":"(","kind":"text"},{