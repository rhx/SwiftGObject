{"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":" uses a floating reference count system.  All functions with","type":"text"},{"type":"text","text":" "},{"text":"names starting with ","type":"text"},{"code":"g_variant_new_","type":"codeVoice"},{"text":" return floating","type":"text"},{"type":"text","text":" "},{"type":"text","text":"references."}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/VariantProtocol"]]},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/VariantProtocol\/refSink()","interfaceLanguage":"swift"},"kind":"symbol","metadata":{"modules":[{"name":"GLib"}],"extendedModule":"GLib","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"refSink","kind":"identifier"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef"},{"text":"!","kind":"text"}],"roleHeading":"Instance Method","title":"refSink()","externalID":"s:4GLib15VariantProtocolPAAE7refSinkAA0B3RefVSgyF","role":"symbol"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"refSink"},{"kind":"text","text":"() -> "},{"text":"VariantRef","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV"},{"text":"!","kind":"text"}]}]},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Calling "},{"code":"g_variant_ref_sink()","type":"codeVoice"},{"type":"text","text":" on a "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference","isActive":true},{"type":"text","text":" with a floating reference"},{"type":"text","text":" "},{"type":"text","text":"will convert the floating reference into a full reference.  Calling"},{"text":" ","type":"text"},{"code":"g_variant_ref_sink()","type":"codeVoice"},{"text":" on a non-floating ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference","isActive":true},{"text":" results in an","type":"text"},{"type":"text","text":" "},{"text":"additional normal reference being added.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In other words, if the "},{"type":"codeVoice","code":"value"},{"text":" is floating, then this call “assumes","type":"text"},{"type":"text","text":" "},{"text":"ownership” of the floating reference, converting it to a normal","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"reference.  If the "},{"code":"value","type":"codeVoice"},{"text":" is not floating, then this call adds a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"new normal reference increasing the reference count by one."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"All calls that result in a "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true,"type":"reference"},{"text":" instance being inserted into a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"container will call "},{"type":"codeVoice","code":"g_variant_ref_sink()"},{"type":"text","text":" on the instance.  This means"},{"type":"text","text":" "},{"type":"text","text":"that if the value was just created (and has only its floating"},{"text":" ","type":"text"},{"text":"reference) then the container will assume sole ownership of the value","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"at that point and the caller will not need to unreference it.  This"},{"text":" ","type":"text"},{"text":"makes certain common styles of programming much easier while still","type":"text"},{"type":"text","text":" "},{"type":"text","text":"maintaining normal refcounting semantics in situations where values"},{"type":"text","text":" "},{"text":"are not floating.","type":"text"}]}],"kind":"content"}],"sections":[],"variants":[{"paths":["\/documentation\/glib\/variantprotocol\/refsink()"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GLib/documentation/GLib/VariantProtocol/refSink()":{"role":"symbol","abstract":[{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"type":"text","text":" uses a floating reference count system.  All functions with"},{"text":" ","type":"text"},{"type":"text","text":"names starting with "},{"type":"codeVoice","code":"g_variant_new_"},{"text":" return floating","type":"text"},{"type":"text","text":" "},{"type":"text","text":"references."}],"kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"refSink"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef"},{"kind":"text","text":"!"}],"url":"\/documentation\/glib\/variantprotocol\/refsink()","type":"topic","title":"refSink()","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantProtocol\/refSink()"},"doc://GLib/documentation/GLib/VariantRef":{"role":"symbol","type":"topic","url":"\/documentation\/glib\/variantref","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef","abstract":[{"code":"GVariant","type":"codeVoice"},{"text":" is a variant datatype; it can contain one or more values","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"along with information about the type of the values."}],"kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"VariantRef","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"VariantRef"}],"title":"VariantRef"},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","ur