{"sections":[],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/VariantProtocol\/takeRef()","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"If "},{"type":"codeVoice","code":"value"},{"type":"text","text":" is floating, sink it.  Otherwise, do nothing."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/variantprotocol\/takeref()"]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/VariantProtocol"]]},"metadata":{"role":"symbol","modules":[{"name":"GLib"}],"symbolKind":"method","externalID":"s:4GLib15VariantProtocolPAAE7takeRefAA0bE0VSgyF","extendedModule":"GLib","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"takeRef","kind":"identifier"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"title":"takeRef()","roleHeading":"Instance Method"},"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"takeRef","kind":"identifier"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef","kind":"typeIdentifier"},{"text":"!","kind":"text"}]}]},{"content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Typically you want to use "},{"code":"g_variant_ref_sink()","type":"codeVoice"},{"type":"text","text":" in order to"},{"type":"text","text":" "},{"type":"text","text":"automatically do the correct thing with respect to floating or"},{"type":"text","text":" "},{"text":"non-floating references, but there is one specific scenario where","type":"text"},{"type":"text","text":" "},{"type":"text","text":"this function is helpful."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The situation where this function is helpful is when creating an API"},{"type":"text","text":" "},{"text":"that allows the user to provide a callback function that returns a","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true,"type":"reference"},{"text":".  We certainly want to allow the user the flexibility to","type":"text"},{"type":"text","text":" "},{"text":"return a non-floating reference from this callback (for the case","type":"text"},{"type":"text","text":" "},{"text":"where the value that is being returned already exists).","type":"text"}]},{"inlineContent":[{"type":"text","text":"At the same time, the style of the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":" API makes it likely that","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for newly-created "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"type":"text","text":" instances, the user can be saved some"},{"type":"text","text":" "},{"text":"typing if they are allowed to return a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"type":"text","text":" with a floating"},{"text":" ","type":"text"},{"type":"text","text":"reference."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Using this function on the return value of the user’s callback allows","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the user to do whichever is more convenient for them.  The caller"},{"type":"text","text":" "},{"type":"text","text":"will always receives exactly one full reference to the value: either"},{"type":"text","text":" "},{"text":"the one that was returned in the first place, or a floating reference","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"that has been converted to a full reference."}]},{"inlineContent":[{"text":"This function has an odd interaction when combined with","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_variant_ref_sink()"},{"text":" running at the same time in another thread on","type":"text"},{"type":"text","text":" "},{"text":"the same ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":" instance.  If ","type":"text"},{"code":"g_variant_ref_sink()","type":"codeVoice"},{"type":"text","text":" runs first then"},{"type":"text","text":" "},{"type":"text","text":"the result will be that the floating reference is converted to a hard"},{"text":" ","type":"text"},{"type":"text","text":"reference.  If "},{"type":"codeVoice","code":"g_variant_take_ref()"},{"text":" runs first then the result will","type":"text"},{"type":"text","text":" "},{"type":"text","text":"be that the floating reference is converted to a hard reference and"},{"type":"text","text":" "},{"type":"text","text":"an additional reference on top of that one is added.  It is best to"},{"type":"text","text":" "},{"text":"avoid this situation.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/VariantProtocol/takeRef()":{"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"takeRef"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef"},{"kind":"text","text":"!"}],"type":"topic","kind":"symbol","abstract":[{"type":"text","text":"If "},{"code":"value","type":"codeVoice"},{"type":"text","text":" is floating, sink it.  Otherwise, do nothing."}],"title":"takeRef()","role":"symbol","url":"\/documentation\/glib\/variantprotocol\/takeref()","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantProtocol\/takeRef()"},"doc://GLib/documentation/GLib/VariantRef":{"abstract":[{"code":"GVariant","type":"codeVoice"},{"text":" is a variant datatype; it can contain one or more values","type":"text"},{"type":"text","text":" "},{"type":"text","text":"along with information about the type of the values."}],"type":"topic","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"VariantRef","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef","title":"VariantRef","url":"\/documentation\/glib\/variantref","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"VariantRef"}]},"doc://GLib/documentation/GLib/Variant":{"abstract":[{"code":"GVariant","type":"codeVoice"},{"type":"text","text":" is a variant datatype; it can contain one or more values"},{"type":"text","text":" "},{"text":"along with information about the type of the values.","type":"text"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"Variant","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","navigatorTitle":[{"text":"Variant","kind":"identifier"}],"title":"Variant","role":"symbol","type":"topic","kind":"symbol","url":"\/documentation\/glib\/variant"},"doc://GLib/documentation/GLib/VariantProtocol":{"abstract":[{"code":"GVariant","type":"codeVoice"},{"text":" is a variant datatype; it can contain one or more values","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"along with information about the type of the values."}],"type":"topic","role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"VariantProtocol","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantProtocol","title":"VariantProtocol","url":"\/documentation\/glib\/varian