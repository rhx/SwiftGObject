{"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/VariantProtocol\/takeRef()","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/variantprotocol\/takeref()"]}],"metadata":{"roleHeading":"Instance Method","externalID":"s:4GLib15VariantProtocolPAAE7takeRefAA0bE0VSgyF","extendedModule":"GLib","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"takeRef"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","text":"VariantRef","preciseIdentifier":"s:4GLib10VariantRefV"},{"text":"!","kind":"text"}],"modules":[{"name":"GLib"}],"symbolKind":"method","title":"takeRef()"},"abstract":[{"type":"text","text":"If "},{"type":"codeVoice","code":"value"},{"type":"text","text":" is floating, sink it.  Otherwise, do nothing."}],"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/VariantProtocol"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"takeRef","kind":"identifier"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:4GLib10VariantRefV","kind":"typeIdentifier","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef","text":"VariantRef"},{"text":"!","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Typically you want to use "},{"code":"g_variant_ref_sink()","type":"codeVoice"},{"text":" in order to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"automatically do the correct thing with respect to floating or"},{"type":"text","text":" "},{"text":"non-floating references, but there is one specific scenario where","type":"text"},{"type":"text","text":" "},{"type":"text","text":"this function is helpful."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The situation where this function is helpful is when creating an API"},{"text":" ","type":"text"},{"type":"text","text":"that allows the user to provide a callback function that returns a"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"type":"text","text":".  We certainly want to allow the user the flexibility to"},{"type":"text","text":" "},{"type":"text","text":"return a non-floating reference from this callback (for the case"},{"type":"text","text":" "},{"type":"text","text":"where the value that is being returned already exists)."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"At the same time, the style of the "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"type":"text","text":" API makes it likely that"},{"text":" ","type":"text"},{"type":"text","text":"for newly-created "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"type":"text","text":" instances, the user can be saved some"},{"text":" ","type":"text"},{"text":"typing if they are allowed to return a ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true,"type":"reference"},{"type":"text","text":" with a floating"},{"text":" ","type":"text"},{"type":"text","text":"reference."}]},{"type":"paragraph","inlineContent":[{"text":"Using this function on the return value of the user’s callback allows","type":"text"},{"text":" ","type":"text"},{"text":"the user to do whichever is more convenient for them.  The caller","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"will always receives exactly one full reference to the value: either"},{"type":"text","text":" "},{"text":"the one that was returned in the first place, or a floating reference","type":"text"},{"text":" ","type":"text"},{"text":"that has been converted to a full reference.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This function has an odd interaction when combined with","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_variant_ref_sink()"},{"type":"text","text":" running at the same time in another thread on"},{"text":" ","type":"text"},{"type":"text","text":"the same "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true,"type":"reference"},{"type":"text","text":" instance.  If "},{"code":"g_variant_ref_sink()","type":"codeVoice"},{"type":"text","text":" runs first then"},{"type":"text","text":" "},{"type":"text","text":"the result will be that the floating reference is converted to a hard"},{"type":"text","text":" "},{"type":"text","text":"reference.  If "},{"type":"codeVoice","code":"g_variant_take_ref()"},{"text":" runs first then the result will","type":"text"},{"text":" ","type":"text"},{"text":"be that the floating reference is converted to a hard reference and","type":"text"},{"type":"text","text":" "},{"text":"an additional reference on top of that one is added.  It is best to","type":"text"},{"type":"text","text":" "},{"text":"avoid this situation.","type":"text"}]}],"kind":"content"}],"kind":"symbol","references":{"doc://GLib/documentation/GLib/Variant":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Variant"}],"kind":"symbol","title":"Variant","role":"symbol","abstract":[{"type":"codeVoice","code":"GVariant"},{"type":"text","text":" is a variant datatype; it can contain one or more values"},{"text":" ","type":"text"},{"type":"text","text":"along with information about the type of the values."}],"url":"\/documentation\/glib\/variant","navigatorTitle":[{"text":"Variant","kind":"identifier"}]},"doc://GLib/documentation/GLib/VariantProtocol/takeRef()":{"title":"takeRef()","url":"\/documentation\/glib\/variantprotocol\/takeref()","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantProtocol\/takeRef()","role":"symbol","type":"topic","abstract":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"value"},{"type":"text","text":" is floating, sink it.  Otherwise, do nothing."}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"takeRef","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"VariantRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV"},{"kind":"text","text":"!"}],"kind":"symbol"},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/VariantProtocol":{"url":"\/documentation\/glib\/variantprotocol","navigatorTitle":[{"kind":"identifier","text":"VariantProtocol"}],"title":"VariantProtocol","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantProtocol","abstract":[{"code":"GVariant","type":"codeVoice"},{"text":" is a variant datatype; it can contain one or more values","type":"text"},{"text":" ","type":"text"},{"text":"along with information about the type of the values.","type":"text"}],"kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"VariantProtocol","kind":"identifier"}],"type":"topic"},"doc://GLib/documentation/GLib/VariantRef":{"role":"symbol","type":"topic","url":"\/documentation\/glib\/variantref","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef","abstract":[{"code":"GVariant","type":"codeVoice"},{"text":" is a variant datatype; it can contain one or more values","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"along with information about the type of the values."}],"kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"VariantRef","kind":"ide