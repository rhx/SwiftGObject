type":"text","text":"string will be replaced with spaces in the output. For example, "},{"type":"codeVoice","code":"foo=bar+baz"},{"type":"text","text":" "},{"text":"will give attribute ","type":"text"},{"code":"foo","type":"codeVoice"},{"text":" with value ","type":"text"},{"code":"bar baz","type":"codeVoice"},{"type":"text","text":". This is commonly used on the"},{"text":" ","type":"text"},{"type":"text","text":"web (the "},{"type":"codeVoice","code":"https"},{"type":"text","text":" and "},{"type":"codeVoice","code":"http"},{"type":"text","text":" schemes only), but is deprecated in favour of"},{"type":"text","text":" "},{"type":"text","text":"the equivalent of encoding spaces as "},{"type":"codeVoice","code":"20"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Unlike with "},{"type":"codeVoice","code":"g_uri_parse_params()"},{"text":", ","type":"text"},{"type":"codeVoice","code":"caseInsensitive"},{"type":"text","text":" has no"},{"text":" ","type":"text"},{"text":"effect if passed to ","type":"text"},{"code":"flags","type":"codeVoice"},{"type":"text","text":" for "},{"type":"codeVoice","code":"g_uri_params_iter_init()"},{"text":". The caller is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"responsible for doing their own case-insensitive comparisons."}]},{"inlineContent":[{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"type":"codeListing","syntax":"C","code":["GUriParamsIter iter;","GError *error = NULL;","gchar *unowned_attr, *unowned_value;","","g_uri_params_iter_init (&iter, \"foo=bar&baz=bar&Foo=frob&baz=bar2\", -1, \"&\", G_URI_PARAMS_NONE);","while (g_uri_params_iter_next (&iter, &unowned_attr, &unowned_value, &error))","  {","    g_autofree gchar *attr = g_steal_pointer (&unowned_attr);","    g_autofree gchar *value = g_steal_pointer (&unowned_value);","    \/\/ do something with attr and value; this code will be called 4 times","    \/\/ for the params string in this example: once with attr=foo and value=bar,","    \/\/ then with baz\/bar, then Foo\/frob, then baz\/bar2.","  }","if (error)","  \/\/ handle parsing error"]}]}],"kind":"symbol","identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/URIParamsIterRef\/init_(params:length:separators:flags:)","interfaceLanguage":"swift"},"references":{"doc://GLib/documentation/GLib/URIParamsIterRef":{"abstract":[{"text":"Many URI schemes include one or more attribute\/value pairs as part of the URI","type":"text"},{"text":" ","type":"text"},{"text":"value. For example ","type":"text"},{"type":"codeVoice","code":"scheme:\/\/server\/path?query=string&is=there"},{"type":"text","text":" has two"},{"text":" ","type":"text"},{"type":"text","text":"attributes – "},{"code":"query=string","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"is=there"},{"type":"text","text":" – in its query part."}],"url":"\/documentation\/glib\/uriparamsiterref","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"URIParamsIterRef","kind":"identifier"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"URIParamsIterRef"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/URIParamsIterRef","title":"URIParamsIterRef","kind":"symbol","type":"topic"},"doc://GLib/documentation/GLib/URIParamsFlags":{"role":"symbol","abstract":[{"text":"Flags modifying the way parameters are handled by ","type":"text"},{"code":"g_uri_parse_params()","type":"codeVoice"},{"text":" and","type":"text"},{"type":"text","text":" "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/URIParamsIter","type":"reference","isActive":true},{"text":".","type":"text"}],"url":"\/documentation\/glib\/uriparamsflags","navigatorTitle":[{"kind":"identifier","text":"URIParamsFlags"}],"type":"topic","title":"URIParamsFlags","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/URIParamsFlags","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"URIParam