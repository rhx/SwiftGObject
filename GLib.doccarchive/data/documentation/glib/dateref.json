now the underlying data type the pointer points to conforms to "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateProtocol","isActive":true},{"text":".","type":"text"}],"type":"strong"}]},"doc://GLib/documentation/GLib/DateRef/init()":{"url":"\/documentation\/glib\/dateref\/init()","title":"init()","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateRef\/init()","abstract":[{"text":"Allocates a ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Date","isActive":true,"type":"reference"},{"type":"text","text":" and initializes"},{"type":"text","text":" "},{"type":"text","text":"it to a safe state. The new date will"},{"text":" ","type":"text"},{"type":"text","text":"be cleared (as if you’d called "},{"type":"codeVoice","code":"g_date_clear()"},{"text":") but invalid (it won’t","type":"text"},{"type":"text","text":" "},{"text":"represent an existing day). Free the return value with ","type":"text"},{"type":"codeVoice","code":"g_date_free()"},{"type":"text","text":"."}],"role":"symbol","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"()"}],"kind":"symbol"},"doc://GLib/documentation/GLib/DateRef/init(_:)-5vh9g":{"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateRef\/init(_:)-5vh9g","url":"\/documentation\/glib\/dateref\/init(_:)-5vh9g","fragments":[{"text":"init","kind":"identifier"},{"kind":"text","text":"!("},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"GDate","kind":"typeIdentifier"},{"kind":"text","text":">?)"}],"abstract":[{"text":"Conditional initialiser from an optional pointer to the underlying ","type":"text"},{"type":"codeVoice","code":"C"},{"type":"text","text":" data type"}],"kind":"symbol","role":"symbol","title":"init(_:)"},"doc://GLib/documentation/GLib/DateRef/new(julian:)":{"role":"symbol","type":"topic","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateRef\/new(juli