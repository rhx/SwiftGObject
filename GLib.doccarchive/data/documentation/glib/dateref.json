{"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"relationshipsSections":[{"title":"Conforms To","identifiers":["doc:\/\/GLib\/documentation\/GLib\/DateProtocol","doc:\/\/GLib\/documentation\/GLib\/PointerWrapper"],"type":"conformsTo","kind":"relationships"}],"topicSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/DateRef\/init()","doc:\/\/GLib\/documentation\/GLib\/DateRef\/init(_:)-15l2w","doc:\/\/GLib\/documentation\/GLib\/DateRef\/init(_:)-5vh9g","doc:\/\/GLib\/documentation\/GLib\/DateRef\/init(_:)-6v7fp","doc:\/\/GLib\/documentation\/GLib\/DateRef\/init(_:)-7pk3a","doc:\/\/GLib\/documentation\/GLib\/DateRef\/init(_:)-9375e","doc:\/\/GLib\/documentation\/GLib\/DateRef\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/DateRef\/init(constPointer:)","doc:\/\/GLib\/documentation\/GLib\/DateRef\/init(dmy:month:year:)","doc:\/\/GLib\/documentation\/GLib\/DateRef\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/DateRef\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/DateRef\/init(julian:)","doc:\/\/GLib\/documentation\/GLib\/DateRef\/init(mutating:)","doc:\/\/GLib\/documentation\/GLib\/DateRef\/init(opaquePointer:)"],"title":"Initializers","anchor":"Initializers","generated":true},{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/DateRef\/ptr"],"generated":true,"title":"Instance Properties","anchor":"Instance-Properties"},{"generated":true,"title":"Type Methods","anchor":"Type-Methods","identifiers":["doc:\/\/GLib\/documentation\/GLib\/DateRef\/new(dmy:month:year:)","doc:\/\/GLib\/documentation\/GLib\/DateRef\/new(julian:)"]},{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/DateRef\/DateProtocol-Implementations","doc:\/\/GLib\/documentation\/GLib\/DateRef\/PointerWrapper-Implementations"],"generated":true,"title":"Default Implementations","anchor":"Default-Implementations"}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"DateRef"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Overview","level":2,"anchor":"overview","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"GDate"},{"text":" data structure represents a day between January 1, Year 1,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and sometime a few thousand years in the future (right now it will go"},{"type":"text","text":" "},{"text":"to the year 65535 or so, but [method","type":"text"},{"type":"codeVoice","code":"GLib.Date.set_parse"},{"type":"text","text":"] only parses up to the"},{"text":" ","type":"text"},{"type":"text","text":"year 8000 or so - just count on “a few thousand”). "},{"code":"GDate","type":"codeVoice"},{"text":" is meant to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"represent everyday dates, not astronomical dates or historical dates"},{"text":" ","type":"text"},{"text":"or ISO timestamps or the like. It extrapolates the current Gregorian","type":"text"},{"type":"text","text":" "},{"type":"text","text":"calendar forward and backward in time; there is no attempt to change"},{"text":" ","type":"text"},{"type":"text","text":"the calendar to match time periods or locations. "},{"type":"codeVoice","code":"GDate"},{"text":" does not store","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"time information; it represents a day."}]},{"inlineContent":[{"type":"text","text":"The "},{"code":"GDate","type":"codeVoice"},{"type":"text","text":" implementation has several nice features; it is only a"},{"type":"text","text":" "},{"type":"text","text":"64-bit struct, so storing large numbers of dates is very efficient. It"},{"text":" ","type":"text"},{"type":"text","text":"can keep both a Julian and day-month-year representation of the date,"},{"text":" ","type":"text"},{"text":"since some calculations are much easier with one representation or the","type":"text"},{"text":" ","type":"text"},{"text":"other. A Julian representation is simply a count of days since some","type":"text"},{"type":"text","text":" "},{"text":"fixed day in the past; for ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Date","isActive":true},{"type":"text","text":" the fixed day is January 1, 1 AD."},{"type":"text","text":" "},{"type":"text","text":"(“Julian” dates in the "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Date","isActive":true,"type":"reference"},{"text":" API aren’t really Julian dates in the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"technical sense; technically, Julian dates count from the start of the"},{"type":"text","text":" "},{"text":"Julian period, Jan 1, 4713 BC).","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"GDate"},{"text":" is simple to use. First you need a “blank” date; you can get a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"dynamically allocated date from [ctor"},{"type":"codeVoice","code":"GLib.Date.new"},{"text":"], or you can declare an","type":"text"},{"type":"text","text":" "},{"type":"text","text":"automatic variable or array and initialize it by calling [method"},{"type":"codeVoice","code":"GLib.Date.clear"},{"type":"text","text":"]."},{"type":"text","text":" "},{"type":"text","text":"A cleared date is safe; it’s safe to call [method"},{"type":"codeVoice","code":"GLib.Date.set_dmy"},{"type":"text","text":"] and the other"},{"text":" ","type":"text"},{"type":"text","text":"mutator functions to initialize the value of a cleared date. However, a cleared date"},{"text":" ","type":"text"},{"text":"is initially invalid, meaning that it doesn’t represent a day that exists.","type":"text"},{"type":"text","text":" "},{"text":"It is undefined to call any of the date calculation routines on an invalid date.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"If you obtain a date from a user or other unpredictable source, you should check"},{"text":" ","type":"text"},{"type":"text","text":"its validity with the [method"},{"type":"codeVoice","code":"GLib.Date.valid"},{"type":"text","text":"] predicate. [method"},{"code":"GLib.Date.valid","type":"codeVoice"},{"text":"]","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is also used to check for errors with [method"},{"code":"GLib.Date.set_parse","type":"codeVoice"},{"text":"] and other functions","type":"text"},{"type":"text","text":" "},{"type":"text","text":"that can fail. Dates can be invalidated by calling [method"},{"code":"GLib.Date.clear","type":"codeVoice"},{"type":"text","text":"] again."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"It is very important to use the API to access the ","type":"text"},{"type":"codeVoice","code":"GDate"},{"type":"text","text":" struct. Often only the"},{"text":" ","type":"text"},{"type":"text","text":"day-month-year or only the Julian representation is valid. Sometimes neither is valid."},{"type":"text","text":" "},{"type":"text","text":"Use the API."}]},{"inlineContent":[{"type":"text","text":"GLib also features "},{"type":"codeVoice","code":"GDateTime"},{"type":"text","text":" which represents a precise time."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateRef","type":"reference","isActive":true},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"code":"GDate","type":"codeVoice"},{"text":" instance.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateProtocol","isActive":true},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"text":"Use ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateRef","isActive":true},{"type":"text","text":" only as an "},{"type":"codeVoice","code":"unowned"},{"text":" reference to an existing ","type":"text"},{"code":"GDate","type":"codeVoice"},{"text":" instance.","type":"text"}],"type":"paragraph"},{"style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Date","type":"reference"},{"type":"text","text":" (instead of "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateRef","type":"reference"},{"text":") if you want to use Automatic Reference Counting for memory management of the underlying ","type":"text"},{"code":"GDate","type":"codeVoice"},{"type":"text","text":" instance."}]}],"type":"aside"}]}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/DateRef","interfaceLanguage":"swift"},"metadata":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"DateRef"}],"symbolKind":"struct","roleHeading":"Structure","title":"DateRef","navigatorTitle":[{"kind":"identifier","text":"DateRef"}],"externalID":"s:4GLib7DateRefV","modules":[{"name":"GLib"}],"role":"symbol"},"abstract":[{"type":"codeVoice","code":"GDate"},{"text":" is a struct for calendrical calculations.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/dateref"]}],"kind":"symbol","references":{"doc://GLib/documentation/GLib/DateRef/init(_:)-7pk3a":{"url":"\/documentation\/glib\/dateref\/init(_:)-7pk3a","role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateRef\/init(_:)-7pk3a","type":"topic","abstract":[{"text":"Designated initialiser from the underlying ","type":"text"},{"type":"codeVoice","code":"C"},{"type":"text","text":" data type"}],"kind":"symbol","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"text":"UnsafeMutablePoin