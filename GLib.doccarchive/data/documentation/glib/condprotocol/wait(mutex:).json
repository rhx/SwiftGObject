{"kind":"symbol","variants":[{"paths":["\/documentation\/glib\/condprotocol\/wait(mutex:)"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/CondProtocol\/wait(mutex:)"},"abstract":[{"type":"text","text":"Atomically releases "},{"type":"codeVoice","code":"mutex"},{"type":"text","text":" and waits until "},{"code":"cond","type":"codeVoice"},{"type":"text","text":" is signalled."},{"type":"text","text":" "},{"type":"text","text":"When this function returns, "},{"type":"codeVoice","code":"mutex"},{"type":"text","text":" is locked again and owned by the"},{"type":"text","text":" "},{"type":"text","text":"calling thread."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"wait","kind":"identifier"},{"text":"<","kind":"text"},{"text":"MutexT","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"mutex","kind":"externalParam"},{"kind":"text","text":": "},{"text":"MutexT","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MutexT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:4GLib13MutexProtocolP","identifier":"doc:\/\/GLib\/documentation\/GLib\/MutexProtocol","text":"MutexProtocol","kind":"typeIdentifier"}],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"When using condition variables, it is possible that a spurious wakeup"},{"type":"text","text":" "},{"type":"text","text":"may occur (ie: "},{"type":"codeVoice","code":"g_cond_wait()"},{"type":"text","text":" returns even though "},{"code":"g_cond_signal()","type":"codeVoice"},{"type":"text","text":" was"},{"text":" ","type":"text"},{"text":"not called).  It’s also possible that a stolen wakeup may occur.","type":"text"},{"type":"text","text":" "},{"text":"This is when ","type":"text"},{"type":"codeVoice","code":"g_cond_signal()"},{"text":" is called, but another thread acquires","type":"text"},{"text":" ","type":"text"},{"code":"mutex","type":"codeVoice"},{"text":" before this thread and modifies the state of the program in","type":"text"},{"type":"text","text":" "},{"type":"text","text":"such a way that when "},{"type":"codeVoice","code":"g_cond_wait()"},{"type":"text","text":" is able to return, the expected"},{"type":"text","text":" "},{"type":"text","text":"condition is no longer met."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For this reason, "},{"code":"g_cond_wait()","type":"codeVoice"},{"text":" must always be used in a loop.  See","type":"text"},{"type":"text","text":" "},{"text":"the documentation for ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond"},{"type":"text","text":" for a complete example."}]}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/CondProtocol"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"metadata":{"modules":[{"name":"GLib"}],"extendedModule":"GLib","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"wait","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"MutexT"},{"kind":"text","text":">("},{"text":"mutex","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"MutexT"},{"text":")","kind":"text"}],"externalID":"s:4GLib12CondProtocolPAAE4wait5mutexyqd___tAA05MutexC0Rd__lF","roleHeading":"Instance Method","role":"symbol","title":"wait(mutex:)","symbolKind":"method"},"references":{"doc://GLib/documentation/GLib/Mutex":{"title":"Mutex","type":"topic","abstract":[{"text":"The ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex"