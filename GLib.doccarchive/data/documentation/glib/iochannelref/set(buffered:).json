{"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"title":"set(buffered:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"set"},{"kind":"text","text":"("},{"kind":"externalParam","text":"buffered"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"text":")","kind":"text"}],"modules":[{"name":"GLib"}],"role":"symbol","symbolKind":"method","extendedModule":"GLib","externalID":"s:4GLib17IOChannelProtocolPAAE3set8bufferedySb_tF::SYNTHESIZED::s:4GLib12IOChannelRefV","roleHeading":"Instance Method"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/IOChannelRef","doc:\/\/GLib\/documentation\/GLib\/IOChannelRef\/IOChannelProtocol-Implementations"]]},"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/IOChannelRef\/set(buffered:)"},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/iochannelref\/set(buffered:)"]}],"abstract":[{"text":"The buffering state can only be set if the channel’s encoding","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is "},{"type":"codeVoice","code":"nil"},{"text":". For any other encoding, the channel must be buffered.","type":"text"}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"set","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"buffered"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"kind":"text","text":")"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A buffered channel can only be set unbuffered if the channel’s"},{"type":"text","text":" "},{"text":"internal buffers have been flushed. Newly created channels or","type":"text"},{"type":"text","text":" "},{"type":"text","text":"channels which have returned "},{"code":"eof","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"not require such a flush. For write-only channels, a call to"},{"type":"text","text":" "},{"type":"text","text":"g_io_channel_flush () is sufficient. For all other channels,"},{"type":"text","text":" "},{"text":"the buffers may be flushed by a call to g_io_channel_seek_position ().","type":"text"},{"text":" ","type":"text"},{"text":"This includes the possibility of seeking with seek type ","type":"text"},{"type":"codeVoice","code":"cur"},{"text":" ","type":"text"},{"text":"and an offset of zero. Note that this means that socket-based","type":"text"},{"text":" ","type":"text"},{"text":"channels cannot be set unbuffered once they have had data","type":"text"},{"type":"text","text":" "},{"text":"read from them.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On unbuffered channels, it is safe to mix read and write"},{"text":" ","type":"text"},{"type":"text","text":"calls from the new and old APIs, if this is necessary for"},{"type":"text","text":" "},{"type":"text","text":"maintaining old code."}]},{"type":"paragraph","inlineContent":[{"text":"The default state of the channel is buffered.","type":"text"}]}]}],"references":{"doc://GLib/documentation/GLib/IOChannelRef/IOChannelProtocol-Implementations":{"role":"collectionGroup","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannelRef\/IOChannelProtocol-Implementations","kind":"article","title":"IOChannelProtocol Implementations","abstract":[],"type":"topic","url":"\/documentation\/glib\/iochannelref\/iochannelprotocol-implementations"},"doc://GLib/documentation/GLib/IOChannelRef/set(buffered:)":{"title":"set(buffered:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"set"},{"kind":"text","text":"("},{"kind":"externalParam","text":"buffered"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"kind":"text","text":")"}],"type":"topic","url":"\/documentation\/glib\/iochannelref\/set(buffered:)","kind":"symbol","abstract":[{"text":"The buffering state can only be set if the channel’s encoding","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is "},{"type":"codeVoice","code":"nil"},{"type":"text","text":". For any other encoding, the channel must be buffered."}],"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannelRef\/set(buffered:)"},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/MainContext":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MainContext"}],"url":"\/documentation\/glib\/maincontext","kind":"symbol","abstract":[{"type":"text","text":"The "},{"code":"GMainContext","type":"codeVoice"},{"type":"text","text":" struct is an opaque data"},{"text":" ","type":"text"},{"text":"type representing a set of sources to be handled in a main loop.","type":"text"}],"title":"MainContext","role":"symbol","navigatorTitle":[{"text":"MainContext","kind":"identifier"}]},"doc://GLib/documentation/GLib/IOChannelRef":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannelRef","title":"IOChannelRef","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"IOChannelRef"}],"navigatorTitle":[{"kind":"identifier","text":"IOChannelRef"}],"url":"\/documentation\/glib\/iochannelref","abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"GIOChannel"},{"text":" data type aims to provide a portable method for","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"using file descriptors, pipes, and sockets, and integrating them"},{"type":"text","text":" "},{"text":"into the main event loop (see [struct","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","type":"reference"},{"type":"text","text":"]). Currently,"},{"type":"text","text":" "},{"text":"full support is available on UNIX platforms; support for Windows","type":"text"},{"text":" ","type":"text"},{"text":"is only partially complete.","type":"text"}],"type":"topic","role":"symbol"}}}