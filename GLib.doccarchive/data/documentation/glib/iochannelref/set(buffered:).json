{"abstract":[{"text":"The buffering state can only be set if the channel’s encoding","type":"text"},{"text":" ","type":"text"},{"text":"is ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":". For any other encoding, the channel must be buffered."}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/IOChannelRef\/set(buffered:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/IOChannelRef","doc:\/\/GLib\/documentation\/GLib\/IOChannelRef\/IOChannelProtocol-Implementations"]]},"metadata":{"externalID":"s:4GLib17IOChannelProtocolPAAE3set8bufferedySb_tF::SYNTHESIZED::s:4GLib12IOChannelRefV","extendedModule":"GLib","symbolKind":"method","role":"symbol","modules":[{"name":"GLib"}],"title":"set(buffered:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"set","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"buffered"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":")"}],"roleHeading":"Instance Method"},"variants":[{"paths":["\/documentation\/glib\/iochannelref\/set(buffered:)"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"set"},{"text":"(","kind":"text"},{"text":"buffered","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"},{"text":")","kind":"text"}],"platforms":["macOS"]}]},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"inlineContent":[{"text":"A buffered channel can only be set unbuffered if the channel’s","type":"text"},{"type":"text","text":" "},{"text":"internal buffers have been flushed. Newly created channels or","type":"text"},{"text":" ","type":"text"},{"text":"channels which have returned ","type":"text"},{"code":"eof","type":"codeVoice"},{"text":" ","type":"text"},{"text":"not require such a flush. For write-only channels, a call to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"g_io_channel_flush () is sufficient. For all other channels,"},{"type":"text","text":" "},{"text":"the buffers may be flushed by a call to g_io_channel_seek_position ().","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"This includes the possibility of seeking with seek type "},{"type":"codeVoice","code":"cur"},{"type":"text","text":" "},{"type":"text","text":"and an offset of zero. Note that this means that socket-based"},{"type":"text","text":" "},{"type":"text","text":"channels cannot be set unbuffered once they have had data"},{"type":"text","text":" "},{"type":"text","text":"read from them."}],"type":"paragraph"},{"inlineContent":[{"text":"On unbuffered channels, it is safe to mix read and write","type":"text"},{"text":" ","type":"text"},{"text":"calls from the new and old APIs, if this is necessary for","type":"text"},{"type":"text","text":" "},{"type":"text","text":"maintaining old code."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The default state of the channel is buffered."}]}],"kind":"content"}],"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"references":{"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/IOChannelRef":{"url":"\/documentation\/glib\/iochannelref","title":"IOChannelRef","abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"GIOChannel"},{"text":" data type aims to provide a portable method for","type":"text"},{"text":" ","type":"text"},{"text":"using file descriptors, pipes, and sockets, and integrating them","type":"text"},{"type":"text","text":" "},{"type":"text","text":"into the main event loop (see [struct"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","isActive":true,"type":"reference"},{"type":"text","text":"]). Currently,"},{"text":" ","type":"text"},{"type":"text","text":"full support is available on UNIX platforms; support for Windows"},{"text":" ","type":"text"},{"text":"is only partially complete.","type":"text"}],"kind":"symbol","type":"topic","role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannelRef","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"IOChannelRef","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"IOChannelRef"}]},"doc://GLib/documentation/GLib/IOChannelRef/IOChannelProtocol-Implementations":{"title":"IOChannelProtocol Implementations","abstract":[],"kind":"article","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannelRef\/IOChannelProtocol-Implementations","role":"collectionGroup","url":"\/documentation\/glib\/iochannelref\/iochannelprotocol-implementations","type":"topic"},"doc://GLib/documentation/GLib/MainContext":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","role":"symbol","type":"topic","navigatorTitle":[{"text":"MainContext","kind":"identifier"}],"abstract":[{"type":"text","text":"The "},{"code":"GMainContext","type":"codeVoice"},{"text":" struct is an opaque data","type":"text"},{"type":"text","text":" "},{"text":"type representing a set of sources to be handled in a main loop.","type":"text"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"MainContext","kind":"identifier"}],"url":"\/documentation\/glib\/maincontext","title":"MainContext","kind":"symbol"},"doc://GLib/documentation/GLib/IOChannelRef/set(buffered:)":{"url":"\/documentation\/glib\/iochannelref\/set(buffered:)","abstract":[{"type":"text","text":"The buffering state can only be set if the channel’s encoding"},{"type":"text","text":" "},{"text":"is ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":". For any other encoding, the channel must be buffered."}],"type":"topic","title":"set(buffered:)","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannelRef\/set(buffered:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"set","kind":"identifier"},{"kind":"text","text":"("},{"text":"buffered","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"kind":"text","text":")"}],"kind":"symbol","role":"symbol"}}}