{"abstract":[{"type":"text","text":"Sets the encoding for the input\/output of the channel."},{"type":"text","text":" "},{"type":"text","text":"The internal encoding is always UTF-8. The default encoding"},{"type":"text","text":" "},{"type":"text","text":"for the external file is UTF-8."}],"sections":[],"metadata":{"title":"set(encoding:)","modules":[{"name":"GLib"}],"role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"set","kind":"identifier"},{"kind":"text","text":"("},{"text":"encoding","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier","text":"gchar"},{"text":">?) ","kind":"text"},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"text":"GIOStatus","kind":"typeIdentifier","preciseIdentifier":"c:@EA@GIOStatus"}],"extendedModule":"GLib","roleHeading":"Instance Method","externalID":"s:4GLib17IOChannelProtocolPAAE3set8encodingSo9GIOStatusaSPys4Int8VGSg_tKF::SYNTHESIZED::s:4GLib12IOChannelRefV","symbolKind":"method"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/IOChannelRef","doc:\/\/GLib\/documentation\/GLib\/IOChannelRef\/IOChannelProtocol-Implementations"]]},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/IOChannelRef\/set(encoding:)","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"set","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"encoding"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">? = nil) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"c:@EA@GIOStatus","text":"GIOStatus","kind":"typeIdentifier"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The encoding ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" is safe to use with binary data."}]},{"inlineContent":[{"text":"The encoding can only be set if one of the following conditions","type":"text"},{"text":" ","type":"text"},{"text":"is true:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"The channel was just created, and has not been written to or read from yet.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"The channel is write-only."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"The channel is a file, and the file pointer was just repositioned","type":"text"},{"type":"text","text":" "},{"type":"text","text":"by a call to "},{"type":"codeVoice","code":"g_io_channel_seek_position()"},{"text":". (This flushes all the","type":"text"},{"text":" ","type":"text"},{"text":"internal buffers.)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The current encoding is "},{"type":"codeVoice","code":"nil"},{"text":" or UTF-8.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"One of the (new API) read functions has just returned "},{"code":"eof","type":"codeVoice"},{"type":"text","text":" "},{"text":"(or, in the case of ","type":"text"},{"type":"codeVoice","code":"g_io_channel_read_to_end()"},{"type":"text","text":", "},{"code":"normal","type":"codeVoice"},{"type":"text","text":")."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"One of the functions "},{"type":"codeVoice","code":"g_io_channel_read_chars()"},{"type":"text","text":" or"},{"type":"text","text":" "},{"code":"g_io_channel_read_unichar()","type":"codeVoice"},{"type":"text","text":" has returned "},{"code":"again","type":"codeVoice"},{"type":"text","text":" or"},{"type":"text","text":" "},{"code":"error","type":"codeVoice"},{"type":"text","text":". This may be useful in the case of"},{"type":"text","text":" "},{"code":"illegalSequence","type":"codeVoice"},{"text":".","type":"text"},{"type":"text","text":" "},{"text":"Returning one of these statuses from ","type":"text"},{"type":"codeVoice","code":"g_io_channel_read_line()"},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_io_channel_read_line_string()"},{"type":"text","text":", or "},{"type":"codeVoice","code":"g_io_channel_read_to_end()"},{"text":" ","type":"text"},{"type":"text","text":"does not guarantee that the encoding can be changed."}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Channels which do not meet one of the above conditions cannot call"},{"type":"text","text":" "},{"code":"g_io_channel_seek_position()","type":"codeVoice"},{"text":" with an offset of ","type":"text"},{"code":"cur","type":"codeVoice"},{"text":", and, if","type":"text"},{"type":"text","text":" "},{"text":"they are “seekable”, cannot call ","type":"text"},{"code":"g_io_channel_write_chars()","type":"codeVoice"},{"text":" after","type":"text"},{"text":" ","type":"text"},{"text":"calling one of the API “read” functions.","type":"text"}]}],"kind":"content"}],"schemaVersion":{"patch":0,"minor":3,"major":0},"variants":[{"paths":["\/documentation\/glib\/iochannelref\/set(encoding:)"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GLib/documentation/GLib/IOChannelRef/set(encoding:)":{"title":"set(encoding:)","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannelRef\/set(encoding:)","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"set","kind":"identi