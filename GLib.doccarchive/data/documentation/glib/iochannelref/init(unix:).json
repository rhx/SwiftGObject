{"kind":"symbol","sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"unix"},{"kind":"text","text":" "},{"kind":"internalParam","text":"fd"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":")"}],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"The returned ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","type":"reference","isActive":true},{"text":" has a reference count of 1.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The default encoding for "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","isActive":true},{"type":"text","text":" is UTF-8. If your application"},{"type":"text","text":" "},{"text":"is reading output from a command using via pipe, you may need to set","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the encoding to the encoding of the current locale (see"},{"type":"text","text":" "},{"code":"g_get_charset()","type":"codeVoice"},{"text":") with the ","type":"text"},{"type":"codeVoice","code":"g_io_channel_set_encoding()"},{"type":"text","text":" function."},{"type":"text","text":" "},{"text":"By default, the fd passed will not be closed when the final reference","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel"},{"text":" data structure is dropped.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If you want to read raw binary data without interpretation, then","type":"text"},{"type":"text","text":" "},{"type":"text","text":"call the "},{"type":"codeVoice","code":"g_io_channel_set_encoding()"},{"type":"text","text":" function with "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" for the"},{"type":"text","text":" "},{"text":"encoding argument.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function is available in GLib on Windows, too, but you should"},{"type":"text","text":" "},{"text":"avoid using it on Windows. The domain of file descriptors and","type":"text"},{"text":" ","type":"text"},{"text":"sockets overlap. There is no way for GLib to know which one you mean","type":"text"},{"type":"text","text":" "},{"type":"text","text":"in case the argument you pass to this function happens to be both a"},{"type":"text","text":" "},{"type":"text","text":"valid file descriptor and socket. If that happens a warning is"},{"type":"text","text":" "},{"type":"text","text":"issued, and GLib assumes that it is the file descriptor you mean."}]}]}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/IOChannelRef\/init(unix:)","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"role":"symbol","symbolKind":"init","title":"init(unix:)","extendedModule":"GLib","fragments":[{"kind":"identifier","text":"init"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"unix"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":")","kind":"text"}],"externalID":"s:4GLib12IOChannelRefV4unixACSi_tcfc","roleHeading":"Initializer","modules":[{"name":"GLib"}]},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/IOChannelRef"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/iochannelref\/init(unix:)"]}],"abstract":[{"type":"text","text":"Creates a new "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","isActive":true,"type":"reference"},{"text":" given a file descriptor. On UNIX systems","type":"text"},{"text":" ","type":"text"},{"text":"this works for plain files, pipes, and sockets.","type":"text"}],"references":{"doc://GLib/documentation/GLib/IOChannelRef":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannelRef","title":"IOChannelRef","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"IOChannelRef"}],"navigatorTitle":[{"kind":"identifier","text":"IOChannelRef"}],"url":"\/documentation\/glib\/iochannelref","abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"GIOChannel"},{"text":" data type aims to provide a portable method for","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"using file descriptors, pipes, and sockets, and integrating them"},{"type":"text","text":" "},{"text":"into the main event loop (see [struct","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","type":"reference"},{"type":"text","text":"]). Currently,"},{"type":"text","text":" "},{"text":"full support is available on UNIX platforms; support for Windows","type":"text"},{"text":" ","type":"text"},{"text":"is only partially complete.","type":"text"}],"type":"topic","role":"symbol"},"doc://GLib/documentation/GLib/IOChannelRef/init(unix:)":{"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannelRef\/init(unix:)","role":"symbol","kind":"symbol","title":"init(unix:)","abstract":[{"type":"text","text":"Creates a new "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel"},{"type":"text","text":" given a file descriptor. On UNIX systems"},{"type":"text","text":" "},{"type":"text","text":"this works for plain files, pipes, and sockets."}],"url":"\/documentation\/glib\/iochannelref\/init(unix:)","fragments":[{"text":"init","kind":"identifier"},{"kind":"text","text":"("},{"text":"unix","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"text":")","kind":