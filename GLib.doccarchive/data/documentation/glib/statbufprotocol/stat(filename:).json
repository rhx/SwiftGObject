{"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/StatBufProtocol\/stat(filename:)"},"abstract":[{"type":"text","text":"A wrapper for the POSIX "},{"code":"stat()","type":"codeVoice"},{"text":" function. The ","type":"text"},{"type":"codeVoice","code":"stat()"},{"text":" function","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"returns information about a file. On Windows the "},{"type":"codeVoice","code":"stat()"},{"text":" function in","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the C library checks only the FAT-style READONLY attribute and does"},{"text":" ","type":"text"},{"text":"not look at the ACL at all. Thus on Windows the protection bits in","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the "},{"type":"codeVoice","code":"st_mode"},{"type":"text","text":" field are a fabrication of little use."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/statbufprotocol\/stat(filename:)"]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/StatBufProtocol"]]},"metadata":{"extendedModule":"GLib","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"stat","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"filename"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">!) -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"modules":[{"name":"GLib"}],"externalID":"s:4GLib15StatBufProtocolPAAE4stat8filenameSiSPys4Int8VGSg_tF","title":"stat(filename:)","role":"symbol","symbolKind":"method"},"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"declarations":[{"language