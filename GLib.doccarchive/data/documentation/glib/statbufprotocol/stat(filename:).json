 the appropriate struct type","type":"text"},{"type":"text","text":" "},{"type":"text","text":"depending on the platform and\/or compiler being used. On POSIX it"},{"type":"text","text":" "},{"text":"is just struct stat, but note that even on POSIX platforms, ","type":"text"},{"code":"stat()","type":"codeVoice"},{"type":"text","text":" "},{"text":"might be a macro.","type":"text"}]},{"inlineContent":[{"text":"See your C library manual for more details about ","type":"text"},{"type":"codeVoice","code":"stat()"},{"type":"text","text":"."}],"type":"paragraph"}]}],"references":{"doc://GLib/documentation/GLib/StatBufProtocol":{"url":"\/documentation\/glib\/statbufprotocol","title":"StatBufProtocol","role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"StatBufProtocol"}],"type":"topic","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/StatBufProtocol","abstract":[{"type":"text","text":"A type corresponding to the appropriate struct type for the "},{"code":"stat()","type":"codeVoice"},{"type":"text","text":" "},{"text":"system call, depending on the platform and\/or compiler being used.","type":"text"}],"navigatorTitle":[{"text":"StatBufProtocol","kind":"identifier"}]},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/StatBufProtocol/stat(filename:)":{"kind":"symbol","type":"topic","abstract":[{"type":"text","text":"A wrapper for the POSIX "},{"type":"codeVoice","code":"stat()"},{"type":"text","text":" function. The "},{"code":"stat()","type":"codeVoice"},{"type":"text","text":" function"},{"text":" ","type":"text"},{"text":"returns information about a file. On Windows the ","type":"text"},{"type":"codeVoice","code":"stat()"},{"text":" function in","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the C library checks only the FAT-style READONLY attribute and does"},{"text":" ","type":"text"},{"type":"text","text":"not look at the ACL at all. Thus on Windows the protection bits in"},{"text":" ","type":"text"},{"type":"text","text":"the "},{"code":"st_mode","type":"codeVoice"},{"text":" field are a fabrication of little use.","type":"text"}],"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/StatBufProtocol\/stat(filename:)","title":"stat(filename:)","url":"\/documentation\/glib\/statbufprotocol\/stat(filename:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"stat"},{"text":"(","kind":"text"},{"text":"filename","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">!) -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}]},"doc://GLib/documentation/GLib/StatBuf":{"abstract":[{"type":"text","text":"A type corresponding to the appropriate struct type for the "},{"code":"stat()","type":"codeVoice"},{"type":"text","text":" "},{"text":"system call, depending on the platform and\/or compiler being used.","type":"text"}],"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/StatBuf","type":"topic","title":"StatBuf","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"StatBuf"}],"url":"\/documentation\/glib\/statbuf","kind":"symbol","navigatorTitle":[{"text":"StatBuf","kind":"identifier"}]}}}