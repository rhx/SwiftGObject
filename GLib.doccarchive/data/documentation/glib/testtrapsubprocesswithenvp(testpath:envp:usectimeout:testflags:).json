{"variants":[{"paths":["\/documentation\/glib\/testtrapsubprocesswithenvp(testpath:envp:usectimeout:testflags:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/testTrapSubprocessWithEnvp(testPath:envp:usecTimeout:testFlags:)","interfaceLanguage":"swift"},"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Respawns the test program to run only "},{"type":"codeVoice","code":"testPath"},{"type":"text","text":" in a subprocess with"},{"text":" ","type":"text"},{"text":"a given environment.","type":"text"}],"metadata":{"title":"testTrapSubprocessWithEnvp(testPath:envp:usecTimeout:testFlags:)","symbolKind":"func","role":"symbol","roleHeading":"Function","externalID":"s:4GLib26testTrapSubprocessWithEnvp0B4Path4envp11usecTimeout0B5FlagsySPys4Int8VGSg_SPyAJGSgs6UInt64VAA04TestdK0VtF","modules":[{"name":"GLib"}],"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"testTrapSubprocessWithEnvp","kind":"identifier"},{"text":"(","kind":"text"},{"text":"testPath","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:s5CChara","text":"CChar"},{"text":">?, ","kind":"text"},{"text":"envp","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"preciseIdentifier":"s:s5CChara","text":"CChar","kind":"typeIdentifier"},{"kind":"text","text":">?>!, "},{"kind":"externalParam","text":"usecTimeout"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@T@guint64","text":"guint64","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"testFlags","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib19TestSubprocessFlagsV","text":"TestSubprocessFlags"},{"text":")","kind":"text"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"testTrapSubprocessWithEnvp","kind":"identifier"},{"text":"(","kind":"text"},{"text":"testPath","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"CChar","kind":"typeIdentifier","preciseIdentifier":"s:s5CChara"},{"text":">? = nil, ","kind":"text"},{"kind":"externalParam","text":"envp"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"text":"CChar","kind":"typeIdentifier","preciseIdentifier":"s:s5CChara"},{"kind":"text","text":">?>! = nil, "},{"kind":"externalParam","text":"usecTimeout"},{"text":": ","kind":"text"},{"text":"guint64","kind":"typeIdentifier","preciseIdentifier":"c:@T@guint64"},{"kind":"text","text":", "},{"text":"testFlags","kind":"externalParam"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/TestSubprocessFlags","preciseIdentifier":"s:4GLib19TestSubprocessFlagsV","text":"TestSubprocessFlags","kind":"typeIdentifier"},{"text":")","kind":"text"}]}]},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"inlineContent":[{"text":"This can be used for a test case that might not return, or that","type":"text"},{"type":"text","text":" "},{"text":"might abort.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"code":"testPath","type":"codeVoice"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"NULL"},{"type":"text","text":" then the same test is re-run in a subprocess."},{"text":" ","type":"text"},{"text":"You can use [func","type":"text"},{"type":"codeVoice","code":"GLib.test_subprocess"},{"text":"] to determine whether the test","type":"text"},{"text":" ","type":"text"},{"text":"is in a subprocess or not.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"code":"testPath","type":"codeVoice"},{"text":" can also be the name of the parent test, followed by","type":"text"},{"type":"text","text":" "},{"type":"text","text":"“"},{"type":"codeVoice","code":"\/subprocess\/"},{"text":"” and then a name for the specific subtest (or just","type":"text"},{"type":"text","text":" "},{"text":"ending with “","type":"text"},{"type":"codeVoice","code":"\/subprocess"},{"text":"” if the test only has one child test);","type":"text"},{"text":" ","type":"text"},{"text":"tests with names of this form will automatically be skipped in the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"parent process."}],"type":"paragraph"},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"envp"},{"type":"text","text":" is "},{"type":"codeVoice","code":"NULL"},{"text":", the parent process’ environment will be inherited.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"usecTimeout"},{"type":"text","text":" is non-0, the test subprocess is aborted and"},{"type":"text","text":" "},{"type":"text","text":"considered failing if its run time exceeds it."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The subprocess behavior can be configured with [flags","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/TestSubprocessFlags","type":"reference"},{"type":"text","text":"]"},{"type":"text","text":" "},{"type":"text","text":"flags."}]},{"inlineContent":[{"text":"You can use methods such as [func","type":"text"},{"type":"codeVoice","code":"GLib.test_trap_assert_passed"},{"text":"],","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.test_trap_assert_failed"},{"text":"], and [func","type":"text"},{"type":"codeVoice","code":"GLib.test_trap_assert_stderr"},{"type":"text","text":"] to"},{"type":"text","text":" "},{"type":"text","text":"check the results of the subprocess. (But note that"},{"text":" ","type":"text"},{"text":"[func","type":"text"},{"type":"codeVoice","code":"GLib.test_trap_assert_stdout"},{"type":"text","text":"] and [func"},{"type":"codeVoice","code":"GLib.test_trap_assert_stderr"},{"text":"]","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"cannot be used if "},{"code":"testFlags","type":"codeVoice"},{"text":" specifies that the child should","type":"text"},{"text":" ","type":"text"},{"text":"inherit the parent stdout\/stderr.)","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If your "},{"type":"codeVoice","code":"main ()"},{"type":"text","text":" needs to behave differently in the subprocess, you can"},{"type":"text","text":" "},{"text":"call [func","type":"text"},{"code":"GLib.test_subprocess","type":"codeVoice"},{"type":"text","text":"] (after calling [func"},{"type":"codeVoice","code":"GLib.test_init"},{"type":"text","text":"])"},{"type":"text","text":" "},{"type":"text","text":"to see whether you are in a subprocess."}]},{"inlineContent":[{"type":"text","text":"Internally, this function tracks the child process using"},{"type":"text","text":" "},{"type":"text","text":"[func"},{"code":"GLib.child_watch_source_new","type":"codeVoice"},{"text":"], so your process must not ignore","type":"text"},{"text":" ","type":"text"},{"code":"SIGCHLD","type":"codeVoice"},{"text":", and must not attempt to watch or wait for the child process","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"via another mechanism."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The following example tests that calling "},{"type":"codeVoice","code":"my_object_new(1000000)"},{"type":"text","text":" will"},{"text":" ","type":"text"},{"text":"abort with an error message.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"c","code":["  static void","  test_create_large_object (void)","  {","    if (g_test_subprocess ())","      {","        my_object_new (1000000);","        return;","      }","","    \/\/ Reruns this same test in a subprocess","    g_test_trap_subprocess (NULL, 0, G_TEST_SUBPROCESS_DEFAULT);","    g_test_trap_assert_failed ();","    g_test_trap_assert_stderr (\"*ERROR*too large*\");","  }","","  static void","  test_different_username (void)","  {","    if (g_test_subprocess ())","      {","        \/\/ Code under test goes here","        g_message (\"Username is now simulated as `s`\", g_getenv (\"USER\"));","        return;","      }","","    \/\/ Reruns this same test in a subprocess","    `g_auto(GStrv)` envp = g_get_environ ();","    envp = g_environ_setenv (g_steal_pointer (&envp), \"USER\", \"charlie\", TRUE);","    g_test_trap_subprocess_with_envp (NULL, envp, 0, G_TEST_SUBPROCESS_DEFAULT);","    g_test_trap_assert_passed ();","    g_test_trap_assert_stdout (\"Username is now simulated as charlie\");","  }","","  int","  main (int argc, char **argv)","  {","    g_test_init (&argc, &argv, NULL);","","    g_test_add_func (\"\/myobject\/create-large-object\",","                     test_create_large_object);","    g_test_add_func (\"\/myobject\/different-username\",","                     test_different_username);","    return g_test_run ();","  }"]}],"kind":"content"}],"sections":[],"references":{"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/testTrapSubprocessWithEnvp(testPath:envp:usecTimeout:testFlags:)":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/testTrapSubprocessWithEnvp(testPath:envp:usecTimeout:testFlags:)","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"testTrapSubprocessWithEnvp","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"testPath"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"s:s5CChara","text":"CChar"},{"kind":"text","text":">?, "},{"text":"envp","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"CChar","preciseIdentifier":"s:s5CChara","kind":"typeIdentifier"},{"text":">?>!, ","kind":"text"},{"kind":"externalParam","text":"usecTimeout"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@guint64","text":"guint64","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"testFlags","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:4GLib19TestSubprocessFlagsV","kind":"typeIdentifier","text":"TestSubprocessFlags"},{"kind":"text","text":")"}],"title":"testTrapSubprocessWithEnvp(testPath:envp:usecTimeout:testFlags:)","url":"\/documentation\/glib\/testtrapsubprocesswithenvp(testpath:envp:usectimeout:testflags:)","role":"symbol","abstract":[{"text":"Respawns the test program to run only ","type":"text"},{"type":"codeVoice","code":"testPath"},{"type":"text","text":" in a subprocess with"},{"text":" ","type":"text"},{"text":"a given environment.","type":"text"}],"type":"topic"},"doc://GLib/documentation/GLib/TestSubprocessFlags":{"title":"TestSubprocessFlags","identifier":"doc:\/\/GLib\/documentation\/GLib\/TestSubprocessFlags","navigatorTitle":[{"text":"TestSubprocessFlags","kind":"identifier"}],"kind":"symbol","abstract":[{"type":"text","text":"Flags to pass to [func"},{"code":"GLib.test_trap_subprocess","type":"codeVoice"},{"type":"text","text":"] to control input and output."}],"url":"\/documentation\/glib\/testsubprocessflags","type":"topic","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TestSubprocessFlags","kind":"identifier"}]}}}