{"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol\/weekOfYear","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Returns the ISO 8601 week number for the week containing "},{"type":"codeVoice","code":"datetime"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The ISO 8601 week number is the same for every day of the week (from"},{"type":"text","text":" "},{"type":"text","text":"Moday through Sunday).  That can produce some unusual results"},{"text":" ","type":"text"},{"type":"text","text":"(described below)."}],"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol"]]},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/datetimeprotocol\/weekofyear"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"weekOfYear","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"kind":"text","text":" }"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"inlineContent":[{"type":"text","text":"The first week of the year is week 1.  This is the week that contains"},{"type":"text","text":" "},{"type":"text","text":"the first Thursday of the year.  Equivalently, this is the first week"},{"text":" ","type":"text"},{"text":"that has more than 4 of its days falling within the calendar year.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The value 0 is never returned by this function.  Days contained"},{"type":"text","text":" "},{"type":"text","text":"within a year but occurring before the first ISO 8601 week of that"},{"text":" ","type":"text"},{"type":"text","text":"year are considered as being contained in the last week of the"},{"text":" ","type":"text"},{"type":"text","text":"previous year.  Similarly, the final days of a calendar year may be"},{"text":" ","type":"text"},{"text":"considered as being part of the first ISO 8601 week of the next year","type":"text"},{"text":" ","type":"text"},{"text":"if 4 or more days of that week are contained within the new year.","type":"text"}],"type":"paragraph"}]}],"metadata":{"fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"weekOfYear","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"modules":[{"name":"GLib"}],"symbolKind":"property","extendedModule":"GLib","externalID":"s:4GLib16DateTimeProtocolPAAE10weekOfYearSivp","roleHeading":"Instance Property","title":"weekOfYear","role":"symbol"},"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://GLib/documentation/GLib/DateTimeProtocol/weekOfYear":{"url":"\/documentation\/glib\/datetimeprotocol\/weekofyear","kind":"symbol","title":"weekOfYear","abstract":[{"text":"Returns the ISO 8601 week number for the week containing ","type":"text"},{"type":"codeVoice","code":"datetime"},{"text":".","type":"text"},{"type":"text","text":" "},{"text":"The ISO 8601 week number is the same for every day of the week (from","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Moday through Sunday).  That can produce some unusual results"},{"text":" ","type":"text"},{"text":"(described below).","type":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol\/weekOfYear","type":"topic","role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"weekOfYear"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}]},"doc://GLib/documentation/GLib/DateTimeProtocol":{"type":"topic","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DateTimeProtocol","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol","role":"symbol","url":"\/documentation\/glib\/datetimeprotocol","navigatorTitle":[{"text":"DateTimeProtocol","kind":"identifier"}],"title":"DateTimeProtocol","abstract":[{"code":"GDateTime","type":"codeVoice"},{"text":" is a structure that combines a Gregorian date and time","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"into a single structure."}],"kind":"symbol"},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"}}}