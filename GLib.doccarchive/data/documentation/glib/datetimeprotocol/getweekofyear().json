{"metadata":{"roleHeading":"Instance Method","externalID":"s:4GLib16DateTimeProtocolPAAE13getWeekOfYearSiyF","modules":[{"name":"GLib"}],"role":"symbol","symbolKind":"method","extendedModule":"GLib","title":"getWeekOfYear()","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"getWeekOfYear","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}]},"abstract":[{"text":"Returns the ISO 8601 week number for the week containing ","type":"text"},{"code":"datetime","type":"codeVoice"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The ISO 8601 week number is the same for every day of the week (from"},{"text":" ","type":"text"},{"type":"text","text":"Moday through Sunday).  That can produce some unusual results"},{"text":" ","type":"text"},{"text":"(described below).","type":"text"}],"kind":"symbol","sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/datetimeprotocol\/getweekofyear()"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol\/getWeekOfYear()","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"getWeekOfYear","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"platforms":["macOS"]}]},{"content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"The first week of the year is week 1.  This is the week that contains","type":"text"},{"text":" ","type":"text"},{"text":"the first Thursday of the year.  Equivalently, this is the first week","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"that has more than 4 of its days falling within the calendar year."}]},{"inlineContent":[{"type":"text","text":"The value 0 is never returned by this function.  Days contained"},{"type":"text","text":" "},{"type":"text","text":"within a year but occurring before the first ISO 8601 week of that"},{"text":" ","type":"text"},{"text":"year are considered as being contained in the last week of the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"previous year.  Similarly, the final days of a calendar year may be"},{"type":"text","text":" "},{"type":"text","text":"considered as being part of the first ISO 8601 week of the next year"},{"text":" ","type":"text"},{"text":"if 4 or more days of that week are contained within the new year.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://GLib/documentation/GLib/DateTimeProtocol/getWeekOfYear()":{"title":"getWeekOfYear()","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol\/getWeekOfYear()","url":"\/documentation\/glib\/datetimeprotocol\/getweekofyear()","type":"topic","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"getWeekOfYear"},{"text":"() -> ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"abstract":[{"text":"Returns the ISO 8601 week number for the week containing ","type":"text"},{"code":"datetime","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"The ISO 8601 week number is the same for every day of the week (from","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Moday through Sunday).  That can produce some unusual results"},{"text":" ","type":"text"},{"type":"text","text":"(described below)."}]},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identif