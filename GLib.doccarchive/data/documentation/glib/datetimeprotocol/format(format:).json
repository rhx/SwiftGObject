{"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"text":"Creates a newly allocated string representing the requested ","type":"text"},{"type":"codeVoice","code":"format"},{"text":".","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/datetimeprotocol\/format(format:)"]}],"metadata":{"roleHeading":"Instance Method","title":"format(format:)","modules":[{"name":"GLib"}],"symbolKind":"method","role":"symbol","extendedModule":"GLib","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"format"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"format"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">!) -> "},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"},{"kind":"text","text":"!"}],"externalID":"s:4GLib16DateTimeProtocolPAAE6formatADSSSgSPys4Int8VGSg_tF"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"format","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"format"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">!) -> ","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":"!","kind":"text"}]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"The format strings understood by this function are a subset of the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"strftime()"},{"text":" format language as specified by C99.  The ","type":"text"},{"code":"D","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"U"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"W"},{"type":"text","text":" "},{"text":"conversions are not supported, nor is the ","type":"text"},{"type":"codeVoice","code":"E"},{"text":" modifier.  The GNU","type":"text"},{"type":"text","text":" "},{"type":"text","text":"extensions "},{"code":"k","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"l"},{"type":"text","text":", "},{"type":"codeVoice","code":"s"},{"type":"text","text":" and "},{"type":"codeVoice","code":"P"},{"text":" are supported, however, as are the","type":"text"},{"type":"text","text":" "},{"code":"0","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"_"},{"type":"text","text":" and "},{"code":"-","type":"codeVoice"},{"type":"text","text":" modifiers. The Python extension "},{"type":"codeVoice","code":"f"},{"text":" is also supported.","type":"text"}]},{"inlineContent":[{"text":"In contrast to ","type":"text"},{"code":"strftime()","type":"codeVoice"},{"type":"text","text":", this function always produces a UTF-8"},{"type":"text","text":" "},{"text":"string, regardless of the current locale.  Note that the rendering of","type":"text"},{"type":"text","text":" "},{"text":"many formats is locale-dependent and may not match the ","type":"text"},{"code":"strftime()","type":"codeVoice"},{"type":"text","text":" "},{"text":"output exactly.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The following format specifiers are supported:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"a"},{"type":"text","text":": the abbreviated weekday name according to the current locale"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"A","type":"codeVoice"},{"text":": the full weekday name according to the current locale","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"b"},{"type":"text","text":": the abbreviated month name according to the current locale"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"B"},{"type":"text","text":": the full month name according to the current locale"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"c"},{"type":"text","text":": the preferred date and time representation for the current locale"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"C"},{"type":"text","text":": the century number (year\/100) as a 2-digit integer (00-99)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"d","type":"codeVoice"},{"type":"text","text":": the day of the month as a decimal number (range 01 to 31)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/e-3m6a4","type":"reference"},{"text":": the day of the month as a decimal number (range 1 to 31);","type":"text"},{"type":"text","text":" "},{"type":"text","text":"single digits are preceded by a figure space (U+2007)"}]}]},{"content":[{"inlineContent":[{"code":"F","type":"codeVoice"},{"type":"text","text":": equivalent to "},{"type":"codeVoice","code":"Y-"},{"text":"m-","type":"text"},{"code":"d","type":"codeVoice"},{"type":"text","text":" (the ISO 8601 date format)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"g"},{"type":"text","text":": the last two digits of the ISO 8601 week-based year as a"},{"type":"text","text":" "},{"text":"decimal number (00-99). This works well with ","type":"text"},{"code":"V","type":"codeVoice"},{"type":"text","text":" and "},{"code":"u","type":"codeVoice"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"G"},{"type":"text","text":": the ISO 8601 week-based year as a decimal number. This works"},{"type":"text","text":" "},{"text":"well with ","type":"text"},{"code":"V","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"u","type":"codeVoice"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"h","type":"codeVoice"},{"text":": equivalent to ","type":"text"},{"type":"codeVoice","code":"b"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"H"},{"type":"text","text":": the hour as a decimal number using a 24-hour clock (range 00 to 23)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"I","type":"codeVoice"},{"type":"text","text":": the hour as a decimal number using a 12-hour clock (range 01 to 12)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"j"},{"type":"text","text":": the day of the year as a decimal number (range 001 to 366)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"k"},{"type":"text","text":": the hour (24-hour clock) as a decimal number (range 0 to 23);"},{"type":"text","text":" "},{"type":"text","text":"single digits are preceded by a figure space (U+2007)"}]}]},{"content":[{"inlineContent":[{"code":"l","type":"codeVoice"},{"type":"text","text":": the hour (12-hour clock) as a decimal number (range 1 to 12);"},{"type":"text","text":" "},{"type":"text","text":"single digits are preceded by a figure space (U+2007)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"m","type":"codeVoice"},{"type":"text","text":": the month as a decimal number (range 01 to 12)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"M","type":"codeVoice"},{"type":"text","text":": the minute as a decimal number (range 00 to 59)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"f"},{"type":"text","text":": the microsecond as a decimal number (range 000000 to 999999)"}]}]},{"content":[{"inlineContent":[{"code":"p","type":"codeVoice"},{"type":"text","text":": either ‘AM’ or ‘PM’ according to the given time value, or the"},{"text":" ","type":"text"},{"text":"corresponding  strings for the current locale.  Noon is treated as","type":"text"},{"type":"text","text":" "},{"text":"‘PM’ and midnight as ‘AM’. Use of this format specifier is discouraged, as","type":"text"},{"type":"text","text":" "},{"type":"text","text":"many locales have no concept of AM\/PM formatting. Use "},{"type":"codeVoice","code":"c"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"X"},{"text":" instead.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"P"},{"text":": like ","type":"text"},{"type":"codeVoice","code":"p"},{"type":"text","text":" but lowercase: ‘am’ or ‘pm’ or a corresponding string for"},{"type":"text","text":" "},{"type":"text","text":"the current locale. Use of this format specifier is discouraged, as"},{"type":"text","text":" "},{"text":"many locales have no concept of AM\/PM formatting. Use ","type":"text"},{"code":"c","type":"codeVoice"},{"type":"text","text":" or "},{"type":"codeVoice","code":"X"},{"type":"text","text":" instead."}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"r"},{"type":"text","text":": the time in a.m. or p.m. notation. Use of this format specifier is"},{"text":" ","type":"text"},{"text":"discouraged, as many locales have no concept of AM\/PM formatting. Use ","type":"text"},{"type":"codeVoice","code":"c"},{"text":" ","type":"text"},{"type":"text","text":"or "},{"code":"X","type":"codeVoice"},{"type":"text","text":" instead."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"R"},{"text":": the time in 24-hour notation (","type":"text"},{"type":"codeVoice","code":"H:"},{"type":"text","text":"M``)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"s"},{"type":"text","text":": the number of seconds since the Epoch, that is, since 1970-01-01"},{"type":"text","text":" "},{"text":"00:00:00 UTC","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"S"},{"type":"text","text":": the second as a decimal number (range 00 to 60)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"t","type":"codeVoice"},{"type":"text","text":": a tab character"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"T"},{"type":"text","text":": the time in 24-hour notation with seconds ("},{"code":"H:","type":"codeVoice"},{"text":"M:","type":"text"},{"code":"S","type":"codeVoice"},{"type":"text","text":")"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"u"},{"text":": the ISO 8601 standard day of the week as a decimal, range 1 to 7,","type":"text"},{"text":" ","type":"text"},{"text":"Monday being 1. This works well with ","type":"text"},{"code":"G","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"V","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"V"},{"type":"text","text":": the ISO 8601 standard week number of the current year as a decimal"},{"type":"text","text":" "},{"type":"text","text":"number, range 01 to 53, where week 1 is the first week that has at"},{"text":" ","type":"text"},{"text":"least 4 days in the new year. See ","type":"text"},{"code":"g_date_time_get_week_of_year()","type":"codeVoice"},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"This works well with ","type":"text"},{"type":"codeVoice","code":"G"},{"type":"text","text":" and "},{"code":"u","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"w","type":"codeVoice"},{"type":"text","text":": the day of the week as a decimal, range 0 to 6, Sunday being 0."},{"text":" ","type":"text"},{"type":"text","text":"This is not the ISO 8601 standard format — use "},{"type":"codeVoice","code":"u"},{"type":"text","text":" instead."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"x","type":"codeVoice"},{"text":": the preferred date representation for the current locale without","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the time"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"X"},{"type":"text","text":": the preferred time representation for the current locale without"},{"type":"text","text":" "},{"text":"the date","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"y","type":"codeVoice"},{"text":": the year as a decimal number without the century","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"Y"},{"text":": the year as a decimal number including the century","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"z","type":"codeVoice"},{"text":": the time zone as an offset from UTC (","type":"text"},{"code":"+hhmm","type":"codeVoice"},{"type":"text","text":")"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":":z"},{"text":": the time zone as an offset from UTC (","type":"text"},{"code":"+hh:mm","type":"codeVoice"},{"text":").","type":"text"},{"text":" ","type":"text"},{"text":"This is a gnulib ","type":"text"},{"code":"strftime()","type":"codeVoice"},{"type":"text","text":" extension. Since: 2.38"}]}]},{"content":[{"inlineContent":[{"code":"::z","type":"codeVoice"},{"text":": the time zone as an offset from UTC (","type":"text"},{"type":"codeVoice","code":"+hh:mm:ss"},{"type":"text","text":"). This is a"},{"type":"text","text":" "},{"type":"text","text":"gnulib "},{"type":"codeVoice","code":"strftime()"},{"type":"text","text":" extension. Since: 2.38"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":":::z","type":"codeVoice"},{"text":": the time zone as an offset from UTC, with ","type":"text"},{"type":"codeVoice","code":":"},{"text":" to necessary","type":"text"},{"type":"text","text":" "},{"type":"text","text":"precision (e.g., "},{"code":"-04","type":"codeVoice"},{"type":"text","text":", "},{"code":"+05:30","type":"codeVoice"},{"type":"text","text":"). This is a gnulib "},{"code":"strftime()","type":"codeVoice"},{"text":" extension. Since: 2.38","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"Z","type":"codeVoice"},{"text":": the time zone or name or abbreviation","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"``````: a literal ```` character"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some conversion specifications can be modified by preceding the"},{"text":" ","type":"text"},{"type":"text","text":"conversion specifier by one or more modifier characters."}]},{"inlineContent":[{"type":"text","text":"The following modifiers are supported for many of the numeric"},{"text":" ","type":"text"},{"text":"conversions:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"O"},{"type":"text","text":": Use alternative numeric symbols, if the current locale supports those."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"_","type":"codeVoice"},{"type":"text","text":": Pad a numeric result with spaces. This overrides the default padding"},{"type":"text","text":" "},{"text":"for the specifier.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"-"},{"text":": Do not pad a numeric result. This overrides the default padding","type":"text"},{"type":"text","text":" "},{"text":"for the specifier.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"0","type":"codeVoice"},{"type":"text","text":": Pad a numeric result with zeros. This overrides the default padding"},{"type":"text","text":" "},{"text":"for the specifier.","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"The following modifiers are supported for many of the alphabetic conversions:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"^","type":"codeVoice"},{"type":"text","text":": Use upper case if possible. This is a gnulib "},{"code":"strftime()","type":"codeVoice"},{"type":"text","text":" extension."},{"text":" ","type":"text"},{"type":"text","text":"Since: 2.80"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"#"},{"text":": Use opposite case if possible. This is a gnulib ","type":"text"},{"type":"codeVoice","code":"strftime()"},{"type":"text","text":" "},{"type":"text","text":"extension. Since: 2.80"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"Additionally, when ","type":"text"},{"type":"codeVoice","code":"O"},{"text":" is used with ","type":"text"},{"code":"B","type":"codeVoice"},{"type":"text","text":", "},{"code":"b","type":"codeVoice"},{"type":"text","text":", or "},{"code":"h","type":"codeVoice"},{"text":", it produces the alternative","type":"text"},{"text":" ","type":"text"},{"text":"form of a month name. The alternative form should be used when the month","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"name is used without a day number (e.g., standalone). It is required in"},{"text":" ","type":"text"},{"type":"text","text":"some languages (Baltic, Slavic, Greek, and more) due to their grammatical"},{"type":"text","text":" "},{"type":"text","text":"rules. For other languages there is no difference. "},{"type":"codeVoice","code":"OB"},{"type":"text","text":" is a GNU and BSD"},{"type":"text","text":" "},{"type":"codeVoice","code":"strftime()"},{"text":" extension expected to be added to the future POSIX specification,","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"Ob"},{"type":"text","text":" and "},{"type":"codeVoice","code":"Oh"},{"type":"text","text":" are GNU "},{"type":"codeVoice","code":"strftime()"},{"text":" extensions. Since: 2.56","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Since GLib 2.80, when "},{"type":"codeVoice","code":"E"},{"text":" is used with ","type":"text"},{"code":"c","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"C"},{"text":", ","type":"text"},{"code":"x","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"X"},{"text":", ","type":"text"},{"type":"codeVoice","code":"y"},{"type":"text","text":" or "},{"type":"codeVoice","code":"Y"},{"text":",","type":"text"},{"type":"text","text":" "},{"text":"the date is formatted using an alternate era representation specific to the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"locale. This is typically used for the Thai solar calendar or Japanese era"},{"text":" ","type":"text"},{"type":"text","text":"names, for example."}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"Ec","type":"codeVoice"},{"type":"text","text":": the preferred date and time representation for the current locale,"},{"text":" ","type":"text"},{"text":"using the alternate era representation","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"EC"},{"text":": the name of the era","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"Ex"},{"type":"text","text":": the preferred date representation for the current locale without"},{"type":"text","text":" "},{"text":"the time, using the alternate era representation","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"EX","type":"codeVoice"},{"type":"text","text":": the preferred time representation for the current locale without"},{"text":" ","type":"text"},{"type":"text","text":"the date, using the alternate era representation"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"Ey"},{"text":": the year since the beginning of the era denoted by the ","type":"text"},{"type":"codeVoice","code":"EC"},{"text":" ","type":"text"},{"text":"specifier","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"EY","type":"codeVoice"},{"text":": the full alternative year representation","type":"text"}]}]}]}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol\/format(format:)"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol"]]},"sections":[],"references":{"doc://GLib/documentation/GLib/e-3m6a4":{"abstract":[{"text":"The base of natural logarithms.","type":"text"}],"fragments":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"text":"e","kind":"identifier"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sd","text":"Double","kind":"typeIdentifier"}],"role":"symbol","title":"e","url":"\/documentation\/glib\/e-3m6a4","type":"topic","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/e-3m6a4"},"doc://GLib/documentation/GLib/DateTimeProtocol/format(format:)":{"abstract":[{"text":"Creates a newly allocated string representing the requested ","type":"text"},{"type":"codeVoice","code":"format"},{"type":"text","text":"."}],"url":"\/documentation\/glib\/datetimeprotocol\/format(format:)","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol\/format(format:)","type":"topic","role":"symbol","title":"format(format:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"format"},{"text":"(","kind":"text"},{"text":"format","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"gchar","preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier"},{"kind":"text","text":">!) -> "},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":"!","kind":"text"}]},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/DateTimeProtocol":{"type":"topic","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DateTimeProtocol","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol","role":"symbol","url":"\/documentation\/glib\/datetimeprotocol","navigatorTitle":[{"text":"DateTimeProtocol","kind":"identifier"}],"title":"DateTimeProtocol","abstract":[{"code":"GDateTime","type":"codeVoice"},{"text":" is a structure that combines a Gregorian date and time","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"into a single structure."}],"kind":"symbol"}}}