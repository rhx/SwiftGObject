{"sections":[],"metadata":{"extendedModule":"GLib","roleHeading":"Instance Method","title":"format(format:)","externalID":"s:4GLib16DateTimeProtocolPAAE6formatADSSSgSPys4Int8VGSg_tF","modules":[{"name":"GLib"}],"symbolKind":"method","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"format"},{"kind":"text","text":"("},{"text":"format","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">!) -> "},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"kind":"text","text":"!"}]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol\/format(format:)"},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"format","kind":"identifier"},{"kind":"text","text":"("},{"text":"format","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"gchar","preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier"},{"text":">!) -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"text":"!","kind":"text"}],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The format strings understood by this function are a subset of the"},{"type":"text","text":" "},{"type":"codeVoice","code":"strftime()"},{"type":"text","text":" format language as specified by C99.  The "},{"type":"codeVoice","code":"D"},{"text":", ","type":"text"},{"code":"U","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"W"},{"type":"text","text":" "},{"type":"text","text":"conversions are not supported, nor is the "},{"code":"E","type":"codeVoice"},{"type":"text","text":" modifier.  The GNU"},{"type":"text","text":" "},{"type":"text","text":"extensions "},{"code":"k","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"l"},{"type":"text","text":", "},{"code":"s","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"P"},{"type":"text","text":" are supported, however, as are the"},{"text":" ","type":"text"},{"code":"0","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"_"},{"text":" and ","type":"text"},{"code":"-","type":"codeVoice"},{"text":" modifiers. The Python extension ","type":"text"},{"code":"f","type":"codeVoice"},{"text":" is also supported.","type":"text"}]},{"inlineContent":[{"type":"text","text":"In contrast to "},{"code":"strftime()","type":"codeVoice"},{"text":", this function always produces a UTF-8","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"string, regardless of the current locale.  Note that the rendering of"},{"type":"text","text":" "},{"type":"text","text":"many formats is locale-dependent and may not match the "},{"type":"codeVoice","code":"strftime()"},{"type":"text","text":" "},{"type":"text","text":"output exactly."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following format specifiers are supported:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"a","type":"codeVoice"},{"type":"text","text":": the abbreviated weekday name according to the current locale"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"A"},{"type":"text","text":": the full weekday name according to the current locale"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"b"},{"type":"text","text":": the abbreviated month name according to the current locale"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"B","type":"codeVoice"},{"type":"text","text":": the full month name according to the current locale"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"c","type":"codeVoice"},{"text":": the preferred date and time representation for the current locale","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"C"},{"type":"text","text":": the century number (year\/100) as a 2-digit integer (00-99)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"d"},{"text":": the day of the month as a decimal number (range 01 to 31)","type":"text"}]}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/GLib\/documentation\/GLib\/e-3m6a4","type":"reference","isActive":true},{"type":"text","text":": the day of the month as a decimal number (range 1 to 31);"},{"text":" ","type":"text"},{"type":"text","text":"single digits are preceded by a figure space (U+2007)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"F"},{"text":": equivalent to ","type":"text"},{"type":"codeVoice","code":"Y-"},{"text":"m-","type":"text"},{"code":"d","type":"codeVoice"},{"type":"text","text":" (the ISO 8601 date format)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"g"},{"type":"text","text":": the last two digits of the ISO 8601 week-based year as a"},{"text":" ","type":"text"},{"text":"decimal number (00-99). This works well with ","type":"text"},{"type":"codeVoice","code":"V"},{"text":" and ","type":"text"},{"code":"u","type":"codeVoice"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"G"},{"type":"text","text":": the ISO 8601 week-based year as a decimal number. This works"},{"type":"text","text":" "},{"text":"well with ","type":"text"},{"code":"V","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"u"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"h"},{"type":"text","text":": equivalent to "},{"type":"codeVoice","code":"b"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"H"},{"type":"text","text":": the hour as a decimal number using a 24-hour clock (range 00 to 23)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"I"},{"type":"text","text":": the hour as a decimal number using a 12-hour clock (range 01 to 12)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"j"},{"type":"text","text":": the day of the year as a decimal number (range 001 to 366)"}]}]},{"content":[{"inlineContent":[{"code":"k","type":"codeVoice"},{"type":"text","text":": the hour (24-hour clock) as a decimal number (range 0 to 23);"},{"type":"text","text":" "},{"text":"single digits are preceded by a figure space (U+2007)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"l"},{"text":": the hour (12-hour clock) as a decimal number (range 1 to 12);","type":"text"},{"type":"text","text":" "},{"type":"text","text":"single digits are preceded by a figure space (U+2007)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"m"},{"text":": the month as a decimal number (range 01 to 12)","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"M"},{"text":": the minute as a decimal number (range 00 to 59)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"f"},{"text":": the microsecond as a decimal number (range 000000 to 999999)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"p"},{"type":"text","text":": either ‘AM’ or ‘PM’ according to the given time value, or the"},{"text":" ","type":"text"},{"text":"corresponding  strings for the current locale.  Noon is treated as","type":"text"},{"text":" ","type":"text"},{"text":"‘PM’ and midnight as ‘AM’. Use of this format specifier is discouraged, as","type":"text"},{"type":"text","text":" "},{"text":"many locales have no concept of AM\/PM formatting. Use ","type":"text"},{"code":"c","type":"codeVoice"},{"type":"text","text":" or "},{"code":"X","type":"codeVoice"},{"text":" instead.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"P"},{"type":"text","text":": like "},{"type":"codeVoice","code":"p"},{"text":" but lowercase: ‘am’ or ‘pm’ or a corresponding string for","type":"text"},{"text":" ","type":"text"},{"text":"the current locale. Use of this format specifier is discouraged, as","type":"text"},{"text":" ","type":"text"},{"text":"many locales have no concept of AM\/PM formatting. Use ","type":"text"},{"type":"codeVoice","code":"c"},{"type":"text","text":" or "},{"type":"codeVoice","code":"X"},{"type":"text","text":" instead."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"r","type":"codeVoice"},{"text":": the time in a.m. or p.m. notation. Use of this format specifier is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"discouraged, as many locales have no concept of AM\/PM formatting. Use "},{"type":"codeVoice","code":"c"},{"text":" ","type":"text"},{"type":"text","text":"or "},{"type":"codeVoice","code":"X"},{"type":"text","text":" instead."}]}]},{"content":[{"inlineContent":[{"code":"R","type":"codeVoice"},{"text":": the time in 24-hour notation (","type":"text"},{"type":"codeVoice","code":"H:"},{"type":"text","text":"M``)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"s"},{"type":"text","text":": the number of seconds since the Epoch, that is, since 1970-01-01"},{"text":" ","type":"text"},{"text":"00:00:00 UTC","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"S"},{"type":"text","text":": the second as a decimal number (range 00 to 60)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"t"},{"type":"text","text":": a tab character"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"T","type":"codeVoice"},{"type":"text","text":": the time in 24-hour notation with seconds ("},{"type":"codeVoice","code":"H:"},{"type":"text","text":"M:"},{"code":"S","type":"codeVoice"},{"text":")","type":"text"}]}]},{"content":[{"inlineContent":[{"code":"u","type":"codeVoice"},{"text":": the ISO 8601 standard day of the week as a decimal, range 1 to 7,","type":"text"},{"type":"text","text":" "},{"text":"Monday being 1. This works well with ","type":"text"},{"type":"codeVoice","code":"G"},{"type":"text","text":" and "},{"type":"codeVoice","code":"V"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"V"},{"type":"text","text":": the ISO 8601 standard week number of the current year as a decimal"},{"type":"text","text":" "},{"text":"number, range 01 to 53, where week 1 is the first week that has at","type":"text"},{"type":"text","text":" "},{"type":"text","text":"least 4 days in the new year. See "},{"type":"codeVoice","code":"g_date_time_get_week_of_year()"},{"type":"text","text":"."},{"text":" ","type":"text"},{"type":"text","text":"This works well with "},{"code":"G","type":"codeVoice"},{"type":"text","text":" and "},{"code":"u","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"w","type":"codeVoice"},{"text":": the day of the week as a decimal, range 0 to 6, Sunday being 0.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This is not the ISO 8601 standard format — use "},{"code":"u","type":"codeVoice"},{"type":"text","text":" instead."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"x","type":"codeVoice"},{"text":": the preferred date representation for the current locale without","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the time"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"X"},{"type":"text","text":": the preferred time representation for the current locale without"},{"type":"text","text":" "},{"text":"the date","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"y"},{"type":"text","text":": the year as a decimal number without the century"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Y"},{"type":"text","text":": the year as a decimal number including the century"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"z","type":"codeVoice"},{"type":"text","text":": the time zone as an offset from UTC ("},{"type":"codeVoice","code":"+hhmm"},{"type":"text","text":")"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":":z"},{"type":"text","text":": the time zone as an offset from UTC ("},{"code":"+hh:mm","type":"codeVoice"},{"text":").","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This is a gnulib "},{"code":"strftime()","type":"codeVoice"},{"type":"text","text":" extension. Since: 2.38"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"::z","type":"codeVoice"},{"type":"text","text":": the time zone as an offset from UTC ("},{"type":"codeVoice","code":"+hh:mm:ss"},{"type":"text","text":"). This is a"},{"type":"text","text":" "},{"type":"text","text":"gnulib "},{"code":"strftime()","type":"codeVoice"},{"type":"text","text":" extension. Since: 2.38"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":":::z"},{"text":": the time zone as an offset from UTC, with ","type":"text"},{"type":"codeVoice","code":":"},{"type":"text","text":" to necessary"},{"type":"text","text":" "},{"text":"precision (e.g., ","type":"text"},{"code":"-04","type":"codeVoice"},{"type":"text","text":", "},{"code":"+05:30","type":"codeVoice"},{"type":"text","text":"). This is a gnulib "},{"code":"strftime()","type":"codeVoice"},{"text":" extension. Since: 2.38","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Z"},{"type":"text","text":": the time zone or name or abbreviation"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"``````: a literal ```` character"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some conversion specifications can be modified by preceding the"},{"type":"text","text":" "},{"type":"text","text":"conversion specifier by one or more modifier characters."}]},{"inlineContent":[{"type":"text","text":"The following modifiers are supported for many of the numeric"},{"text":" ","type":"text"},{"text":"conversions:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"O","type":"codeVoice"},{"type":"text","text":": Use alternative numeric symbols, if the current locale supports those."}]}]},{"content":[{"inlineContent":[{"code":"_","type":"codeVoice"},{"text":": Pad a numeric result with spaces. This overrides the default padding","type":"text"},{"text":" ","type":"text"},{"text":"for the specifier.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"-","type":"codeVoice"},{"text":": Do not pad a numeric result. This overrides the default padding","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for the specifier."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"0"},{"text":": Pad a numeric result with zeros. This overrides the default padding","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for the specifier."}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following modifiers are supported for many of the alphabetic conversions:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"code":"^","type":"codeVoice"},{"text":": Use upper case if possible. This is a gnulib ","type":"text"},{"code":"strftime()","type":"codeVoice"},{"text":" extension.","type":"text"},{"type":"text","text":" "},{"text":"Since: 2.80","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"#"},{"type":"text","text":": Use opposite case if possible. This is a gnulib "},{"type":"codeVoice","code":"strftime()"},{"type":"text","text":" "},{"text":"extension. Since: 2.80","type":"text"}]}]}]},{"inlineContent":[{"type":"text","text":"Additionally, when "},{"type":"codeVoice","code":"O"},{"type":"text","text":" is used with "},{"type":"codeVoice","code":"B"},{"type":"text","text":", "},{"type":"codeVoice","code":"b"},{"text":", or ","type":"text"},{"type":"codeVoice","code":"h"},{"type":"text","text":", it produces the alternative"},{"text":" ","type":"text"},{"text":"form of a month name. The alternative form should be used when the month","type":"text"},{"type":"text","text":" "},{"text":"name is used without a day number (e.g., standalone). It is required in","type":"text"},{"type":"text","text":" "},{"text":"some languages (Baltic, Slavic, Greek, and more) due to their grammatical","type":"text"},{"type":"text","text":" "},{"type":"text","text":"rules. For other languages there is no difference. "},{"code":"OB","type":"codeVoice"},{"type":"text","text":" is a GNU and BSD"},{"text":" ","type":"text"},{"type":"codeVoice","code":"strftime()"},{"type":"text","text":" extension expected to be added to the future POSIX specification,"},{"type":"text","text":" "},{"type":"codeVoice","code":"Ob"},{"type":"text","text":" and "},{"type":"codeVoice","code":"Oh"},{"text":" are GNU ","type":"text"},{"code":"strftime()","type":"codeVoice"},{"text":" extensions. Since: 2.56","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Since GLib 2.80, when "},{"code":"E","type":"codeVoice"},{"type":"text","text":" is used with "},{"type":"codeVoice","code":"c"},{"text":", ","type":"text"},{"code":"C","type":"codeVoice"},{"text":", ","type":"text"},{"code":"x","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"X"},{"type":"text","text":", "},{"code":"y","type":"codeVoice"},{"type":"text","text":" or "},{"type":"codeVoice","code":"Y"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"the date is formatted using an alternate era representation specific to the"},{"text":" ","type":"text"},{"type":"text","text":"locale. This is typically used for the Thai solar calendar or Japanese era"},{"text":" ","type":"text"},{"text":"names, for example.","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Ec"},{"type":"text","text":": the preferred date and time representation for the current locale,"},{"text":" ","type":"text"},{"text":"using the alternate era representation","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"EC"},{"type":"text","text":": the name of the era"}]}]},{"content":[{"inlineContent":[{"code":"Ex","type":"codeVoice"},{"type":"text","text":": the preferred date representation for the current locale without"},{"text":" ","type":"text"},{"text":"the time, using the alternate era representation","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"EX"},{"type":"text","text":": the preferred time representation for the current locale without"},{"type":"text","text":" "},{"type":"text","text":"the date, using the alternate era representation"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"Ey","type":"codeVoice"},{"text":": the year since the beginning of the era denoted by the ","type":"text"},{"code":"EC","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"specifier"}]}]},{"content":[{"inlineContent":[{"code":"EY","type":"codeVoice"},{"text":": the full alternative year representation","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol"]]},"variants":[{"paths":["\/documentation\/glib\/datetimeprotocol\/format(format:)"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"Creates a newly allocated string representing the requested ","type":"text"},{"code":"format","type":"codeVoice"},{"text":".","type":"text"}],"references":{"doc://GLib/documentation/GLib/e-3m6a4":{"title":"e","url":"\/documentation\/glib\/e-3m6a4","kind":"symbol","abstract":[{"text":"The base of natural logarithms.","type":"text"}],"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/e-3m6a4","type":"topic","fragments":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"text":"e","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"}]},"doc://GLib/documentation/GLib/DateTimeProtocol":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol","kind":"symbol","role":"symbol","abstract":[{"type":"codeVoice","code":"GDateTime"},{"text":" is a structure that combines a Gregorian date and time","type":"text"},{"type":"text","text":" "},{"type":"text","text":"into a single structure."}],"type":"topic","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"DateTimeProtocol","kind":"identifier"}],"title":"DateTimeProtocol","navigatorTitle":[{"text":"DateTimeProtocol","kind":"identifier"}],"url":"\/documentation\/glib\/datetimeprotocol"},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/G