{"sections":[],"abstract":[{"type":"text","text":"Returns the ISO 8601 week-numbering year in which the week containing"},{"text":" ","type":"text"},{"code":"datetime","type":"codeVoice"},{"type":"text","text":" falls."}],"variants":[{"paths":["\/documentation\/glib\/datetimeprotocol\/weeknumberingyear"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol"]]},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol\/weekNumberingYear","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"weekNumberingYear","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"text":" }","kind":"text"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function, taken together with "},{"type":"codeVoice","code":"g_date_time_get_week_of_year()"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_date_time_get_day_of_week()"},{"text":" can be used to determine the full ISO","type":"text"},{"type":"text","text":" "},{"type":"text","text":"week date on which "},{"code":"datetime","type":"codeVoice"},{"type":"text","text":" falls."}]},{"type":"paragraph","inlineContent":[{"text":"This is usually equal to the normal Gregorian year (as returned by","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_date_time_get_year()"},{"type":"text","text":"), except as detailed below:"}]},{"inlineContent":[{"type":"text","text":"For Thursday, the week-numbering year is always equal to the usual"},{"text":" ","type":"text"},{"type":"text","text":"calendar year.  For other days, the number is such that every day"},{"text":" ","type":"text"},{"text":"within a complete week (Monday to Sunday) is contained within the","type":"text"},{"type":"text","text":" "},{"text":"same week-numbering year.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For Monday, Tuesday and Wednesday occurring near the end of the year,"},{"type":"text","text":" "},{"type":"text","text":"this may mean that the week-numbering year is one greater than the"},{"text":" ","type":"text"},{"text":"calendar year (so that these days have the same week-numbering year","type":"text"},{"type":"text","text":" "},{"type":"text","text":"as the Thursday occurring early in the next year)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For Friday, Saturday and Sunday occurring near the start of the year,"},{"type":"text","text":" "},{"type":"text","text":"this may mean that the week-numbering year is one less than the"},{"text":" ","type":"text"},{"type":"text","text":"calendar year (so that these days have the same week-numbering year"},{"type":"text","text":" "},{"text":"as the Thursday occurring late in the previous year).","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"An equivalent description is that the week-numbering year is equal to"},{"text":" ","type":"text"},{"type":"text","text":"the calendar year containing the majority of the days in the current"},{"text":" ","type":"text"},{"text":"week (Monday to Sunday).","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that January 1 0001 in the proleptic Gregorian calendar is a"},{"type":"text","text":" "},{"text":"Monday, so this function never returns 0.","type":"text"}]}]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"symbolKind":"property","modules":[{"name":"GLib"}],"fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"weekNumberingYear"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"extendedModule":"GLib","roleHeading":"Instance Property","title":"weekNumberingYear","role":"symbol","externalID":"s:4GLib16DateTimeProtocolPAAE17weekNumberingYearSivp"},"references":{"doc://GLib/documentation/GLib/DateTimeProtocol":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol","kind":"symbol","role":"symbol","abstract":[{"type":"codeVoice","code":"GDateTime"},{"text":" is a structure that combines a Gregorian date and time","type":"text"},{"type":"text","text":" "},{"type":"text","text":"into a single structure."}],"type":"topic","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"DateTimeProtocol","kind":"identifier"}],"title":"DateTimeProtocol","navigatorTitle":[{"text":"DateTimeProtocol","kind":"identifier"}],"url":"\/documentation\/glib\/datetimeprotocol"},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/DateTimeProtocol/weekNumberingYear":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol\/weekNumberingYear","url":"\/documentation\/glib\/datetimeprotocol\/weeknumberingyear","role":"symbol","title":"weekNumberingYear","type":"topic","abstract":[{"text":"Returns the ISO 8601 week-numbering year in which the week containing","type":"text"},{"text":" ","type":"text"},{"code":"datetime","type":"codeVoice"},{"type":"text","text":" falls."}],"kind":"symbol","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"weekNumberingYear","kind":"identifier"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}]}}}