{"abstract":[{"text":"Returns the ISO 8601 week-numbering year in which the week containing","type":"text"},{"text":" ","type":"text"},{"code":"datetime","type":"codeVoice"},{"type":"text","text":" falls."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol\/weekNumberingYear"},"metadata":{"modules":[{"name":"GLib"}],"externalID":"s:4GLib16DateTimeProtocolPAAE17weekNumberingYearSivp","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"weekNumberingYear"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"roleHeading":"Instance Property","extendedModule":"GLib","title":"weekNumberingYear","symbolKind":"property","role":"symbol"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"weekNumberingYear"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":" { "},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"text":"This function, taken together with ","type":"text"},{"type":"codeVoice","code":"g_date_time_get_week_of_year()"},{"text":" and","type":"text"},{"type":"text","text":" "},{"code":"g_date_time_get_day_of_week()","type":"codeVoice"},{"text":" can be used to determine the full ISO","type":"text"},{"text":" ","type":"text"},{"text":"week date on which ","type":"text"},{"code":"datetime","type":"codeVoice"},{"text":" falls.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This is usually equal to the normal Gregorian year (as returned by","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_date_time_get_year()"},{"text":"), except as detailed below:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"For Thursday, the week-numbering year is always equal to the usual","type":"text"},{"type":"text","text":" "},{"text":"calendar year.  For other days, the number is such that every day","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"within a complete week (Monday to Sunday) is contained within the"},{"text":" ","type":"text"},{"text":"same week-numbering year.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For Monday, Tuesday and Wednesday occurring near the end of the year,"},{"text":" ","type":"text"},{"type":"text","text":"this may mean that the week-numbering year is one greater than the"},{"type":"text","text":" "},{"type":"text","text":"calendar year (so that these days have the same week-numbering year"},{"text":" ","type":"text"},{"text":"as the Thursday occurring early in the next year).","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For Friday, Saturday and Sunday occurring near the start of the year,"},{"type":"text","text":" "},{"type":"text","text":"this may mean that the week-numbering year is one less than the"},{"type":"text","text":" "},{"text":"calendar year (so that these days have the same week-numbering year","type":"text"},{"type":"text","text":" "},{"text":"as the Thursday occurring late in the previous year).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An equivalent description is that the week-numbering year is equal to"},{"text":" ","type":"text"},{"type":"text","text":"the calendar year containing the majority of the days in the current"},{"text":" ","type":"text"},{"text":"week (Monday to Sunday).","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Note that January 1 0001 in the proleptic Gregorian calendar is a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Monday, so this function never returns 0."}]}],"kind":"content"}],"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/datetimeprotocol\/weeknumberingyear"]}],"references":{"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/DateTimeProtocol/weekNumberingYear":{"url":"\/documentation\/glib\/datetimeprotocol\/weeknumberingyear","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol\/weekNumberingYear","type":"topic","kind":"symbol","abstract":[{"text":"Returns the ISO 8601 week-numbering year in which the week containing","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"datetime"},{"type":"text","text":" falls."}],"fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"weekNumberingYear","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}],"title":"weekNumberingYear","role":"symbol"},"doc://GLib/documentation/GLib/DateTimeProtocol":{"type":"topic","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DateTimeProtocol","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol","role":"symbol","url":"\/documentation\/glib\/datetimeprotocol","navigatorTitle":[{"text":"DateTimeProtocol","kind":"identifier"}],"title":"DateTimeProtocol","abstract":[{"code":"GDateTime","type":"codeVoice"},{"text":" is a structure that combines a Gregorian date and time","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"into a single structure."}],"kind":"symbol"}}}