{"sections":[],"abstract":[{"text":"Returns the ISO 8601 week-numbering year in which the week containing","type":"text"},{"text":" ","type":"text"},{"code":"datetime","type":"codeVoice"},{"text":" falls.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/datetimeprotocol\/getweeknumberingyear()"]}],"metadata":{"externalID":"s:4GLib16DateTimeProtocolPAAE20getWeekNumberingYearSiyF","modules":[{"name":"GLib"}],"title":"getWeekNumberingYear()","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"getWeekNumberingYear"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"extendedModule":"GLib","symbolKind":"method","roleHeading":"Instance Method"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"getWeekNumberingYear","kind":"identifier"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"platforms":["macOS"]}]},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"inlineContent":[{"text":"This function, taken together with ","type":"text"},{"code":"g_date_time_get_week_of_year()","type":"codeVoice"},{"text":" and","type":"text"},{"type":"text","text":" "},{"code":"g_date_time_get_day_of_week()","type":"codeVoice"},{"text":" can be used to determine the full ISO","type":"text"},{"text":" ","type":"text"},{"text":"week date on which ","type":"text"},{"code":"datetime","type":"codeVoice"},{"text":" falls.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is usually equal to the normal Gregorian year (as returned by"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_date_time_get_year()"},{"type":"text","text":"), except as detailed below:"}]},{"type":"paragraph","inlineContent":[{"text":"For Thursday, the week-numbering year is always equal to the usual","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"calendar year.  For other days, the number is such that every day"},{"type":"text","text":" "},{"type":"text","text":"within a complete week (Monday to Sunday) is contained within the"},{"type":"text","text":" "},{"type":"text","text":"same week-numbering year."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For Monday, Tuesday and Wednesday occurring near the end of the year,"},{"text":" ","type":"text"},{"type":"text","text":"this may mean that the week-numbering year is one greater than the"},{"text":" ","type":"text"},{"type":"text","text":"calendar year (so that these days have the same week-numbering year"},{"text":" ","type":"text"},{"text":"as the Thursday occurring early in the next year).","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For Friday, Saturday and Sunday occurring near the start of the year,"},{"text":" ","type":"text"},{"type":"text","text":"this may mean that the week-numbering year is one less than the"},{"type":"text","text":" "},{"type":"text","text":"calendar year (so that these days have the same week-numbering year"},{"text":" ","type":"text"},{"text":"as the Thursday occurring late in the previous year).","type":"text"}]},{"inlineContent":[{"type":"text","text":"An equivalent description is that the week-numbering year is equal to"},{"type":"text","text":" "},{"type":"text","text":"the calendar year containing the majority of the days in the current"},{"type":"text","text":" "},{"text":"week (Monday to Sunday).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that January 1 0001 in the proleptic Gregorian calendar is a"},{"type":"text","text":" "},{"text":"Monday, so this function never returns 0.","type":"text"}]}],"kind":"content"}],"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol\/getWeekNumberingYear()"},"references":{"doc://GLib/documentation/GLib/DateTimeProtocol":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol","kind":"symbol","role":"symbol","abstract":[{"type":"codeVoice","code":"GDateTime"},{"text":" is a structure that combines a Gregorian date and time","type":"text"},{"type":"text","text":" "},{"type":"text","text":"into a single structure."}],"type":"topic","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"DateTimeProtocol","kind":"identifier"}],"title":"DateTimeProtocol","navigatorTitle":[{"text":"DateTimeProtocol","kind":"identifier"}],"url":"\/documentation\/glib\/datetimeprotocol"},"doc://GLib/documentation/GLib/DateTimeProtocol/getWeekNumberingYear()":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol\/getWeekNumberingYear()","url":"\/documentation\/glib\/datetimeprotocol\/getweeknumberingyear()","role":"symbol","title":"getWeekNumberingYear()","abstract":[{"type":"text","text":"Returns the ISO 8601 week-numbering year in which the week containing"},{"type":"text","text":" "},{"code":"datetime","type":"codeVoice"},{"text":" falls.","type":"text"}],"type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"getWeekNumberingYear","kind":"identifier"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}]},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"}}}