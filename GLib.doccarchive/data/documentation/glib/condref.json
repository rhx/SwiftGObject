{"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"CondRef","kind":"identifier"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"anchor":"overview","type":"heading","level":2,"text":"Overview"},{"inlineContent":[{"text":"Consider the following example of a shared variable.  One or more","type":"text"},{"type":"text","text":" "},{"type":"text","text":"threads can wait for data to be published to the variable and when"},{"type":"text","text":" "},{"type":"text","text":"another thread publishes the data, it can signal one of the waiting"},{"text":" ","type":"text"},{"type":"text","text":"threads to wake up to collect the data."}],"type":"paragraph"},{"inlineContent":[{"text":"Here is an example for using GCond to block a thread until a condition","type":"text"},{"type":"text","text":" "},{"text":"is satisfied:","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"type":"codeListing","syntax":"C","code":["  gpointer current_data = NULL;","  GMutex data_mutex;","  GCond data_cond;","","  void","  push_data (gpointer data)","  {","    g_mutex_lock (&data_mutex);","    current_data = data;","    g_cond_signal (&data_cond);","    g_mutex_unlock (&data_mutex);","  }","","  gpointer","  pop_data (void)","  {","    gpointer data;","","    g_mutex_lock (&data_mutex);","    while (!current_data)","      g_cond_wait (&data_cond, &data_mutex);","    data = current_data;","    current_data = NULL;","    g_mutex_unlock (&data_mutex);","","    return data;","  }"]},{"inlineContent":[{"text":"Whenever a thread calls ","type":"text"},{"type":"codeVoice","code":"pop_data()"},{"text":" now, it will wait until","type":"text"},{"text":" ","type":"text"},{"text":"current_data is non-","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":", i.e. until some other thread"},{"text":" ","type":"text"},{"text":"has called ","type":"text"},{"type":"codeVoice","code":"push_data()"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The example shows that use of a condition variable must always be"},{"text":" ","type":"text"},{"text":"paired with a mutex.  Without the use of a mutex, there would be a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"race between the check of "},{"type":"codeVoice","code":"current_data"},{"text":" by the while loop in","type":"text"},{"type":"text","text":" "},{"code":"pop_data()","type":"codeVoice"},{"type":"text","text":" and waiting. Specifically, another thread could set"},{"type":"text","text":" "},{"code":"current_data","type":"codeVoice"},{"type":"text","text":" after the check, and signal the cond (with nobody"},{"text":" ","type":"text"},{"type":"text","text":"waiting on it) before the first thread goes to sleep. "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","isActive":true},{"text":" is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"specifically useful for its ability to release the mutex and go"},{"type":"text","text":" "},{"type":"text","text":"to sleep atomically."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"It is also important to use the ","type":"text"},{"code":"g_cond_wait()","type":"codeVoice"},{"type":"text","text":" and "},{"code":"g_cond_wait_until()","type":"codeVoice"},{"type":"text","text":" "},{"text":"functions only inside a loop which checks for the condition to be","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"true.  See "},{"type":"codeVoice","code":"g_cond_wait()"},{"text":" for an explanation of why the condition may","type":"text"},{"text":" ","type":"text"},{"text":"not be true even after it returns.","type":"text"}]},{"inlineContent":[{"text":"If a ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","isActive":true,"type":"reference"},{"text":" is allocated in static storage then it can be used","type":"text"},{"type":"text","text":" "},{"text":"without initialisation.  Otherwise, you should call ","type":"text"},{"type":"codeVoice","code":"g_cond_init()"},{"text":" ","type":"text"},{"type":"text","text":"on it and "},{"code":"g_cond_clear()","type":"codeVoice"},{"text":" when done.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","isActive":true},{"type":"text","text":" should only be accessed via the g_cond_ functions."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/CondRef","type":"reference"},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GCond"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/CondProtocol"},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/CondRef","isActive":true,"type":"reference"},{"type":"text","text":" only as an "},{"code":"unowned","type":"codeVoice"},{"text":" reference to an existing ","type":"text"},{"type":"codeVoice","code":"GCond"},{"type":"text","text":" instance."}]},{"name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","isActive":true},{"text":" (instead of ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/CondRef","isActive":true},{"type":"text","text":") if you want to use Automatic Reference Counting for memory management of the underlying "},{"type":"codeVoice","code":"GCond"},{"text":" instance.","type":"text"}]}],"style":"note","type":"aside"}],"kind":"content"}],"metadata":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"CondRef"}],"externalID":"s:4GLib7CondRefV","role":"symbol","navigatorTitle":[{"text":"CondRef","kind":"identifier"}],"roleHeading":"Structure","modules":[{"name":"GLib"}],"title":"CondRef","symbolKind":"struct"},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/CondRef","interfaceLanguage":"swift"},"topicSections":[{"anchor":"Initializers","generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/CondRef\/init(_:)-3vuu1","doc:\/\/GLib\/documentation\/GLib\/CondRef\/init(_:)-5lwo4","doc:\/\/GLib\/documentation\/GLib\/CondRef\/init(_:)-64xk6","doc:\/\/GLib\/documentation\/GLib\/CondRef\/init(_:)-858ub","doc:\/\/GLib\/documentation\/GLib\/CondRef\/init(_:)-d6nf","doc:\/\/GLib\/documentation\/GLib\/CondRef\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/CondRef\/init(constPointer:)","doc:\/\/GLib\/documentation\/GLib\/CondRef\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/CondRef\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/CondRef\/init(mutating:)","doc:\/\/GLib\/documentation\/GLib\/CondRef\/init(opaquePointer:)"],"title":"Initializers"},{"title":"Instance Properties","anchor":"Instance-Properties","generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/CondRef\/ptr"]},{"title":"Default Implementations","identifiers":["doc:\/\/GLib\/documentation\/GLib\/CondRef\/CondProtocol-Implementations","doc:\/\/GLib\/documentation\/GLib\/CondRef\/PointerWrapper-Implementations"],"anchor":"Default-Implementations","generated":true}],"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","relationshipsSections":[{"kind":"relationships","title":"Conforms To","type":"conformsTo","identifiers":["doc:\/\/GLib\/documentation\/G