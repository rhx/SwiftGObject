{"sections":[],"abstract":[{"type":"text","text":"Installs a non-error fatal log handler which can be"},{"text":" ","type":"text"},{"text":"used to decide whether log messages which are counted","type":"text"},{"text":" ","type":"text"},{"text":"as fatal abort the program.","type":"text"}],"metadata":{"modules":[{"name":"GLib"}],"title":"testLogSetFatalHandler(logFunc:userData:)","roleHeading":"Function","role":"symbol","externalID":"s:4GLib22testLogSetFatalHandler7logFunc8userDatays5Int32VSPys4Int8VGSg_So14GLogLevelFlagsaAJSvSgtXCSg_AMtF","symbolKind":"func","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"testLogSetFatalHandler"},{"text":"(","kind":"text"},{"text":"logFunc","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GTestLogFatalFunc","text":"GTestLogFatalFunc"},{"text":"?, ","kind":"text"},{"text":"userData","kind":"externalParam"},{"kind":"text","text":": "},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:@T@gpointer"},{"kind":"text","text":"?)"}]},"kind":"symbol","identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/testLogSetFatalHandler(logFunc:userData:)","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"testLogSetFatalHandler","kind":"identifier"},{"kind":"text","text":"("},{"text":"logFunc","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GTestLogFatalFunc","text":"GTestLogFatalFunc"},{"kind":"text","text":"?, "},{"text":"userData","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"gpointer","preciseIdentifier":"c:@T@gpointer"},{"kind":"text","text":"? = nil)"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The use case here is that you are running a test case"},{"text":" ","type":"text"},{"type":"text","text":"that depends on particular libraries or circumstances"},{"type":"text","text":" "},{"text":"and cannot prevent certain known critical or warning","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"messages. So you install a handler that compares the"},{"type":"text","text":" "},{"type":"text","text":"domain and message to precisely not abort in such a case."}]},{"inlineContent":[{"text":"Note that the handler is reset at the beginning of","type":"text"},{"text":" ","type":"text"},{"text":"any test case, so you have to set it inside each test","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"function which needs the special behavior."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This handler has no effect on g_error messages."}]},{"inlineContent":[{"type":"text","text":"This handler also has no effect on structured log messages (using"},{"text":" ","type":"text"},{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.log_structured"},{"text":"] or [func","type":"text"},{"type":"codeVoice","code":"GLib.log_structured_array"},{"text":"]). To change the fatal","type":"text"},{"type":"text","text":" "},{"type":"text","text":"behaviour for specific log messages, programs must install a custom log"},{"type":"text","text":" "},{"type":"text","text":"writer function using [func"},{"type":"codeVoice","code":"GLib.log_set_writer_func"},{"text":"].See","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"logging.html#using-structured-logging"},{"type":"text","text":"."}],"type":"paragraph"}]}],"variants":[{"paths":["\/documentation\/glib\/testlogsetfatalhandler(logfunc:userdata:)"],"traits":[{"interfaceLa