{"schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"variants":[{"paths":["\/documentation\/glib\/hashfunc"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"Specifies the type of the hash function which is passed to"},{"text":" ","type":"text"},{"code":"g_hash_table_new()","type":"codeVoice"},{"type":"text","text":" when a "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/HashTable","type":"reference"},{"text":" is created.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"typealias"},{"text":" ","kind":"text"},{"kind":"identifier","text":"HashFunc"},{"kind":"text","text":" = "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GHashFunc","text":"GHashFunc"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"The function is passed a key and should return a ","type":"text"},{"type":"codeVoice","code":"guint"},{"type":"text","text":" hash value."},{"type":"text","text":" "},{"text":"The functions ","type":"text"},{"code":"g_direct_hash()","type":"codeVoice"},{"type":"text","text":", "},{"code":"g_int_hash()","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"g_str_hash()"},{"type":"text","text":" provide"},{"type":"text","text":" "},{"text":"hash functions which can be used when the key is a ","type":"text"},{"code":"gpointer","type":"codeVoice"},{"text":", ","type":"text"},{"code":"gint","type":"codeVoice"},{"inlineContent":[{"type":"text","text":","},{"text":" ","type":"text"},{"text":"and ","type":"text"},{"code":"gchar","type":"codeVoice"}],"type":"emphasis"},{"type":"text","text":" respectively."}]},{"inlineContent":[{"type":"codeVoice","code":"g_direct_hash()"},{"text":" is also the appropriate hash function for keys","type":"text"},{"text":" ","type":"text"},{"text":"of the form ","type":"text"},{"type":"codeVoice","code":"GINT_TO_POINTER (n)"},{"text":" (or similar macros).","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A good hash functions should produce"},{"text":" ","type":"text"},{"text":"hash values that are evenly distributed over a fairly large range.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The modulus is taken with the hash table size (a prime number) to"},{"text":" ","type":"text"},{"text":"find the ‘bucket’ to place each key into. The function should also","type":"text"},{"type":"text","text":" "},{"text":"be very fast, since it is called for each key lookup.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Note that the hash functions provided by GLib have these qualities,","type":"text"},{"text":" ","type":"text"},{"text":"but are not particularly robust against manufactured keys that","type":"text"},{"type":"text","text":" "},{"type":"text","text":"cause hash collisions. Therefore, you should consider choosing"},{"text":" ","type":"text"},{"text":"a more secure hash function when using a GHashTable with keys","type":"text"},{"text":" ","type":"text"},{"text":"that originate in untrusted data (such as HTTP requests).","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Using "},{"type":"codeVoice","code":"g_str_hash()"},{"type":"text","text":" in that situation might make your application"},{"text":" ","type":"text"},{"text":"vulnerable to","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/lwn.net\/Articles\/474912\/"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The key to choosing a good hash is unpredictability.  Even"},{"text":" ","type":"text"},{"type":"text","text":"cryptographic hashes are very easy to find collisions for when the"},{"text":" ","type":"text"},{"text":"remainder is taken modulo a somewhat predictable prime number.  There","type":"text"},{"text":" ","type":"text"},{"text":"must be an element of randomness that an attacker is unable to guess.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"kind":"symbol","identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/HashFunc","interfaceLanguage":"swift"},"metadata":{"roleHeading":"Type Alias","navigatorTitle":[{"text":"HashFunc","kind":"identifier"}],"role":"symbol","symbolKind":"typealias","fragments":[{"kind":"keyword","text":"typealias"},{"text":" ","kind":"text"},{"kind":"identifier","text":"HashFunc"}],"title":"HashFunc","externalID":"s:4GLib8HashFunca","modules":[{"name":"GLib"}]},"references":{"doc://GLib/documentation/GLib/HashTable":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"HashTable"}],"role":"symbol","abstract":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/HashTable","type":"reference","isActive":true},{"type":"text","text":" struct is an opaque data structure to represent a"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"data-structures.html#hash-tables"},{"type":"text","text":". It should only be accessed via the"},{"type":"text","text":" "},{"type":"text","text":"following functions."}],"url":"\/documentation\/glib\/hashtable","kind":"symbol","title":"HashTable","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/HashTable","navigatorTitle":[{"text":"HashTable","kind":"identifier"}]},"data-structures.html#hash-tables":{"titleInlineContent":[{"text":"Hash Table","type":"text"}],"title":"Hash Table","url":"data-structures.html#hash-tables","identifier":"data-structures.html#hash-tables","type":"link"},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/HashFunc