{"metadata":{"modules":[{"name":"GLib"}],"externalID":"s:4GLib8HashFunca","title":"HashFunc","roleHeading":"Type Alias","symbolKind":"typealias","navigatorTitle":[{"text":"HashFunc","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"text":"HashFunc","kind":"identifier"}],"role":"symbol"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"typealias","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"HashFunc"},{"text":" = ","kind":"text"},{"text":"GHashFunc","preciseIdentifier":"c:@T@GHashFunc","kind":"typeIdentifier"}],"platforms":["macOS"]}]},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"The function is passed a key and should return an ","type":"text"},{"type":"codeVoice","code":"unsigned int"},{"type":"text","text":" hash value."},{"type":"text","text":" "},{"text":"The functions [func","type":"text"},{"type":"codeVoice","code":"direct_hash"},{"text":"], [func","type":"text"},{"type":"codeVoice","code":"int_hash"},{"type":"text","text":"] and [func"},{"type":"codeVoice","code":"str_hash"},{"type":"text","text":"] provide"},{"text":" ","type":"text"},{"type":"text","text":"hash functions which can be used when the key is a "},{"code":"void*","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"int*"},{"type":"text","text":","},{"text":" ","type":"text"},{"text":"and ","type":"text"},{"code":"char*","type":"codeVoice"},{"type":"text","text":" respectively."}]},{"inlineContent":[{"text":"[func","type":"text"},{"type":"codeVoice","code":"direct_hash"},{"type":"text","text":"] is also the appropriate hash function for keys"},{"type":"text","text":" "},{"text":"of the form ","type":"text"},{"identifier":"conversion-macros.html#gint-to-pointer","type":"reference","isActive":true},{"type":"text","text":" "},{"text":"(or similar macros).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"A good hash functions should produce","type":"text"},{"type":"text","text":" "},{"type":"text","text":"hash values that are evenly distributed over a fairly large range."},{"type":"text","text":" "},{"text":"The modulus is taken with the hash table size (a prime number) to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"find the ‘bucket’ to place each key into. The function should also"},{"type":"text","text":" "},{"type":"text","text":"be very fast, since it is called for each key lookup."}]},{"inlineContent":[{"text":"Note that the hash functions provided by GLib have these qualities,","type":"text"},{"type":"text","text":" "},{"text":"but are not particularly robust against manufactured keys that","type":"text"},{"text":" ","type":"text"},{"text":"cause hash collisions. Therefore, you should consider choosing","type":"text"},{"text":" ","type":"text"},{"text":"a more secure hash function when using a [struct","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/HashTable","isActive":true},{"text":"] with keys","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"that originate in untrusted data (such as HTTP requests)."},{"type":"text","text":" "},{"text":"Using [func","type":"text"},{"type":"codeVoice","code":"str_hash"},{"type":"text","text":"] in that situation might make your application"},{"type":"text","text":" "},{"text":"vulnerable to","type":"text"},{"type":"text","text":" "},{"identifier":"https:\/\/lwn.net\/Articles\/474912\/","isActive":true,"type":"reference"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The key to choosing a good hash is unpredictability.  Even","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"cryptographic hashes are very easy to find collisions for when the"},{"type":"text","text":" "},{"type":"text","text":"remainder is taken modulo a somewhat predictable prime number.  There"},{"text":" ","type":"text"},{"type":"text","text":"must be an element of randomness that an attacker is unable to guess."}]}],"kind":"content"}],"abstract":[{"text":"Specifies the type of the hash function which is passed to","type":"text"},{"text":" ","type":"text"},{"text":"[func","type":"text"},{"type":"codeVoice","code":"HashTable.new"},{"type":"text","text":"] when a [struct"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/HashTable","type":"reference"},{"type":"text","text":"] is created."}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/HashFunc","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/glib\/hashfunc"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","references":{"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"data-structures.html#hash-tables":{"identifier":"data-structures.html#hash-tables","title":"Hash Table","type":"link","url":"data-structures.html#hash-tables","titleInlineContent":[{"text":"Hash Table","type":"text"}]},"doc://GLib/documentation/GLib/HashFunc":{"kind":"symbol","role":"symbol","url":"\/documentation\/glib\/hashfunc","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/HashFunc","title":"HashFunc","abstract":[{"type":"text","text":"Specifies the type of the hash function which is passed to"},{"text":" ","type":"text"},{"type":"text","text":"[func"},{"type":"codeVoice","code":"HashTable.new"},{"text":"] when a [struct","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/HashTable","type":"reference","isActive":true},{"text":"] is created.","type":"text"}],"navigatorTitle":[{"text":"HashFunc","kind":"identifier"}],"fragments":[{"text":