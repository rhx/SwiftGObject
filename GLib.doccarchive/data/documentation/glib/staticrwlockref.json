{"metadata":{"modules":[{"name":"GLib"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"StaticRWLockRef"}],"symbolKind":"struct","roleHeading":"Structure","navigatorTitle":[{"kind":"identifier","text":"StaticRWLockRef"}],"title":"StaticRWLockRef","externalID":"s:4GLib15StaticRWLockRefV","role":"symbol"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/staticrwlockref"]}],"sections":[],"topicSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef\/init(_:)-10mti","doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef\/init(_:)-37bn","doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef\/init(_:)-3nxea","doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef\/init(_:)-56q6n","doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef\/init(_:)-qfhc","doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef\/init(constPointer:)","doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef\/init(mutating:)","doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef\/init(opaquePointer:)"],"title":"Initializers","generated":true,"anchor":"Initializers"},{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef\/ptr"],"title":"Instance Properties","anchor":"Instance-Properties","generated":true},{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef\/PointerWrapper-Implementations","doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef\/StaticRWLockProtocol-Implementations"],"generated":true,"anchor":"Default-Implementations","title":"Default Implementations"}],"abstract":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLock","isActive":true,"type":"reference"},{"text":" struct represents a read-write lock. A read-write","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"lock can be used for protecting data that some portions of code only"},{"text":" ","type":"text"},{"type":"text","text":"read from, while others also write. In such situations it is"},{"type":"text","text":" "},{"text":"desirable that several readers can read at once, whereas of course","type":"text"},{"type":"text","text":" "},{"type":"text","text":"only one writer may write at a time."}],"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef"},"relationshipsSections":[{"title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","doc:\/\/GLib\/documentation\/GLib\/StaticRWLockProtocol"],"type":"conformsTo"}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"StaticRWLockRef","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"anchor":"overview","text":"Overview","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Take a look at the following example:"}]},{"syntax":null,"type":"codeListing","code":["  GStaticRWLock rwlock = G_STATIC_RW_LOCK_INIT;","  GPtrArray *array;","","  gpointer","  my_array_get (guint index)","  {","    gpointer retval = NULL;","","    if (!array)","      return NULL;","","    g_static_rw_lock_reader_lock (&rwlock);","    if (index < array->len)","      retval = g_ptr_array_index (array, index);","    g_static_rw_lock_reader_unlock (&rwlock);","","    return retval;","  }","","  void","  my_array_set (guint index, gpointer data)","  {","    g_static_rw_lock_writer_lock (&rwlock);","","    if (!array)","      array = g_ptr_array_new ();","","    if (index >= array->len)","      g_ptr_array_set_size (array, index + 1);","    g_ptr_array_index (array, index) = data;","","    g_static_rw_lock_writer_unlock (&rwlock);","  }"]},{"inlineContent":[{"type":"text","text":"This example shows an array which can be accessed by many readers"},{"type":"text","text":" "},{"type":"text","text":"(the "},{"type":"codeVoice","code":"my_array_get()"},{"type":"text","text":" function) simultaneously, whereas the writers"},{"text":" ","type":"text"},{"text":"(the ","type":"text"},{"type":"codeVoice","code":"my_array_set()"},{"type":"text","text":" function) will only be allowed once at a time"},{"text":" ","type":"text"},{"text":"and only if no readers currently access the array. This is because","type":"text"},{"type":"text","text":" "},{"text":"of the potentially dangerous resizing of the array. Using these","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"functions is fully multi-thread safe now."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Most of the time, writers should have precedence over readers. That","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"means, for this implementation, that as soon as a writer wants to"},{"type":"text","text":" "},{"type":"text","text":"lock the data, no other reader is allowed to lock the data, whereas,"},{"text":" ","type":"text"},{"type":"text","text":"of course, the readers that already have locked the data are allowed"},{"type":"text","text":" "},{"type":"text","text":"to finish their operation. As soon as the last reader unlocks the"},{"text":" ","type":"text"},{"text":"data, the writer will lock it.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Even though ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLock","isActive":true,"type":"reference"},{"text":" is not opaque, it should only be used","type":"text"},{"type":"text","text":" "},{"text":"with the following functions.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"All of the g_static_rw_lock_* functions can be used even if"},{"type":"text","text":" "},{"code":"g_thread_init()","type":"codeVoice"},{"text":" has not been called. Then they do nothing, apart","type":"text"},{"text":" ","type":"text"},{"text":"from g_static_rw_lock_*_trylock, which does nothing but returning ","type":"text"},{"type":"codeVoice","code":"true"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A read-write lock has a higher overhead than a mutex. For example, both"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_static_rw_lock_reader_lock()"},{"type":"text","text":" and "},{"code":"g_static_rw_lock_reader_unlock()","type":"codeVoice"},{"type":"text","text":" have"},{"text":" ","type":"text"},{"text":"to lock and unlock a ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex","isActive":true},{"text":", so it takes at least twice the time","type":"text"},{"type":"text","text":" "},{"text":"to lock and unlock a ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLock","isActive":true,"type":"reference"},{"type":"text","text":" that it does to lock and unlock a"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex"},{"text":". So only data structures that are accessed by multiple","type":"text"},{"text":" ","type":"text"},{"text":"readers, and which keep the lock for a considerable time justify a","type":"text"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLock"},{"type":"text","text":". The above example most probably would fare better with a"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex","isActive":true},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef"},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"code":"GStaticRWLock","type":"codeVoice"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"text":"It exposes methods that can operate on this data type through ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLockProtocol","type":"reference","isActive":true},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef","isActive":true,"type":"reference"},{"type":"text","text":" only as an "},{"type":"codeVoice","code":"unowned"},{"type":"text","text":" reference to an existing "},{"type":"codeVoice","code":"GStaticRWLock"},{"type":"text","text":" instance."}]},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLock"},{"text":" (instead of ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef","isActive":true,"type":"reference"},{"type":"text","text":") if you want to use Automatic Reference Counting for memory management of the underlying "},{"type":"codeVoice","code":"GStaticRWLock"},{"type":"text","text":" instance."}]}],"name":"Note","type":"aside"}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"references":{"doc://GLib/documentation/GLib/StaticRWLockRef/StaticRWLockProtocol-Implementations":{"abstract":[],"kind":"article","role":"collectionGroup","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef\/StaticRWLockProtocol-Implementations","title":"StaticRWLockProtocol Implementations","url":"\/documentation\/glib\/staticrwlockref\/staticrwlockprotocol-implementations"},"doc://GLib/documentation/GLib/StaticRWLockRef/init(_:)-37bn":{"title":"init(_:)","abstract":[{"type":"text","text":"Designated in