{"abstract":[{"text":"Initialises a ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder","isActive":true},{"type":"text","text":" structure."}],"metadata":{"extendedModule":"GLib","role":"symbol","title":"init_(type:)","modules":[{"name":"GLib"}],"externalID":"s:4GLib22VariantBuilderProtocolPAAE5init_4typeyqd___tAA0b4TypeD0Rd__lF::SYNTHESIZED::s:4GLib17VariantBuilderRefV","symbolKind":"method","roleHeading":"Instance Method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"init_","kind":"identifier"},{"text":"<","kind":"text"},{"text":"VariantTypeT","kind":"genericParameter"},{"kind":"text","text":">("},{"kind":"externalParam","text":"type"},{"text":": ","kind":"text"},{"text":"VariantTypeT","kind":"typeIdentifier"},{"text":")","kind":"text"}]},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/VariantBuilderRef","doc:\/\/GLib\/documentation\/GLib\/VariantBuilderRef\/VariantBuilderProtocol-Implementations"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"init_","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"VariantTypeT"},{"kind":"text","text":">("},{"text":"type","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"VariantTypeT"},{"text":") ","kind":"text"},{"kind":"keyword","text":"where"},{"text":" ","kind":"text"},{"text":"VariantTypeT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"VariantTypeProtocol","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantTypeProtocol","kind":"typeIdentifier","preciseIdentifier":"s:4GLib19VariantTypeProtocolP"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"type"},{"type":"text","text":" must be non-"},{"code":"nil","type":"codeVoice"},{"text":".  It specifies the type of container to","type":"text"},{"type":"text","text":" "},{"text":"construct.  It can be an indefinite type such as","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"G_VARIANT_TYPE_ARRAY"},{"type":"text","text":" or a definite type such as “as” or “(ii)”."},{"type":"text","text":" "},{"text":"Maybe, array, tuple, dictionary entry and variant-typed values may be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"constructed."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If using a static type such as one of the "},{"type":"codeVoice","code":"G_VARIANT_TYPE_*"},{"text":" constants","type":"text"},{"text":" ","type":"text"},{"text":"or a ","type":"text"},{"code":"G_VARIANT_TYPE (\"(ii)\")","type":"codeVoice"},{"text":" macro, it is more performant to use","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_variant_builder_init_static()"},{"text":" rather than ","type":"text"},{"code":"g_variant_builder_init()","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"After the builder is initialised, values are added using","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_variant_builder_add_value()"},{"type":"text","text":" or "},{"code":"g_variant_builder_add()","type":"codeVoice"},{"text":".","type":"text"}]},{"inlineContent":[{"type":"text","text":"After all the child values are added, "},{"type":"codeVoice","code":"g_variant_builder_end()"},{"text":" frees","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the memory associated with the builder and returns the "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"text":" that","type":"text"},{"type":"text","text":" "},{"text":"was created.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function completely ignores the previous contents of "},{"type":"codeVoice","code":"builder"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"On one hand this means that it is valid to pass in completely"},{"type":"text","text":" "},{"type":"text","text":"uninitialised memory.  On the other hand, this means that if you are"},{"type":"text","text":" "},{"type":"text","text":"initialising over top of an existing "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder","type":"reference","isActive":true},{"type":"text","text":" you need to"},{"text":" ","type":"text"},{"text":"first call ","type":"text"},{"type":"codeVoice","code":"g_variant_builder_clear()"},{"type":"text","text":" in order to avoid leaking"},{"type":"text","text":" "},{"type":"text","text":"memory."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You must not call "},{"type":"codeVoice","code":"g_variant_builder_ref()"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"code":"g_variant_builder_unref()","type":"codeVoice"},{"text":" on a ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder"},{"type":"text","text":" that was initialised"},{"type":"text","text":" "},{"type":"text","text":"with this function.  If you ever pass a reference to a"},{"text":" ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder","isActive":true,"type":"reference"},{"text":" outside of the control of your own code then you","type":"text"},{"type":"text","text":" "},{"text":"should assume that the person receiving that reference may try to use","type":"text"},{"type":"text","text":" "},{"text":"reference counting; you should use ","type":"text"},{"type":"codeVoice","code":"g_variant_builder_new()"},{"type":"text","text":" instead of"},{"type":"text","text":" "},{"type":"text","text":"this function."}]}]}],"identifier":{"url":"doc:\/\/GLib\/docu