{"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/VariantBuilderRef","doc:\/\/GLib\/documentation\/GLib\/VariantBuilderRef\/VariantBuilderProtocol-Implementations"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"init_","kind":"identifier"},{"kind":"text","text":"<"},{"text":"VariantTypeT","kind":"genericParameter"},{"kind":"text","text":">("},{"text":"type","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"VariantTypeT"},{"text":") ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"VariantTypeT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib19VariantTypeProtocolP","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantTypeProtocol","text":"VariantTypeProtocol"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"inlineContent":[{"code":"type","type":"codeVoice"},{"type":"text","text":" must be non-"},{"code":"nil","type":"codeVoice"},{"text":".  It specifies the type of container to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"construct.  It can be an indefinite type such as"},{"text":" ","type":"text"},{"code":"G_VARIANT_TYPE_ARRAY","type":"codeVoice"},{"type":"text","text":" or a definite type such as “as” or “(ii)”."},{"type":"text","text":" "},{"text":"Maybe, array, tuple, dictionary entry and variant-typed values may be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"constructed."}],"type":"paragraph"},{"inlineContent":[{"text":"If using a static type such as one of the ","type":"text"},{"code":"G_VARIANT_TYPE_*","type":"codeVoice"},{"text":" constants","type":"text"},{"type":"text","text":" "},{"type":"text","text":"or a "},{"code":"G_VARIANT_TYPE (\"(ii)\")","type":"codeVoice"},{"type":"text","text":" macro, it is more performant to use"},{"text":" ","type":"text"},{"code":"g_variant_builder_init_static()","type":"codeVoice"},{"type":"text","text":" rather than "},{"type":"codeVoice","code":"g_variant_builder_init()"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"After the builder is initialised, values are added using"},{"text":" ","type":"text"},{"code":"g_variant_builder_add_value()","type":"codeVoice"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"g_variant_builder_add()"},{"text":".","type":"text"}]},{"inlineContent":[{"text":"After all the child values are added, ","type":"text"},{"code":"g_variant_builder_end()","type":"codeVoice"},{"type":"text","text":" frees"},{"type":"text","text":" "},{"text":"the memory associated with the builder and returns the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":" that","type":"text"},{"text":" ","type":"text"},{"text":"was created.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This function completely ignores the previous contents of ","type":"text"},{"type":"codeVoice","code":"builder"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"On one hand this means that it is valid to pass in completely"},{"text":" ","type":"text"},{"text":"uninitialised memory.  On the other hand, this means that if you are","type":"text"},{"text":" ","type":"text"},{"text":"initialising over top of an existing ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder","isActive":true},{"type":"text","text":" you need to"},{"text":" ","type":"text"},{"text":"first call ","type":"text"},{"type":"codeVoice","code":"g_variant_builder_clear()"},{"type":"text","text":" in order to avoid leaking"},{"text":" ","type":"text"},{"type":"text","text":"memory."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"You must not call ","type":"text"},{"type":"codeVoice","code":"g_variant_builder_ref()"},{"type":"text","text":" or"},{"text":" ","type":"text"},{"code":"g_variant_builder_unref()","type":"codeVoice"},{"text":" on a ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder","isActive":true},{"text":" that was initialised","type":"text"},{"text":" ","type":"text"},{"text":"with this function.  If you ever pass a reference to a","type":"text"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder","isActive":true},{"type":"text","text":" outside of the control of your own code then you"},{"text":" ","type":"text"},{"text":"should assume that the person receiving that reference may try to use","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"reference counting; you should use "},{"type":"codeVoice","code":"g_variant_builder_new()"},{"text":" instead of","type":"text"},{"type":"text","text":" "},{"text":"this function.","type":"text"}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/variantbuilderref\/init_(type:)"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilderRef\/init_(type:)"},"abstract":[{"text":"Initialises a ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder","isActive":true},{"type":"text","text":" structure."}],"metadata":{"title":"init_(type:)","modules":[{"name":"GLib"}],"role":"symbol","externalID":"s:4GLib22VariantBuilderProtocolPAAE5init_4typeyqd___tAA0b4TypeD0Rd__lF::SYNTHESIZED::s:4GLib17VariantBuilderRefV","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"init_","kind":"identifier"},{"kind":"text","text":"<"