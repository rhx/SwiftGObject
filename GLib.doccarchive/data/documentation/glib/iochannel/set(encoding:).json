eContent":[{"type":"text","text":"The encoding "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" is safe to use with binary data."}]},{"type":"paragraph","inlineContent":[{"text":"The encoding can only be set if one of the following conditions","type":"text"},{"type":"text","text":" "},{"text":"is true:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The channel was just created, and has not been written to or read from yet.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The channel is write-only."}]}]},{"content":[{"inlineContent":[{"text":"The channel is a file, and the file pointer was just repositioned","type":"text"},{"text":" ","type":"text"},{"text":"by a call to ","type":"text"},{"type":"codeVoice","code":"g_io_channel_seek_position()"},{"type":"text","text":". (This flushes all the"},{"text":" ","type":"text"},{"text":"internal buffers.)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The current encoding is "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" or UTF-8."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"One of the (new API) read functions has just returned "},{"type":"codeVoice","code":"eof"},{"type":"text","text":" "},{"type":"text","text":"(or, in the case of "},{"code":"g_io_channel_read_to_end()","type":"codeVoice"},{"type":"text","text":", "},{"code":"normal","type":"codeVoice"},{"type":"text","text":")."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"One of the functions "},{"type":"codeVoice","code":"g_io_channel_read_chars()"},{"text":" or","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_io_channel_read_unichar()"},{"text":" has returned ","type":"text"},{"type":"codeVoice","code":"again"},{"type":"text","text":" or"},{"type":"text","text":" "},{"code":"error","type":"codeVoice"},{"text":". This may be useful in the case of","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"illegalSequence"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Returning one of these statuses from "},{"type":"codeVoice","code":"g_io_channel_read_line()"},{"text":",","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_io_channel_read_line_string()"},{"type":"text","text":", or "},{"type":"codeVoice","code":"g_io_channel_read_to_end()"},{"type":"text","text":" "},{"type":"text","text":"does not guarantee that the encoding can be changed."}],"type":"paragraph"}]}]},{"inlineContent":[{"text":"Channels which do not meet one of the above conditions cannot call","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_io_channel_seek_position()"},{"text":" with an offset of ","type":"text"},{"type":"codeVoice","code":"cur"},{"type":"text","text":", and, if"},{"text":" ","type":"text"},{"type":"text","text":"they are “seekable”, cannot call "},{"code":"g_io_channel_write_chars()","type":"codeVoice"},{"text":" after","type":"text"},{"type":"text","text":" "},{"type":"text","text":"calling one of the API “read” functions."}],"type":"paragraph"}]}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/iochannel\/set(encoding:)"]}],"sections":[],"abstract":[{"type":"text","text":"Sets the encoding for the input\/output of the channel."},{"text":" ","type":"text"},{"text":"The internal encoding is always UTF-8. The default encoding","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for the external file is UTF-8."}],"references":{"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/IOChannel/set(encoding:)":{"abstract":[{"type":"text","text":"Sets the encoding for the in