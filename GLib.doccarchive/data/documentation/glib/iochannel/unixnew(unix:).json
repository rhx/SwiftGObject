{"metadata":{"roleHeading":"Type Method","externalID":"s:4GLib9IOChannelC7unixNew0C0ACSgSi_tFZ","modules":[{"name":"GLib"}],"role":"symbol","symbolKind":"method","fragments":[{"kind":"keyword","text":"static"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"unixNew"},{"kind":"text","text":"("},{"kind":"externalParam","text":"unix"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:4GLib9IOChannelC","kind":"typeIdentifier","text":"IOChannel"},{"text":"!","kind":"text"}],"title":"unixNew(unix:)"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"unixNew","kind":"identifier"},{"kind":"text","text":"("},{"text":"unix","kind":"externalParam"},{"text":" ","kind":"text"},{"kind":"internalParam","text":"fd"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"text":") -> ","kind":"text"},{"text":"IOChannel","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","kind":"typeIdentifier","preciseIdentifier":"s:4GLib9IOChannelC"},{"text":"!","kind":"text"}]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"inlineContent":[{"text":"The returned ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","isActive":true},{"text":" has a reference count of 1.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The default encoding for ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","type":"reference","isActive":true},{"type":"text","text":" is UTF-8. If your application"},{"text":" ","type":"text"},{"text":"is reading output from a command using via pipe, you may need to set","type":"text"},{"type":"text","text":" "},{"text":"the encoding to the encoding of the current locale (see","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_get_charset()"},{"type":"text","text":") with the "},{"code":"g_io_channel_set_encoding()","type":"codeVoice"},{"type":"text","text":" function."},{"text":" ","type":"text"},{"text":"By default, the fd passed will not be closed when the final reference","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel"},{"text":" data structure is dropped.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you want to read raw binary data without interpretation, then"},{"type":"text","text":" "},{"type":"text","text":"call the "},{"type":"codeVoice","code":"g_io_channel_set_encoding()"},{"type":"text","text":" function with "},{"code":"nil","type":"codeVoice"},{"text":" for the","type":"text"},{"type":"text","text":" "},{"text":"encoding argument.","type":"text"}]},{"inlineContent":[{"type":"text","text":"This function is available in GLib on Windows, too, but you should"},{"text":" ","type":"text"},{"text":"avoid using it on Windows. The domain of file descriptors and","type":"text"},{"type":"text","text":" "},{"text":"sockets overlap. There is no way for GLib to know which one you mean","type":"text"},{"type":"text","text":" "},{"type":"text","text":"in case the argument you pass to this function happens to be both a"},{"type":"text","text":" "},{"text":"valid file descriptor and socket. If that happens a warning is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"issued, and GLib assumes that it is the file descriptor you mean."}],"type":"paragraph"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/IOChannel"]]},"abstract":[{"text":"Creates a new ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","isActive":true,"type":"reference"},{"text":" given a file descriptor. On UNIX systems","type":"text"},{"type":"text","text":" "},{"type":"text","text":"this works for plain files, pipes, and sockets."}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/IOChannel\/unixNew(unix:)","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/glib\/iochannel\/unixnew(unix:)"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"kind":"symbol","references":{"doc://GLib/documentation/GLib/IOChannel":{"type":"topic","abstract":[{"text":"The ","type":"text"},{"code":"GIOChannel","type":"codeVoice"},{"type":"text","text":" data type aims to provide a portable method for"},{"type":"text","text":" "},{"type":"text","text":"using file descriptors, pipes, and sockets, and integrating them"},{"text":" ","type":"text"},{"text":"into the main event loop (see [struct","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext"},{"type":"text","text":"]). Currently,"},{"text":" ","type":"text"},{"type":"text","text":"full support is available on UNIX platforms; support for Windows"},{"text":" ","type":"text"},{"text":"is only partially complete.","type":"text"}],"role":"symbol","kind":"symbol","navigatorTitle":[{"text":"IOChannel","kind":"identifier"}],"title":"IOChannel","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"IOChannel"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","url":"\/documentation\/glib\/iochannel"},"doc://GLib/documentation/GLib/MainContext":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MainContext"}],"url":"\/documentation\/glib\/maincontext","kind":"symbo