"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"inlineContent":[{"type":"text","text":"The returned "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","isActive":true},{"text":" has a reference count of 1.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The default encoding for ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","isActive":true},{"type":"text","text":" is UTF-8. If your application"},{"type":"text","text":" "},{"type":"text","text":"is reading output from a command using via pipe, you may need to set"},{"text":" ","type":"text"},{"text":"the encoding to the encoding of the current locale (see","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_get_charset()"},{"text":") with the ","type":"text"},{"code":"g_io_channel_set_encoding()","type":"codeVoice"},{"type":"text","text":" function."},{"type":"text","text":" "},{"type":"text","text":"By default, the fd passed will not be closed when the final reference"},{"type":"text","text":" "},{"text":"to the ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","type":"reference","isActive":true},{"type":"text","text":" data structure is dropped."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you want to read raw binary data without interpretation, then"},{"text":" ","type":"text"},{"type":"text","text":"call the "},{"type":"codeVoice","code":"g_io_channel_set_encoding()"},{"type":"text","text":" function with "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" for the"},{"type":"text","text":" "},{"type":"text","text":"encoding argument."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This function is available in GLib on Windows, too, but you should","type":"text"},{"type":"text","text":" "},{"text":"avoid using it on Windows. The domain of file descriptors and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"sockets overlap. There is no way for GLib to know which one you mean"},{"text":" ","type":"text"},{"text":"in case the argument you pass to this function happens to be both a","type":"text"},{"text":" ","type":"text"},{"text":"valid file descriptor and socket. If that happens a warning is","type":"text"},{"text":" ","type":"text"},{"text":"issued, and GLib assumes that it is the file descriptor you mean.","type":"text"}]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"references":{"doc://GLib/documentation/GLib/IOChannel/unixNew(unix:)":{"role":"symbol","type":"topic","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"unixNew"},{"kind":"text","text":"("},{"kind":"externalParam","text":"unix"},{"kind":"text","text":": "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib9IOChannelC","text":"IOChannel"},{"kind":"text","text":"!"}],"kind":"symbol","title":"unixNew(unix:)","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel\/unixNew(unix:)","url":"\/documentation\/glib\/iochannel\/unixnew(unix:)","abstract":[{"text":"Creates a new ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","isActive":true,"type":"reference"},{"text":" given a file descriptor. On UNIX systems","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this works for plain files, pipes, and sockets."}]},"doc://GLib/documentation/GLib/IOChannel":{"url":"\/documentation\/glib\/iochannel","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"GIOChannel"},{"text":" data type aims to provide a portable method for","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"using file descriptors, pipes, and sockets, and integrating them"},{"text":" ","type":"text"},{"text":"into the main event loop (see [struct","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","isActive":true,"type":"reference"},{"type":"text","text":"]). Currently,"},{"text":" ","type":"text"},{"text":"full support is available on UNIX platforms; support for Windows","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is only partially complete."}],"role":"symbol","kind":"symbol","navigatorTitle":[{"text":"IOChannel","kind":"identifier"}],"title":"IOChannel","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"IOChannel"}]},"doc://GLib/documentation/GLib/MainContext":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","role":"symbol","type":"topic","navigatorTitle":[{"text":"MainContext","kind":"identifier"}],"abstract":[{"type":"text","text":"The "},{"code":"GMainContext","type":"codeVoice"},{"text":" struct is an opaque data","type":"text"},{"type":"text","text":" "},{"text":"type representing a set of sources to be handled in a main loop.","type":"text"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"MainContext","kind":"identifier"}],"url":"\/documentation\/glib\/maincontext","title":"MainContext","kind":"symbol"},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"}}}