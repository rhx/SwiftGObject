{"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"init"},{"kind":"text","text":"("},{"text":"unix","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"fd","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":")","kind":"text"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"text":"The returned ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel"},{"text":" has a reference count of 1.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The default encoding for ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel"},{"type":"text","text":" is UTF-8. If your application"},{"type":"text","text":" "},{"type":"text","text":"is reading output from a command using via pipe, you may need to set"},{"text":" ","type":"text"},{"type":"text","text":"the encoding to the encoding of the current locale (see"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_get_charset()"},{"type":"text","text":") with the "},{"type":"codeVoice","code":"g_io_channel_set_encoding()"},{"type":"text","text":" function."},{"type":"text","text":" "},{"type":"text","text":"By default, the fd passed will not be closed when the final reference"},{"text":" ","type":"text"},{"type":"text","text":"to the "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","isActive":true},{"text":" data structure is dropped.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If you want to read raw binary data without interpretation, then","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"call the "},{"type":"codeVoice","code":"g_io_channel_set_encoding()"},{"type":"text","text":" function with "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" for the"},{"text":" ","type":"text"},{"type":"text","text":"encoding argument."}]},{"inlineContent":[{"type":"text","text":"This function is available in GLib on Windows, too, but you should"},{"type":"text","text":" "},{"text":"avoid using it on Windows. The domain of file descriptors and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"sockets overlap. There is no way for GLib to know which one you mean"},{"text":" ","type":"text"},{"text":"in case the argument you pass to this function happens to be both a","type":"text"},{"text":" ","type":"text"},{"text":"valid file descriptor and socket. If that happens a warning is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"issued, and GLib assumes that it is the file descriptor you mean."}],"type":"paragraph"}]}],"kind":"symbol","identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/IOChannel\/init(unix:)","interfaceLanguage":"swift"},"sections":[],"metadata":{"title":"init(unix:)","role":"symbol","roleHeading":"Initializer","symbolKind":"init","modules":[{"name":"GLib"}],"externalID":"s:4GLib9IOChannelC4unixACSi_tcfc","fragments":[{"text":"init","kind":"identifier"},{"kind":"text","text":"("},{"text":"unix","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"text":")","kind":"text"}]},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/IOChannel"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/iochannel\/init(unix:)"]}],"abstract":[{"type":"text","text":"Creates a new "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","type":"reference"},{"type":"text","text":" given a file descriptor. On UNIX systems"},{"type":"text","text":" "},{"text":"this works for plain files, pipes, and sockets.","type":"text"}],"references":{"doc://GLib/documentation/GLib/IOChannel":{"url":"\/documentation\/glib\/iochannel","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"GIOChannel"},{"text":" data type aims to provide a portable method for","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"using file descriptors, pipes, and sockets, and integrating them"},{"text":" ","type":"text"},{"text":"into the main event loop (see [struct","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","isActive":true,"type":"reference"},{"type":"text","text":"]). Currently,"},{"text":" ","type":"text"},{"text":"full support is available on UNIX platforms; support for Windows","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is only partially complete."}],"role":"symbol","kind":"symbol","navigatorTitle":[{"text":"IOChannel","kind":"identifier"}],"title":"IOChannel","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"IOChannel"}]},"doc://GLib/documentation/GLib/IOChannel/init(unix:)":{"type":"topic","kind":"symbol","title":"init(unix:)","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel\/init(unix:)","fragments":[{"text":"init","kind":"identifier"},{"kind":"text","text":"("},{"text":"unix","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":")"}],"role":"symbol","url":"\/documentation\/glib\/iochannel\/init(unix:)","abstract":[{"text":"Creates a new ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","isActive":true,"type":"reference"},{"type":"text","text":" given a file descriptor. On UNIX systems"},{"type":"text","text":" "},{"type":"text","text":"this works for plain files, pipes, and sockets."}]},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/MainContext":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","role":"symbol","type":"topic","navigatorTitle":[{"text":"MainContext","kind":"identifier"}],"abstract":[{"type":"text","text":"The "},{"code":"GMainContext","type":"codeVoice"},{"text":" struct is an opaque data","type":"text"},{"type":"text","text":" "},{"text":"type representing a set of sources to be handled in a main loop.","type":"text"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"MainContext","kind":"identifier"}],"url":"\/documentation\/glib\/maincontext","title":"MainContext","kind":"symbol"}}}