{"kind":"symbol","sections":[],"variants":[{"paths":["\/documentation\/glib\/maindepth()"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"mainDepth","kind":"identifier"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"inlineContent":[{"text":"That is, when called from the top level, it gives ","type":"text"},{"type":"codeVoice","code":"0"},{"text":". When","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"called from within a callback from [method"},{"type":"codeVoice","code":"GLib.MainContext.iteration"},{"type":"text","text":"]"},{"type":"text","text":" "},{"type":"text","text":"(or [method"},{"type":"codeVoice","code":"GLib.MainLoop.run"},{"type":"text","text":"], etc.) it returns "},{"type":"codeVoice","code":"1"},{"type":"text","text":". When called from within"},{"type":"text","text":" "},{"type":"text","text":"a callback to a recursive call to [method"},{"code":"GLib.MainContext.iteration","type":"codeVoice"},{"type":"text","text":"],"},{"text":" ","type":"text"},{"text":"it returns ","type":"text"},{"code":"2","type":"codeVoice"},{"text":". And so forth.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function is useful in a situation like the following:"},{"type":"text","text":" "},{"type":"text","text":"Imagine an extremely simple ‘garbage collected’ system."}]},{"syntax":"c","type":"codeListing","code":["static GList *free_list;","","gpointer","allocate_memory (gsize size)","{","  gpointer result = g_malloc (size);","  free_list = g_list_prepend (free_list, result);","  return result;","}","","void","free_allocated_memory (void)","{","  GList *l;","  for (l = free_list; l; l = l->next);","    g_free (l->data);","  g_list_free (free_list);","  free_list = NULL;"," }","","[...]","","while (TRUE);"," {","   g_main_context_iteration (NULL, TRUE);","   `free_allocated_memory()`;","  }"]},{"inlineContent":[{"type":"text","text":"This works from an application, however, if you want to do the same"},{"type":"text","text":" "},{"text":"thing from a library, it gets more difficult, since you no longer","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"control the main loop. You might think you can simply use an idle"},{"type":"text","text":" "},{"type":"text","text":"function to make the call to "},{"code":"free_allocated_memory()","type":"codeVoice"},{"text":", but that","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"doesn’t work, since the idle function could be called from a"},{"type":"text","text":" "},{"type":"text","text":"recursive callback. This can be fixed by using [func"},{"type":"codeVoice","code":"GLib.main_depth"},{"text":"]","type":"text"}],"type":"paragraph"},{"code":["gpointer","allocate_memory (gsize size)","{","  FreeListBlock *block = g_new (FreeListBlock, 1);","  block->mem = g_malloc (size);","  block->depth = g_main_depth ();","  free_list = g_list_prepend (free_list, block);","  return block->mem;","}","","void","free_allocated_memory (void)","{","  GList *l;","  ","  int depth = g_main_depth ();","  for (l = free_list; l; );","    {","      GList *next = l->next;","      FreeListBlock *block = l->data;","      if (block->depth > depth)","        {","          g_free (block->mem);","          g_free (block);","          free_list = g_list_delete_link (free_list, l);","        }","              ","      l = next;","    }","  }"],"syntax":"c","type":"codeListing"},{"inlineContent":[{"text":"There is a temptation to use [func","type":"text"},{"type":"codeVoice","code":"GLib.main_depth"},{"type":"text","text":"] to solve"},{"type":"text","text":" "},{"type":"text","text":"problems with reentrancy. For instance, while waiting for data"},{"text":" ","type":"text"},{"text":"to be received from the network in response to a menu item,","type":"text"},{"type":"text","text":" "},{"text":"the menu item might be selected again. It might seem that","type":"text"},{"text":" ","type":"text"},{"text":"one could make the menu item’s callback return immediately","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and do nothing if [func"},{"code":"GLib.main_depth","type":"codeVoice"},{"type":"text","text":"] returns a value greater than 1."},{"type":"text","text":" "},{"text":"However, this should be avoided since the user then sees selecting","type":"text"},{"type":"text","text":" "},{"text":"the menu item do nothing. Furthermore, you’ll find yourself adding","type":"text"},{"type":"text","text":" "},{"text":"these checks all over your code, since there are doubtless many,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"many things that the user could do. Instead, you can use the"},{"type":"text","text":" "},{"type":"text","text":"following techniques:"}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":"gtk_widget_set_sensitive()"},{"type":"text","text":" or modal dialogs to prevent"},{"type":"text","text":" "},{"type":"text","text":"the user from interacting with elements while the main"},{"text":" ","type":"text"},{"text":"loop is recursing.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Avoid main loop recursion in situations where you can’t handle"},{"type":"text","text":" "},{"type":"text","text":"arbitrary  callbacks. Instead, structure your code so that you"},{"type":"text","text":" "},{"type":"text","text":"simply return to the main loop and then get called again when"},{"type":"text","text":" "},{"text":"there is more work to do.","type":"text"}]}]}]}]}],"metadata":{"modules":[{"name":"GLib"}],"symbolKind":"func","title":"mainDepth()","roleHeading":"Function","role":"symbol","externalID":"s:4GLib9mainDepthSiyF","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"mainDepth","kind":"identifier"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/mainDepth()"},"abstract":[{"type":"text","text":"Returns the depth of the stack of calls to"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"code":"GLib.MainContext.dispatch","type":"codeVoice"},{"type":"text","text":"] on any "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext"},{"type":"text","text":" in the current thread."}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"references":{"doc://GLib/documentation/GLib/mainDepth()":{"url":"\/documentation\/glib\/maindepth()","title":"mainDepth()","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"mainDepth","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"role":"symbol","abstract":[{"text":"Returns the depth of the stack of calls to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"code":"GLib.MainContext.dispatch","type":"codeVoice"},{"text":"] on any ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","isActive":true,"type":"reference"},{"type":"text","text":" in the current thread."}],"type":"topic","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/mainDepth()"},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/MainContext":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MainContext"}],"url":"\/documentation\/glib\/maincontext","kind":"symbol","abstract":[{"type":"text","text":"The "},{"code":"GMainContext","type":"codeVoice"},{"type":"text","text":" struct is an opaque data"},{"text":" ","type":"text"},{"text":"type representing a set of sources to be handled in a main loop.","type":"text"}],"title":"MainContext","role":"symbol","navigatorTitle":[{"text":"MainContext","kind":"identifier"}]}}}