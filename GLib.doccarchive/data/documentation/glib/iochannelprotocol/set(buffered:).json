{"schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/IOChannelProtocol"]]},"abstract":[{"type":"text","text":"The buffering state can only be set if the channel’s encoding"},{"type":"text","text":" "},{"type":"text","text":"is "},{"code":"nil","type":"codeVoice"},{"type":"text","text":". For any other encoding, the channel must be buffered."}],"metadata":{"externalID":"s:4GLib17IOChannelProtocolPAAE3set8bufferedySb_tF","roleHeading":"Instance Method","symbolKind":"method","extendedModule":"GLib","title":"set(buffered:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"set"},{"kind":"text","text":"("},{"text":"buffered","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"text":")","kind":"text"}],"role":"symbol","modules":[{"name":"GLib"}]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/iochannelprotocol\/set(buffered:)"]}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"set"},{"text":"(","kind":"text"},{"text":"buffered","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"},{"kind":"text","text":")"}]}],"kind":"declarations"},{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"A buffered channel can only be set unbuffered if the channel’s","type":"text"},{"type":"text","text":" "},{"type":"text","text":"internal buffers have been flushed. Newly created channels or"},{"type":"text","text":" "},{"text":"channels which have returned ","type":"text"},{"type":"codeVoice","code":"eof"},{"text":" ","type":"text"},{"text":"not require such a flush. For write-only channels, a call to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"g_io_channel_flush () is sufficient. For all other channels,"},{"text":" ","type":"text"},{"text":"the buffers may be flushed by a call to g_io_channel_seek_position ().","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"This includes the possibility of seeking with seek type "},{"type":"codeVoice","code":"cur"},{"text":" ","type":"text"},{"type":"text","text":"and an offset of zero. Note that this means that socket-based"},{"type":"text","text":" "},{"type":"text","text":"channels cannot be set unbuffered once they have had data"},{"text":" ","type":"text"},{"type":"text","text":"read from them."}]},{"inlineContent":[{"text":"On unbuffered channels, it is safe to mix read and write","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"calls from the new and old APIs, if this is necessary for"},{"type":"text","text":" "},{"text":"maintaining old code.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The default state of the channel is buffered."}],"type":"paragraph"}],"kind":"content"}],"kind":"symbol","identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/IOChannelProtocol\/set(buffered:)","interfaceLanguage":"swift"},"references":{"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/MainContext":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MainContext"}],"url":"\/documentation\/glib\/maincontext","kind":"symbol","abstract":[{"type":"text","text":"The "},{"code":"GMainContext","type":"codeVoice"},{"type":"text","text":" struct is an opaque data"},{"text":" ","type":"text"},{"text":"type representing a set of sources to be handled in a main loop.","type":"text"}],"title":"MainContext","role":"symbol","navigatorTitle":[{"text":"MainContext","kind":"identifier"}]},"doc://GLib/documentation/GLib/IOChannelProtocol":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannelProtocol","type":"topic","abstract":[{"type":"text","text":"The "},{"code":"GIOChannel","type":"codeVoice"},{"text":" data type aims to provide a portable method for","type":"text"},{"text":" ","type":"text"},{"text":"using file descriptors, pipes, and sockets, and integrating them","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"into the main event loop (see [struct"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","type":"reference"},{"type":"text","text":"]). Currently,"},{"text":" ","type":"text"},{"text":"full support is available on UNIX platforms; support for Windows","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is only partially complete."}],"title":"IOChannelProtocol","navigatorTitle":[{"kind":"identifier","text":"IOChannelProtocol"}],"fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"IOChannelProtocol"}],"url":"\/documentation\/glib\/iochannelprotocol","kind":"symbol","role":"symbol"},"doc://GLib/documentation/GLib/IOChannelProtocol/set(buffered:)":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannelProtocol\/set(buffered:)","title":"set(buffered:)","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"set","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"buffered"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"kind":"text","text":")"}],"url":"\/documentation\/glib\/iochannelprotocol\/set(buffered:)","abstract":[{"text":"The buffering state can only be set if the channel’s encoding","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is "},{"code":"nil","type":"codeVoice"},{"text":". For any other encoding, the channel must be buffered.","type":"text"}],"type":"topic","role":"symbol"}}}