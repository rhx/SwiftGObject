l_read_chars()","type":"codeVoice"},{"type":"text","text":" or"},{"type":"text","text":" "},{"code":"g_io_channel_read_unichar()","type":"codeVoice"},{"type":"text","text":" has returned "},{"code":"again","type":"codeVoice"},{"type":"text","text":" or"},{"type":"text","text":" "},{"code":"error","type":"codeVoice"},{"type":"text","text":". This may be useful in the case of"},{"type":"text","text":" "},{"code":"illegalSequence","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"Returning one of these statuses from ","type":"text"},{"type":"codeVoice","code":"g_io_channel_read_line()"},{"text":",","type":"text"},{"type":"text","text":" "},{"code":"g_io_channel_read_line_string()","type":"codeVoice"},{"type":"text","text":", or "},{"code":"g_io_channel_read_to_end()","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"does not guarantee that the encoding can be changed."}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Channels which do not meet one of the above conditions cannot call"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_io_channel_seek_position()"},{"type":"text","text":" with an offset of "},{"type":"codeVoice","code":"cur"},{"text":", and, if","type":"text"},{"type":"text","text":" "},{"type":"text","text":"they are “seekable”, cannot call "},{"type":"codeVoice","code":"g_io_channel_write_chars()"},{"type":"text","text":" after"},{"type":"text","text":" "},{"type":"text","text":"calling one of the API “read” functions."}]}],"kind":"content"}],"references":{"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/IOChannelProtocol/set(encoding:)":{"abstract":[{"type":"text","text":"Sets the encoding for the input\/output of the channel."},{"type":"text","text":" "},{"text":"The internal enco