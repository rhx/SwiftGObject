{"variants":[{"paths":["\/documentation\/glib\/sourcefuncsprotocol"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","topicSections":[{"title":"Instance Properties","identifiers":["doc:\/\/GLib\/documentation\/GLib\/SourceFuncsProtocol\/check","doc:\/\/GLib\/documentation\/GLib\/SourceFuncsProtocol\/dispatch","doc:\/\/GLib\/documentation\/GLib\/SourceFuncsProtocol\/finalize","doc:\/\/GLib\/documentation\/GLib\/SourceFuncsProtocol\/prepare"],"anchor":"Instance-Properties","generated":true},{"title":"Instance Methods","anchor":"Instance-Methods","generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/SourceFuncsProtocol\/sourceRemoveByFuncs(userData:)"]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SourceFuncsProtocol","kind":"identifier"},{"kind":"text","text":" : "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","text":"PointerWrapper","preciseIdentifier":"s:4GLib14PointerWrapperP","kind":"typeIdentifier"}]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"For idle sources, the prepare and check functions always return ","type":"text"},{"type":"codeVoice","code":"true"},{"text":" ","type":"text"},{"text":"to indicate that the source is always ready to be processed. The prepare","type":"text"},{"type":"text","text":" "},{"type":"text","text":"function also returns a timeout value of 0 to ensure that the "},{"code":"poll()","type":"codeVoice"},{"text":" call","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"doesn’t block (since that would be time wasted which could have been spent"},{"text":" ","type":"text"},{"text":"running the idle function).","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"For timeout sources, the prepare and check functions both return ","type":"text"},{"type":"codeVoice","code":"true"},{"text":" ","type":"text"},{"type":"text","text":"if the timeout interval has expired. The prepare function also returns"},{"type":"text","text":" "},{"text":"a timeout value to ensure that the ","type":"text"},{"code":"poll()","type":"codeVoice"},{"type":"text","text":" call doesn’t block too long"},{"type":"text","text":" "},{"type":"text","text":"and miss the next timeout."}]},{"inlineContent":[{"type":"text","text":"For file descriptor sources, the prepare function typically returns "},{"type":"codeVoice","code":"false"},{"type":"text","text":","},{"type":"text","text":" "},{"text":"since it must wait until ","type":"text"},{"type":"codeVoice","code":"poll()"},{"type":"text","text":" has been called before it knows whether"},{"text":" ","type":"text"},{"text":"any events need to be processed. It sets the returned timeout to -1 to","type":"text"},{"type":"text","text":" "},{"text":"indicate that it doesn’t mind how long the ","type":"text"},{"code":"poll()","type":"codeVoice"},{"type":"text","text":" call blocks. In the"},{"type":"text","text":" "},{"type":"text","text":"check function, it tests the results of the "},{"code":"poll()","type":"codeVoice"},{"text":" call to see if the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"required condition has been met, and returns "},{"type":"codeVoice","code":"true"},{"text":" if so.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsProtocol"},{"text":" protocol exposes the methods and properties of an underlying ","type":"text"},{"type":"codeVoice","code":"GSourceFuncs"},{"text":" instance.","type":"text"},{"text":" ","type":"text"},{"text":"The default implementation of these can be found in the protocol extension below.","type":"text"},{"type":"text","text":" "},{"text":"For a concrete class that implements these methods and properties, see ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncs","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Alternatively, use "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef","isActive":true},{"text":" as a lighweight, ","type":"text"},{"type":"codeVoice","code":"unowned"},{"type":"text","text":" reference if you already have an instance you just want to use."}]}]}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsProtocol","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"relationshipsSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper"],"type":"inheritsFrom","title":"Inherits From","kind":"relationships"},{"title":"Conforming Types","identifiers":["doc:\/\/GLib\/documentation\/GLib\/SourceFuncs","doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef"],"kind":"relationships","type":"conformingTypes"}],"abstract":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"GSourceFuncs"},{"type":"text","text":" struct contains a table of"},{"text":" ","type":"text"},{"type":"text","text":"functions used to handle event sources in a generic manner."}],"metadata":{"navigatorTitle":[{"text":"SourceFuncsProtocol","kind":"identifier"}],"title":"SourceFuncsProtocol","roleHeading":"Protocol","symbolKind":"protocol","role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"SourceFuncsProtocol","kind":"identifier"}],"modules":[{"name":"GLib"}],"externalID":"s:4GLib19SourceFuncsProtocolP"},"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"references":{"doc://GLib/documentation/GLib/sourceRemove":{"type":"topic","role":"symbol","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"sourceRemove"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:s5Int32V","text":"Int32","kind":"typeIdentifier"}],"kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/sourceRemove","url":"\/documentation\/glib\/sourceremove","abstract":[{"text":"Use this macro as the return value of a [callback","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFunc","type":"reference","isActive":true},{"type":"text","text":"] to remove"},{"type":"text","text":" "},{"type":"text","text":"the [struct"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Source"},{"type":"text","text":"] from the main loop."}],"title":"sourceRemove"},"doc://GLib/documentation/GLib/SourceFuncsProtocol/prepare":{"url":"\/documentation\/glib\/sourcefuncsprotocol\/prepare","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"prepare","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@GSourceFuncsPrepareFunc","text":"GSourceFuncsPrepareFunc","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"type":"topic","abstract":[{"text":"Called before all the file descriptors are polled. If","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the source can determine that it is ready here (without waiting for the"},{"type":"text","text":" "},{"text":"results of the ","type":"text"},{"code":"poll()","type":"codeVoice"},{"text":" call) it should return ","type":"text"},{"type":"codeVoice","code":"true"},{"type":"text","text":". It can also return"},{"text":" ","type":"text"},{"type":"text","text":"a "},{"type":"codeVoice","code":"timeout_"},{"type":"text","text":" value which should be the maximum timeout (in milliseconds)"},{"type":"text","text":" "},{"text":"which should be passed to the ","type":"text"},{"type":"codeVoice","code":"poll()"},{"type":"text","text":" call. The actual timeout used will"},{"type":"text","text":" "},{"type":"text","text":"be -1 if all sources returned -1, or it will be the minimum of all"},{"type":"text","text":" "},{"type":"text","text":"the "},{"code":"timeout_","type":"codeVoice"},{"type":"text","text":" values returned which were >= 0.  Since 2.36 this may"},{"type":"text","text":" "},{"text":"be ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":", in which case the effect is as if the function always returns","type":"text"},{"type":"text","text":" "},{"code":"false","type":"codeVoice"},{"text":" with a timeout of -1.  If ","type":"text"},{"code":"prepare","type":"codeVoice"},{"text":" returns a","type":"text"},{"type":"text","text":" "},{"text":"timeout and the source also has a ready time set, then the","type":"text"},{"text":" ","type":"text"},{"text":"lower of the two will be used.","type":"text"}],"role":"symbol","kind":"symbol","title":"prepare","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsProtocol\/prepare"},"doc://GLib/documentation/GLib/MainContext":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MainContext"}],"url":"\/documentation\/glib\/maincontext","kind":"symbol","abstract":[{"type":"text","text":"The "},{"code":"GMainContext","type":"codeVoice"},{"type":"text","text":" struct is an opaque data"},{"text":" ","type":"text"},{"text":"type representing a set of sources to be handled in a main loop.","type":"text"}],"title":"MainContext","role":"symbol","navigatorTitle":[{"text":"MainContext","kind":"identifier"}]},"doc://GLib/documentation/GLib/SourceFuncsProtocol/finalize":{"kind":"symbol","title":"finalize","role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"finalize"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@T@GSourceFuncsFinalizeFunc","text":"GSourceFuncsFinalizeFunc","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsProtocol\/finalize","abstract":[{"type":"text","text":"Called when the source is finalized. At this point,"},{"type":"text","text":" "},{"type":"text","text":"the source will have been destroyed, had its callback cleared, and have"},{"type":"text","text":" "},{"text":"been removed from its [struct","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","isActive":true},{"type":"text","text":"], but it will still have"},{"type":"text","text":" "},{"type":"text","text":"its final reference count, so methods can be called on it from within"},{"type":"text","text":" "},{"text":"this function. This may be ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":", in which case the effect is as if the","type":"text"},{"text":" ","type":"text"},{"text":"function does nothing and returns.","type":"text"}],"url":"\/documentation\/glib\/sourcefuncsprotocol\/finalize"},"doc://GLib/documentation/GLib/PointerWrapper":{"abstract":[{"text":"Protocol for GLib types that wrap pointers.","type":"text"}],"role":"symbol","url":"\/documentation\/glib\/pointerwrapper","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","title":"PointerWrapper","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"PointerWrapper"}],"type":"topic","navigatorTitle":[{"text":"PointerWrapper","kind":"identifier"}]},"doc://GLib/documentation/GLib/SourceFuncsProtocol/check":{"fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"check"},{"text":": ","kind":"text"},{"text":"GSourceFuncsCheckFunc","kind":"typeIdentifier","preciseIdentifier":"c:@T@GSourceFuncsCheckFunc"},{"kind":"text","text":"!"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsProtocol\/check","type":"topic","abstract":[{"type":"text","text":"Called after all the file descriptors are polled. The"},{"text":" ","type":"text"},{"type":"text","text":"source should return "},{"code":"true","type":"codeVoice"},{"type":"text","text":" if it is ready to be dispatched. Note that"},{"text":" ","type":"text"},{"type":"text","text":"some time may have passed since the previous prepare function was called,"},{"text":" ","type":"text"},{"text":"so the source should be checked again here.  Since 2.36 this may","type":"text"},{"type":"text","text":" "},{"type":"text","text":"be "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", in which case the effect is as if the function always returns"},{"text":" ","type":"text"},{"type":"codeVoice","code":"false"},{"type":"text","text":"."}],"title":"check","role":"symbol","kind":"symbol","url":"\/documentation\/glib\/sourcefuncsprotocol\/check"},"doc://GLib/documentation/GLib/SourceFuncsProtocol":{"navigatorTitle":[{"text":"SourceFuncsProtocol","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsProtocol","url":"\/documentation\/glib\/sourcefuncsprotocol","abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"GSourceFuncs"},{"type":"text","text":" struct contains a table of"},{"type":"text","text":" "},{"type":"text","text":"functions used to handle event sources in a generic manner."}],"role":"symbol","title":"SourceFuncsProtocol","kind":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"SourceFuncsProtocol"}]},"doc://GLib/documentation/GLib/SourceFuncsRef":{"abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"GSourceFuncs"},{"text":" struct contains a table of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"functions used to handle event sources in a generic manner."}],"title":"SourceFuncsRef","url":"\/documentation\/glib\/sourcefuncsref","type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"SourceFuncsRef"}],"role":"symbol","kind":"symbol","navigatorTitle":[{"text":"SourceFuncsRef","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef"},"doc://GLib/documentation/GLib/sourceContinue":{"kind":"symbol","role":"symbol","title":"sourceContinue","url":"\/documentation\/glib\/sourcecontinue","abstract":[{"type":"text","text":"Use this macro as the return value of a [callback"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFunc"},{"type":"text","text":"] to leave"},{"type":"text","text":" "},{"type":"text","text":"the [struct"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","type":"reference","isActive":true},{"text":"] in the main loop.","type":"text"}],"fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"sourceContinue"},{"text":": ","kind":"text"},{"text":"gboolean","kind":"typeIdentifier","preciseIdentifier":"c:@T@gboolean"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/sourceContinue","type":"topic"},"doc://GLib/documentation/GLib/SourceFuncs":{"type":"topic","kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"The "},{"code":"GSourceFuncs","type":"codeVoice"},{"text":" struct contains a table of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"functions used to handle event sources in a generic manner."}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncs","title":"SourceFuncs","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"SourceFuncs"}],"navigatorTitle":[{"text":"SourceFuncs","kind":"identifier"}],"url":"\/documentation\/glib\/sourcefuncs"},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/SourceFuncsProtocol/sourceRemoveByFuncs(userData:)":{"title":"sourceRemoveByFuncs(userData:)","abstract":[{"text":"Removes a source from the default main loop context given the","type":"text"},{"text":" ","type":"text"},{"text":"source functions and user data.","type":"text"}],"type":"topic","kind":"symbol","url":"\/documentation\/glib\/sourcefuncsprotocol\/sourceremovebyfuncs(userdata:)","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsProtocol\/sourceRemoveByFuncs(userData:)","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"sourceRemoveByFuncs"},{"kind":"text","text":"("},{"text":"userData","kind":"externalParam"},{"kind":"text","text":": "},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:@T@gpointer"},{"kind":"text","text":"?) -> "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}]},"doc://GLib/documentation/GLib/SourceFuncsProtocol/dispatch":{"url":"\/documentation\/glib\/sourcefuncsprotocol\/dispatch","abstract":[{"text":"Called to dispatch the event source, after it has returned","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"true"},{"text":" in either its ","type":"text"},{"type":"codeVoice","code":"prepare"},{"text":" or its ","type":"text"},{"code":"check","type":"codeVoice"},{"text":" function, or if a ready time","type":"text"},{"text":" ","type":"text"},{"text":"has been reached. The ","type":"text"},{"code":"dispatch","type":"codeVoice"},{"type":"text","text":" function receives a callback function and"},{"text":" ","type":"text"},{"type":"text","text":"user data. The callback function may be "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" if the source was never"},{"text":" ","type":"text"},{"text":"connected to a callback using [method","type":"text"},{"type":"codeVoice","code":"GLib.Source.set_callback"},{"text":"]. The","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"dispatch"},{"text":" function should call the callback function with ","type":"text"},{"code":"user_data","type":"codeVoice"},{"type":"text","text":" and"},{"type":"text","text":" "},{"text":"whatever additional parameters are needed for this type of event source.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"The return value of the "},{"type":"codeVoice","code":"dispatch"},{"text":" function should be","type":"text"},{"type":"text","text":" "},{"text":"[const","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/sourceRemove","type":"reference","isActive":true},{"type":"text","text":"] if the source should be removed or"},{"text":" ","type":"text"},{"text":"[const","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/sourceContinue"},{"type":"text","text":"] to keep it."}],"type":"topic","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"dispatch","kind":"identifier"},{"text":": ","kind":"text"},{"text":"GSourceFuncsDispatchFunc","kind":"typeIdentifier","preciseIdentifier":"c:@T@GSourceFuncsDispatchFunc"},{"text":"!","kind":"text"}],"kind":"symbol","title":"dispatch","role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsProtocol\/dispatch"}}}