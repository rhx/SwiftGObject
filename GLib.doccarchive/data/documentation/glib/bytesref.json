{"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"BytesRef"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"anchor":"overview","level":2,"type":"heading","text":"Overview"},{"inlineContent":[{"text":"The purpose of a ","type":"text"},{"type":"codeVoice","code":"GBytes"},{"text":" is to keep the memory region that it holds","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"alive for as long as anyone holds a reference to the bytes.  When"},{"type":"text","text":" "},{"type":"text","text":"the last reference count is dropped, the memory is released. Multiple"},{"text":" ","type":"text"},{"type":"text","text":"unrelated callers can use byte data in the "},{"code":"GBytes","type":"codeVoice"},{"type":"text","text":" without coordinating"},{"type":"text","text":" "},{"type":"text","text":"their activities, resting assured that the byte data will not change or"},{"text":" ","type":"text"},{"type":"text","text":"move while they hold a reference."}],"type":"paragraph"},{"inlineContent":[{"text":"A ","type":"text"},{"code":"GBytes","type":"codeVoice"},{"text":" can come from many different origins that may have","type":"text"},{"type":"text","text":" "},{"text":"different procedures for freeing the memory region.  Examples are","type":"text"},{"type":"text","text":" "},{"text":"memory from [func","type":"text"},{"type":"codeVoice","code":"GLib.malloc"},{"type":"text","text":"], from memory slices, from a"},{"text":" ","type":"text"},{"text":"[struct","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MappedFile","type":"reference","isActive":true},{"type":"text","text":"] or memory from other allocators."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"GBytes"},{"type":"text","text":" work well as keys in [struct"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/HashTable","isActive":true},{"type":"text","text":"]. Use"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.Bytes.equal"},{"text":"] and [method","type":"text"},{"code":"GLib.Bytes.hash","type":"codeVoice"},{"type":"text","text":"] as parameters to"},{"text":" ","type":"text"},{"text":"[func","type":"text"},{"code":"GLib.HashTable.new","type":"codeVoice"},{"text":"] or [func","type":"text"},{"type":"codeVoice","code":"GLib.HashTable.new_full"},{"text":"].","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"GBytes"},{"type":"text","text":" can also be used as keys in a [struct"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Tree"},{"type":"text","text":"] by passing the"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.Bytes.compare"},{"type":"text","text":"] function to [ctor"},{"type":"codeVoice","code":"GLib.Tree.new"},{"type":"text","text":"]."}]},{"type":"paragraph","inlineContent":[{"text":"The data pointed to by this bytes must not be modified. For a mutable","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"array of bytes see [struct"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/ByteArray"},{"type":"text","text":"]. Use"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GLib.Bytes.unref_to_array"},{"type":"text","text":"] to create a mutable array for a "},{"code":"GBytes","type":"codeVoice"},{"text":" ","type":"text"},{"text":"sequence. To create an immutable ","type":"text"},{"type":"codeVoice","code":"GBytes"},{"type":"text","text":" from a mutable"},{"text":" ","type":"text"},{"text":"[struct","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/ByteArray","isActive":true},{"type":"text","text":"], use the [func"},{"type":"codeVoice","code":"GLib.ByteArray.free_to_bytes"},{"type":"text","text":"]"},{"type":"text","text":" "},{"type":"text","text":"function."}]},{"inlineContent":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/BytesRef"},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"code":"GBytes","type":"codeVoice"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"text":"It exposes methods that can operate on this data type through ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/BytesProtocol","isActive":true},{"text":" conformance.","type":"text"},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/BytesRef"},{"text":" only as an ","type":"text"},{"code":"unowned","type":"codeVoice"},{"type":"text","text":" reference to an existing "},{"type":"codeVoice","code":"GBytes"},{"text":" instance.","type":"text"}],"type":"paragraph"},{"type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Bytes","type":"reference","isActive":true},{"type":"text","text":" (instead of "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/BytesRef","type":"reference","isActive":true},{"type":"text","text":") if you want to use Automatic Reference Counting for memory management of the underlying "},{"type":"codeVoice","code":"GBytes"},{"type":"text","text":" instance."}]}],"style":"note"}],"kind":"content"}],"abstract":[{"text":"A simple reference counted data type representing an immutable sequence of","type":"text"},{"text":" ","type":"text"},{"text":"zero or more bytes from an unspecified origin.","type":"text"}],"topicSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/BytesRef\/init(_:)-2v7gp","doc:\/\/GLib\/documentation\/GLib\/BytesRef\/init(_:)-2zlxv","doc:\/\/GLib\/documentation\/GLib\/BytesRef\/init