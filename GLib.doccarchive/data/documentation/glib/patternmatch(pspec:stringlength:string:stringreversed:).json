{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/patternmatch(pspec:stringlength:string:stringreversed:)"]}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/patternMatch(pspec:stringLength:string:stringReversed:)","interfaceLanguage":"swift"},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"patternMatch"},{"text":"<","kind":"text"},{"text":"PatternSpecT","kind":"genericParameter"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"pspec"},{"text":": ","kind":"text"},{"text":"PatternSpecT","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"stringLength","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"string","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">!, "},{"text":"stringReversed","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">? = nil) -> ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"text":"PatternSpecT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:4GLib19PatternSpecProtocolP","identifier":"doc:\/\/GLib\/documentation\/GLib\/PatternSpecProtocol","kind":"typeIdentifier","text":"PatternSpecProtocol"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"inlineContent":[{"type":"text","text":"Passing the correct"},{"text":" ","type":"text"},{"type":"text","text":"length of the string given is mandatory. The reversed string can be"},{"type":"text","text":" "},{"text":"omitted by passing ","type":"text"},{"code":"NULL","type":"codeVoice"},{"text":", this is more efficient if the reversed","type":"text"},{"type":"text","text":" "},{"type":"text","text":"version of the string to be matched is not at hand, as"},{"text":" ","type":"text"},{"code":"g_pattern_match()","type":"codeVoice"},{"text":" will only construct it if the compiled pattern","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"requires reverse matches."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Note that, if the user code will (possibly) match a string against a","type":"text"},{"type":"text","text":" "},{"text":"multitude of patterns containing wildcards, chances are high that","type":"text"},{"type":"text","text":" "},{"type":"text","text":"some patterns will require a reversed string. In this case, it’s"},{"type":"text","text":" "},{"type":"text","text":"more efficient to provide the reversed string to avoid multiple"},{"text":" ","type":"text"},{"type":"text","text":"constructions thereof in the various calls to "},{"type":"codeVoice","code":"g_pattern_match()"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note also that the reverse of a UTF-8 encoded string can in general"},{"text":" ","type":"text"},{"type":"text","text":"not be obtained by [func"},{"code":"GLib.strreverse","type":"codeVoice"},{"text":"]. This works only if the string","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"does not contain any multibyte characters. GLib offers the"},{"text":" ","type":"text"},{"text":"[func","type":"text"},{"code":"GLib.utf8_strreverse","type":"codeVoice"},{"text":"] function to reverse UTF-8 encoded strings.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"pattern_match is deprecated:"}]},{"text":" ","type":"text"},{"text":"Use [method@GLib.PatternSpec.match] instead","type":"text"}]}]}],"metadata":{"roleHeading":"Function","externalID":"s:4GLib12patternMatch5pspec12stringLength0E00E8ReversedSbx_SiSPys4Int8VGSgAJtAA19PatternSpecProtocolRzlF","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"patternMatch"},{"kind":"text","text":"<"},{"text":"PatternSpecT","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"pspec","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"PatternSpecT","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"stringLength"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"string","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"text":"stringReversed","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"text":">?) -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"platforms":[],"role":"symbol","modules":[{"name":"GLib"}],"symbolKind":"func","title":"patternMatch(pspec:stringLength:string:stringReversed:)"},"abstract":[{"text":"Matches a string against a compiled pattern.","type":"text"}],"references":{"doc://GLib/documentation/GLib/patternMatch(pspec:stringLength:string:stringRever