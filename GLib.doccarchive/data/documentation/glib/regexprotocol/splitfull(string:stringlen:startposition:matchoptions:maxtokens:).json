 from just passing over a shortened"},{"text":" ","type":"text"},{"type":"text","text":"string and setting "},{"type":"codeVoice","code":"notbol"},{"type":"text","text":" in the case of a pattern"},{"type":"text","text":" "},{"type":"text","text":"that begins with any kind of lookbehind assertion, such as “\\b”."}]}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/RegexProtocol"]]},"references":{"doc://GLib/documentation/GLib/RegexMatchFlags":{"abstract":[{"text":"Flags specifying match-time options.","type":"text"}],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexMatchFlags","role":"symbol","title":"RegexMatchFlags","kind":"symbol","url":"\/documentation\/glib\/regexmatchflags","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"RegexMatchFlags","kind":"identifier"}],"navigatorTitle":[{"text":"RegexMatchFlags","kind":"identifier"}]},"doc://GLib/documentation/GLib/RegexProtocol/splitFull(string:stringLen:startPosition:matchOptions:maxTokens:)":{"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"splitFull","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"string"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier","text":"gchar"},{"text":">!, ","kind":"text"},{"text":"stringLen","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gssize","text":"gssize"},{"text":", ","kind":"text"},{"text":"startPosition","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"kind":"externalParam","text":"matchOptions"},{"kind":"text","text":": "},{"text":"RegexMatchFlags","kind":"typeIdentifier","preciseIdentifier":"s:4GLib15RegexMatchFlagsV"},{"