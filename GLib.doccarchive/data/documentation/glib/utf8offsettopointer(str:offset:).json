code":"offset"},{"text":" is within string boundaries","type":"text"},{"type":"text","text":" "},{"type":"text","text":"before calling that function. Call [func"},{"code":"GLib.utf8_strlen","type":"codeVoice"},{"text":"] when unsure.","type":"text"},{"type":"text","text":" "},{"text":"This limitation exists as this function is called frequently during","type":"text"},{"text":" ","type":"text"},{"text":"text rendering and therefore has to be as fast as possible.","type":"text"}]}],"kind":"content"}],"sections":[],"variants":[{"paths":["\/documentation\/glib\/utf8offsettopointer(str:offset:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"kind":"symbol","metadata":{"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"utf8OffsetToPointer"},{"kind":"text","text":"("},{"text":"str","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">!, ","kind":"text"},{"text":"offset","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":"!"}],"title":"utf8OffsetToPointer(str:offset:)","externalID":"s:4GLib19utf8OffsetToPointer3str6offsetSSSgSPys4Int8VGSg_SitF","symbolKind":"func","roleHeading":"Function","modules":[{"name":"GLib"}],"role":"symbol"},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/utf8OffsetToPointer(str:offset:)","interfaceLanguage":"swift"},"references":{"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/utf8OffsetToPo