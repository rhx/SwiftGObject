{"metadata":{"extendedModule":"GLib","roleHeading":"Instance Method","modules":[{"name":"GLib"}],"symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"set","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"strictPosix"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"},{"text":")","kind":"text"}],"externalID":"s:4GLib21OptionContextProtocolPAAE3set11strictPosixySb_tF","role":"symbol","title":"set(strictPosix:)"},"abstract":[{"text":"Sets strict POSIX mode.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"set"},{"kind":"text","text":"("},{"kind":"externalParam","text":"strictPosix"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"},{"kind":"text","text":")"}],"platforms":["macOS"]}]},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"By default, this mode is disabled.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In strict POSIX mode, the first non-argument parameter encountered"},{"text":" ","type":"text"},{"type":"text","text":"(eg: filename) terminates argument processing.  Remaining arguments"},{"type":"text","text":" "},{"text":"are treated as non-options and are not attempted to be parsed.","type":"text"}]},{"inlineContent":[{"type":"text","text":"If strict POSIX mode is disabled then parsing is done in the GNU way"},{"type":"text","text":" "},{"type":"text","text":"where option arguments can be freely mixed with non-options."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"As an example, consider “ls foo -l”.  With GNU style parsing, this","type":"text"},{"type":"text","text":" "},{"type":"text","text":"will list “foo” in long mode.  In strict POSIX style, this will list"},{"type":"text","text":" "},{"text":"the files named “foo” and “-l”.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"It may be useful to force strict POSIX mode when creating “verb","type":"text"},{"type":"text","text":" "},{"text":"style” command line tools.  For example, the “gsettings” command line","type":"text"},{"text":" ","type":"text"},{"text":"tool supports the global option “–schemadir” as well as many","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"subcommands (“get”, “set”, etc.) which each have their own set of"},{"text":" ","type":"text"},{"text":"arguments.  Using strict POSIX mode will allow parsing the global","type":"text"},{"type":"text","text":" "},{"type":"text","text":"options up to the verb name while leaving the remaining options to be"},{"type":"text","text":" "},{"type":"text","text":"parsed by the relevant subcommand (which can be determined by"},{"type":"text","text":" "},{"type":"text","text":"examining the verb name, which should be present in argv[1] after"},{"text":" ","type":"text"},{"type":"text","text":"parsing)."}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/OptionContextProtocol"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/OptionContextProtocol\/set(strictPosix:)"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/optioncontextprotocol\/set(strictposix:)"]}],"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"references":{"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/OptionContextProtocol":{"kind":"symbol","type":"topic","role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/OptionContextProtocol","abstract":[{"type":"text","text":"A "},{"code":"GOptionContext","type":"codeVoice"},{"type":"text","text":" struct defines which options"},{"text":" ","type":"text"},{"text":"are accepted by the commandline option parser. The struct has only private","type":"text"},{"type":"text","text":" "},{"text":"fields and should not be directly accessed.","type":"text"}],"url":"\/documentation\/glib\/optioncontextprotocol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"OptionContextProtocol"}],"title":"OptionContextProtocol","navigatorTitle":[{"text":"OptionContextProtocol","kind":"identifier"}]},"doc://GLib/documentation/GLib/OptionContextProtocol/set(strictPosix:)":{"url":"\/documentation\/glib\/optioncontextprotocol\/set(strictposix:)","abstract":[{"text":"Sets strict POSIX mode.","type":"text"}],"title":"set(strictPosix:)","identifier":"doc:\/\/GLib\/documentation\/GLib\/OptionContextProtocol\/set(strictPosix:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"set"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"strictPosix"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"},{"text":")","kind":"text"}],"type":"topic","kind":"symbol","role":"symbol"}}}