{"kind":"symbol","abstract":[{"type":"text","text":"Locks "},{"code":"recMutex","type":"codeVoice"},{"type":"text","text":". If "},{"code":"recMutex","type":"codeVoice"},{"type":"text","text":" is already locked by another"},{"type":"text","text":" "},{"type":"text","text":"thread, the current thread will block until "},{"code":"recMutex","type":"codeVoice"},{"text":" is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"unlocked by the other thread. If "},{"code":"recMutex","type":"codeVoice"},{"text":" is already locked","type":"text"},{"type":"text","text":" "},{"text":"by the current thread, the ‘lock count’ of ","type":"text"},{"type":"codeVoice","code":"recMutex"},{"type":"text","text":" is increased."},{"text":" ","type":"text"},{"text":"The mutex will only become available again when it is unlocked","type":"text"},{"type":"text","text":" "},{"text":"as many times as it has been locked.","type":"text"}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/RecMutexProtocol\/lock()","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"role":"symbol","externalID":"s:4GLib16RecMutexProtocolPAAE4lockyyF","title":"lock()","extendedModule":"GLib","symbolKind":"method","roleHeading":"Instance Method","modules":[{"name":"GLib"}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"lock","kind":"identifier"},{"text":"()","kind":"text"}]},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/RecMutexProtocol"]]},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"lock","kind":"identifier"},{"kind":"text","text":"()"}],"platforms":["macOS"],"languages":["swift"]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/recmutexprotocol\/lock()"]}],"references":{"doc://GLib/documentation/GLib/RecMutexProtocol":{