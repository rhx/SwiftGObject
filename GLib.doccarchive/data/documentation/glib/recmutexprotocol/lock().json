ad. If "},{"code":"recMutex","type":"codeVoice"},{"text":" is already locked","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"by the current thread, the ‘lock count’ of "},{"code":"recMutex","type":"codeVoice"},{"text":" is increased.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The mutex will only become available again when it is unlocked"},{"text":" ","type":"text"},{"type":"text","text":"as many times as it has been locked."}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutexProtocol\/lock()","role":"symbol"},"doc://GLib/documentation/GLib/Mutex":{"kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","role":"symbol","abstract":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","type":"reference","isActive":true},{"text":" struct is an opaque data structure to represent a mutex","type":"text"},{"type":"text","text":" "},{"text":"(mutual exclusion). It can be used to protect data against shared","type":"text"},{"type":"text","text":" "},{"text":"access.","type":"text"}],"type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"Mutex","kind":"identifier"}],"title":"Mutex","navigatorTitle":[{"kind":"identifier","text":"Mutex"}],"url":"\/documentation\/glib\/mutex"}}}