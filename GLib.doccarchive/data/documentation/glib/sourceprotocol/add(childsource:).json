{"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"text":"Adds ","type":"text"},{"type":"codeVoice","code":"childSource"},{"type":"text","text":" to "},{"type":"codeVoice","code":"source"},{"type":"text","text":" as a ‘polled’ source."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/sourceprotocol\/add(childsource:)"]}],"metadata":{"roleHeading":"Instance Method","title":"add(childSource:)","externalID":"s:4GLib14SourceProtocolPAAE3add05childB0yqd___tAaBRd__lF","symbolKind":"method","modules":[{"name":"GLib"}],"role":"symbol","extendedModule":"GLib","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"add"},{"text":"<","kind":"text"},{"text":"SourceT","kind":"genericParameter"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"childSource"},{"kind":"text","text":": "},{"text":"SourceT","kind":"typeIdentifier"},{"kind":"text","text":")"}]},"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"add","kind":"identifier"},{"kind":"text","text":"<"},{"text":"SourceT","kind":"genericParameter"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"childSource"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"SourceT"},{"kind":"text","text":") "},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SourceT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"kind":"typeIdentifier","text":"SourceProtocol","preciseIdentifier":"s:4GLib14SourceProtocolP","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceProtocol"}]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When "},{"code":"source","type":"codeVoice"},{"type":"text","text":" is added to a [struct"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","isActive":true,"type":"reference"},{"text":"], ","type":"text"},{"type":"codeVoice","code":"childSource"},{"type":"text","text":" will be"},{"text":" ","type":"text"},{"type":"text","text":"automatically added with the same priority. When "},{"code":"childSource","type":"codeVoice"},{"text":" is triggered,","type":"text"},{"text":" ","type":"text"},{"text":"it will cause ","type":"text"},{"type":"codeVoice","code":"source"},{"text":" to dispatch (in addition to calling its own callback),","type":"text"},{"text":" ","type":"text"},{"text":"and when ","type":"text"},{"type":"codeVoice","code":"source"},{"text":" is destroyed, it will destroy ","type":"text"},{"code":"childSource","type":"codeVoice"},{"type":"text","text":" as well."}]},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"source"},{"text":" will also still be dispatched if its own prepare\/check functions","type":"text"},{"type":"text","text":" "},{"type":"text","text":"indicate that it is ready."}],"type":"paragraph"},{"inlineContent":[{"text":"If you don’t need ","type":"text"},{"code":"childSource","type":"codeVoice"},{"text":" to do anything on its own when it","type":"text"},{"type":"text","text":" "},{"type":"text","text":"triggers, you can call "},{"code":"g_source_set_dummy_callback()","type":"codeVoice"},{"text":" on it to set a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"callback that does nothing (except return true if appropriate)."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"source"},{"type":"text","text":" will hold a reference on "},{"type":"codeVoice","code":"childSource"},{"type":"text","text":" while "},{"type":"codeVoice","code":"childSource"},{"text":" ","type":"text"},{"text":"is attached to it.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This API is only intended to be used by implementations of [struct","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","isActive":true},{"text":"].","type":"text"},{"type":"text","text":" "},{"text":"Do not call this API on a [struct","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","type":"reference","isActive":true},{"type":"text","text":"] that you did not create."}],"type":"paragraph"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/SourceProtocol\/add(childSource:)"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/SourceProtocol"]]},"sections":[],"references":{"doc://GLib/documentation/GLib/SourceProtocol/add(childSource:)":{"title":"add(childSource:)","url":"\/documentation\/glib\/sourceprotocol\/add(childsource:)","abstract":[{"type":"text","text":"Adds "},{"type":"codeVoice","code":"childSource"},{"type":"text","text":" to "},{"type":"codeVoice","code":"source"},{"text":" as a ‘polled’ source.","type":"text"}],"kind":"symbol","role":"symbol","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceProtocol\/add(childSource:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"add","kind":"identifier"},{"text":"<","kind":"text"},{"text":"SourceT","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"childSource","kind":"externalParam"},{"kind":"text","text":": "},{"text":"SourceT","kind":"typeIdentifier"},{"text":")","kind":"text"}]},"doc://GLib/documentation/GLib/MainContext":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MainContext"}],"url":"\/documentation\/glib\/maincontext","kind":"symbol","abstract":[{"type":"text","text":"The "},{"code":"GMainContext","type":"codeVoice"},{"type":"text","text":" struct is an opaque data"},{"text":" ","type":"text"},{"text":"type representing a set of sources