{"abstract":[{"type":"text","text":"Adds "},{"type":"codeVoice","code":"childSource"},{"type":"text","text":" to "},{"code":"source","type":"codeVoice"},{"text":" as a ‘polled’ source.","type":"text"}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/SourceProtocol\/add(childSource:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/SourceProtocol"]]},"metadata":{"modules":[{"name":"GLib"}],"title":"add(childSource:)","extendedModule":"GLib","roleHeading":"Instance Method","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"add"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"SourceT"},{"text":">(","kind":"text"},{"text":"childSource","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"SourceT"},{"text":")","kind":"text"}],"externalID":"s:4GLib14SourceProtocolPAAE3add05childB0yqd___tAaBRd__lF","role":"symbol","symbolKind":"method"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"add","kind":"identifier"},{"text":"<","kind":"text"},{"text":"SourceT","kind":"genericParameter"},{"kind":"text","text":">("},{"text":"childSource","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"SourceT","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"typeIdentifier","text":"SourceT"},{"kind":"text","text":" : "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceProtocol","preciseIdentifier":"s:4GLib14SourceProtocolP","text":"SourceProtocol","kind":"typeIdentifier"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"inlineContent":[{"type":"text","text":"When "},{"code":"source","type":"codeVoice"},{"type":"text","text":" is added to a [struct"},