{"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/SourceProtocol\/destroy()"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/SourceProtocol"]]},"abstract":[{"type":"text","text":"Removes a source from its [struct"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","isActive":true},{"text":"], if any, and marks it as","type":"text"},{"text":" ","type":"text"},{"text":"destroyed.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/sourceprotocol\/destroy()"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"destroy"},{"text":"()","kind":"text"}],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The source cannot be subsequently added to another"},{"type":"text","text":" "},{"type":"text","text":"context. It is safe to call this on sources which have already been"},{"type":"text","text":" "},{"text":"removed from their context.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This does not unref the [struct"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Source"},{"text":"]: if you still hold a reference,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"use [method"},{"code":"GLib.Source.unref","type":"codeVoice"},{"type":"text","text":"] to drop it."}]},{"type":"paragraph","inlineContent":[{"text":"This function is safe to call from any thread, regardless of which thread","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the [struct"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","isActive":true,"type":"reference"},{"type":"text","text":"] is running in."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the source is currently attached to a [struct"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","isActive":true},{"text":"],","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"destroying it will effectively unset the callback similar to calling"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.Source.set_callback"},{"text":"]. This can mean, that the data’s","type":"text"},{"type":"text","text":" "},{"text":"[callback","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/DestroyNotify","isActive":true},{"text":"] gets called right away.","type":"text"}]}]}],"metadata":{"symbolKind":"method","title":"destroy()","roleHeading":"Instance Method","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"destroy","kind":"identifier"},{"kind":"text","text":"()"}],"role":"symbol","extendedModule":"GLib","externalID":"s:4GLib14SourceProtocolPAAE7destroyyyF","modules":[{"name":"GLib"}]},"kind":"symbol","references":{"doc://GLib/documentation/GLib/Source":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","role":"symbol","title":"Source","url":"\/documentation\/glib\/source","type":"topic","navigatorTitle":[{"text":"Source","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"Source","kind":"identifier"}],"abstract":[{"type":"text","text":"The "},{"code":"GSource","type":"codeVoice"},{"text":" struct is an opaque data type","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"representing an event source."}],"kind":"symbol"},"doc://GLib/documentation/GLib/DestroyNotify":{"title":"DestroyNotify","identifier":"doc:\/\/GLib\/documentation\/GLib\/DestroyNotify","kind":"symbol","type":"topic","url":"\/doc