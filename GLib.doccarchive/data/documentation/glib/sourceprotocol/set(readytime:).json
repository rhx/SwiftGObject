{"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"set","kind":"identifier"},{"text":"(","kind":"text"},{"text":"readyTime","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"gint64","preciseIdentifier":"c:@T@gint64"},{"text":")","kind":"text"}],"roleHeading":"Instance Method","title":"set(readyTime:)","modules":[{"name":"GLib"}],"symbolKind":"method","extendedModule":"GLib","externalID":"s:4GLib14SourceProtocolPAAE3set9readyTimeys5Int64V_tF"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/SourceProtocol"]]},"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/SourceProtocol\/set(readyTime:)"},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/sourceprotocol\/set(readytime:)"]}],"abstract":[{"type":"text","text":"Sets a source to be dispatched when the given monotonic time is"},{"type":"text","text":" "},{"text":"reached (or passed).","type":"text"}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"set"},{"text":"(","kind":"text"},{"text":"readyTime","kind":"externalParam"},{"kind":"text","text":": "},{"text":"gint64","preciseIdentifier":"c:@T@gint64","kind":"typeIdentifier"},{"kind":"text","text":")"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the monotonic time is in the past (as it"},{"text":" ","type":"text"},{"type":"text","text":"always will be if "},{"code":"readyTime","type":"codeVoice"},{"type":"text","text":" is "},{"code":"0","type":"codeVoice"},{"type":"text","text":") then the source will be"},{"type":"text","text":" "},{"text":"dispatched immediately.","type":"text"}]},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"readyTime"},{"type":"text","text":" is "},{"type":"codeVoice","code":"-1"},{"type":"text","text":" then the source is never woken up on the basis"},{"text":" ","type":"text"},{"type":"text","text":"of the passage of time."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Dispatching the source does not reset the ready time.  You should do"},{"type":"text","text":" "},{"text":"so yourself, from the source dispatch function.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Note that if you have a pair of sources where the ready time of one","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"suggests that it will be delivered first but the priority for the"},{"type":"text","text":" "},{"text":"other suggests that it would be delivered first, and the ready time","type":"text"},{"type":"text","text":" "},{"text":"for both sources is reached during the same main context iteration,","type":"text"},{"type":"text","text":" "},{"text":"then the order of dispatch is undefined.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"It is a no-op to call this function on a [struct","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","isActive":true},{"text":"] which has","type":"text"},{"type":"text","text":" "},{"type":"text","text":"already been destroyed with [method"},{"type":"codeVoice","code":"GLib.Source.destroy"},{"text":"].","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This API is only intended to be used by implementations of [struct","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","isActive":true},{"type":"text","text":"]."},{"type":"text","text":" "},{"text":"Do not call this API on a [struct","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Source"},{"type":"text","text":"] that you did not create."}]}]}],"references":{"doc://GLib/documentation/GLib/Source":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","role":"symbol","title":"Source","url":"\/documentation\/glib\/source","type":"topic","navigatorTitle":[{"text":"Source","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"Source","kind":"identifier"}],"abstract":[{"type":"text","text":"The "},{"code":"GSource","type":"codeVoice"},{"text":" struct is an opaque data type","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"representing an event source."}],"kind":"symbol"},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/SourceProtocol/set(readyTime:)":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceProtocol\/set(readyTime:)","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"set"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"readyTime"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gint64","text":"gint64"},{"text":")","kind":"text"}],"url":"\/documentation\/glib\/sourceprotocol\/set(readytime:)","type":"topic","title":"set(readyTime:)","kind":"symbol","abstract":[{"text":"Sets a source to be dispatched when the given monotonic time is","type":"text"},{"type":"text","text":" "},{"text":"reached (or passed).","type":"text"}]},"doc://GLib/documentation/GLib/SourceProtocol":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceProtocol","abstract":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"GSource"},{"type":"text","text":" struct is an opaque data type"},{"type":"text","text":" "},{"text":"representing an event source.","type"