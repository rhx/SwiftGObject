{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/SourceProtocol"]]},"kind":"symbol","abstract":[{"type":"text","text":"Sets a source to be dispatched when the given monotonic time is"},{"text":" ","type":"text"},{"text":"reached (or passed).","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"set"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"readyTime"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gint64","text":"gint64"},{"text":")","kind":"text"}]}]},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the monotonic time is in the past (as it"},{"text":" ","type":"text"},{"type":"text","text":"always will be if "},{"code":"readyTime","type":"codeVoice"},{"type":"text","text":" is "},{"code":"0","type":"codeVoice"},{"text":") then the source will be","type":"text"},{"text":" ","type":"text"},{"text":"dispatched immediately.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"readyTime","type":"codeVoice"},{"text":" is ","type":"text"},{"code":"-1","type":"codeVoice"},{"text":" then the source is never woken up on the basis","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of the passage of time."}]},{"inlineContent":[{"text":"Dispatching the source does not reset the ready time.  You should do","type":"text"},{"text":" ","type":"text"},{"text":"so yourself, from the source dispatch function.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Note that if you have a pair of sources where the ready time of one","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"suggests that it will be delivered first but the priority for the"},{"type":"text","text":" "},{"type":"text","text":"other suggests that it would be delivered first, and the ready time"},{"type":"text","text":" "},{"text":"for both sources is reached during the same main context iteration,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"then the order of dispatch is undefined."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is a no-op to call this function on a [struct"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","isActive":true},{"type":"text","text":"] which has"},{"type":"text","text":" "},{"text":"already been destroyed with [method","type":"text"},{"code":"GLib.Source.destroy","type":"codeVoice"},{"text":"].","type":"text"}]},{"inlineContent":[{"type":"text","text":"This API is only intended to be used by implementations of [struct"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Source"},{"text":"].","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Do not call this API on a [struct"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Source"},{"type":"text","text":"] that you did not create."}],"type":"paragraph"}],"kind":"content"}],"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/sourceprotocol\/set(readytime:)"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/SourceProtocol\/set(readyTime:)"},"metadata":{"symbolKind":"method","modules":[{"name":"GLib"}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"set","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"readyTime"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"gint64","preciseIdentifier":"c:@T@gint64"},{"text":")","kind":"text"}],"roleHeading":"Instance Method","extendedModule":"GLib"