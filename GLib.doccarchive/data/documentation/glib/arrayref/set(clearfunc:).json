{"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"set","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"clearFunc"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GDestroyNotify","text":"GDestroyNotify"},{"kind":"text","text":"? = nil)"}]}]},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"clearFunc"},{"type":"text","text":" will be called when an element in the array"},{"text":" ","type":"text"},{"text":"data segment is removed and when the array is freed and data","type":"text"},{"type":"text","text":" "},{"type":"text","text":"segment is deallocated as well. "},{"type":"codeVoice","code":"clearFunc"},{"text":" will be passed a","type":"text"},{"text":" ","type":"text"},{"text":"pointer to the element to clear, rather than the element itself.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Note that in contrast with other uses of [callback"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/DestroyNotify","isActive":true,"type":"reference"},{"text":"]","type":"text"},{"type":"text","text":" "},{"type":"text","text":"functions, "},{"code":"clearFunc","type":"codeVoice"},{"type":"text","text":" is expected to clear the contents of"},{"text":" ","type":"text"},{"type":"text","text":"the array element it is given, but not free the element itself."}],"type":"paragraph"},{"syntax":"c","code":["typedef struct","{","  gchar *str;","  GObject *obj;","} ArrayElement;","","static void","array_element_clear (ArrayElement *element)","{","  g_clear_pointer (&element->str, g_free);","  g_clear_object (&element->obj);","}","","\/\/ main code","GArray *garray = g_array_new (FALSE, FALSE, sizeof (ArrayElement));","g_array_set_clear_func (garray, (GDestroyNotify) array_element_clear);","\/\/ assign data to the structure","g_array_free (garray, TRUE);"],"type":"codeListing"}],"kind":"content"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/ArrayRef\/set(clearFunc:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/ArrayRef","doc:\/\/GLib\/documentation\/GLib\/ArrayRef\/ArrayProtocol-Implementations"]]},"abstract":[{"type":"text","text":"Sets a function to clear an element of "},{"code":"array","type":"codeVoice"},{"type":"text","text":"."}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/arrayref\/set(clearfunc:)"]}],"sections":[],"metadata":{"title":"set(clearFunc:)","symbolKind":"method","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"set"},{"text":"(","kind":"text"},{"text":"clearFunc","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@GDestroyNotify","text":"GDestroyNotify","kind":"typeIdentifier"},{"kind":"text","text":"?)"}],"modules":[{"name":"GLib"}],"roleHeading":"Instance Method","externalID":"s:4GLib13ArrayProtocolPAAE3set9clearFuncyySvSgXCSg_tF::SYNTHESIZED::s:4GLib8ArrayRefV","extendedModule":"GLib"},"references":{"doc://GLib/documentation/GLib/ArrayRef":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/ArrayRef","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"ArrayRef","kind":"identifier"}],"url":"\/documentation\/glib\/arrayref","kind":"symbol","abstract":[{"text":"Contains the public fields of a ","type":"text"},{"code":"GArray","type":"codeVoice"},{"type":"text","text":"."}],"title":"ArrayRef","role":"symbol","navigatorTitle":[{"text":"ArrayRef","kind":"identifier"}]},"doc://GLib/documentation/GLib/DestroyNotify":{"title":"DestroyNotify","identifier":"doc:\/\/G