{"abstract":[{"type":"text","text":"Atomically releases "},{"code":"mutex","type":"codeVoice"},{"type":"text","text":" and waits until "},{"type":"codeVoice","code":"cond"},{"text":" is signalled.","type":"text"},{"type":"text","text":" "},{"text":"When this function returns, ","type":"text"},{"type":"codeVoice","code":"mutex"},{"type":"text","text":" is locked again and owned by the"},{"type":"text","text":" "},{"text":"calling thread.","type":"text"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"wait","kind":"identifier"},{"kind":"text","text":"<"},{"text":"MutexT","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"mutex","kind":"externalParam"},{"kind":"text","text":": "},{"text":"MutexT","kind":"typeIdentifier"},{"kind":"text","text":") "},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MutexT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"MutexProtocol","preciseIdentifier":"s:4GLib13MutexProtocolP","identifier":"doc:\/\/GLib\/documentation\/GLib\/MutexProtocol","kind":"typeIdentifier"}]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"When using condition variables, it is possible that a spurious wakeup"},{"type":"text","text":" "},{"text":"may occur (ie: ","type":"text"},{"code":"g_cond_wait()","type":"codeVoice"},{"type":"text","text":" returns even though "},{"code":"g_cond_signal()","type":"codeVoice"},{"text":" was","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"not called).  It’s also possible that a stolen wakeup may occur."},{"type":"text","text":" "},{"type":"text","text":"This is when "},{"type":"codeVoice","code":"g_cond_signal()"},{"type":"text","text":" is called, but another thread acquires"},{"text":" ","type":"text"},{"code":"mutex","type":"codeVoice"},{"text":" before this thread and modifies the state of the program in","type":"text"},{"type":"text","text":" "},{"type":"text","text":"such a way that when "},{"type":"codeVoice","code":"g_cond_wait()"},{"type":"text","text":" is able to return, the expected"},{"type":"text","text":" "},{"type":"text","text":"condition is no longer met."}],"type":"paragraph"},{"inlineContent":[{"text":"For this reason, ","type":"text"},{"code":"g_cond_wait()","type":"codeVoice"},{"type":"text","text":" must always be used in a loop.  See"},{"text":" ","type":"text"},{"type":"text","text":"the documentation for "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","isActive":true},{"type":"text","text":" for a complete example."}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/Cond","doc:\/\/GLib\/documentation\/GLib\/Cond\/CondProtocol-Implementations"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/cond\/wait(mutex:)"]}],"metadata":{"roleHeading":"Instance Method","title":"wait(mutex:)","symbolKind":"method","role":"symbol","modules":[{"name":"GLib"}],"extendedModule":"GLib","externalID":"s:4GLib12CondProtocolPAAE4wait5mutexyqd___tAA05MutexC0Rd__lF::SYNTHESIZED::s:4GLib4CondC","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"wait"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"MutexT"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"mutex"},{"kind":"text","text":": "},{"text":"MutexT","kind":"typeIdentifier"},{"kind":"text","text":")"}]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/Cond\/wait(mutex:)"},"kind":"symbol","sections":[],"references":{"doc://GLib/documentation/GLib/Cond/wait(mutex:)":{"role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","k