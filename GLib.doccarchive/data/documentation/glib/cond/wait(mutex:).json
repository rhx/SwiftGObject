:"g_cond_signal()","type":"codeVoice"},{"type":"text","text":" was"},{"type":"text","text":" "},{"text":"not called).  It’s also possible that a stolen wakeup may occur.","type":"text"},{"type":"text","text":" "},{"text":"This is when ","type":"text"},{"type":"codeVoice","code":"g_cond_signal()"},{"type":"text","text":" is called, but another thread acquires"},{"text":" ","type":"text"},{"code":"mutex","type":"codeVoice"},{"text":" before this thread and modifies the state of the program in","type":"text"},{"type":"text","text":" "},{"text":"such a way that when ","type":"text"},{"type":"codeVoice","code":"g_cond_wait()"},{"type":"text","text":" is able to return, the expected"},{"type":"text","text":" "},{"type":"text","text":"condition is no longer met."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For this reason, "},{"code":"g_cond_wait()","type":"codeVoice"},{"text":" must always be used in a loop.  See","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the documentation for "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","type":"reference"},{"text":" for a complete example.","type":"text"}]}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/Cond","doc:\/\/GLib\/documentation\/GLib\/Cond\/CondProtocol-Implementations"]]},"abstract":[{"type":"text","text":"Atomically releases "},{"type":"codeVoice","code":"mutex"},{"type":"text","text":" and waits until "},{"code":"cond","type":"codeVoice"},{"text":" is signalled.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"When this function returns, "},{"code":"mutex","type":"codeVoice"},{"type":"text","text":" is locked again and owned by the"},{"type":"text","text":" "},{"type":"text","text":"calling thread."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://GLib/documentation/GLib/Mutex":{"kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","role":"symbol",