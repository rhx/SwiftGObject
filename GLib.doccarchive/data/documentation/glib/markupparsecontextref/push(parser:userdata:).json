{"abstract":[{"text":"Temporarily redirects markup data to a sub-parser.","type":"text"}],"sections":[],"metadata":{"modules":[{"name":"GLib"}],"role":"symbol","externalID":"s:4GLib26MarkupParseContextProtocolPAAE4push6parser8userDatayqd___SvSgtAA0b6ParserE0Rd__lF::SYNTHESIZED::s:4GLib21MarkupParseContextRefV","extendedModule":"GLib","title":"push(parser:userData:)","roleHeading":"Instance Method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"push"},{"kind":"text","text":"<"},{"text":"MarkupParserT","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"parser","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"MarkupParserT","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"userData","kind":"externalParam"},{"kind":"text","text":": "},{"text":"gpointer","preciseIdentifier":"c:@T@gpointer","kind":"typeIdentifier"},{"text":"?)","kind":"text"}],"symbolKind":"method"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/MarkupParseContextRef","doc:\/\/GLib\/documentation\/GLib\/MarkupParseContextRef\/MarkupParseContextProtocol-Implementations"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/MarkupParseContextRef\/push(parser:userData:)"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"push"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"MarkupParserT"},{"kind":"text","text":">("},{"kind":"externalParam","text":"parser"},{"text":": ","kind":"text"},{"text":"MarkupParserT","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"userData","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:@T@gpointer"},{"text":"? = nil) ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"typeIdentifier","text":"MarkupParserT"},{"kind":"text","text":" : "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MarkupParserProtocol","kind":"typeIdentifier","text":"MarkupParserProtocol","preciseIdentifier":"s:4GLib20MarkupParserProtocolP"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"This function may only be called from the start_element handler of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/MarkupParser"},{"type":"text","text":". It must be matched with a corresponding call to"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_markup_parse_context_pop()"},{"type":"text","text":" in the matching end_element handler"},{"type":"text","text":" "},{"type":"text","text":"(except in the case that the parser aborts due to an error)."}]},{"inlineContent":[{"type":"text","text":"All tags, text and other data between the matching tags is"},{"type":"text","text":" "},{"text":"redirected to the subparser given by ","type":"text"},{"code":"parser","type":"codeVoice"},{"type":"text","text":". "},{"code":"userData","type":"codeVoice"},{"text":" is used","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"as the user_data for that parser. "},{"code":"userData","type":"codeVoice"},{"type":"text","text":" is also passed to the"},{"type":"text","text":" "},{"text":"error callback in the event that an error occurs. This includes","type":"text"},{"text":" ","type":"text"},{"text":"errors that occur in subparsers of the subparser.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The end tag matching the start tag for which this call was made is"},{"type":"text","text":" "},{"text":"handled by the previous parser (which is given its own user_data)","type":"text"},{"type":"text","text":" "},{"type":"text","text":"which is why "},{"code":"g_markup_parse_context_pop()","type":"codeVoice"},{"text":" is provided to allow “one","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"last access” to the "},{"code":"userData","type":"codeVoice"},{"text":" provided to this function. In the","type":"text"},{"type":"text","text":" "},{"text":"case of error, the ","type":"text"},{"type":"codeVoice","code":"userData"},{"type":"text","text":" provided here is passed directly to"},{"text":" ","type":"text"},{"type":"text","text":"the error callback of the subparser and "},{"type":"codeVoice","code":"g_markup_parse_context_pop()"},{"type":"text","text":" "},{"type":"text","text":"should not be called. In either case, if "},{"type":"codeVoice","code":"userData"},{"text":" was allocated","type":"text"},{"type":"text","text":" "},{"type":"text","text":"then it ought to be freed from both of these locations."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function is not intended to be directly called by users"},{"type":"text","text":" "},{"type":"text","text":"interested in invoking subparsers. Instead, it is intended to be"},{"text":" ","type":"text"},{"text":"used by the subparsers themselves to implement a higher-level","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"interface."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"As an example, see the following implementation of a simple"},{"type":"text","text":" "},{"text":"parser that counts the number of tags encountered.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"type":"codeListing","syntax":"C","code":["typedef struct","{","  gint tag_count;","} CounterData;","","static void","counter_start_element (GMarkupParseContext  *context,","                       const gchar          *element_name,","                       const gchar         **attribute_names,","                       const gchar         **attribute_values,","                       gpointer              user_data,","                       GError              **error)","{","  CounterData *data = user_data;","","  data->tag_count++;","}","","static void","counter_error (GMarkupParseContext *context,","               GError              *error,","               gpointer             user_data)","{","  CounterData *data = user_data;","","  g_slice_free (CounterData, data);","}","","static GMarkupParser counter_subparser =","{","  counter_start_element,","  NULL,","  NULL,","  NULL,","  counter_error","};"]},{"type":"paragraph","inlineContent":[{"text":"In order to allow this parser to be easily used as a subparser, the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"following interface is provided:"}]},{"inlineContent":[{"text":"(C Language Example):","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"C","code":["void","start_counting (GMarkupParseContext *context)","{","  CounterData *data = g_slice_new (CounterData);","","  data->tag_count = 0;","  g_markup_parse_context_push (context, &counter_subparser, data);","}","","gint","end_counting (GMarkupParseContext *context)","{","  CounterData *data = g_markup_parse_context_pop (context);","  int result;","","  result = data->tag_count;","  g_slice_free (CounterData, data);","","  return result;","}"]},{"type":"paragraph","inlineContent":[{"text":"The subparser would then be used as follows:","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"type":"codeListing","syntax":"C","code":["static void start_element (context, element_name, ...)","{","  if (strcmp (element_name, \"count-these\") == 0)","    start_counting (context);","","  \/\/ else, handle other tags...","}","","static void end_element (context, element_name, ...)","{","  if (strcmp (element_name, \"count-these\") == 0)","    g_print (\"Counted %d tags\\n\", end_counting (context));","","  \/\/ else, handle other tags...","}"]}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/markupparsecontextref\/push(parser:userdata:)"]}],"references":{"doc://GLib/documentation/GLib/MarkupParser":{"title":"MarkupParser","abstract":[{"type":"text","text":"Any of the fields in "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MarkupParser","type":"reference","isActive":true},{"text":" can be ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":", in which case they","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"will be ignored. Except for the "},{"type":"codeVoice","code":"error"},{"type":"text","text":" function, any of these callbacks"},{"type":"text","text":" "},{"type":"text","text":"can set an error; in particular the "},{"type":"codeVoice","code":"unknownElement"},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"codeVoice","code":"unknownAttribute"},{"type":"text","text":", and "},{"type":"codeVoice","code":"invalidContent"},{"type":"text","text":" "},{"text":"errors are intended to be set from these callbacks. If you set an error","type":"text"},{"type":"text","text":" "},{"text":"from a callback, ","type":"text"},{"code":"g_markup_parse_context_parse()","type":"codeVoice"},{"text":" will report that error","type":"text"},{"type":"text","text":" "},{"text":"back to its caller.","type":"text"}],"url":"\/documentation\/glib\/markupparser","identifier":"doc:\/\/GLib\/documentation\/GLib\/MarkupParser","role":"symbol","navigatorTitle":[{"text":"MarkupParser","kind":"identifier"}],"type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MarkupParser"}]},"doc://GLib/documentation/GLib/MarkupParserProtocol":{"kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/MarkupParserProtocol","navigatorTitle":[{"text":"MarkupParserProtocol","kind":"identifier"}],"title":"MarkupParserProtocol","type":"topic","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MarkupParserProtocol","kind":"identifier"}],"url":"\/documentation\/glib\/markupparserprotocol","role":"symbol","abstract":[{"type":"text","text":"Any of the fields in "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/MarkupParser"},{"type":"text","text":" can be "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", in which case they"},{"text":" ","type":"text"},{"text":"will be ignored. Except for the ","type":"text"},{"code":"error","type":"codeVoice"},{"type":"text","text":" function, any of these callbacks"},{"text":" ","type":"text"},{"text":"can set an error; in particular the ","type":"text"},{"type":"codeVoice","code":"unknownElement"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"codeVoice","code":"unknownAttribute"},{"text":", and ","type":"text"},{"code":"invalidContent","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"errors are intended to be set from these callbacks. If you set an error"},{"text":" ","type":"text"},{"type":"text","text":"from a callback, "},{"type":"codeVoice","code":"g_markup_parse_context_parse()"},{"type":"text","text":" will report that error"},{"text":" ","type":"text"},{"type":"text","text":"back to its caller."}]},"doc://GLib/documentation/GLib/MarkupParseContextRef/push(parser:userData:)":{"kind":"symbol","url":"\/documentation\/glib\/markupparsecontextref\/push(parser:userdata:)","abstract":[{"text":"Temporarily redirects markup data to a sub-parser.","type":"text"}],"title":"push(parser:userData:)","identifier":"doc:\/\/GLib\/documentation\/GLib\/MarkupParseContextRef\/push(parser:userData:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"push"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"MarkupParserT"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"parser"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"MarkupParserT"},{"text":", ","kind":"text"},{"text":"userData","kind":"externalParam"},{"kind":"text","text":": "},{"text":"gpointer","preciseIdentifier":"c:@T@gpointer","kind":"typeIdentifier"},{"kind":"text","text":"?)"}],"role":"symbol","type":"topic"},"doc://GLib/documentation/GLib/MarkupParseContextRef":{"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"MarkupParseContextRef"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/MarkupParseContextRef","url":"\/documentation\/glib\/markupparsecontextref","abstract":[{"text":"A parse context is used to parse a stream of bytes that","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"you expect to contain marked-up text."}],"role":"symbol","title":"MarkupParseContextRef","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MarkupParseContextRef"}],"type":"topic"},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/MarkupParseContextRef/MarkupParseContextProtocol-Implementations":{"kind":"article","title":"MarkupParseContextProtocol Implementations","identifier":"doc:\/\/GLib\/documentation\/GLib\/MarkupParseContextRef\/MarkupParseContextProtocol-Implementations","role":"collectionGroup","type":"topic","abstract":[],"url":"\/documentation\/glib\/markupparsecontextref\/markupparsecontextprotocol-implementations"}}}