{"schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/DirProtocol"]]},"abstract":[{"text":"Decrements the reference count of ","type":"text"},{"code":"dir","type":"codeVoice"},{"text":".","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"unref"},{"kind":"text","text":"()"}],"platforms":["macOS"]}]},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"Once the reference count reaches zero, the directory will be closed and all"},{"text":" ","type":"text"},{"text":"resources associated with it will be freed. If [method","type":"text"},{"type":"codeVoice","code":"GLib.Dir.close"},{"type":"text","text":"] is"},{"type":"text","text":" "},{"type":"text","text":"called when the reference count is greater than zero, the directory is closed"},{"type":"text","text":" "},{"text":"but the ","type":"text"},{"code":"GDir","type":"codeVoice"},{"type":"text","text":" structure will not be freed until its reference count reaches"},{"text":" ","type":"text"},{"text":"zero.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"It is an error to call any of the ","type":"text"},{"type":"codeVoice","code":"GDir"},{"text":" methods other than","type":"text"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"code":"GLib.Dir.ref","type":"codeVoice"},{"text":"] and [method","type":"text"},{"type":"codeVoice","code":"GLib.Dir.unref"},{"type":"text","text":"] on a "},{"type":"codeVoice","code":"GDir"},{"text":" after calling","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GLib.Dir.close"},{"type":"text","text":"] on it."}],"type":"paragraph"}],"kind":"content"}],"kind":"symbol","sections":[],"identifier":{"in