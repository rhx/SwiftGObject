{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/dirprotocol\/unref()"]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"type":"text","text":"Decrements the reference count of "},{"type":"codeVoice","code":"dir"},{"type":"text","text":"."}],"metadata":{"extendedModule":"GLib","roleHeading":"Instance Method","role":"symbol","symbolKind":"method","externalID":"s:4GLib11DirProtocolPAAE5unrefyyF","title":"unref()","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"unref","kind":"identifier"},{"kind":"text","text":"()"}],"modules":[{"name":"GLib"}]},"sections":[],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/DirProtocol"]]},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/DirProtocol\/unref()","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"unref"},{"text":"()","kind":"text"}]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"inlineContent":[{"type":"text","text":"Once the reference count reaches zero, the directory will be closed and all"},{"type":"text","text":" "},{"type":"text","text":"resources associated with it will be freed. If [method"},{"code":"GLib.Dir.close","type":"codeVoice"},{"text":"] is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"called when the reference count is greater than zero, the directory is closed"},{"type":"text","text":" "},{"text":"but the ","type":"text"},{"type":"codeVoice","code":"GDir"},{"type":"text","text":" structure will not be freed until its reference count reaches"},{"text":" ","type":"text"},{"type":"text","text":"zero."}],"type":"paragraph"},{"inlineContent":[{"text":"It is an error to call any of the ","type":"text"},{"type":"codeVoice","code":"GDir"},{"text":" methods other than","type":"text"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"code":"GLib.Dir.ref","type":"codeVoice"},{"type":"text","text":"] and [method"},{"type":"codeVoice","code":"GLib.Dir.unref"},{"type":"text","text":"] on a "},{"type":"codeVoice","code":"GDir"},{"type":"text","text":" after calling"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.Dir.close"},{"text":"] on it.","type":"text"}],"type":"paragraph"}]}],"references":{"doc://GLib/documentation/GLib/DirProtocol/unref()":{"type":"topic","abstract":[{"text":"Decrements the reference count of ","type":"text"},{"code":"dir","type":"codeVoice"},{"text":".","type":"text"}],"url":"\/documentation\/glib\/dirprotocol\/unref()","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"unref"},{"kind":"text","text":"()"}],"kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/DirProtocol\/unref()","title":"unref()","role":"symbol"},"doc://GLib/documentation/GLib/DirProtocol":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DirProtocol","kind":"identifier"}],"title":"DirProtocol","abstract":[{"text":"An opaque structure representing an opened directory.","type":"text"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"DirProtocol"}],"url":"\/documentation\/glib\/dirprotocol","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/DirProtocol","type":"topic"},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"}}}