{"kind":"article","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/troubleshooting"]}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/Troubleshooting","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"This section shows some common errors you might encounter and how to fix them."}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"FFI Module Errors","anchor":"FFI-Module-Errors","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"On some versions of macOS, when Xcode is installed,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"there is a conflict between the FFI library module"},{"type":"text","text":" "},{"type":"text","text":"available through Xcode and the command line tools."},{"type":"text","text":" "},{"text":"This typically results in an error such as","type":"text"}]},{"type":"codeListing","syntax":null,"code":["\/Applications\/Xcode.app\/Contents\/Developer\/Platforms\/MacOSX.platform\/Developer\/SDKs\/MacOSX14.2.sdk\/usr\/include\/ffi\/module.modulemap:1:8: error: redefinition of module 'FFI'","module FFI [system] {","       ^","\/Library\/Developer\/CommandLineTools\/SDKs\/MacOSX13.sdk\/usr\/include\/ffi\/module.modulemap:1:8: note: previously defined here","module FFI [system] [extern_c] {","       ^","error: fatalError"]},{"inlineContent":[{"type":"text","text":"A way to resolve this is to remove the Command Line Tools."},{"text":" ","type":"text"},{"type":"text","text":"Alternatively, you can temporarily rename the CommandLineTools folder, i.e."}],"type":"paragraph"},{"syntax":null,"code":["sudo mv \/Library\/Developer\/CommandLineTools{,.orig}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Later you can move the folder back:","type":"text"}]},{"type":"codeListing","code":["sudo mv \/Library\/Developer\/CommandLineTools{.orig,}"],"syntax":null},{"text":"Missing `.gir` Files","type":"heading","anchor":"Missing-gir-Files","level":2},{"type":"paragraph","inlineContent":[{"text":"If you get an error such as","type":"text"}]},{"type":"codeListing","syntax":null,"code":["Girs located at","Cannot open '\/GLib-2.0.gir': No such file or directory"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Make sure that you have the relevant "},{"code":"gobject-introspection","type":"codeVoice"},{"text":" packages installed (as per the Pre-requisites section), including their ","type":"text"},{"code":".gir","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":".pc"},{"text":" files.","type":"text"}]},{"type":"heading","level":2,"text":"Old Swift toolchain or Xcode","anchor":"Old-Swift-toolchain-or-Xcode"},{"inlineContent":[{"text":"If, when you run ","type":"text"},{"code":"swift build","type":"codeVoice"},{"type":"text","text":", you get a "},{"type":"codeVoice","code":"Segmentation fault (core dumped)"},{"text":" or circular dependency error such as","type":"text"}],"type":"paragraph"},{"syntax":null,"code":["warning: circular dependency detected while parsing pangocairo: harfbuzz -> freetype2 -> harfbuzz"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"this probably means that your Swift toolchain is too old, particularly on Linux."},{"type":"text","text":" "},{"type":"text","text":"Make sure the latest toolchain is the one that is found when you run the Swift compiler (see above)."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you get an older version, make sure that the right version of the swift compiler is found first in your "},{"type":"codeVoice","code":"PATH"},{"text":".  On macOS, use xcode-select to select and install the latest version, e.g.:","type":"text"}]},{"type":"codeListing","code":["sudo xcode-select -s \/Applications\/Xcode.app","xcode-select --install"],"syntax":null}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"metadata":{"modules":[{"name":"GLib"}],"role":"article","title":"Troubleshooting","roleHeading":"Article"},"references":{"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"}}}