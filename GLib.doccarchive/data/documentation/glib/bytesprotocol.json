uct"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/MappedFile","isActive":true},{"text":"] or memory from other allocators.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"GBytes"},{"type":"text","text":" work well as keys in [struct"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/HashTable","isActive":true,"type":"reference"},{"text":"]. Use","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"code":"GLib.Bytes.equal","type":"codeVoice"},{"type":"text","text":"] and [method"},{"code":"GLib.Bytes.hash","type":"codeVoice"},{"type":"text","text":"] as parameters to"},{"text":" ","type":"text"},{"text":"[func","type":"text"},{"code":"GLib.HashTable.new","type":"codeVoice"},{"text":"] or [func","type":"text"},{"type":"codeVoice","code":"GLib.HashTable.new_full"},{"type":"text","text":"]."},{"type":"text","text":" "},{"code":"GBytes","type":"codeVoice"},{"text":" can also be used as keys in a [struct","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Tree","type":"reference","isActive":true},{"type":"text","text":"] by passing the"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GLib.Bytes.compare"},{"type":"text","text":"] function to [ctor"},{"type":"codeVoice","code":"GLib.Tree.new"},{"type":"text","text":"]."}]},{"type":"paragraph","inlineContent":[{"text":"The data pointed to by this bytes must not be modified. For a mutable","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"array of bytes see [struct"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/ByteArray"},{"text":"]. Use","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GLib.Bytes.unref_to_array"},{"type":"text","text":"] to create a mutable array for a "},{"code":"GBytes","type":"codeVoice"},{"type":"text","text":" "},{"text":"sequence. To crea