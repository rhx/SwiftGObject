pe":"codeVoice"},{"text":" schemes only), but is deprecated in favour of","type":"text"},{"type":"text","text":" "},{"text":"the equivalent of encoding spaces as ","type":"text"},{"code":"20","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Unlike with "},{"code":"g_uri_parse_params()","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"caseInsensitive"},{"text":" has no","type":"text"},{"type":"text","text":" "},{"type":"text","text":"effect if passed to "},{"type":"codeVoice","code":"flags"},{"text":" for ","type":"text"},{"type":"codeVoice","code":"g_uri_params_iter_init()"},{"type":"text","text":". The caller is"},{"text":" ","type":"text"},{"type":"text","text":"responsible for doing their own case-insensitive comparisons."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"code":["GUriParamsIter iter;","GError *error = NULL;","gchar *unowned_attr, *unowned_value;","","g_uri_params_iter_init (&iter, \"foo=bar&baz=bar&Foo=frob&baz=bar2\", -1, \"&\", G_URI_PARAMS_NONE);","while (g_uri_params_iter_next (&iter, &unowned_attr, &unowned_value, &error))","  {","    g_autofree gchar *attr = g_steal_pointer (&unowned_attr);","    g_autofree gchar *value = g_steal_pointer (&unowned_value);","    \/\/ do something with attr and value; this code will be called 4 times","    \/\/ for the params string in this example: once with attr=foo and value=bar,","    \/\/ then with baz\/bar, then Foo\/frob, then baz\/bar2.","  }","if (error)","  \/\/ handle parsing error"],"type":"codeListing","syntax":"C"}]}],"kind":"symbol","sections":[],"abstract":[{"type":"text","text":"Initializes an attribute\/value pair iterator."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/URIParamsIterProtocol\/init_(params:length:separators:flags:)"},"variants":[{"paths":["\/documentation\/glib\/uriparamsiterprotocol\/init_(p