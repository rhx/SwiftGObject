ontext","kind":"symbol"},"doc://GLib/documentation/GLib/SourceFuncs/check":{"title":"check","role":"symbol","abstract":[{"type":"text","text":"Called after all the file descriptors are polled. The"},{"text":" ","type":"text"},{"text":"source should return ","type":"text"},{"type":"codeVoice","code":"true"},{"type":"text","text":" if it is ready to be dispatched. Note that"},{"type":"text","text":" "},{"type":"text","text":"some time may have passed since the previous prepare function was called,"},{"type":"text","text":" "},{"text":"so the source should be checked again here.  Since 2.36 this may","type":"text"},{"text":" ","type":"text"},{"text":"be ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":", in which case the effect is as if the function always returns"},{"type":"text","text":" "},{"type":"codeVoice","code":"false"},{"text":".","type":"text"}],"type":"topic","url":"\/documentation\/glib\/sourcefuncs\/check","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncs\/check","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"check","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GSourceFuncsCheckFunc","text":"GSourceFuncsCheckFunc"},{"kind":"text","text":"!"}]},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/SourceFuncs/sourceRemoveByFuncs(userData:)":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncs\/sourceRemoveByFuncs(userData:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"sourceRemoveByFuncs","kind":"identifier"},{"kind":"text","text":"("},{"text":"userData","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gpointer","text":"gpointer"},{"text":"?) -> ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"role":"symbol","title":"sourceRemoveByFuncs(userData:)","kind":"symbol","type":"topic","url":"\/documentation\/glib\/sourcefuncs\/sourceremovebyfuncs(userdata:)","abstract":[{"text":"Removes a source from the default main loop context given the","type":"text"},{"type":"text","text":" "},{"text":"source functions and user data.","type":"text"}]},"doc://GLib/documentation/GLib/SourceFuncs":{"type":"topic","abstract":[{"type":"text","text":"The "},{"code":"GSourceFuncs","type":"codeVoice"},{"type":"text","text":" struct contains a table of"},{"type":"text","text":" "},{"text":"functions used to handle event sources in a generic manner.","type":"text"}],"role":"symbol","url":"\/documentation\/glib\/sourcefuncs","kind":"symbol","navigatorTitle":[{"text":"SourceFuncs","kind":"identifier"}],"title":"SourceFuncs","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncs","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SourceFuncs","kind":"identifier"}]},"doc://GLib/documentation/GLib/SourceFuncs/prepare":{"title":"prepare","kind":"symbol","role":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"kind":"identifier","text":"prepare"},{"kind":"text","text":": "},{"text":"GSourceFuncsPrepareFunc","preciseIdentifier":"c:@T@GSourceFuncsPrepareFunc","kind":"typeIdentifier"},{"kind":"text","text":"!"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncs\/prepare","abstract":[{"text":"Called before all the file descriptors are polled. If","type":"text"},{"type":"text","text":" "},{"text":"the source can determine that it is ready here (without waiting for the","type":"text"},{"text":" ","type":"text"},{"text":"results of the ","type":"text"},{"code":"poll()","type":"codeVoice"},{"text":" call) it should return ","type":"text"},{"code":"true","type":"codeVoice"},{"text":". It can also return","type":"text"},{"type":"text","text":" "},{"text":"a ","type":"text"},{"type":"codeVoice","code":"timeout_"},{"text":" value which should be the maximum timeout (in milliseconds)","type":"text"},{"text":" ","type":"text"},{"text":"which should be passed to the ","type":"text"},{"code":"poll()","type":"codeVoice"},{"type":"text","text":" call. The actual timeout used will"},{"type":"text","text":" "},{"text":"be -1 if all sources returned -1, or it will be the minimum of all","type":"text"},{"type":"text","text":" "},{"text":"the ","type":"text"},{"type":"codeVoice","code":"timeout_"},{"text":" values returned which were >= 0.  Since 2.36 this may","type":"text"},{"type":"text","text":" "},{"type":"text","text":"be "},{"code":"nil","type":"codeVoice"},{"type":"text","text":", in which case the effect is as if the function always returns"},{"type":"text","text":" "},{"code":"false","type":"codeVoice"},{"text":" with a timeout of -1.  If ","type":"text"},{"type":"codeVoice","code":"prepare"},{"type":"text","text":" returns a"},{"text":" ","type":"text"},{"text":"timeout and the source also has a ready time set, then the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"lower of the two will be used."}],"url":"\/documentation\/glib\/sourcefuncs\/prepare"},"doc://GLib/documentation/GLib/sourceContinue":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/sourceContinue","fragments":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"text":"sourceContinue","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@gboolean","text":"gboolean","kind":"typeIdentifier"}],"role":"symbol","url":"\/documentation\/glib\/sourcecontinue","kind":"symbol","title":"sourceContinue","type":"topic","abstract":[{"type":"text","text":"Use this macro as the return value of a [callback"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFunc","type":"reference"},{"type":"text","text":"] to leave"},{"type":"text","text":" "},{"type":"text","text":"the [struct"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","isActive":true},{"type":"text","text":"] in the main loop."}]},"doc://GLib/documentation/GLib/SourceFuncs/dispatch":{"type":"topic","abstract":[{"text":"Called to dispatch the event source, after it has returned","type":"text"},{"type":"text","text":" "},{"code":"true","type":"codeVoice"},{"type":"text","text":" in either its "},{"code":"prepare","type":"codeVoice"},{"type":"text","text":" or its "},{"type":"codeVoice","code":"check"},{"text":" function, or if a ready time","type":"text"},{"type":"text","text":" "},{"type":"text","text":"has been reached. The "},{"type":"codeVoice","code":"dispatch"},{"type":"text","text":" function receives a callback function and"},{"type":"text","text":" "},{"text":"user data. The callback function may be ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":" if the source was never"},{"type":"text","text":" "},{"text":"connected to a callback using [method","type":"text"},{"type":"codeVoice","code":"GLib.Source.set_callback"},{"type":"text","text":"]. The"},{"type":"text","text":" "},{"code":"dispatch","type":"codeVoice"},{"type":"text","text":" function should call the callback function with "},{"type":"codeVoice","code":"user_data"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"text","text":"whatever additional parameters are needed for this type of event source."},{"text":" ","type":"text"},{"type":"text","text":"The return value of the "},{"type":"codeVoice","code":"dispatch"},{"text":" function should be","type":"text"},{"text":" ","type":"text"},{"text":"[const","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/sourceRemove","isActive":true},{"text":"] if the source should be removed or","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[const"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/sourceContinue"},{"type":"text","text":"] to keep it."}],"role":"symbol","url":"\/documentation\/glib\/sourcefuncs\/dispatch","kind":"symbol","title":"dispatch","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncs\/dispatch","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"dispatch","kind":"identifier"},{"text":": ","kind":"text"},{"text":"GSourceFuncsDispatchFunc","kind":"typeIdentifier","preciseIdentifier":"c:@T@GSourceFuncsDispatchFunc"},{"text":"!","kind":"text"}]}}}