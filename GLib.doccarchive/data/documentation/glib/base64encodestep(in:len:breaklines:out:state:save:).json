eIdentifier","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"text":"gint","kind":"typeIdentifier","preciseIdentifier":"c:@T@gint"},{"text":">!) -> ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"}],"roleHeading":"Function"},"sections":[],"abstract":[{"type":"text","text":"Incrementally encode a sequence of binary data into its Base-64 stringified"},{"type":"text","text":" "},{"type":"text","text":"representation. By calling this function multiple times you can convert"},{"text":" ","type":"text"},{"text":"data in chunks to avoid having to have the full encoded data in memory.","type":"text"}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"base64EncodeStep","kind":"identifier"},{"kind":"text","text":"("},{"text":"in","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@guchar","text":"guchar"},{"text":">!, ","kind":"text"},{"text":"len","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"breakLines"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"},{"kind":"text","text":", "},{"text":"out","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"text":">!, ","kind":"text"},{"text":"state","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"gint","preciseIdentifier":"c:@T@gint","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"text":"save","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gint","kind":"typeIdentifier","text":"gint"},{"kind":"text","text":">!) -> "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"inlineContent":[{"type":"text","text":"When all of the data has been converted you must call"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_base64_encode_close()"},{"text":" to flush the saved state.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The output buffer must be large enough to fit all the data that will","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"be written to it. Due to the way base64 encodes you will need"},{"text":" ","type":"text"},{"text":"at least: (","type":"text"},{"type":"codeVoice","code":"len"},{"type":"text","text":" \/ 3 + 1) * 4 + 4 bytes (+ 4 may be needed in case of"},{"text":" ","type":"text"},{"type":"text","text":"non-zero state). If you enable line-breaking you will need at least:"},{"text":" ","type":"text"},{"type":"text","text":"(("},{"type":"codeVoice","code":"len"},{"type":"text","text":" \/ 3 + 1) * 4 + 4) \/ 76 + 1 bytes of extra space."}]},{"type":"paragraph","inlineContent":[{"code":"breakLines","type":"codeVoice"},{"type":"text","text":" is typically used when putting base64-encoded data in emails."},{"type":"text","text":" "},{"text":"It breaks the lines at 76 columns instead of putting all of the text on","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the same line. This avoids problems with long lines in the email system."},{"type":"text","text":" "},{"text":"Note however that it breaks the lines with ","type":"text"},{"type":"codeVoice","code":"LF"},{"text":" characters, not","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"CR LF"},{"text":" sequences, so the result cannot be passed directly to SMTP","type":"text"},{"type":"text","text":" "},{"type":"text","text":"or certain other protocols."}]}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"references":{"doc://GLib/documentation/GLib/base64EncodeStep(in:len:breakLines:out:state:save:)":{"abstract":[{"text":"Incrementally encode a sequence of binary data into its Base-64 stringified","type":"text"},{"type":"text","text":" "},{"text":"representation. By calling this function multiple times you can convert","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"data in chunks to avoid having to have the full encoded data in memory."}],"url":"\/documentation\/glib\/base64encodestep(in:len:breaklines:out:state:save:)","role":"symbol","title":"base64EncodeStep(in:len:breakLines:out:state:save:)","type":"topic","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"base64EncodeStep"},{"text":"(","kind":"text"},{"text":"in","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@guchar","text":"guchar","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"text":"len","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"text":"breakLines","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"},{"kind":"text","text":", "},{"kind":"externalParam","text":"out"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sp","kind":"typeIdentifier","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@g