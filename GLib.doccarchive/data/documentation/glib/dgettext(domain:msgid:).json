{"sections":[],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"abstract":[{"type":"text","text":"This function is a wrapper of "},{"code":"dgettext()","type":"codeVoice"},{"text":" which does not translate","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the message if the default domain as set with "},{"code":"textdomain()","type":"codeVoice"},{"text":" has no","type":"text"},{"type":"text","text":" "},{"text":"translations for the current locale.","type":"text"}],"metadata":{"symbolKind":"func","modules":[{"name":"GLib"}],"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"dgettext"},{"kind":"text","text":"("},{"kind":"externalParam","text":"domain"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"gchar","preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier"},{"text":">?, ","kind":"text"},{"kind":"externalParam","text":"msgid"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"kind":"text","text":">!) -> "},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"roleHeading":"Function","title":"dgettext(domain:msgid:)","role":"symbol","externalID":"s:4GLib8dgettext6domain5msgidSSSgSPys4Int8VGSg_AItF"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/dgettext(domain:msgid:)"]}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"dgettext"},{"kind":"text","text":"("},{"text":"domain","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">? = nil, ","kind":"text"},{"kind":"externalParam","text":"msgid"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"gchar","preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier"},{"kind":"text","text":">!) -> "},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"kind":"text","text":"!"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"The advantage of using this function over "},{"code":"dgettext()","type":"codeVoice"},{"type":"text","text":" proper is that"},{"text":" ","type":"text"},{"text":"libraries using this function (like GTK) will not use translations","type":"text"},{"type":"text","text":" "},{"type":"text","text":"if the application using the library does not have translations for"},{"text":" ","type":"text"},{"text":"the current locale.  This results in a consistent English-only","type":"text"},{"type":"text","text":" "},{"type":"text","text":"interface instead of one having partial translations.  For this"},{"type":"text","text":" "},{"text":"feature to work, the call to ","type":"text"},{"code":"textdomain()","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"setlocale()"},{"type":"text","text":" should"},{"text":" ","type":"text"},{"type":"text","text":"precede any "},{"code":"g_dgettext()","type":"codeVoice"},{"text":" invocations.  For GTK, it means calling","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"textdomain()"},{"type":"text","text":" before gtk_init or its variants."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This function disables translations if and only if upon its first","type":"text"},{"type":"text","text":" "},{"type":"text","text":"call all the following conditions hold:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"domain","type":"codeVoice"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"}]}]},{"content":[{"inlineContent":[{"code":"textdomain()","type":"codeVoice"},{"type":"text","text":" has been called to set a default text domain"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"there is no translations available for the default text domain","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and the current locale"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"current locale is not “C” or any English locales (those"},{"type":"text","text":" "},{"type":"text","text":"starting with “en_”)"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"Note that this behavior may not be desired for example if an application","type":"text"},{"text":" ","type":"text"},{"text":"has its untranslated messages in a language other than English. In those","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"cases the application should call "},{"code":"textdomain()","type":"codeVoice"},{"text":" after initializing GTK.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Applications should normally not use this function directly,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"but use the "},{"code":"_()","type":"codeVoice"},{"text":" macro for translations.","type":"text"}]}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/dgettext(domain:msgid:)"},"references":{"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/dgettext(domain:msgid:)":{"abstract":[{"text":"This f