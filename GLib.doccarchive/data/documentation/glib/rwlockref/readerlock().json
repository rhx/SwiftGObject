bstract":[],"url":"\/documentation\/glib\/rwlockref\/rwlockprotocol-implementations","title":"RWLockProtocol Implementations","type":"topic","kind":"article","identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockRef\/RWLockProtocol-Implementations"}}}