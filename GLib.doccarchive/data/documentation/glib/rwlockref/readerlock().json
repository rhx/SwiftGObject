lockprotocol-implementations","title":"RWLockProtocol Implementations"},"doc://GLib/documentation/GLib/RWLockRef":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockRef","kind":"symbol","abstract":[{"text":"The GRWLock struct is an opaque data structure to represent a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"reader-writer lock. It is similar to a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex"},{"text":" in that it allows","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"multiple threads to coordinate access to a shared resource."}],"role":"symbol","navigatorTitle":[{"text":"RWLockRef","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"RWLockRef"}],"type":"topic","url":"\/documentation\/glib\/rwlockref","title":"RWLockRef"},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/RWLockRef/readerLock()":{"url":"\/documentation\/glib\/rwlockref\/readerlock()","abstract":[{"type":"text","text":"Obtain a read lock on "},{"type":"codeVoice","code":"rwLock"},{"text":". If another thread currently holds","type":"text"},{"type":"text","text":" "},{"text":"the write lock on ","type":"text"},{"code":"rwLock","type":"codeVoice"},{"type":"text","text":", the current thread will block until the"},{"type":"text","text":" "},{"type":"text","text":"write lock was (held and) released. If another thread does not hold"},{"type":"text","text":" "},{"text":"the write lock, but is waiting for it, it is implementation defined","type":"text"},{"text":" ","type":"text"},{"text":"whether the reader or writer will block. Read locks can be taken","type":"text"},{"type":"text","text":" "},{"type":"text","text":"recursively."}],"title":"readerLock()","kind":"symbol"