{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/atexit(func:)"},"metadata":{"symbolKind":"func","roleHeading":"Function","externalID":"s:4GLib6atexit4funcyyyXCSg_tF","modules":[{"name":"GLib"}],"platforms":[],"title":"atexit(func:)","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"atexit"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"func"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@T@GVoidFunc","text":"GVoidFunc","kind":"typeIdentifier"},{"text":"?)","kind":"text"}]},"abstract":[{"type":"text","text":"Specifies a function to be called at normal program termination."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/atexit(func:)"]}],"kind":"symbol","sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"atexit"},{"kind":"text","text":"("},{"kind":"externalParam","text":"func"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@GVoidFunc","text":"GVoidFunc","kind":"typeIdentifier"},{"text":"?)","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"text":"Since GLib 2.8.2, on Windows ","type":"text"},{"code":"g_atexit()","type":"codeVoice"},{"type":"text","text":" actually is a preprocessor"},{"text":" ","type":"text"},{"text":"macro that maps to a call to the ","type":"text"},{"type":"codeVoice","code":"atexit()"},{"text":" function in the C","type":"text"},{"text":" ","type":"text"},{"text":"library. This means that in case the code that calls ","type":"text"},{"code":"g_atexit()","type":"codeVoice"},{"text":",","type":"text"},{"type":"text","text":" "},{"type":"text","text":"i.e. "},{"type":"codeVoice","code":"atexit()"},{"text":", is in a DLL, the function will be called when the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"DLL is detached from the program. This typically makes more sense"},{"text":" ","type":"text"},{"type":"text","text":"than that the function is called when the GLib DLL is detached,"},{"type":"text","text":" "},{"text":"which happened earlier when ","type":"text"},{"type":"codeVoice","code":"g_atexit()"},{"text":" was a function in the GLib","type":"text"},{"text":" ","type":"text"},{"text":"DLL.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The behaviour of "},{"type":"codeVoice","code":"atexit()"},{"text":" in the context of dynamically loaded","type":"text"},{"type":"text","text":" "},{"text":"modules is not formally specified and varies wildly.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On POSIX systems, calling "},{"type":"codeVoice","code":"g_atexit()"},{"type":"text","text":" (or "},{"type":"codeVoice","code":"atexit()"},{"text":") in a dynamically","type":"text"},{"type":"text","text":" "},{"text":"loaded module which is unloaded before the program terminates might","type":"text"},{"type":"text","text":" "},{"type":"text","text":"well cause a crash at program exit."}]},{"inlineContent":[{"type":"text","text":"Some POSIX systems implement "},{"code":"atexit()","type":"codeVoice"},{"type":"text","text":" like Windows, and have each"},{"type":"text","text":" "},{"text":"dynamically loaded module maintain an own atexit chain that is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"called when the module is unloaded."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"On other POSIX systems, before a dynamically loaded module is"},{"text":" ","type":"text"},{"type":"text","text":"unloaded, the registered atexit functions (if any) residing in that"},{"text":" ","type":"text"},{"type":"text","text":"module are called, regardless where the code that registered them"},{"type":"text","text":" "},{"type":"text","text":"resided. This is presumably the most robust approach."}]},{"type":"paragraph","inlineContent":[{"text":"As can be seen from the above, for portability it’s best to avoid","type":"text"},{"type":"text","text":" "},{"type":"text","text":"calling "},{"type":"codeVoice","code":"g_atexit()"},{"type":"text","text":" (or "},{"type":"codeVoice","code":"atexit()"},{"text":") except in the main executable of a","type":"text"},{"type":"text","text":" "},{"text":"program.","type":"text"}]},{"inlineContent":[{"inlineContent":[{"text":"atexit is deprecated:","type":"text"}],"type":"strong"},{"type":"text","text":" "},{"text":"It is best to avoid g_atexit().","type":"text"}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"references":{"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/atexit(func:)":{"deprecated":true,"url":"\/documentation\/glib\/atexit(func:)","identifier":"doc:\/\/GLib\/documentation\/GLib\/atexit(func:)","type":"topic","title":"atexit(func:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"atexit","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"func"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GVoidFunc","text":"GVoidFunc"},{"kind":"text","text":"?)"}],"kind":"symbol","role":"symbol","abstract":[{"text":"Specifies a function to be called at normal program termination.","type":"text"}]}}}