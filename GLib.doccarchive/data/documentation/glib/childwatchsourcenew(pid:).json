{"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/childWatchSourceNew(pid:)"},"metadata":{"roleHeading":"Function","externalID":"s:4GLib19childWatchSourceNew3pidAA0D3RefVSgs5Int32V_tF","title":"childWatchSourceNew(pid:)","symbolKind":"func","modules":[{"name":"GLib"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"childWatchSourceNew","kind":"identifier"},{"text":"(","kind":"text"},{"text":"pid","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GPid","text":"GPid"},{"kind":"text","text":") -> "},{"text":"SourceRef","preciseIdentifier":"s:4GLib9SourceRefV","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"role":"symbol"},"abstract":[{"type":"text","text":"Creates a new child watch source."}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"childWatchSourceNew"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"pid"},{"kind":"text","text":": "},{"text":"GPid","kind":"typeIdentifier","preciseIdentifier":"c:@T@GPid"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"SourceRef","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceRef","preciseIdentifier":"s:4GLib9SourceRefV"},{"kind":"text","text":"!"}]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"The source will not initially be associated with any"},{"type":"text","text":" "},{"text":"[struct","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext"},{"text":"] and must be added to one with","type":"text"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.Source.attach"},{"text":"] before it will be executed.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Note that child watch sources can only be used in conjunction with","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_spawn..."},{"type":"text","text":" when the [flags"},{"type":"codeVoice","code":"GLib.SpawnFlags.DO_NOT_REAP_CHILD"},{"type":"text","text":"] flag is used."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Note that on platforms where [type","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Pid","type":"reference","isActive":true},{"text":"] must be explicitly closed","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(see [func"},{"code":"GLib.spawn_close_pid","type":"codeVoice"},{"text":"]) ","type":"text"},{"type":"codeVoice","code":"pid"},{"type":"text","text":" must not be closed while the"},{"type":"text","text":" "},{"text":"source is still active. Typically, you will want to call","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.spawn_close_pid"},{"type":"text","text":"] in the callback function for the source."}]},{"type":"paragraph","inlineContent":[{"text":"On POSIX platforms, the following restrictions apply to this API","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"due to limitations in POSIX process interfaces:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"pid"},{"type":"text","text":" must be a child of this process."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"pid","type":"codeVoice"},{"type":"text","text":" must be positive."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"The application must not call "},{"isActive":true,"type":"reference","identifier":"man:waitpid(1)"},{"type":"text","text":" with a"},{"type":"text","text":" "},{"text":"non-positive first argument, for instance in another thread.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The application must not wait for "},{"code":"pid","type":"codeVoice"},{"type":"text","text":" to exit by any other"},{"text":" ","type":"text"},{"type":"text","text":"mechanism, including "},{"type":"codeVoice","code":"waitpid(pid, ...)"},{"text":" or a second child-watch","type":"text"},{"type":"text","text":" "},{"type":"text","text":"source for the same "},{"code":"pid","type":"codeVoice"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The application must not ignore ","type":"text"},{"type":"codeVoice","code":"SIGCHLD"},{"type":"text","text":"."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Before 2.78, the application could not send a signal ("},{"type":"reference","isActive":true,"identifier":"man:kill(2)"},{"text":") to the","type":"text"},{"type":"text","text":" "},{"text":"watched ","type":"text"},{"type":"codeVoice","code":"pid"},{"type":"text","text":" in a race free manner. Since 2.78, you can do that while the"},{"type":"text","text":" "},{"type":"text","text":"associated [struct"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","isActive":true},{"text":"] is acquired.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Before 2.78, even after destroying the [struct"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Source"},{"type":"text","text":"], you could not"},{"text":" ","type":"text"},{"type":"text","text":"be sure that "},{"type":"codeVoice","code":"pid"},{"type":"text","text":" wasn’t already reaped. Hence, it was also not"},{"type":"text","text":" "},{"type":"text","text":"safe to "},{"type":"codeVoice","code":"kill()"},{"text":" or ","type":"text"},{"code":"waitpid()","type":"codeVoice"},{"type":"text","text":" on the process ID after the child watch"},{"type":"text","text":" "},{"text":"source was gone. Destroying the source before it fired made it","type":"text"},{"text":" ","type":"text"},{"text":"impossible to reliably reap the process.","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If any of those conditions are not met, this and related APIs will"},{"text":" ","type":"text"},{"type":"text","text":"not work correctly. This can often be diagnosed via a GLib warning"},{"text":" ","type":"text"},{"type":"text","text":"stating that "},{"type":"codeVoice","code":"ECHILD"},{"type":"text","text":" was received by "},{"type":"codeVoice","code":"waitpid()"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Calling ","type":"text"},{"type":"reference","isActive":true,"identifier":"man:waitpid(2)"},{"type":"text","text":" for specific processes other than "},{"code":"pid","type":"codeVoice"},{"type":"text","text":" "},{"text":"remains a valid thing to do.","type":"text"}]}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/childwatchsourcenew(pid:)"]}],"references":{"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/Source":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","kind":"symbol","abstract":[{"type":"text","text":"The "},{"code":"GSource","type":"codeVoice"},{"type":"text","text":" struct is an opaque data type"},{"text":" ","type":"text"},{"text":"representing an event source.","type":"text"}],"type":"topic","navigatorTitle":[{"text":"Source","kind":"identifier"}],"url":"\/documentation\/glib\/source","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"Source"}],"title":"Source","role":"sy