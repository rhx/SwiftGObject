{"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"title":"RelationRef","modules":[{"name":"GLib"}],"fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"RelationRef","kind":"identifier"}],"role":"symbol","symbolKind":"struct","externalID":"s:4GLib11RelationRefV","roleHeading":"Structure","navigatorTitle":[{"text":"RelationRef","kind":"identifier"}]},"sections":[],"kind":"symbol","abstract":[{"type":"text","text":"A "},{"type":"codeVoice","code":"GRelation"},{"type":"text","text":" is a table of data which can be indexed on any number"},{"text":" ","type":"text"},{"text":"of fields, rather like simple database tables. A ","type":"text"},{"code":"GRelation","type":"codeVoice"},{"text":" contains","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a number of records, called tuples. Each record contains a number of"},{"text":" ","type":"text"},{"type":"text","text":"fields. Records are not ordered, so it is not possible to find the"},{"text":" ","type":"text"},{"text":"record at a particular index.","type":"text"}],"topicSections":[{"generated":true,"anchor":"Initializers","title":"Initializers","identifiers":["doc:\/\/GLib\/documentation\/GLib\/RelationRef\/init(_:)-2jk2d","doc:\/\/GLib\/documentation\/GLib\/RelationRef\/init(_:)-5ljad","doc:\/\/GLib\/documentation\/GLib\/RelationRef\/init(_:)-6gu2d","doc:\/\/GLib\/documentation\/GLib\/RelationRef\/init(_:)-9ej7s","doc:\/\/GLib\/documentation\/GLib\/RelationRef\/init(_:)-zu22","doc:\/\/GLib\/documentation\/GLib\/RelationRef\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/RelationRef\/init(constPointer:)","doc:\/\/GLib\/documentation\/GLib\/RelationRef\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/RelationRef\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/RelationRef\/init(mutating:)","doc:\/\/GLib\/documentation\/GLib\/RelationRef\/init(opaquePointer:)"]},{"generated":true,"title":"Instance Properties","anchor":"Instance-Properties","ide