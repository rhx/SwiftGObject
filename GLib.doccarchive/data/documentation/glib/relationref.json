,"type":"codeVoice"},{"text":" use [method","type":"text"},{"type":"codeVoice","code":"GLib.Relation.insert"},{"text":"].","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To determine if a given record appears in a "},{"code":"GRelation","type":"codeVoice"},{"text":", use","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GLib.Relation.exists"},{"type":"text","text":"]. Note that fields are compared directly, so"},{"type":"text","text":" "},{"type":"text","text":"pointers must point to the exact same position (i.e. different"},{"text":" ","type":"text"},{"type":"text","text":"copies of the same string will not match.)"}]},{"type":"paragraph","inlineContent":[{"text":"To count the number of records which have a particular value in a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"given field, use [method"},{"type":"codeVoice","code":"GLib.Relation.count"},{"type":"text","text":"]."}]},{"inlineContent":[{"text":"To get all the records which have a particular value in a given","type":"text"},{"type":"text","text":" "},{"text":"field, use [method","type":"text"},{"type":"codeVoice","code":"GLib.Relation.select"},{"type":"text","text":"]. To access fields of the resulting"},{"type":"text","text":" "},{"type":"text","text":"records, use [method"},{"type":"codeVoice","code":"GLib.Tuples.index"},{"type":"text","text":"]. To free the resulting records use"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.Tuples.destroy"},{"text":"].","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To delete all records which have a particular value in a given"},{"text":" ","type":"text"},{"type":"text","text":"field, use [method"},{"code":"GLib.Relation.delete","type":"codeVoice"},{"text":"].","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To destroy the "},{"type":"codeVo