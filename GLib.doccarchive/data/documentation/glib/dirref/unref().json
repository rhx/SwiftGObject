{"kind":"symbol","sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"symbolKind":"method","title":"unref()","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"unref"},{"text":"()","kind":"text"}],"role":"symbol","extendedModule":"GLib","externalID":"s:4GLib11DirProtocolPAAE5unrefyyF::SYNTHESIZED::s:4GLib6DirRefV","modules":[{"name":"GLib"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"unref","kind":"identifier"},{"text":"()","kind":"text"}]}]},{"content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"inlineContent":[{"type":"text","text":"Once the reference count reaches zero, the directory will be closed and all"},{"type":"text","text":" "},{"type":"text","text":"resources associated with it will be freed. If [method"},{"code":"GLib.Dir.close","type":"codeVoice"},{"type":"text","text":"] is"},{"text":" ","type":"text"},{"type":"text","text":"called when the reference count is greater than zero, the directory is closed"},{"type":"text","text":" "},{"text":"but the ","type":"text"},{"code":"GDir","type":"codeVoice"},{"type":"text","text":" structure will not be freed until its reference count reaches"},{"type":"text","text":" "},{"type":"text","text":"zero."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"It is an error to call any of the "},{"type":"codeVoice","code":"GDir"},{"type":"text","text":" methods other than"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.Dir.ref"},{"text":"] and [method","type":"text"},{"type":"codeVoice","code":"GLib.Dir.unref"},{"type":"text","text":"] on a "},{"type":"codeVoice","code":"GDir"},{"type":"text","text":" after calling"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"code":"GLib.Dir.close","type":"codeVoice"},{"text":"] on it.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/glib\/dirref\/unref()"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/DirRef\/unref()","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Decrements the reference count of "},{"type":"codeVoice","code":"dir"},{"text":".","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/DirRef","doc:\/\/GLib\/documentation\/GLib\/DirRef\/DirProtocol-Implementations"]]},"references":{"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/DirRef/DirProtocol-Implementations":{"role":"collectionGroup","type":"topic","url":"\/documentation\/glib\/dirref\/dirprotocol-implementations","title":"DirProtocol Implementations","abstract":[],"kind":"article","identifier":"doc:\/\/GLib\/documentation\/GLib\/DirRef\/DirProtocol-Implementations"},"doc://GLib/documentation/GLib/DirRef/unref()":{"title":"unref()","abstract":[{"text":"Decrements the reference count of ","type":"text"},{"type":"codeVoice","code":"dir"},{"text":".","type":"text"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"unref"},{"text":"()","kind":"text"}],"url":"\/documentation\/glib\/dirref\/unref()","role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/DirRef\/unref()","type":"topic"},"doc://GLib/documentation/GLib/DirRef":{"fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"DirRef","kind":"identifier"}],"title":"DirRef","type":"topic","abstract":[{"text":"An opaque structure representing an opened directory.","type":"text"}],"role":"symbol","kind":"symbol","url":"\/documentatio