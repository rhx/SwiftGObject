{"abstract":[{"type":"text","text":"Decrements the reference count of "},{"code":"dir","type":"codeVoice"},{"type":"text","text":"."}],"metadata":{"extendedModule":"GLib","role":"symbol","title":"unref()","modules":[{"name":"GLib"}],"externalID":"s:4GLib11DirProtocolPAAE5unrefyyF::SYNTHESIZED::s:4GLib6DirRefV","symbolKind":"method","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"unref","kind":"identifier"},{"text":"()","kind":"text"}]},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/DirRef","doc:\/\/GLib\/documentation\/GLib\/DirRef\/DirProtocol-Implementations"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"unref","kind":"identifier"},{"text":"()","kind":"text"}]}]},{"content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Once the reference count reaches zero, the directory will be closed and all"},{"type":"text","text":" "},{"text":"resources associated with it will be freed. If [method","type":"text"},{"type":"codeVoice","code":"GLib.Dir.close"},{"text":"] is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"called when the reference count is greater than zero, the directory is closed"},{"text":" ","type":"text"},{"text":"but the ","type":"text"},{"type":"codeVoice","code":"GDir"},{"type":"text","text":" structure will not be freed until its reference count reaches"},{"type":"text","text":" "},{"type":"text","text":"zero."}]},{"inlineContent":[{"text":"It is an error to call any of the ","type":"text"},{"code":"GDir","type":"codeVoice"},{"type":"text","text":" methods other than"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GLib.Dir.ref"},{"type":"text","text":"] and [method"},{"type":"codeVoice","code":"GLib.Dir.unref"},{"text":"] on a ","type":"text"},{"type":"codeVoice","code":"GDir"},{"type":"text","text":" after calling"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GLib.Dir.close"},{"type":"text","text":"] on it."}],"type":"paragraph"}],"kind":"content"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/DirRef\/unref()","interfaceLanguage":"swift"},"sections":[],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/dirref\/unref()"]}],"references":{"doc://GLib/documentation/GLib/DirRef/unref()":{"kind":"symbol","abstract":[{"text":"Decrements the reference count of ","type":"text"},{"code":"dir","type":"codeVoice"},{"type":"text","text":"."}],"type":"topic","title":"unref()","role":"symbol","url":"\/documentation\/glib\/dirref\/unref()","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"unref"},{"kind":"text","text":"()"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/DirRef\/unref()"},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/DirRef/DirProtocol-Implementations":{"title":"DirProtocol Implementations","kind":"article","identifier":"doc:\/\/GLib\/documentation\/GLib\/DirRef\/DirProtocol-Implementations","url":"\/documentation\/glib\/dirref\/dirprotocol-implementations","role":"collectionGroup","abstract":[],"type":"topic"},"doc://GLib/documentation/GLib/DirRef":{"url":"\/documentation\/glib\/dirref","abstract":[{"type":"text","text":"An opaque structure representing an opened directory."}],"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"DirRef","kind":"identifier"}],"type":"topic","title":"DirRef","fragments":[{"text":"struct","kind":"ke