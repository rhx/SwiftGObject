{"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef","interfaceLanguage":"swift"},"topicSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init()","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(_:)-2fawg","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(_:)-2gux1","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(_:)-5l1bm","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(_:)-9fjcb","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(_:)-x28p","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(constPointer:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(mutating:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(opaquePointer:)"],"title":"Initializers","generated":true,"anchor":"Initializers"},{"generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/ptr"],"title":"Instance Properties","anchor":"Instance-Properties"},{"title":"Default Implementations","generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/BookmarkFileProtocol-Implementations","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/PointerWrapper-Implementations"],"anchor":"Default-Implementations"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"BookmarkFileRef","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"overview","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Bookmarks refer to a URI, along with some meta-data about the resource"},{"type":"text","text":" "},{"type":"text","text":"pointed by the URI like its MIME type, the application that is registering"},{"text":" ","type":"text"},{"type":"text","text":"the bookmark and the icon that should be used to represent the bookmark."},{"type":"text","text":" "},{"text":"The data is stored using the","type":"text"},{"type":"text","text":" "},{"identifier":"https:\/\/www.freedesktop.org\/wiki\/Specifications\/desktop-bookmark-spec\/","type":"reference","isActive":true},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The syntax of the bookmark files is described in detail inside the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Desktop Bookmark Specification, here is a quick summary: bookmark"},{"text":" ","type":"text"},{"text":"files use a sub-class of the XML Bookmark Exchange Language","type":"text"},{"text":" ","type":"text"},{"text":"specification, consisting of valid UTF-8 encoded XML, under the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"<xbel>"},{"text":" root element; each bookmark is stored inside a","type":"text"},{"type":"text","text":" "},{"code":"<bookmark>","type":"codeVoice"},{"type":"text","text":" element, using its URI: no relative paths can"},{"text":" ","type":"text"},{"text":"be used inside a bookmark file. The bookmark may have a user defined","type":"text"},{"type":"text","text":" "},{"text":"title and description, to be used instead of the URI. Under the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"<metadata>"},{"type":"text","text":" element, with its owner attribute set to"},{"text":" ","type":"text"},{"code":"http:\/\/freedesktop.org","type":"codeVoice"},{"text":", is stored the meta-data about a resource","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"pointed by its URI. The meta-data consists of the resource’s MIME"},{"type":"text","text":" "},{"text":"type; the applications that have registered a bookmark; the groups","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to which a bookmark belongs to; a visibility flag, used to set the"},{"text":" ","type":"text"},{"text":"bookmark as “private” to the applications and groups that has it","type":"text"},{"type":"text","text":" "},{"type":"text","text":"registered; the URI and MIME type of an icon, to be used when"},{"text":" ","type":"text"},{"type":"text","text":"displaying the bookmark inside a GUI."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Here is an example of a bookmark file:"},{"type":"text","text":" "},{"identifier":"https:\/\/gitlab.gnome.org\/GNOME\/glib\/-\/blob\/HEAD\/glib\/tests\/bookmarks.xbel","type":"reference","isActive":true}]},{"inlineContent":[{"type":"text","text":"A bookmark file might contain more than one bookmark; each bookmark"},{"type":"text","text":" "},{"type":"text","text":"is accessed through its URI."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The important caveat of bookmark files is that when you add a new","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"bookmark you must also add the application that is registering it, using"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"code":"GLib.BookmarkFile.add_application","type":"codeVoice"},{"type":"text","text":"] or [method"},{"code":"GLib.BookmarkFile.set_application_info","type":"codeVoice"},{"type":"text","text":"]."},{"text":" ","type":"text"},{"text":"If a bookmark has no applications then it won’t be dumped when creating","type":"text"},{"type":"text","text":" "},{"text":"the on disk representation, using [method","type":"text"},{"type":"codeVoice","code":"GLib.BookmarkFile.to_data"},{"text":"] or","type":"text"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"code":"GLib.BookmarkFile.to_file","type":"codeVoice"},{"type":"text","text":"]."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef","isActive":true,"type":"reference"},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"code":"GBookmarkFile","type":"codeVoice"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFileProtocol","isActive":true,"type":"reference"},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef"},{"type":"text","text":" only as an "},{"code":"unowned","type":"codeVoice"},{"text":" reference to an existing ","type":"text"},{"type":"codeVoice","code":"GBookmarkFile"},{"type":"text","text":" instance."}]},{"style":"note","type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFile","isActive":true,"type":"reference"},{"text":" (instead of ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef","isActive":true,"type":"reference"},{"text":") if you want to use Automatic Reference Counting for memory management of the underlying ","type":"text"},{"code":"GBookmarkFile","type":"codeVoice"},{"type":"text","text":" instance."}]}]}]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"metadata":{"externalID":"s:4GLib15BookmarkFileRefV","roleHeading":"Structure","role":"symbol","modules":[{"name":"GLib"}],"symbolKind":"struct","title":"BookmarkFileRef","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"BookmarkFileRef"}],"navigatorTitle":[{"text":"BookmarkFileRef","kind":"identifier"}]},"relationshipsSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/BookmarkFileProtocol","doc:\/\/GLib\/documentation\/GLib\/PointerWrapper"],"type":"conformsTo","k