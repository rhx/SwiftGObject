{"abstract":[{"code":"GBookmarkFile","type":"codeVoice"},{"type":"text","text":" lets you parse, edit or create files containing bookmarks."}],"metadata":{"title":"BookmarkFileRef","roleHeading":"Structure","modules":[{"name":"GLib"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"BookmarkFileRef","kind":"identifier"}],"navigatorTitle":[{"text":"BookmarkFileRef","kind":"identifier"}],"role":"symbol","symbolKind":"struct","externalID":"s:4GLib15BookmarkFileRefV"},"sections":[],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"topicSections":[{"title":"Initializers","anchor":"Initializers","generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init()","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(_:)-2fawg","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(_:)-2gux1","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(_:)-5l1bm","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(_:)-9fjcb","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(_:)-x28p","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(constPointer:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(mutating:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(opaquePointer:)"]},{"generated":true,"anchor":"Instance-Properties","title":"Instance Properties","identifiers":["doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/ptr"]},{"anchor":"Default-Implementations","identifiers":["doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/BookmarkFileProtocol-Implementations","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/PointerWrapper-Implementations"],"generated":true,"title":"Default Implementations"}],"relationshipsSections":[{"kind":"relationships","type":"conformsTo","title":"Conforms To","identifiers":["doc:\/\/GLib\/documentation\/GLib\/BookmarkFileProtocol","doc:\/\/GLib\/documentation\/GLib\/PointerWrapper"]}],"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"paths":["\/documentation\/glib\/bookmarkfileref"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"BookmarkFileRef","kind":"identifier"}]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"anchor":"overview","text":"Overview","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Bookmarks refer to a URI, along with some meta-data about the resource","type":"text"},{"text":" ","type":"text"},{"text":"pointed by the URI like its MIME type, the application that is registering","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the bookmark and the icon that should be used to represent the bookmark."},{"text":" ","type":"text"},{"type":"text","text":"The data is stored using the"},{"type":"text","text":" "},{"identifier":"https:\/\/www.freedesktop.org\/wiki\/Specifications\/desktop-bookmark-spec\/","type":"reference","isActive":true},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"The syntax of the bookmark files is described in detail inside the","type":"text"},{"type":"text","text":" "},{"text":"Desktop Bookmark Specification, here is a quick summary: bookmark","type":"text"},{"type":"text","text":" "},{"type":"text","text":"files use a sub-class of the XML Bookmark Exchange Language"},{"text":" ","type":"text"},{"text":"specification, consisting of valid UTF-8 encoded XML, under the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"<xbel>"},{"type":"text","text":" root element; each bookmark is stored inside a"},{"type":"text","text":" "},{"type":"codeVoice","code":"<bookmark>"},{"text":" element, using its URI: no relative paths can","type":"text"},{"type":"text","text":" "},{"text":"be used inside a bookmark file. The bookmark may have a user defined","type":"text"},{"type":"text","text":" "},{"text":"title and description, to be used instead of the URI. Under the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"<metadata>"},{"type":"text","text":" element, with its owner attribute set to"},{"text":" ","type":"text"},{"type":"codeVoice","code":"http:\/\/freedesktop.org"},{"text":", is stored the meta-data about a resource","type":"text"},{"type":"text","text":" "},{"type":"text","text":"pointed by its URI. The meta-data consists of the resource’s MIME"},{"text":" ","type":"text"},{"text":"type; the applications that have registered a bookmark; the groups","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to which a bookmark belongs to; a visibility flag, used to set the"},{"text":" ","type":"text"},{"text":"bookmark as “private” to the applications and groups that has it","type":"text"},{"type":"text","text":" "},{"type":"text","text":"registered; the URI and MIME type of an icon, to be used when"},{"text":" ","type":"text"},{"type":"text","text":"displaying the bookmark inside a GUI."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Here is an example of a bookmark file:"},{"type":"text","text":" "},{"identifier":"https:\/\/gitlab.gnome.org\/GNOME\/glib\/-\/blob\/HEAD\/glib\/tests\/bookmarks.xbel","type":"reference","isActive":true}]},{"type":"paragraph","inlineContent":[{"text":"A bookmark file might contain more than one bookmark; each bookmark","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is accessed through its URI."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The important caveat of bookmark files is that when you add a new"},{"type":"text","text":" "},{"type":"text","text":"bookmark you must also add the application that is registering it, using"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GLib.BookmarkFile.add_application"},{"type":"text","text":"] or [method"},{"code":"GLib.BookmarkFile.set_application_info","type":"codeVoice"},{"type":"text","text":"]."},{"type":"text","text":" "},{"text":"If a bookmark has no applications then it won’t be dumped when creating","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the on disk representation, using [method"},{"code":"GLib.BookmarkFile.to_data","type":"codeVoice"},{"text":"] or","type":"text"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.BookmarkFile.to_file"},{"type":"text","text":"]."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef","type":"reference"},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GBookmarkFile"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFileProtocol","type":"reference"},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"text":"Use ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef","isActive":true},{"text":" only as an ","type":"text"},{"code":"unowned","type":"codeVoice"},{"text":" reference to an existing ","type":"text"},{"type":"codeVoice","code":"GBookmarkFile"},{"type":"text","text":" instance."}]},{"name":"Note","type":"aside","style":"note","content":[{"inlineContent":[{"text":"Use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFile"},{"type":"text","text":" (instead of "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef","isActive":true},{"text":") if you want to use Automatic Reference Counting for memory management of the underlying ","type":"text"},{"type":"codeVoice","code":"GBookmarkFile"},{"text":" instance.","type":"text"}],"type":"paragraph"}]}]}],"references":{"https://www.freedesktop.org/wiki/Specifications/desktop-bookmark-spec/":{"title":"Desktop Bookmark Specification","url":"https:\/\/www.freedesktop.org\/wiki\/Specifications\/desktop-bookmark-spec\/","titleInlineContent":[{"text":"Desktop Bookmark Specification","type":"text"}],"type":"link","identifier":"https:\/\/www.freedesktop.org\/wiki\/Specifications\/desktop-bookmark-spec\/"},"doc://GLib/documentation/GLib/BookmarkFileRef/init(mutating:)":{"abstract":[{"text":"Unsafe untyped initialiser.","type":"text"},{"text":" ","type":"text"},{"type":"strong","inlineContent":[{"text":"Do not use unless you know the underlying data type the pointer points to conforms to ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFileProtocol"},{"text":".","type":"text"}]}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(mutating:)","fragments":[{"text":"init","kind":"identifier"},{"kind":"text","text":"("},{"text":"mutating","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SV","kind":"typeIdentifier","text":"UnsafeRawPointer"},{"kind":"text","text":")"}],"role":"symbol","url":"\/documentation\/glib\/bookmarkfileref\/init(mutating:)","kind":"symbol","type":"topic","title":"init(mutating:)"},"doc://GLib/documentation/GLib/BookmarkFileRef/init()":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init()","role":"symbol","fragments":[{"text":"init","kind":"identifier"},{"kind":"text","text":"()"}],"url":"\/documentation\/glib\/bookmarkfileref\/init()","abstract":[{"type":"text","text":"Creates a new 