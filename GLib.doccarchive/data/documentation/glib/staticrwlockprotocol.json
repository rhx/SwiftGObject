{"schemaVersion":{"patch":0,"minor":3,"major":0},"relationshipsSections":[{"kind":"relationships","title":"Inherits From","identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper"],"type":"inheritsFrom"},{"type":"conformingTypes","identifiers":["doc:\/\/GLib\/documentation\/GLib\/StaticRWLock","doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef"],"kind":"relationships","title":"Conforming Types"}],"metadata":{"title":"StaticRWLockProtocol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"StaticRWLockProtocol"}],"modules":[{"name":"GLib"}],"role":"symbol","symbolKind":"protocol","navigatorTitle":[{"text":"StaticRWLockProtocol","kind":"identifier"}],"externalID":"s:4GLib20StaticRWLockProtocolP","roleHeading":"Protocol"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"kind":"symbol","topicSections":[{"title":"Instance Methods","anchor":"Instance-Methods","generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/StaticRWLockProtocol\/free()","doc:\/\/GLib\/documentation\/GLib\/StaticRWLockProtocol\/init_()","doc:\/\/GLib\/documentation\/GLib\/StaticRWLockProtocol\/readerLock()","doc:\/\/GLib\/documentation\/GLib\/StaticRWLockProtocol\/readerTrylock()","doc:\/\/GLib\/documentation\/GLib\/StaticRWLockProtocol\/readerUnlock()","doc:\/\/GLib\/documentation\/GLib\/StaticRWLockProtocol\/writerLock()","doc:\/\/GLib\/documentation\/GLib\/StaticRWLockProtocol\/writerTrylock()","doc:\/\/GLib\/documentation\/GLib\/StaticRWLockProtocol\/writerUnlock()"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLockProtocol"},"sections":[],"variants":[{"paths":["\/documentation\/glib\/staticrwlockprotocol"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLock"},{"type":"text","text":" struct represents a read-write lock. A read-write"},{"type":"text","text":" "},{"text":"lock can be used for protecting data that some portions of code only","type":"text"},{"type":"text","text":" "},{"text":"read from, while others also write. In such situations it is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"desirable that several readers can read at once, whereas of course"},{"text":" ","type":"text"},{"type":"text","text":"only one writer may write at a time."}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"StaticRWLockProtocol"},{"text":" : ","kind":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","text":"PointerWrapper","kind":"typeIdentifier","preciseIdentifier":"s:4GLib14PointerWrapperP"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"inlineContent":[{"type":"text","text":"Take a look at the following example:"}],"type":"paragraph"},{"syntax":null,"type":"codeListing","code":["  GStaticRWLock rwlock = G_STATIC_RW_LOCK_INIT;","  GPtrArray *array;","","  gpointer","  my_array_get (guint index)","  {","    gpointer retval = NULL;","","    if (!array)","      return NULL;","","    g_static_rw_lock_reader_lock (&rwlock);","    if (index < array->len)","      retval = g_ptr_array_index (array, index);","    g_static_rw_lock_reader_unlock (&rwlock);","","    return retval;","  }","","  void","  my_array_set (guint index, gpointer data)","  {","    g_static_rw_lock_writer_lock (&rwlock);","","    if (!array)","      array = g_ptr_array_new ();","","    if (index >= array->len)","      g_ptr_array_set_size (array, index + 1);","    g_ptr_array_index (array, index) = data;","","    g_static_rw_lock_writer_unlock (&rwlock);","  }"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This example shows an array which can be accessed by many readers"},{"text":" ","type":"text"},{"text":"(the ","type":"text"},{"type":"codeVoice","code":"my_array_get()"},{"text":" function) simultaneously, whereas the writers","type":"text"},{"type":"text","text":" "},{"text":"(the ","type":"text"},{"code":"my_array_set()","type":"codeVoice"},{"type":"text","text":" function) will only be allowed once at a time"},{"text":" ","type":"text"},{"text":"and only if no readers currently access the array. This is because","type":"text"},{"text":" ","type":"text"},{"text":"of the potentially dangerous resizing of the array. Using these","type":"text"},{"text":" ","type":"text"},{"text":"functions is fully multi-thread safe now.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Most of the time, writers should have precedence over readers. That"},{"type":"text","text":" "},{"type":"text","text":"means, for this implementation, that as soon as a writer wants to"},{"type":"text","text":" "},{"text":"lock the data, no other reader is allowed to lock the data, whereas,","type":"text"},{"type":"text","text":" "},{"text":"of course, the readers that already have locked the data are allowed","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to finish their operation. As soon as the last reader unlocks the"},{"type":"text","text":" "},{"type":"text","text":"data, the writer will lock it."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Even though "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLock","type":"reference","isActive":true},{"type":"text","text":" is not opaque, it should only be used"},{"type":"text","text":" "},{"type":"text","text":"with the following functions."}]},{"type":"paragraph","inlineContent":[{"text":"All of the g_static_rw_lock_* functions can be used even if","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_thread_init()"},{"text":" has not been called. Then they do nothing, apart","type":"text"},{"type":"text","text":" "},{"text":"from g_static_rw_lock_*_trylock, which does nothing but returning ","type":"text"},{"type":"codeVoice","code":"true"},{"text":".","type":"text"}]},{"inlineContent":[{"type":"text","text":"A read-write lock has a higher overhead than a mutex. For example, both"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_static_rw_lock_reader_lock()"},{"type":"text","text":" and "},{"type":"codeVoice","code":"g_static_rw_lock_reader_unlock()"},{"text":" have","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to lock and unlock a "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex","isActive":true,"type":"reference"},{"type":"text","text":", so it takes at least twice the time"},{"type":"text","text":" "},{"text":"to lock and unlock a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLock"},{"type":"text","text":" that it does to lock and unlock a"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex","isActive":true},{"text":". So only data structures that are accessed by multiple","type":"text"},{"type":"text","text":" "},{"text":"readers, and which keep the lock for a considerable time justify a","type":"text"},{"type":"text","text":" "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLock","type":"reference","isActive":true},{"type":"text","text":". The above example most probably would fare better with a"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex","type":"reference"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLockProtocol","isActive":true},{"type":"text","text":" protocol exposes the methods and properties of an underlying "},{"type":"codeVoice","code":"GStaticRWLock"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"text":"The default implementation of these can be found in the protocol extension below.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"For a concrete class that implements these methods and properties, see "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLock","isActive":true},{"type":"text","text":"."},{"text":" ","type":"text"},{"type":"text","text":"Alternatively, use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef"},{"text":" as a lighweight, ","type":"text"},{"type":"codeVoice","code":"unowned"},{"text":" reference if you already have an instance you just want to use.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://GLib/documentation/GLib/StaticRWLockProtocol/init_()":{"deprecated":true,"title":"init_()","abstract":[{"text":"A ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLock","isActive":true},{"text":" must be initialized with this function before it","type":"text"},{"type":"text","text":" "},{"type":"text","text":"can be used. Alternatively you can initialize it with"},{"text":" ","type":"text"},{"type":"codeVoice","code":"G_STATIC_RW_LOCK_INIT"},{"type":"text","text":"."}],"kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"init_"},{"text":"()","kind":"text"}],"url":"\/documentation\/glib\/staticrwlockprotocol\/init_()","role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLockProtocol\/init_()","type":"topic"},"doc://GLib/documentation/GLib/StaticRWLockProtocol/writerTrylock()":{"title":"writerTrylock()","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"writerTrylock","kind":"identifier"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"type":"topic","url":"\/documentation\/glib\/staticrwlockprotocol\/writertrylock()","abstract":[{"type":"text","text":"Tries to lock "},{"type":"codeVoice","code":"lock"},{"text":" for writing. If ","type":"text"},{"code":"lock","type":"codeVoice"},{"text":" is already locked (for","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"either reading or writing) by another thread, it immediately returns"},{"text":" ","type":"text"},{"code":"false","type":"codeVoice"},{"text":". Otherwise it locks ","type":"text"},{"code":"lock","type":"codeVoice"},{"text":" for writing and returns ","type":"text"},{"code":"true","type":"codeVoice"},{"type":"text","text":". This"},{"text":" ","type":"text"},{"type":"text","text":"lock has to be unlocked by "},{"code":"g_static_rw_lock_writer_unlock()","type":"codeVoice"},{"type":"text","text":"."}],"kind":"symbol","role":"symbol","deprecated":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLockProtocol\/writerTrylock()"},"doc://GLib/documentation/GLib/StaticRWLockProtocol/writerUnlock()":{"abstract":[{"text":"Unlocks ","type":"text"},{"code":"lock","type":"codeVoice"},{"text":". If a thread is waiting to lock ","type":"text"},{"code":"lock","type":"codeVoice"},{"type":"text","text":" for writing and"},{"type":"text","text":" "},{"type":"text","text":"all locks for reading have been unlocked, the waiting thread is"},{"text":" ","type":"text"},{"text":"woken up and can lock ","type":"text"},{"type":"codeVoice","code":"lock"},{"type":"text","text":" for writing. If no thread is waiting to"},{"type":"text","text":" "},{"text":"lock ","type":"text"},{"code":"lock","type":"codeVoice"},{"text":" for writing, and some thread or threads are waiting to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"lock "},{"type":"codeVoice","code":"lock"},{"type":"text","text":" for reading, the waiting threads are woken up and can"},{"type":"text","text":" "},{"text":"lock ","type":"text"},{"type":"codeVoice","code":"lock"},{"text":" for reading.","type":"text"}],"deprecated":true,"title":"writerUnlock()","type":"topic","kind":"symbol","url":"\/documentation\/glib\/staticrwlockprotocol\/writerunlock()","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"writerUnlock","kind":"identifier"},{"text":"()","kind":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLockProtocol\/writerUnlock()"},"doc://GLib/documentation/GLib/StaticRWLockProtocol":{"title":"StaticRWLockProtocol","type":"topic","role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLockProtocol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"StaticRWLockProtocol"}],"abstract":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLock","isActive":true},{"type":"text","text":" struct represents a read-write lock. A read-write"},{"text":" ","type":"text"},{"type":"text","text":"lock can be used for protecting data that some portions of code only"},{"type":"text","text":" "},{"type":"text","text":"read from, while others also write. In such situations it is"},{"type":"text","text":" "},{"type":"text","text":"desirable that several readers can read at once, whereas of course"},{"text":" ","type":"text"},{"text":"only one writer may write at a time.","type":"text"}],"kind":"symbol","url":"\/documentation\/glib\/staticrwlockprotocol","navigatorTitle":[{"kind":"identifier","text":"StaticRWLockProtocol"}]},"doc://GLib/documentation/GLib/PointerWrapper":{"abstract":[{"text":"Protocol for GLib types that wrap pointers.","type":"text"}],"role":"symbol","url":"\/documentation\/glib\/pointerwrapper","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","title":"PointerWrapper","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"PointerWrapper"}],"type":"topic","navigatorTitle":[{"text":"PointerWrapper","kind":"identifier"}]},"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/StaticRWLockProtocol/free()":{"kind":"symbol","title":"free()","abstract":[{"text":"Releases all resources allocated to ","type":"text"},{"code":"lock","type":"codeVoice"},{"text":".","type":"text"}],"deprecated":true,"type":"topic","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"free"},{"text":"()","kind":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLockProtocol\/free()","url":"\/documentation\/glib\/staticrwlockprotocol\/free()"},"doc://GLib/documentation/GLib/Mutex":{"title":"Mutex","type":"topic","abstract":[{"text":"The ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex"},{"text":" struct is an opaque data structure to represent a mutex","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(mutual exclusion). It can be used to protect data against shared"},{"text":" ","type":"text"},{"text":"access.","type":"text"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Mutex"}],"navigatorTitle":[{"kind":"identifier","text":"Mutex"}],"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","url":"\/documentation\/glib\/mutex","kind":"symbol"},"doc://GLib/documentation/GLib/StaticMutex":{"kind":"symbol","role":"symbol","title":"StaticMutex","url":"\/documentation\/glib\/staticmutex","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex","navigatorTitle":[{"kind":"identifier","text":"StaticMutex"}],"type":"topic","abstract":[{"type":"text","text":"A "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex"},{"text":" works like a ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","isActive":true,"type":"reference"},{"text":".","type":"text"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"StaticMutex"}]},"doc://GLib/documentation/GLib/StaticRWLockProtocol/readerLock()":{"url":"\/documentation\/glib\/staticrwlockprotocol\/readerlock()","role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLockProtocol\/readerLock()","type":"topic","abstract":[{"text":"Locks ","type":"text"},{"type":"codeVoice","code":"lock"},{"text":" for reading. There may be unlimited concurrent locks for","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"reading of a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLock"},{"text":" at the same time.  If ","type":"text"},{"code":"lock","type":"codeVoice"},{"text":" is already","type":"text"},{"type":"text","text":" "},{"type":"text","text":"locked for writing by another thread or if another thread is already"},{"text":" ","type":"text"},{"type":"text","text":"waiting to lock "},{"type":"codeVoice","code":"lock"},{"type":"text","text":" for writing, this function will block until"},{"text":" ","type":"text"},{"type":"codeVoice","code":"lock"},{"text":" is unlocked by the other writing thread and no other writing","type":"text"},{"type":"text","text":" "},{"type":"text","text":"threads want to lock "},{"type":"codeVoice","code":"lock"},{"type":"text","text":". This lock has to be unlocked by"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_static_rw_lock_reader_unlock()"},{"text":".","type":"text"}],"kind":"symbol","deprecated":true,"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"readerLock","kind":"identifier"},{"text":"()","kind":"text"}],"title":"readerLock()"},"doc://GLib/documentation/GLib/StaticRWLockProtocol/readerUnlock()":{"type":"topic","url":"\/documentation\/glib\/staticrwlockprotocol\/readerunlock()","title":"readerUnlock()","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLockProtocol\/readerUnlock()","deprecated":true,"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"readerUnlock","kind":"identifier"},{"kind":"text","text":"()"}],"abstract":[{"type":"text","text":"Unlocks "},{"code":"lock","type":"codeVoice"},{"type":"text","text":". If a thread waits to lock "},{"code":"lock","type":"codeVoice"},{"type":"text","text":" for writing and all"},{"text":" ","type":"text"},{"text":"locks for reading have been unlocked, the waiting thread is woken up","type":"text"},{"text":" ","type":"text"},{"text":"and can lock ","type":"text"},{"code":"lock","type":"codeVoice"},{"text":" for writing.","type":"text"}],"role":"symbol"},"doc://GLib/documentation/GLib/StaticRWLockRef":{"url":"\/documentation\/glib\/staticrwlockref","navigatorTitle":[{"kind":"identifier","text":"StaticRWLockRef"}],"title":"StaticRWLockRef","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef","type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"StaticRWLockRef","kind":"identifier"}],"role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLock","isActive":true,"type":"reference"},{"type":"text","text":" struct represents a read-write lock. A read-write"},{"type":"text","text":" "},{"type":"text","text":"lock can be used for protecting data that some portions of code only"},{"text":" ","type":"text"},{"type":"text","text":"read from, while others also write. In such situations it is"},{"text":" ","type":"text"},{"type":"text","text":"desirable that several readers can read at once, whereas of course"},{"type":"text","text":" "},{"type":"text","text":"only one writer may write at a time."}]},"doc://GLib/documentation/GLib/StaticRWLockProtocol/writerLock()":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"writerLock","kind":"identifier"},{"text":"()","kind":"text"}],"type":"topic","abstract":[{"type":"text","text":"Locks "},{"type":"codeVoice","code":"lock"},{"type":"text","text":" for writing. If "},{"type":"codeVoice","code":"lock"},{"text":" is already locked for writing or","type":"text"},{"text":" ","type":"text"},{"text":"reading by other threads, this function will block until ","type":"text"},{"code":"lock","type":"codeVoice"},{"type":"text","text":" is"},{"text":" ","type":"text"},{"type":"text","text":"completely unlocked and then lock "},{"type":"codeVoice","code":"lock"},{"text":" for writing. While this","type":"text"},{"type":"text","text":" "},{"text":"functions waits to lock ","type":"text"},{"type":"codeVoice","code":"lock"},{"type":"text","text":", no other thread can lock "},{"type":"codeVoice","code":"lock"},{"type":"text","text":" for"},{"text":" ","type":"text"},{"type":"text","text":"reading. When "},{"code":"lock","type":"codeVoice"},{"type":"text","text":" is locked for writing, no other thread can lock"},{"type":"text","text":" "},{"type":"codeVoice","code":"lock"},{"type":"text","text":" (neither for reading nor writing). This lock has to be"},{"type":"text","text":" "},{"type":"text","text":"unlocked by "},{"type":"codeVoice","code":"g_static_rw_lock_writer_unlock()"},{"text":".","type":"text"}],"url":"\/documentation\/glib\/staticrwlockprotocol\/writerlock()","deprecated":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLockProtocol\/writerLock()","role":"symbol","kind":"symbol","title":"writerLock()"},"doc://GLib/documentation/GLib/StaticRWLockProtocol/readerTrylock()":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLockProtocol\/readerTrylock()","type":"topic","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"readerTrylock"},{"text":"() -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"title":"readerTrylock()","url":"\/documentation\/glib\/staticrwlockprotocol\/readertrylock()","abstract":[{"text":"Tries to lock ","type":"text"},{"type":"codeVoice","code":"lock"},{"type":"text","text":" for reading. If "},{"code":"lock","type":"codeVoice"},{"type":"text","text":" is already locked for"},{"text":" ","type":"text"},{"type":"text","text":"writing by another thread or if another thread is already waiting to"},{"type":"text","text":" "},{"type":"text","text":"lock "},{"code":"lock","type":"codeVoice"},{"type":"text","text":" for writing, immediately returns "},{"type":"codeVoice","code":"false"},{"text":". Otherwise locks","type":"text"},{"text":" ","type":"text"},{"code":"lock","type":"codeVoice"},{"text":" for reading and returns ","type":"text"},{"type":"codeVoice","code":"true"},{"type":"text","text":". This lock has to be unlocked by"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_static_rw_lock_reader_unlock()"},{"text":".","type":"text"}],"role":"symbol","deprecated":true,"kind":"symbol"},"doc://GLib/documentation/GLib/StaticRWLock":{"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"StaticRWLock"}],"abstract":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLock","isActive":true,"type":"reference"},{"text":" struct represents a read-write lock. A read-write","type":"text"},{"type":"text","text":" "},{"type":"text","text":"lock can be used for protecting data that some portions of code only"},{"type":"text","text":" "},{"type":"text","text":"read from, while others also write. In such situations it is"},{"type":"text","text":" "},{"text":"desirable that several readers can read at once, whereas of course","type":"text"},{"type":"text","text":" "},{"text":"only one writer may write at a time.","type":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLock","url":"\/documentation\/glib\/staticrwlock","role":"symbol","navigatorTitle":[{"text":"StaticRWLock","kind":"identifier"}],"title":"StaticRWLock","type":"topic","kind":"symbol"}}}