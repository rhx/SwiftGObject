{"topicSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef\/init(_:)-23tja","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef\/init(_:)-34spm","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef\/init(_:)-5mqz7","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef\/init(_:)-92aql","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef\/init(_:)-eq03","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef\/init(constPointer:)","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef\/init(mutating:)","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef\/init(opaquePointer:)"],"generated":true,"anchor":"Initializers","title":"Initializers"},{"title":"Instance Properties","anchor":"Instance-Properties","generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef\/ptr"]},{"anchor":"Type-Methods","title":"Type Methods","identifiers":["doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef\/new(full:userData:itemFreeFunc:maxThreads:exclusive:)"],"generated":true},{"anchor":"Default-Implementations","generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef\/PointerWrapper-Implementations","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef\/ThreadPoolProtocol-Implementations"],"title":"Default Implementations"}],"metadata":{"modules":[{"name":"GLib"}],"navigatorTitle":[{"text":"ThreadPoolRef","kind":"identifier"}],"roleHeading":"Structure","role":"symbol","title":"ThreadPoolRef","symbolKind":"struct","externalID":"s:4GLib13ThreadPoolRefV","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ThreadPoolRef","kind":"identifier"}]},"abstract":[{"type":"text","text":"The "},{"code":"GThreadPool","type":"codeVoice"},{"type":"text","text":" struct represents a thread pool."}],"schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"relationshipsSections":[{"kind":"relationships","type":"conformsTo","identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol"],"title":"Conforms To"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/threadpoolref"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"ThreadPoolRef","kind":"identifier"}]}]},{"kind":"content","content":[{"text":"Overview","anchor":"overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"A thread pool is useful when you wish to asynchronously fork out the execution of work","type":"text"},{"text":" ","type":"text"},{"text":"and continue working in your own thread. If that will happen often, the overhead of starting","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and destroying a thread each time might be too high. In such cases reusing already started"},{"type":"text","text":" "},{"text":"threads seems like a good idea. And it indeed is, but implementing this can be tedious","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and error-prone."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Therefore GLib provides thread pools for your convenience. An added advantage is, that the"},{"text":" ","type":"text"},{"type":"text","text":"threads can be shared between the different subsystems of your program, when they are using GLib."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To create a new thread pool, you use [func"},{"type":"codeVoice","code":"GLib.ThreadPool.new"},{"type":"text","text":"]."},{"text":" ","type":"text"},{"text":"It is destroyed by [method","type":"text"},{"code":"GLib.ThreadPool.free","type":"codeVoice"},{"text":"].","type":"text"}]},{"inlineContent":[{"type":"text","text":"If you want to execute a certain task within a thread pool, use [method"},{"type":"codeVoice","code":"GLib.ThreadPool.push"},{"text":"].","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To get the current number of running threads you call [method"},{"type":"codeVoice","code":"GLib.ThreadPool.get_num_threads"},{"text":"].","type":"text"},{"type":"text","text":" "},{"text":"To get the number of still unprocessed tasks you call [method","type":"text"},{"type":"codeVoice","code":"GLib.ThreadPool.unprocessed"},{"type":"text","text":"]."},{"text":" ","type":"text"},{"text":"To control the maximum number of threads for a thread pool, you use","type":"text"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.ThreadPool.get_max_threads"},{"text":"]. and [method","type":"text"},{"type":"codeVoice","code":"GLib.ThreadPool.set_max_threads"},{"text":"].","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Finally you can control the number of unused threads, that are kept alive by GLib for future use."},{"text":" ","type":"text"},{"text":"The current number can be fetched with [func","type":"text"},{"code":"GLib.ThreadPool.get_num_unused_threads","type":"codeVoice"},{"type":"text","text":"]."},{"type":"text","text":" "},{"text":"The maximum number can be controlled by [func","type":"text"},{"code":"GLib.ThreadPool.get_max_unused_threads","type":"codeVoice"},{"text":"] and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[func"},{"code":"GLib.ThreadPool.set_max_unused_threads","type":"codeVoice"},{"type":"text","text":"]. All currently unused threads"},{"type":"text","text":" "},{"type":"text","text":"can be stopped by calling [func"},{"code":"GLib.ThreadPool.stop_unused_threads","type":"codeVoice"},{"text":"].","type":"text"}]},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef","isActive":true},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GThreadPool"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol","isActive":true,"type":"reference"},{"text":" conformance.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Use "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef","isActive":true},{"type":"text","text":" only as an "},{"code":"unowned","type":"codeVoice"},{"type":"text","text":" reference to an existing "},{"type":"codeVoice","code":"GThreadPool"},{"text":" instance.","type":"text"}],"type":"paragraph"},{"style":"note","type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/ThreadPool"},{"type":"text","text":" (instead of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef"},{"text":") if you want to use Automatic Reference Counting for memory management of the underlying ","type":"text"},{"code":"GThreadPool","type":"codeVoice"},{"text":" instance.","type":"text"}]}]}]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"references":{"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/ThreadPoolRef/ptr":{"kind":"symbol","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef\/ptr","url":"\/documentation\/glib\/threadpoolref\/ptr",