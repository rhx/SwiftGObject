{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/filesetcontentsfull(filename:contents:length:flags:mode:)"]}],"abstract":[{"text":"Writes all of ","type":"text"},{"type":"codeVoice","code":"contents"},{"type":"text","text":" to a file named "},{"type":"codeVoice","code":"filename"},{"text":", with good error checking.","type":"text"},{"text":" ","type":"text"},{"text":"If a file called ","type":"text"},{"type":"codeVoice","code":"filename"},{"type":"text","text":" already exists it will be overwritten."}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/fileSetContentsFull(filename:contents:length:flags:mode:)","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"fileSetContentsFull","kind":"identifier"},{"text":"(","kind":"text"},{"text":"filename","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"contents"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">!, ","kind":"text"},{"text":"length","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@T@gssize","kind":"typeIdentifier","text":"gssize"},{"kind":"text","text":", "},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"FileSetContentsFlags","identifier":"doc:\/\/GLib\/documentation\/GLib\/FileSetContentsFlags","preciseIdentifier":"s:4GLib20FileSetContentsFlagsV"},{"kind":"text","text":", "},{"text":"mode","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"flags"},{"type":"text","text":" control the properties of the write operation: whether it’s atomic,"},{"type":"text","text":" "},{"type":"text","text":"and what the tradeoff is between returning quickly or being resilient to"},{"type":"text","text":" "},{"type":"text","text":"system crashes."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"As this function performs file I\/O, it is recommended to not call it anywhere"},{"type":"text","text":" "},{"type":"text","text":"where blocking would cause problems, such as in the main loop of a graphical"},{"text":" ","type":"text"},{"text":"application. In particular, if ","type":"text"},{"type":"codeVoice","code":"flags"},{"type":"text","text":" has any value other than"},{"text":" ","type":"text"},{"code":"none","type":"codeVoice"},{"text":" then this function may call ","type":"text"},{"code":"fsync()","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"consistent"},{"type":"text","text":" is set in "},{"type":"codeVoice","code":"flags"},{"type":"text","text":", the operation is atomic"},{"text":" ","type":"text"},{"text":"in the sense that it is first written to a temporary file which is then","type":"text"},{"type":"text","text":" "},{"text":"renamed to the final name.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Notes:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"On UNIX, if ","type":"text"},{"type":"codeVoice","code":"filename"},{"text":" already exists hard links to ","type":"text"},{"code":"filename","type":"codeVoice"},{"type":"text","text":" will break."},{"type":"text","text":" "},{"text":"Also since the file is recreated, existing permissions, access control","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"lists, metadata etc. may be lost. If "},{"type":"codeVoice","code":"filename"},{"type":"text","text":" is a symbolic link,"},{"text":" ","type":"text"},{"text":"the link itself will be replaced, not the linked file.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"On UNIX, if ","type":"text"},{"code":"filename","type":"codeVoice"},{"type":"text","text":" already exists and is non-empty, and if the system"},{"text":" ","type":"text"},{"type":"text","text":"supports it (via a journalling filesystem or equivalent), and if"},{"type":"text","text":" "},{"type":"codeVoice","code":"consistent"},{"text":" is set in ","type":"text"},{"code":"flags","type":"codeVoice"},{"text":", the ","type":"text"},{"type":"codeVoice","code":"fsync()"},{"text":" call (or","type":"text"},{"type":"text","text":" "},{"text":"equivalent) will be used to ensure atomic replacement: ","type":"text"},{"type":"codeVoice","code":"filename"},{"text":" ","type":"text"},{"type":"text","text":"will contain either its old contents or "},{"type":"codeVoice","code":"contents"},{"text":", even in the face of","type":"text"},{"text":" ","type":"text"},{"text":"system power loss, the disk being unsafely removed, etc.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"On UNIX, if "},{"type":"codeVoice","code":"filename"},{"type":"text","text":" does not already exist or is empty, there is a"},{"type":"text","text":" "},{"text":"possibility that system power loss etc. after calling this function will","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"leave "},{"type":"codeVoice","code":"filename"},{"text":" empty or full of NUL bytes, depending on the underlying","type":"text"},{"text":" ","type":"text"},{"text":"filesystem, unless ","type":"text"},{"code":"durable","type":"codeVoice"},{"text":" and","type":"text"},{"type":"text","text":" "},{"code":"consistent","type":"codeVoice"},{"type":"text","text":" are set in "},{"type":"codeVoice","code":"flags"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"On Windows renaming a file will not remove an existing file with the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"new name, so on Windows there is a race condition between the existing"},{"type":"text","text":" "},{"type":"text","text":"file being removed and the temporary file being renamed."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"On Windows there is no way to remove a file that is open to some"},{"type":"text","text":" "},{"text":"process, or mapped into memory. Thus, this function will fail if","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"filename"},{"type":"text","text":" already exists and is open."}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the call was successful, it returns "},{"type":"codeVoice","code":"true"},{"text":". If the call was not successful,","type":"text"},{"text":" ","type":"text"},{"text":"it returns ","type":"text"},{"code":"false","type":"codeVoice"},{"type":"text","text":" and sets "},{"code":"error","type":"codeVoice"},{"type":"text","text":". The error domain is "},{"code":"G_FILE_ERROR","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Possible error codes are those in the "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/FileError","isActive":true},{"text":" enumeration.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Note that the name for the temporary file is constructed by appending up"},{"text":" ","type":"text"},{"text":"to 7 characters to ","type":"text"},{"type":"codeVoice","code":"filename"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If the file didn’t exist before and is created, it will be given the"},{"type":"text","text":" "},{"type":"text","text":"permissions from "},{"code":"mode","type":"codeVoice"},{"type":"text","text":". Otherwise, the permissions of the existing file will"},{"type":"text","text":" "},{"text":"remain unchanged.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"sections":[],"metadata":{"role":"symbol","externalID":"s:4GLib19fileSetContentsFull8filename8contents6length5flags4modeSbSPys4Int8VGSg_AKSiAA04FilecD5FlagsVSitKF","title":"fileSetContentsFull(filename:contents:length:flags:mode:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"fileSetContentsFull","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"filename"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"kind":"text","text":">!, "},{"text":"contents","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"length"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"gssize","preciseIdentifier":"c:@T@gssize"},{"text":", ","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib20FileSetContentsFlagsV","text":"FileSetContentsFlags"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"mode"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"symbolKind":"func","modules":[{"name":"GLib"}],"roleHeading":"Function"},"references":{"doc://GLib/documentation/GLib":{"abstract":[],"kind":"symbol","title":"GLib","role":"collection","url":"\/documentation\/glib","identifier":"doc:\/\/GLib\/documentation\/GLib","type":"topic"},"doc://GLib/documentation/GLib/FileError":{"fragments":[{"kind":"keyword","text":"typealias"},{"text":" ","kind":"text"},{"text":"FileError","kind":"identifier"}],"abstract":[{"text":"Values corresponding to ","type":"text"},{"code":"errno","type":"codeVoice"},{"text":" codes returned from file operations","type":"text"},{"text":" ","type":"text"},{"text":"on UNIX. Unlike ","type":"text"},{"code":"errno","type":"codeVoice"},{"type":"text","text":" codes, GFileError values are available on"},{"type":"text","text":" "},{"type":"text","text":"all systems, even Windows. The exact meaning of each code depends"},{"type":"text","text":" "},{"type":"text","text":"on what sort of file operation you were performing; the UNIX"},{"type":"text","text":" "},{"text":"documentation gives more details. The following error code descriptions","type":"text"},{"type":"text","text":" "},{"type":"text","text":"come from the GNU C Library manual, and are under the copyright"},{"text":" ","type":"text"},{"text":"of that manual.","type":"text"}],"url":"\/documentation\/glib\/fileerror","kind":"symbol","navigatorTitle":[{"text":"FileError","kind":"identifier"}],"title":"FileError","identifier":"doc:\/\/GLib\/documentation\/GLib\/FileError","type":"topic","role":"symbol"},"doc://GLib/documentation/GLib/fileSetContentsFull(filename:contents:length:flags:mode:)":{"role":"symbol","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"fileSetContentsFull"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"filename"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"kind":"text","text":">!, "},{"text":"contents","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"length"},{"kind":"text","text":": "},{"text":"gssize","kind":"typeIdentifier","preciseIdentifier":"c:@T@gssize"},{"kind":"text","text":", "},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"text":"FileSetContentsFlags","kind":"typeIdentifier","preciseIdentifier":"s:4GLib20FileSetContentsFlagsV"},{"text":", ","kind":"text"},{"text":"mode","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"abstract":[{"text":"Writes all of ","type":"text"},{"type":"codeVoice","code":"contents"},{"text":" to a file named ","type":"text"},{"type":"codeVoice","code":"filename"},{"type":"text","text":", with good error checking."},{"text":" ","type":"text"},{"type":"text","text":"If a file called "},{"type":"codeVoice","code":"filename"},{"type":"text","text":" already exists it will be overwritten."}],"url":"\/documentation\/glib\/filesetcontentsfull(filename:contents:length:flags:mode:)","identifier":"doc:\/\/GLib\/documentation\/GLib\/fileSetContentsFull(filename:contents:length:flags:mode:)","title":"fileSetContentsFull(filename:contents:length:flags:mode:)","type":"topic"},"doc://GLib/documentation/GLib/FileSetContentsFlags":{"abstract":[{"text":"Flags to pass to ","type":"text"},{"type":"codeVoice","code":"g_file_set_contents_full()"},{"text":" to affect its safety and","type":"text"},{"text":" ","type":"text"},{"text":"performance.","type":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/FileSetContentsFlags","type":"topic","title":"FileSetContentsFlags","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"FileSetContentsFlags","kind":"identifier"}],"url":"\/documentation\/glib\/filesetcontentsflags","kind":"symbol","role":"symbol","navigatorTitle":[{"text":"FileSetContentsFlags","kind":"identifier"}]}}}