{"abstract":[{"type":"text","text":"Writes all of "},{"type":"codeVoice","code":"contents"},{"text":" to a file named ","type":"text"},{"type":"codeVoice","code":"filename"},{"type":"text","text":", with good error checking."},{"text":" ","type":"text"},{"type":"text","text":"If a file called "},{"type":"codeVoice","code":"filename"},{"type":"text","text":" already exists it will be overwritten."}],"sections":[],"metadata":{"title":"fileSetContentsFull(filename:contents:length:flags:mode:)","modules":[{"name":"GLib"}],"role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"fileSetContentsFull"},{"kind":"text","text":"("},{"kind":"externalParam","text":"filename"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"gchar","preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"text":"contents","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">!, ","kind":"text"},{"text":"length","kind":"externalParam"},{"kind":"text","text":": "},{"text":"gssize","kind":"typeIdentifier","preciseIdentifier":"c:@T@gssize"},{"text":", ","kind":"text"},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"FileSetContentsFlags","kind":"typeIdentifier","preciseIdentifier":"s:4GLib20FileSetContentsFlagsV"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"mode"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"roleHeading":"Function","externalID":"s:4GLib19fileSetContentsFull8filename8contents6length5flags4modeSbSPys4Int8VGSg_AKSiAA04FilecD5FlagsVSitKF","symbolKind":"func"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/fileSetContentsFull(filename:contents:length:flags:mode:)","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"fileSetContentsFull"},{"kind":"text","text":"("},{"kind":"externalParam","text":"filename"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier","text":"gchar"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"contents"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">!, "},{"text":"length","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@gssize","kind":"typeIdentifier","text":"gssize"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/FileSetContentsFlags","preciseIdentifier":"s:4GLib20FileSetContentsFlagsV","text":"FileSetContentsFlags","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"mode","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":") ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"platforms":["macOS"]}]},{"content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"code":"flags","type":"codeVoice"},{"type":"text","text":" control the properties of the write operation: whether it’s atomic,"},{"type":"text","text":" "},{"type":"text","text":"and what the tradeoff is between returning quickly or being resilient to"},{"type":"text","text":" "},{"text":"system crashes.","type":"text"}]},{"inlineContent":[{"text":"As this function performs file I\/O, it is recommended to not call it anywhere","type":"text"},{"type":"text","text":" "},{"text":"where blocking would cause problems, such as in the main loop of a graphical","type":"text"},{"type":"text","text":" "},{"type":"text","text":"application. In particular, if "},{"code":"flags","type":"codeVoice"},{"type":"text","text":" has any value other than"},{"type":"text","text":" "},{"code":"none","type":"codeVoice"},{"text":" then this function may call ","type":"text"},{"type":"codeVoice","code":"fsync()"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"consistent","type":"codeVoice"},{"type":"text","text":" is set in "},{"type":"codeVoice","code":"flags"},{"type":"text","text":", the operation is atomic"},{"type":"text","text":" "},{"type":"text","text":"in the sense that it is first written to a temporary file which is then"},{"type":"text","text":" "},{"type":"text","text":"renamed to the final name."}]},{"inlineContent":[{"type":"text","text":"Notes:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"On UNIX, if "},{"code":"filename","type":"codeVoice"},{"text":" already exists hard links to ","type":"text"},{"type":"codeVoice","code":"filename"},{"type":"text","text":" will break."},{"type":"text","text":" "},{"text":"Also since the file is recreated, existing permissions, access control","type":"text"},{"type":"text","text":" "},{"text":"lists, metadata etc. may be lost. If ","type":"text"},{"type":"codeVoice","code":"filename"},{"type":"text","text":" is a symbolic link,"},{"type":"text","text":" "},{"type":"text","text":"the link itself will be replaced, not the linked file."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"On UNIX, if "},{"type":"codeVoice","code":"filename"},{"text":" already exists and is non-empty, and if the system","type":"text"},{"text":" ","type":"text"},{"text":"supports it (via a journalling filesystem or equivalent), and if","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"consistent"},{"type":"text","text":" is set in "},{"type":"codeVoice","code":"flags"},{"text":", the ","type":"text"},{"type":"codeVoice","code":"fsync()"},{"type":"text","text":" call (or"},{"text":" ","type":"text"},{"text":"equivalent) will be used to ensure atomic replacement: ","type":"text"},{"type":"codeVoice","code":"filename"},{"type":"text","text":" "},{"type":"text","text":"will contain either its old contents or "},{"type":"codeVoice","code":"contents"},{"text":", even in the face of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"system power loss, the disk being unsafely removed, etc."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"On UNIX, if "},{"type":"codeVoice","code":"filename"},{"text":" does not already exist or is empty, there is a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"possibility that system power loss etc. after calling this function will"},{"text":" ","type":"text"},{"text":"leave ","type":"text"},{"code":"filename","type":"codeVoice"},{"type":"text","text":" empty or full of NUL bytes, depending on the underlying"},{"type":"text","text":" "},{"type":"text","text":"filesystem, unless "},{"type":"codeVoice","code":"durable"},{"text":" and","type":"text"},{"type":"text","text":" "},{"code":"consistent","type":"codeVoice"},{"type":"text","text":" are set in "},{"type":"codeVoice","code":"flags"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"On Windows renaming a file will not remove an existing file with the"},{"type":"text","text":" "},{"type":"text","text":"new name, so on Windows there is a race condition between the existing"},{"type":"text","text":" "},{"text":"file being removed and the temporary file being renamed.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"On Windows there is no way to remove a file that is open to some","type":"text"},{"text":" ","type":"text"},{"text":"process, or mapped into memory. Thus, this function will fail if","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"filename"},{"text":" already exists and is open.","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"If the call was successful, it returns ","type":"text"},{"type":"codeVoice","code":"true"},{"text":". If the call was not successful,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"it returns "},{"type":"codeVoice","code":"false"},{"type":"text","text":" and sets "},{"type":"codeVoice","code":"error"},{"text":". The error domain is ","type":"text"},{"type":"codeVoice","code":"G_FILE_ERROR"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"Possible error codes are those in the ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/FileError","isActive":true},{"text":" enumeration.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that the name for the temporary file is constructed by appending up"},{"type":"text","text":" "},{"type":"text","text":"to 7 characters to "},{"code":"filename","type":"codeVoice"},{"text":".","type":"text"}]},{"inlineContent":[{"type":"text","text":"If the file didn’t exist before and is created, it will be given the"},{"type":"text","text":" "},{"type":"text","text":"permissions from "},{"code":"mode","type":"codeVoice"},{"text":". Otherwise, the permissions of the existing file will","type":"text"},{"type":"text","text":" "},{"type":"text","text":"remain unchanged."}],"type":"paragraph"}],"kind":"content"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/filesetcontentsfull(filename:contents:length:flags:mode:)"]}],"references":{"doc://GLib/documentation/GLib/FileSetContentsFlags":{"navigatorTitle":[{"text":"FileSetContentsFlags","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/FileSetContentsFlags","title":"FileSetContentsFlags","url":"\/documentation\/glib\/filesetcontentsflags","abstract":[{"type":"text","text":"Flags to pass to "},{"code":"g_file_set_contents_full()","type":"codeVoice"},{"text":" to affect its safety and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"performance."}],"role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"FileSetContentsFlags","kind":"identifier"}],"type":"topic"},"doc://GLib/documentation/GLib/FileError":{"navigatorTitle":[{"kind":"identifier","text":"FileError"}],"kind":"symbol","abstract":[{"text":"Values corresponding to ","type":"text"},{"code":"errno","type":"codeVoice"},{"text":" codes returned from file operations","type":"text"},{"type":"text","text":" "},{"type":"text","text":"on UNIX. Unlike "},{"code":"errno","type":"codeVoice"},{"text":" codes, GFileError values are available on","type":"text"},{"type":"text","text":" "},{"type":"text","text":"all systems, even Windows. The exact meaning of each code depends"},{"type":"text","text":" "},{"type":"text","text":"on what sort of file operation you were performing; the UNIX"},{"text":" ","type":"text"},{"type":"text","text":"documentation gives more details. The following error code descriptions"},{"type":"text","text":" "},{"type":"text","text":"come from the GNU C Library manual, and are under the copyright"},{"type":"text","text":" "},{"text":"of that manual.","type":"text"}],"title":"FileError","role":"symbol","type":"topic","fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"FileError"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/FileError","url":"\/documentation\/glib\/fileerror"},"doc://GLib/documentation/GLib":{"url":"\/documentation\/glib","kind":"symbol","title":"GLib","abstract":[],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib","role":"collection"},"doc://GLib/documentation/GLib/fileSetContentsFull(filename:contents:length:flags:mode:)":{"title":"fileSetContentsFull(filename:contents:length:flags:mode:)","identifier":"doc:\/\/GLib\/documentation\/GLib\/fileSetContentsFull(filename:contents:length:flags:mode:)","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"fileSetContentsFull","kind":"identifier"},{"text":"(","kind":"text"},{"text":"filename","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"contents"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"length"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gssize","text":"gssize"},{"text":", ","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"text":"FileSetContentsFlags","preciseIdentifier":"s:4GLib20FileSetContentsFlagsV","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"mode","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"abstract":[{"text":"Writes all of ","type":"text"},{"code":"contents","type":"codeVoice"},{"text":" to a file named ","type":"text"},{"type":"codeVoice","code":"filename"},{"type":"text","text":", with good error checking."},{"text":" ","type":"text"},{"text":"If a file called ","type":"text"},{"type":"codeVoice","code":"filename"},{"type":"text","text":" already exists it will be overwritten."}],"url":"\/documentation\/glib\/filesetcontentsfull(filename:contents:length:flags:mode:)","type":"topic"}}}