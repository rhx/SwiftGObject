{"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"creat"},{"kind":"text","text":"("},{"text":"filename","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier","text":"gchar"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"mode"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"inlineContent":[{"text":"On POSIX systems file descriptors are implemented by the operating","type":"text"},{"type":"text","text":" "},{"text":"system. On Windows, it’s the C library that implements ","type":"text"},{"code":"creat()","type":"codeVoice"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"text","text":"file descriptors. The actual Windows API for opening files is"},{"type":"text","text":" "},{"type":"text","text":"different, see MSDN documentation for "},{"type":"codeVoice","code":"CreateFile()"},{"text":". The Win32 API","type":"text"},{"type":"text","text":" "},{"type":"text","text":"uses file handles, which are more randomish integers, not small"},{"type":"text","text":" "},{"type":"text","text":"integers like file descriptors."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Because file descriptors are specific to the C library on Windows,"},{"type":"text","text":" "},{"text":"the file descriptor returned by this function makes sense only to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"functions in the same C library. Thus if the GLib-using code uses a"},{"type":"text","text":" "},{"type":"text","text":"different C library than GLib does, the file descriptor returned by"},{"type":"text","text":" "},{"text":"this function cannot be passed to C library functions like ","type":"text"},{"code":"write()","type":"codeVoice"},{"type":"text","text":" "},{"text":"or ","type":"text"},{"type":"codeVoice","code":"read()"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"See your C library manual for more details about "},{"code":"creat()","type":"codeVoice"},{"text":".","type":"text"}]}]}],"variants":[{"paths":["\/documentation\/glib\/creat(filename:mode:)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","metadata":{"title":"creat(filename:mode:)","role":"symbol","externalID":"s:4GLib5creat8filename4modeSiSPys4Int8VGSg_SitF","modules":[{"name":"GLib"}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"creat"},{"kind":"text","text":"("},{"text":"filename","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"text":">!, ","kind":"text"},{"text":"mode","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"text":") -> ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"roleHeading":"Function","symbolKind":"func"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"abstract":[{"type":"text","text":"A wrapper for the POSIX "},{"type":"codeVoice","code":"creat()"},{"type":"text","text":" function. The "},{"type":"codeVoice","code":"creat()"},{"text":" function is","type":"text"},{"type":"text","text":" "},{"text":"used to convert a pathname into a file descriptor, creating a file","type":"text"},{"text":" ","type":"text"},{"type":"