{"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLibObject\/documentation\/GLibObject\/Closure"},"abstract":[{"type":"text","text":"A "},{"type":"codeVoice","code":"GClosure"},{"type":"text","text":" represents a callback supplied by the programmer."}],"topicSections":[{"title":"Initializers","generated":true,"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/init(_:)-3dal7","doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/init(_:)-3g7pp","doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/init(_:)-3sg1w","doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/init(_:)-6iibg","doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/init(_:)-8g8g2","doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/init(cPointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/init(gconstpointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/init(gpointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/init(object:object:)","doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/init(opaquePointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/init(raw:)-26247","doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/init(raw:)-797bm","doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/init(retaining:)","doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/init(retainingCPointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/init(retainingOpaquePointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/init(retainingRaw:)-16wjq","doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/init(retainingRaw:)-7dv4s","doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/init(simple:data:)"],"anchor":"Initializers"},{"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/ptr"],"generated":true,"anchor":"Instance-Properties","title":"Instance Properties"},{"title":"Type Methods","generated":true,"anchor":"Type-Methods","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/new(object:object:)","doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/new(simple:data:)"]},{"anchor":"Default-Implementations","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/ClosureProtocol-Implementations"],"generated":true,"title":"Default Implementations"}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"relationshipsSections":[{"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureProtocol","doc:\/\/GLibObject\/4GLib14PointerWrapperP"],"kind":"relationships","type":"conformsTo","title":"Conforms To"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/closure"]}],"metadata":{"roleHeading":"Class","symbolKind":"class","navigatorTitle":[{"kind":"identifier","text":"Closure"}],"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"Closure"}],"role":"symbol","externalID":"s:10GLibObject7ClosureC","title":"Closure","modules":[{"name":"GLibObject"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"Closure","kind":"identifier"}]}]},{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It will generally comprise a function of some kind and a marshaller"},{"text":" ","type":"text"},{"text":"used to call it. It is the responsibility of the marshaller to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"convert the arguments for the invocation from "},{"type":"reference","identifier":"#struct@Value","isActive":true},{"type":"text","text":" into"},{"text":" ","type":"text"},{"text":"a suitable form, perform the callback on the converted arguments,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and transform the return value back into a [struct"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Value"},{"type":"text","text":"]."}]},{"inlineContent":[{"text":"In the case of C programs, a closure usually just holds a pointer","type":"text"},{"text":" ","type":"text"},{"text":"to a function and maybe a data argument, and the marshaller","type":"text"},{"type":"text","text":" "},{"text":"converts between [struct","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Value","type":"reference"},{"type":"text","text":"] and native C types. The GObject"},{"type":"text","text":" "},{"type":"text","text":"library provides the [struct"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/CClosure","isActive":true,"type":"reference"},{"text":"] type for this purpose. Bindings for","type":"text"},{"type":"text","text":" "},{"type":"text","text":"other languages need marshallers which convert between "},{"identifier":"#struct@Value","overridingTitle":"GValues","type":"reference","overridingTitleInlineContent":[{"text":"GValues","type":"text"}],"isActive":true},{"type":"text","text":" "},{"type":"text","text":"and suitable representations in the runtime of the language in"},{"type":"text","text":" "},{"type":"text","text":"order to use functions written in that language as callbacks. Use"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Closure.set_marshal"},{"type":"text","text":"] to set the marshaller on such a custom"},{"text":" ","type":"text"},{"text":"closure implementation.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Within GObject, closures play an important role in the","type":"text"},{"type":"text","text":" "},{"text":"implementation of signals. When a signal is registered, the","type":"text"},{"type":"text","text":" "},{"code":"c_marshaller","type":"codeVoice"},{"type":"text","text":" argument to [func"},{"code":"signal_new","type":"codeVoice"},{"type":"text","text":"] specifies the default C"},{"type":"text","text":" "},{"type":"text","text":"marshaller for any closure which is connected to this"},{"type":"text","text":" "},{"type":"text","text":"signal. GObject provides a number of C marshallers for this"},{"type":"text","text":" "},{"text":"purpose, see the ","type":"text"},{"type":"codeVoice","code":"g_cclosure_marshal_*()"},{"text":" functions. Additional C","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"marshallers can be generated with the "},{"type":"reference","isActive":true,"identifier":"#glib-genmarshal"},{"type":"text","text":" "},{"text":"utility.  Closures can be explicitly connected to signals with","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[func"},{"type":"codeVoice","code":"signal_connect_closure"},{"type":"text","text":"], but it usually more convenient to let"},{"text":" ","type":"text"},{"text":"GObject create a closure automatically by using one of the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_signal_connect_*()"},{"type":"text","text":" functions which take a callback function\/user"},{"type":"text","text":" "},{"text":"data pair.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Using closures has a number of important advantages over a simple"},{"text":" ","type":"text"},{"type":"text","text":"callback function\/data pointer combination:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Closures allow the callee to get the types of the callback parameters,"},{"text":" ","type":"text"},{"type":"text","text":"which means that language bindings don’t have to write individual glue"},{"type":"text","text":" "},{"type":"text","text":"for each callback type."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The reference counting of [struct"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Closure","isActive":true,"type":"reference"},{"text":"] makes it easy to handle reentrancy","type":"text"},{"type":"text","text":" "},{"type":"text","text":"right; if a callback is removed while it is being invoked, the closure"},{"type":"text","text":" "},{"text":"and its parameters won’t be freed until the invocation finishes.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"[method"},{"type":"codeVoice","code":"Closure.invalidate"},{"type":"text","text":"] and invalidation notifiers allow callbacks to be"},{"type":"text","text":" "},{"text":"automatically removed when the objects they point to go away.","type":"text"}]}]}]},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Closure","isActive":true},{"type":"text","text":" type acts as a reference-counted owner of an underlying "},{"type":"codeVoice","code":"GClosure"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"text":"It provides the methods that can operate on this data type through ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureProtocol","isActive":true,"type":"reference"},{"text":" conformance.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Use "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Closure","isActive":true},{"type":"text","text":" as a strong reference or owner of a "},{"type":"codeVoice","code":"GClosure"},{"type":"text","text":" instance."}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef","type":"reference","isActive":true},{"type":"text","text":" (instead of "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Closure","isActive":true},{"type":"text","text":") for a lightweight Swift reference to an underlying "},{"code":"GClosure","type":"codeVoice"},{"type":"text","text":" instance."}]}],"type":"aside","style":"note","name":"Note"}],"kind":"content"}],"references":{"doc://GLibObject/documentation/GLibObject/Closure/init(_:)-6iibg":{"url":"\/documentation\/glibobject\/closure\/init(_:)-6iibg","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"GClosure"},{"text":">)","kind":"text"}],"abstract":[{"text":"Designated initialiser from the underlying ","type":"text"},{"code":"C","type":"codeVoice"},{"type":"text","text":" data type."},{"type":"text","text":" "},{"text":"This creates an instance without performing an unbalanced retain","type":"text"},{"type":"text","text":" "},{"type":"text","text":"i.e., ownership is transferred to the "},{"code":"Closure","type":"codeVoice"},{"type":"text","text":" instance."}],"role":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/init(_:)-6iibg","type":"topic","kind":"symbol","title":"init(_:)"},"doc://GLibObject/documentation/GLibObject":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","url":"\/documentation\/glibobject","abstract":[],"role":"collection","kind":"symbol","title":"GLibObject","type":"topic"},"doc://GLibObject/documentation/GLibObject/Closure/init(raw:)-797bm":{"type":"topic","url":"\/documentation\/glibobject\/closure\/init(raw:)-797bm","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/init(raw:)-797bm","kind":"symbol","title":"init(raw:)","fragments":[{"kind":"identifier","text":"init"},{"text":"(","kind":"text"},{"text":"raw","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafeMutableRawPointer","kind":"typeIdentifier","preciseIdentifier":"s:Sv"},{"kind":"text