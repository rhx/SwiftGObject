{"sections":[],"relationshipsSections":[{"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/Object"],"title":"Inherits From","type":"inheritsFrom","kind":"relationships"},{"title":"Conforms To","type":"conformsTo","kind":"relationships","identifiers":["doc:\/\/GLibObject\/4GLib14PointerWrapperP","doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectProtocol","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleProtocol","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol"]}],"topicSections":[{"anchor":"Initializers","generated":true,"title":"Initializers","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/init(_:)-531ch","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/init(_:)-60iue","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/init(_:)-9pmip","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/init(_:)-scop","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/init(cPointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/init(gconstpointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/init(gpointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/init(opaquePointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/init(raw:)-3beng","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/init(raw:)-9g5d6","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/init(retaining:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/init(retainingCPointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/init(retainingOpaquePointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/init(retainingRaw:)-7tq4c","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/init(retainingRaw:)-8qtkh","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/init(typeModule:)"]},{"anchor":"Instance-Properties","generated":true,"title":"Instance Properties","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/metatypeReferenceForTypeModule","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/wrapperForTypeModule"]},{"generated":true,"anchor":"Type-Properties","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/metatypeForTypeModule"],"title":"Type Properties"},{"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/TypeModuleProtocol-Implementations","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/TypePluginProtocol-Implementations"],"anchor":"Default-Implementations","generated":true,"title":"Default Implementations"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"TypeModule"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"text":"Overview","anchor":"overview","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The model of "},{"code":"GTypeModule","type":"codeVoice"},{"text":" is a dynamically loaded module which","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"implements some number of types and interface implementations."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When the module is loaded, it registers its types and interfaces"},{"type":"text","text":" "},{"text":"using [method","type":"text"},{"type":"codeVoice","code":"GObject.TypeModule.register_type"},{"type":"text","text":"] and"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GObject.TypeModule.add_interface"},{"text":"].","type":"text"},{"type":"text","text":" "},{"type":"text","text":"As long as any instances of these types and interface implementations"},{"type":"text","text":" "},{"type":"text","text":"are in use, the module is kept loaded. When the types and interfaces"},{"text":" ","type":"text"},{"text":"are gone, the module may be unloaded. If the types and interfaces","type":"text"},{"text":" ","type":"text"},{"text":"become used again, the module will be reloaded. Note that the last","type":"text"},{"text":" ","type":"text"},{"text":"reference cannot be released from within the module code, since that","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"would lead to the caller’s code being unloaded before "},{"code":"g_object_unref()","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"returns to it."}]},{"inlineContent":[{"type":"text","text":"Keeping track of whether the module should be loaded or not is done by"},{"type":"text","text":" "},{"type":"text","text":"using a use count - it starts at zero, and whenever it is greater than"},{"type":"text","text":" "},{"type":"text","text":"zero, the module is loaded. The use count is maintained internally by"},{"text":" ","type":"text"},{"type":"text","text":"the type system, but also can be explicitly controlled by"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GObject.TypeModule.use"},{"text":"] and [method","type":"text"},{"code":"GObject.TypeModule.unuse","type":"codeVoice"},{"type":"text","text":"]."},{"text":" ","type":"text"},{"text":"Typically, when loading a module for the first type, ","type":"text"},{"type":"codeVoice","code":"g_type_module_use()"},{"type":"text","text":" "},{"text":"will be used to load it so that it can initialize its types. At some later","type":"text"},{"text":" ","type":"text"},{"text":"point, when the module no longer needs to be loaded except for the type","type":"text"},{"type":"text","text":" "},{"type":"text","text":"implementations it contains, "},{"code":"g_type_module_unuse()","type":"codeVoice"},{"type":"text","text":" is called."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"GTypeModule"},{"type":"text","text":" does not actually provide any implementation of module"},{"text":" ","type":"text"},{"type":"text","text":"loading and unloading. To create a particular module type you must"},{"text":" ","type":"text"},{"type":"text","text":"derive from "},{"type":"codeVoice","code":"GTypeModule"},{"type":"text","text":" and implement the load and unload functions"},{"type":"text","text":" "},{"type":"text","text":"in "},{"type":"codeVoice","code":"GTypeModuleClass"},{"text":".","type":"text"}]},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule","type":"reference","isActive":true},{"text":" type acts as a reference-counted owner of an underlying ","type":"text"},{"type":"codeVoice","code":"GTypeModule"},{"text":" instance.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It provides the methods that can operate on this data type through "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleProtocol","isActive":true},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule"},{"text":" as a strong reference or owner of a ","type":"text"},{"type":"codeVoice","code":"GTypeModule"},{"text":" instance.","type":"text"}],"type":"paragraph"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef","isActive":true},{"text":" (instead of ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule","type":"reference","isActive":true},{"type":"text","text":") for a lightweight Swift reference to an underlying "},{"code":"GTypeModule","type":"codeVoice"},{"type":"text","text":" instance."}]}],"type":"aside","name":"Note"}],"kind":"content"}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject"]]},"metadata":{"externalID":"s: