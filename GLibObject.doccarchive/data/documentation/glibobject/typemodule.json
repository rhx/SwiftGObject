{"sections":[],"metadata":{"roleHeading":"Class","title":"TypeModule","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"TypeModule"}],"modules":[{"name":"GLibObject"}],"externalID":"s:10GLibObject10TypeModuleC","symbolKind":"class","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"TypeModule","kind":"identifier"}]},"abstract":[{"type":"codeVoice","code":"GTypeModule"},{"type":"text","text":" provides a simple implementation of the "},{"code":"GTypePlugin","type":"codeVoice"},{"text":" ","type":"text"},{"text":"interface.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/typemodule"]}],"topicSections":[{"anchor":"Initializers","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/init(_:)-531ch","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/init(_:)-60iue","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/init(_:)-9pmip","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/init(_:)-scop","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/init(cPointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/init(gconstpointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/init(gpointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/init(opaquePointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/init(raw:)-3beng","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/init(raw:)-9g5d6","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/init(retaining:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/init(retainingCPointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/init(retainingOpaquePointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/init(retainingRaw:)-7tq4c","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/init(retainingRaw:)-8qtkh","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/init(typeModule:)"],"title":"Initializers","generated":true},{"title":"Instance Properties","generated":true,"anchor":"Instance-Properties","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/metatypeReferenceForTypeModule","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/wrapperForTypeModule"]},{"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/metatypeForTypeModule"],"anchor":"Type-Properties","title":"Type Properties","generated":true},{"generated":true,"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/TypeModuleProtocol-Implementations","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/TypePluginProtocol-Implementations"],"anchor":"Default-Implementations","title":"Default Implementations"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"TypeModule","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"anchor":"overview","text":"Overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The model of "},{"code":"GTypeModule","type":"codeVoice"},{"type":"text","text":" is a dynamically loaded module which"},{"text":" ","type":"text"},{"text":"implements some number of types and interface implementations.","type":"text"}]},{"inlineContent":[{"type":"text","text":"When the module is loaded, it registers its types and interfaces"},{"type":"text","text":" "},{"type":"text","text":"using [method"},{"type":"codeVoice","code":"GObject.TypeModule.register_type"},{"type":"text","text":"] and"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GObject.TypeModule.add_interface"},{"type":"text","text":"]."},{"text":" ","type":"text"},{"text":"As long as any instances of these types and interface implementations","type":"text"},{"type":"text","text":" "},{"type":"text","text":"are in use, the module is kept loaded. When the types and interfaces"},{"text":" ","type":"text"},{"type":"text","text":"are gone, the module may be unloaded. If the types and interfaces"},{"text":" ","type":"text"},{"type":"text","text":"become used again, the module will be reloaded. Note that the last"},{"type":"text","text":" "},{"text":"reference cannot be released from within the module code, since that","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"would lead to the caller’s code being unloaded before "},{"code":"g_object_unref()","type":"codeVoice"},{"type":"text","text":" "},{"text":"returns to it.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Keeping track of whether the module should be loaded or not is done by"},{"type":"text","text":" "},{"type":"text","text":"using a use count - it starts at zero, and whenever it is greater than"},{"type":"text","text":" "},{"text":"zero, the module is loaded. The use count is maintained internally by","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the type system, but also can be explicitly controlled by"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"code":"GObject.TypeModule.use","type":"codeVoice"},{"type":"text","text":"] and [method"},{"code":"GObject.TypeModule.unuse","type":"codeVoice"},{"text":"].","type":"text"},{"text":" ","type":"text"},{"text":"Typically, when loading a module for the first type, ","type":"text"},{"code":"g_type_module_use()","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"will be used to load it so that it can initialize its types. At some later"},{"text":" ","type":"text"},{"type":"text","text":"point, when the module no longer needs to be loaded except for the type"},{"type":"text","text":" "},{"text":"implementations it contains, ","type":"text"},{"code":"g_type_module_unuse()","type":"codeVoice"},{"text":" is called.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"GTypeModule"},{"type":"text","text":" does not actually provide any implementation of module"},{"text":" ","type":"text"},{"type":"text","text":"loading and unloading. To create a particular module type you must"},{"type":"text","text":" "},{"type":"text","text":"derive from "},{"code":"GTypeModule","type":"codeVoice"},{"text":" and implement the load and unload functions","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"in "},{"code":"GTypeModuleClass","type":"codeVoice"},{"text":".","type":"text"}]},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule"},{"type":"text","text":" type acts as a reference-counted owner of an underlying "},{"type":"codeVoice","code":"GTypeModule"},{"text":" instance.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"It provides the methods that can operate on this data type through "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleProtocol","isActive":true},{"text":" conformance.","type":"text"},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule"},{"type":"text","text":" as a strong reference or owner of a "},{"code":"GTypeModule","type":"codeVoice"},{"type":"text","text":" instance."}],"type":"paragraph"},{"name":"Note","type":"aside","style":"note","content":[{"inlineContent":[{"type":"text","text":"Use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef"},{"text":" (instead of ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule","isActive":true,"type":"reference"},{"type":"text","text":") for a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GTypeModule"},{"type":"text","text":" instance."}],"type":"paragraph"}]}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject"]]},"relationshipsSections":[{"title":"Inherits From","kind":"relationships","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/Object"],"type":"inheritsFrom"},{"type":"conformsTo","identifiers":["doc:\/\/GLibObject\/4GLib14PointerWrapperP","doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectProtocol","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleProtocol","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol"],"title":"Conforms To","kind":"relationships"}],"kind":"symbol","identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule","interfaceLanguage":"swift"},"references":{"doc://GLibObject/documentation/GLibObject/TypeModule/init(retaining:)":{"url":"\/documentation\/glibobject\/typemodule\/init(retaining:)","title":"init(retaining:)","type":"topic","abstract":[{"type":"text","text":"Designated initialiser from the underlying "},{"code":"C","type":"codeVoice"},{"type":"text","text":" data type."},{"type":"text","text":" "},{"text":"Will retain ","type":"text"},{"code":"GTypeModule","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"i.e., ownership is transferred to the ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule","isActive":true},{"text":" instance.","type":"text"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/init(retaining:)","fragments":[{"kind":"identifier","text":"init"},{"text":"(","kind":"text"},{"text":"retaining","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"GTypeModule"},{"text":">)","kind":"text"}]},"doc://GLibOb