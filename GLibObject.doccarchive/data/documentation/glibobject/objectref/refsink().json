ading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"In other words, if the object is floating, then this call “assumes","type":"text"},{"text":" ","type":"text"},{"text":"ownership” of the floating reference, converting it to a normal","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"reference by clearing the floating flag while leaving the reference"},{"type":"text","text":" "},{"type":"text","text":"count unchanged.  If the object is not floating, then this call"},{"type":"text","text":" "},{"text":"adds a new normal reference increasing the reference count by one.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Since GLib 2.56, the type of "},{"type":"codeVoice","code":"object"},{"type":"text","text":" will be propagated to the return type"},{"text":" ","type":"text"},{"type":"text","text":"under the same conditions as for "},{"code":"g_object_ref()","type":"codeVoice"},{"type":"text","text":"."}]}],"kind":"content"}],"kind":"symbol","references":{"doc://GLibObject/documentation/GLibObject/ObjectRef/refSink()":{"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"refSink","kind":"identifier"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject0B3RefV","text":"ObjectRef"},{"text":"!","kind":"text"}],"type":"topic","url":"\/documentation\/glibobject\/objectref\/refsink()","kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef\/refSink()","title":"refSink()","abstract":[{"text":"Increase the reference count of ","type":"text"},{"type":"codeVoice","code":"object"},{"type":"text","text":", and possibly remove the"},{"text":" ","type":"text"},{"type":"reference","identifier":"#floating-ref","isActive":true},{"type":"text","text":" reference, if "},{"code":"object","type":"codeVoice"},{"type":"text","text":" has a floating reference."}],"role":"symbol"},"doc://GLibObject/documentation/GLibObje