{"metadata":{"roleHeading":"Instance Method","title":"addToggleRef(notify:data:)","externalID":"s:10GLibObject0B8ProtocolPAAE12addToggleRef6notify4datayySvSg_SpySo8_GObjectVGSgs5Int32VtXCSg_AGtF::SYNTHESIZED::s:10GLibObject0B3RefV","extendedModule":"GLibObject","modules":[{"name":"GLibObject"}],"role":"symbol","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"addToggleRef","kind":"identifier"},{"text":"(","kind":"text"},{"text":"notify","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:gobject.h@T@GToggleNotify","text":"GToggleNotify"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"data"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer"},{"kind":"text","text":"?)"}]},"sections":[],"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef\/addToggleRef(notify:data:)","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"addToggleRef","kind":"identifier"},{"text":"(","kind":"text"},{"text":"notify","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gobject.h@T@GToggleNotify","text":"GToggleNotify","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"data"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer"},{"kind":"text","text":"? = nil)"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This functionality is intended for binding "},{"type":"codeVoice","code":"object"},{"type":"text","text":" to a proxy"},{"type":"text","text":" "},{"type":"text","text":"object managed by another memory manager. This is done with two"},{"type":"text","text":" "},{"text":"paired references: the strong reference added by","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"type":"text","text":" and a reverse reference to the proxy"},{"type":"text","text":" "},{"text":"object which is either a strong reference or weak reference.","type":"text"}]},{"inlineContent":[{"type":"text","text":"The setup is that when there are no other references to "},{"type":"codeVoice","code":"object"},{"type":"text","text":","},{"type":"text","text":" "},{"text":"only a weak reference is held in the reverse direction from ","type":"text"},{"type":"codeVoice","code":"object"},{"type":"text","text":" "},{"type":"text","text":"to the proxy object, but when there are other references held to"},{"type":"text","text":" "},{"type":"codeVoice","code":"object"},{"text":", a strong reference is held. The ","type":"text"},{"type":"codeVoice","code":"notify"},{"text":" callback is called","type":"text"},{"type":"text","text":" "},{"text":"when the reference from ","type":"text"},{"type":"codeVoice","code":"object"},{"text":" to the proxy object should be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"“toggled” from strong to weak ("},{"type":"codeVoice","code":"is_last_ref"},{"type":"text","text":" true) or weak to strong"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"type":"codeVoice","code":"is_last_ref"},{"text":" false).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Since a (normal) reference must be held to the object before"},{"text":" ","type":"text"},{"type":"text","text":"calling "},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"text":", the initial state of the reverse","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"link is always strong."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Multiple toggle references may be added to the same gobject,"},{"type":"text","text":" "},{"type":"text","text":"however if there are multiple toggle references to an object, none"},{"text":" ","type":"text"},{"text":"of them will ever be notified until all but one are removed.  For","type":"text"},{"type":"text","text":" "},{"type":"text","text":"this reason, you should only ever use a toggle reference if there"},{"type":"text","text":" "},{"type":"text","text":"is important state in the proxy object."}]},{"inlineContent":[{"type":"text","text":"Note that if you unref the object on another thread, then "},{"type":"codeVoice","code":"notify"},{"type":"text","text":" might"},{"text":" ","type":"text"},{"type":"text","text":"still be invoked after "},{"code":"g_object_remove_toggle_ref()","type":"codeVoice"},{"type":"text","text":", and the object argument"},{"type":"text","text":" "},{"type":"text","text":"might be a dangling pointer. If the object is destroyed on other threads,"},{"type":"text","text":" "},{"text":"you must take care of that yourself.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A "},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"text":" must be released with ","type":"text"},{"type":"codeVoice","code":"g_object_remove_toggle_ref()"},{"text":".","type":"text"}],"type":"paragraph"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/glibobject\/objectref\/addtoggleref(notify:data:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef","doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef\/ObjectProtocol-Implementations"]]},"abstract":[{"text":"Increases the reference count of the object by one and sets a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"callback to be called when all other references to the object are"},{"text":" ","type":"text"},{"type":"text","text":"dropped, or when this is already the last reference to the object"},{"type":"text","text":" "},{"type":"text","text":"and another reference is established."}],"kind":"symbol","references":{"doc://GLibObject/documentation/GLibObject/ObjectRef":{"type":"topic","kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef","abstract":[{"text":"The base object type.","type":"text"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"ObjectRef","kind":"identifier"}],"url":"\/documentation\/glibobject\/objectref","title":"ObjectRef","navigatorTitle":[{"text":"ObjectRef","kind":"identifier"}],"role":"symbol"},"doc://GLibObject/documentation/GLibObject/ObjectRef/addToggleRef(notify:data:)":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"addToggleRef"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"notify"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"GToggleNotify","preciseIdentifier":"c:gobject.h@T@GToggleNotify"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"data"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"text":"?)","kind":"text"}],"url":"\/documentation\/glibobject\/objectref\/addtoggleref(notify:data:)","title":"addToggleRef(notify:data:)","kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef\/addToggleRef(notify:data:)","role":"symbol","abstract":[{"type":"text","text":"Increases the reference count of the object by one and sets a"},{"type":"text","text":" "},{"type":"text","text":"callback to be called when all other references to the object are"},{"text":" ","type":"text"},{"type":"text","text":"dropped, or when this is already the last reference to the object"},{"text":" ","type":"text"},{"type":"text","text":"and another reference is established."}],"type":"topic"},"doc://GLibObject/documentation/GLibObject":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","url":"\/documentation\/glibobject","abstract":[],"role":"collection","kind":"symbol","title":"GLibObject","type":"topic"},"doc://GLibObject/documentation/GLibObject/ObjectRef/ObjectProtocol-Implementations":{"type":"topic","kind":"article","abstract":[],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef\/ObjectProtocol-Implementations","url":"\/documentation\/glibobject\/objectref\/objectprotocol-implementations","title":"ObjectProtocol Implementations","role":"collectionGroup"}}}