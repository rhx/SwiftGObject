{"kind":"symbol","abstract":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"object"},{"text":" is floating, sink it.  Otherwise, do nothing.","type":"text"}],"variants":[{"paths":["\/documentation\/glibobject\/objectref\/takeref()"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef","doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef\/ObjectProtocol-Implementations"]]},"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef\/takeRef()","interfaceLanguage":"swift"},"metadata":{"roleHeading":"Instance Method","symbolKind":"method","extendedModule":"GLibObject","role":"symbol","title":"takeRef()","modules":[{"name":"GLibObject"}],"externalID":"s:10GLibObject0B8ProtocolPAAE7takeRefAA0bE0VSgyF::SYNTHESIZED::s:10GLibObject0B3RefV","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"takeRef","kind":"identifier"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject0B3RefV","text":"ObjectRef"},{"text":"!","kind":"text"}]},"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"takeRef","kind":"identifier"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject0B3RefV","text":"ObjectRef","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef"},{"kind":"text","text":"!"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"In other words, this function will convert a floating reference (if","type":"text"},{"type":"text","text":" "},{"type":"text","text":"present) into a full reference."}]},{"inlineContent":[{"text":"Typically you want to use ","type":"text"},{"type":"codeVoice","code":"g_object_ref_sink()"},{"type":"text","text":" in order to"},{"text":" ","type":"text"},{"text":"automatically do the correct thing with respect to floating or","type":"text"},{"type":"text","text":" "},{"type":"text","text":"non-floating references, but there is one specific scenario where"},{"text":" ","type":"text"},{"type":"text","text":"this function is helpful."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The situation where this function is helpful is when creating an API"},{"type":"text","text":" "},{"type":"text","text":"that allows the user to provide a callback function that returns a"},{"text":" ","type":"text"},{"type":"text","text":"GObject. We certainly want to allow the user the flexibility to"},{"text":" ","type":"text"},{"type":"text","text":"return a non-floating reference from this callback (for the case"},{"text":" ","type":"text"},{"type":"text","text":"where the object that is being returned already exists)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"At the same time, the API style of some popular GObject-based"},{"type":"text","text":" "},{"type":"text","text":"libraries (such as Gtk) make it likely that for newly-created GObject"},{"type":"text","text":" "},{"text":"instances, the user can be saved some typing if they are allowed to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"return a floating reference."}]},{"type":"paragraph","inlineContent":[{"text":"Using this function on the return value of the user’s callback allows","type":"text"},{"type":"text","text":" "},{"text":"the user to do whichever is more convenient for them. The caller will","type":"text"},{"text":" ","type":"text"},{"text":"always receives exactly one full reference to the value: either the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"one that was returned in the first place, or a floating reference"},{"type":"text","text":" "},{"text":"that has been converted to a full reference.","type":"text"}]},{"inlineContent":[{"text":"This function has an odd interaction when combined with","type":"text"},{"text":" ","type":"text"},{"code":"g_object_ref_sink()","type":"codeVoice"},{"type":"text","text":" running at the same time in another thread on"},{"text":" ","type":"text"},{"text":"the same ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","type":"reference"},{"type":"text","text":" instance. If "},{"code":"g_object_ref_sink()","type":"codeVoice"},{"text":" runs first then","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the result will be that the floating reference is converted to a hard"},{"text":" ","type":"text"},{"type":"text","text":"reference. If "},{"code":"g_object_take_ref()","type":"codeVoice"},{"text":" runs first then the result will be","type":"text"},{"type":"text","text":" "},{"text":"that the floating reference is converted to a hard reference and an","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"additional reference on top of that one is added. It is best to avoid"},{"text":" ","type":"text"},{"type":"text","text":"this situation."}],"type":"paragraph"}]}],"references":{"doc://GLibObject/documentation/GLibObject/ObjectRef/takeRef()":{"kind":"symbol","abstract":[{"text":"If ","type":"text"},{"code":"object","type":"codeVoice"},{"type":"text","text":" is floating, sink it.  Otherwise, do nothing."}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"takeRef","kind":"identifier"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:10GLibObject0B3RefV","text":"ObjectRef","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"url":"\/documentation\/glibobject\/objectref\/takeref()","role":"symbol","title":"takeRef()","type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef\/takeRef()"},"doc://GLibObject/documentation/GLibObject/ObjectRef/ObjectProtocol-Implementations":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef\/ObjectProtocol-Implementations","abstract":[],"kind":"article","title":"ObjectProtocol Implementations","role":"collectionGroup","url":"\/documentation\/glibobject\/objectref\/objectprotocol-implementations","type":"topic"},"doc://GLibObject/documentation/GLibObject/ObjectRef":{"type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ObjectRef","kind":"identifier"}],"url":"\/documentation\/glibobject\/objectref","kind":"symbol","navigatorTitle":[{"text":"ObjectRef","kind":"identifier"}],"abstract":[{"type":"text","text":"The base object type."}],"role":"symbol","title":"ObjectRef"},"doc://GLibObject/documentation/GLibObject":{"role":"collection","type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","abstract":[],"title":"GLibObject","kind":"symbol","url":"\/documentation\/glibobject"},"doc://GLibObject/documentation/GLibObject/Object":{"title":"Object","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Object","kind":"identifier"}],"navigatorTitle":[{"text":"Object","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/glibobject\/object","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","type":"topic","abstract":[{"type":"text","text":"The base object type."}],"role":"symbol"}}}