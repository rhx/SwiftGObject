nd":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"signalHasHandlerPending","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"signalID"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"detail","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@GQuark","text":"GQuark","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"mayBeBlocked"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"},{"kind":"text","text":") -> "},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"detail","type":"codeVoice"},{"type":"text","text":" is 0 then it will only match handlers that were connected"},{"type":"text","text":" "},{"type":"text","text":"without detail.  If "},{"code":"detail","type":"codeVoice"},{"type":"text","text":" is non-zero then it will match handlers"},{"text":" ","type":"text"},{"type":"text","text":"connected both without detail and with the given detail.  This is"},{"text":" ","type":"text"},{"type":"text","text":"consistent with how a signal emitted with "},{"type":"codeVoice","code":"detail"},{"type":"text","text":" would be delivered"},{"type":"text","text":" "},{"type":"text","text":"to those handlers."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Since 2.46 this also checks for a non-default class closure being"},{"type":"text","text":" "},{"type":"text","text":"installed, as this is basically always what you want."}]},{"type":"paragraph","inlineContent":[{"text":"One example of when you might use this is when the arguments to the","typ