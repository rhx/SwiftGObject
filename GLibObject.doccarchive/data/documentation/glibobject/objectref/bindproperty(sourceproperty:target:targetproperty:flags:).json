mentation\/GLibObject\/ObjectProtocol","text":"ObjectProtocol"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Whenever the ","type":"text"},{"code":"sourceProperty","type":"codeVoice"},{"type":"text","text":" is changed the "},{"type":"codeVoice","code":"targetProperty"},{"text":" is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"updated using the same value. For instance:"}]},{"type":"paragraph","inlineContent":[{"text":"(C Language Example):","type":"text"}]},{"syntax":"C","type":"codeListing","code":["  g_object_bind_property (action, \"active\", widget, \"sensitive\", 0);"]},{"inlineContent":[{"type":"text","text":"Will result in the “sensitive” property of the widget "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","type":"reference","isActive":true},{"type":"text","text":" instance to be"},{"text":" ","type":"text"},{"text":"updated with the same value of the “active” property of the action ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object"},{"text":" ","type":"text"},{"type":"text","text":"instance."}],"type":"paragraph"},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"flags"},{"text":" contains ","type":"text"},{"code":"bidirectional","type":"codeVoice"},{"type":"text","text":" then the binding will be mutual:"},{"type":"text","text":" "},{"text":"if ","type":"text"},{"code":"targetProperty","type":"codeVoice"},{"text":" on ","type":"text"},{"type":"codeVoice","code":"target"},{"type":"text","text":" changes then the "},{"type":"codeVoice","code":"sourceProperty"},{"text":" on ","type":"text"},{"type":"codeVoice","code":"source"},{"type":"text","text":" "},{"text":"will be updated as well.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inline