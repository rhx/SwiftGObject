{"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/takeRef()","interfaceLanguage":"swift"},"abstract":[{"text":"If ","type":"text"},{"code":"object","type":"codeVoice"},{"type":"text","text":" is floating, sink it.  Otherwise, do nothing."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"takeRef","kind":"identifier"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","text":"ObjectRef","preciseIdentifier":"s:10GLibObject0B3RefV","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef"},{"text":"!","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"In other words, this function will convert a floating reference (if"},{"text":" ","type":"text"},{"type":"text","text":"present) into a full reference."}]},{"inlineContent":[{"text":"Typically you want to use ","type":"text"},{"code":"g_object_ref_sink()","type":"codeVoice"},{"type":"text","text":" in order to"},{"type":"text","text":" "},{"type":"text","text":"automatically do the correct thing with respect to floating or"},{"text":" ","type":"text"},{"text":"non-floating references, but there is one specific scenario where","type":"text"},{"text":" ","type":"text"},{"text":"this function is helpful.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The situation where this function is helpful is when creating an API","type":"text"},{"text":" ","type":"text"},{"text":"that allows the user to provide a callback function that returns a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"GObject. We certainly want to allow the user the flexibility to"},{"text":" ","type":"text"},{"text":"return a non-floating reference from this callback (for the case","type":"text"},{"text":" ","type":"text"},{"text":"where the object that is being returned already exists).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"At the same time, the API style of some popular GObject-based","type":"text"},{"text":" ","type":"text"},{"text":"libraries (such as Gtk) make it likely that for newly-created GObject","type":"text"},{"type":"text","text":" "},{"text":"instances, the user can be saved some typing if they are allowed to","type":"text"},{"type":"text","text":" "},{"text":"return a floating reference.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Using this function on the return value of the user’s callback allows"},{"text":" ","type":"text"},{"type":"text","text":"the user to do whichever is more convenient for them. The caller will"},{"type":"text","text":" "},{"text":"always receives exactly one full reference to the value: either the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"one that was returned in the first place, or a floating reference"},{"type":"text","text":" "},{"text":"that has been converted to a full reference.","type":"text"}]},{"inlineContent":[{"type":"text","text":"This function has an odd interaction when combined with"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_object_ref_sink()"},{"type":"text","text":" running at the same time in another thread on"},{"type":"text","text":" "},{"type":"text","text":"the same "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","type":"reference","isActive":true},{"text":" instance. If ","type":"text"},{"type":"codeVoice","code":"g_object_ref_sink()"},{"type":"text","text":" runs first then"},{"text":" ","type":"text"},{"text":"the result will be that the floating reference is converted to a hard","type":"text"},{"type":"text","text":" "},{"type":"text","text":"reference. If "},{"code":"g_object_take_ref()","type":"codeVoice"},{"text":" runs first then the result will be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"that the floating reference is converted to a hard reference and an"},{"type":"text","text":" "},{"text":"additional reference on top of that one is added. It is best to avoid","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this situation."}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/ObjectProtocol-Implementations"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/typemoduleref\/takeref()"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","metadata":{"title":"takeRef()","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"takeRef","kind":"identifier"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","text":"ObjectRef","preciseIdentifier":"s:10GLibObject0B3RefV"},{"text":"!","kind":"text"}],"roleHeading":"Instance Method","role":"symbol","extendedModule":"GLibObject","symbolKind":"method","externalID":"s:10GLibObject0B8ProtocolPAAE7takeRefAA0bE0VSgyF::SYNTHESIZED::s:10GLibObject13TypeModuleRefV","modules":[{"name":"GLibObject"}]},"sections":[],"references":{"doc://GLibObject/documentation/GLibObject/ObjectRef":{"type":"topic","kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef","abstract":[{"text":"The base object type.","type":"text"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"ObjectRef","kind":"identifier"}],"url":"\/documentation\/glibobject\/objectref","title":"ObjectRef","navigatorTitle":[{"text":"ObjectRef","kind":"identifier"}],"role":"symbol"},"doc://GLibObject/documentation/GLibObject":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","url":"\/documentation\/glibobject","abstract":[],"role":"collection","kind":"symbol","title":"GLibObject","type":"topic"},"doc://GLibObject/documentation/GLibObject/TypeModuleRef/takeRef()":{"url":"\/documentation\/glibobject\/typemoduleref\/takeref()","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/takeRef()","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"takeRef","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"ObjectRef","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject0B3RefV"},{"text":"!","kind":"text"}],"type":"topic","title":"takeRef()","abstract":[{"type":"text","text":"If "},{"code":"object","type":"codeVoice"},{"text":" is floating, sink it.  Otherwise, do nothing.","type":"text"}],"role":"symbol"},"doc://GLibObject/documentation/GLibObject/Object":{"url":"\/documentation\/glibobject\/object","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","kind":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"Object","kind":"identifier"}],"type":"topic","title":"Object","navigatorTitle":[{"text":"Object","kind":"identifier"}],"abstract":[{"type":"text","text":"The base object type."}],"role":"symbol"},"doc://GLibObject/documentation/GLibObject/TypeModuleRef/ObjectProtocol-Implementations":{"role":"collectionGroup","type":"topic","kind":"article","title":"ObjectProtocol Implementations","abstract":[],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/ObjectProtocol-Implementations","url":"\/documentation\/glibobject\/typemoduleref\/objectprotocol-implementations"},"doc://GLibObject/documentation/GLibObject/TypeModuleRef":{"title":"TypeModuleRef","type":"topic","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"TypeModuleRef","kind":"identifier"}],"abstract":[{"type":"codeVoice","code":"GTypeModule"},{"text":" provides a simple implementation of the ","type":"text"},{"code":"GTypePlugin","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"interface."}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef","url":"\/documentation\/glibobject\/typemoduleref","navigatorTitle":[{"text":"TypeModuleRef","kind":"identifier"}],"kind":"symbol"}}}