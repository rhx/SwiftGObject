{"kind":"symbol","sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/typemoduleref\/addtoggleref(notify:data:)"]}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/ObjectProtocol-Implementations"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"addToggleRef"},{"kind":"text","text":"("},{"kind":"externalParam","text":"notify"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"GToggleNotify","preciseIdentifier":"c:gobject.h@T@GToggleNotify"},{"text":"?, ","kind":"text"},{"text":"data","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"text":"? = nil)","kind":"text"}],"platforms":["macOS"]}]},{"content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This functionality is intended for binding "},{"type":"codeVoice","code":"object"},{"text":" to a proxy","type":"text"},{"type":"text","text":" "},{"text":"object managed by another memory manager. This is done with two","type":"text"},{"type":"text","text":" "},{"type":"text","text":"paired references: the strong reference added by"},{"text":" ","type":"text"},{"code":"g_object_add_toggle_ref()","type":"codeVoice"},{"type":"text","text":" and a reverse reference to the proxy"},{"text":" ","type":"text"},{"type":"text","text":"object which is either a strong reference or weak reference."}]},{"inlineContent":[{"text":"The setup is that when there are no other references to ","type":"text"},{"code":"object","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"only a weak reference is held in the reverse direction from "},{"type":"codeVoice","code":"object"},{"type":"text","text":" "},{"type":"text","text":"to the proxy object, but when there are other references held to"},{"type":"text","text":" "},{"type":"codeVoice","code":"object"},{"type":"text","text":", a strong reference is held. The "},{"type":"codeVoice","code":"notify"},{"type":"text","text":" callback is called"},{"type":"text","text":" "},{"text":"when the reference from ","type":"text"},{"type":"codeVoice","code":"object"},{"text":" to the proxy object should be","type":"text"},{"type":"text","text":" "},{"text":"“toggled” from strong to weak (","type":"text"},{"type":"codeVoice","code":"is_last_ref"},{"text":" true) or weak to strong","type":"text"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"type":"codeVoice","code":"is_last_ref"},{"type":"text","text":" false)."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Since a (normal) reference must be held to the object before"},{"type":"text","text":" "},{"type":"text","text":"calling "},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"type":"text","text":", the initial state of the reverse"},{"type":"text","text":" "},{"type":"text","text":"link is always strong."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Multiple toggle references may be added to the same gobject,"},{"text":" ","type":"text"},{"text":"however if there are multiple toggle references to an object, none","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of them will ever be notified until all but one are removed.  For"},{"type":"text","text":" "},{"text":"this reason, you should only ever use a toggle reference if there","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is important state in the proxy object."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Note that if you unref the object on another thread, then "},{"type":"codeVoice","code":"notify"},{"type":"text","text":" might"},{"type":"text","text":" "},{"text":"still be invoked after ","type":"text"},{"type":"codeVoice","code":"g_object_remove_toggle_ref()"},{"type":"text","text":", and the object argument"},{"type":"text","text":" "},{"text":"might be a dangling pointer. If the object is destroyed on other threads,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"you must take care of that yourself."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"type":"text","text":" must be released with "},{"code":"g_object_remove_toggle_ref()","type":"codeVoice"},{"type":"text","text":"."}]}],"kind":"content"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"Increases the reference count of the object by one and sets a"},{"type":"text","text":" "},{"type":"text","text":"callback to be called when all other references to the object are"},{"text":" ","type":"text"},{"type":"text","text":"dropped, or when this is already the last reference to the object"},{"type":"text","text":" "},{"text":"and another reference is established.","type":"text"}],"metadata":{"role":"symbol","externalID":"s:10GLibObject0B8ProtocolPAAE12addToggleRef6notify4datayySvSg_SpySo8_GObjectVGSgs5Int32VtXCSg_AGtF::SYNTHESIZED::s:10GLibObject13TypeModuleRefV","title":"addToggleRef(notify:data:)","extendedModule":"GLibObject","symbolKind":"method","roleHeading":"Instance Method","modules":[{"name":"GLibObject"}],"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"addToggleRef"},{"kind":"text","text":"("},{"text":"notify","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:gobject.h@T@GToggleNotify","text":"GToggleNotify"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"data"},{"text":": ","kind":"text"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"text":"?)","kind":"text"}]},"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/addToggleRef(notify:data:)","interfaceLanguage":"swift"},"references":{"doc://GLibObject/documentation/GLibObject/TypeModuleRef":{"title":"TypeModuleRef","type":"topic","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"TypeModuleRef","kind":"identifier"}],"abstract":[{"type":"codeVoice","code":"GTypeModule"},{"text":" provides a simple implementation of the ","type":"text"},{"code":"GTypePlugin","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"interface."}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef","url":"\/documentation\/glibobject\/typemoduleref","navigatorTitle":[{"text":"TypeModuleRef","kind":"identifier"}],"kind":"symbol"},"doc://GLibObject/documentation/GLibObject/TypeModuleRef/ObjectProtocol-Implementations":{"role":"collectionGroup","type":"topic","kind":"article","title":"ObjectProtocol Implementations","abstract":[],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/ObjectProtocol-Implementations","url":"\/documentation\/glibobject\/typemoduleref\/objectprotocol-implementations"},"doc://GLibObject/documentation/GLibObject/TypeModuleRef/addToggleRef(notify:data:)":{"url":"\/documentation\/glibobject\/typemoduleref\/addtoggleref(notify:data:)","kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/addToggleRef(notify:data:)","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"addToggleRef"},{"text":"(","kind":"text"},{"text":"notify","kind":"externalParam"},{"kind":"text","text":": "},{"text":"GToggleNotify","preciseIdentifier":"c:gobject.h@T@GToggleNotify","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"data"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer"},{"text":"?)","kind":"text"}],"title":"addToggleRef(notify:data:)","abstract":[{"type":"text","text":"Increases the reference count of the object by one and sets a"},{"type":"text","text":" "},{"text":"callback to be called when all other references to the object are","type":"text"},{"type":"text","text":" "},{"text":"dropped, or when this is already the last reference to the object","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and another reference is established."}],"type":"topic"},"doc://GLibObject/documentation/GLibObject":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","url":"\/documentation\/glibobject","abstract":[],"role":"collection","kind":"symbol","title":"GLibObject","type":"topic"}}}