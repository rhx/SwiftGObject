{"abstract":[{"type":"text","text":"Increases the reference count of the object by one and sets a"},{"text":" ","type":"text"},{"type":"text","text":"callback to be called when all other references to the object are"},{"text":" ","type":"text"},{"type":"text","text":"dropped, or when this is already the last reference to the object"},{"text":" ","type":"text"},{"text":"and another reference is established.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/ObjectProtocol-Implementations"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"addToggleRef","kind":"identifier"},{"kind":"text","text":"("},{"text":"notify","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:gobject.h@T@GToggleNotify","text":"GToggleNotify"},{"kind":"text","text":"?, "},{"text":"data","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier","text":"gpointer"},{"text":"? = nil)","kind":"text"}]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"inlineContent":[{"text":"This functionality is intended for binding ","type":"text"},{"type":"codeVoice","code":"object"},{"text":" to a proxy","type":"text"},{"type":"text","text":" "},{"type":"text","text":"object managed by another memory manager. This is done with two"},{"text":" ","type":"text"},{"type":"text","text":"paired references: the strong reference added by"},{"type":"text","text":" "},{"code":"g_object_add_toggle_ref()","type":"codeVoice"},{"type":"text","text":" and a reverse reference to the proxy"},{"type":"text","text":" "},{"type":"text","text":"object which is either a strong reference or weak reference."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The setup is that when there are no other references to ","type":"text"},{"type":"codeVoice","code":"object"},{"type":"text","text":","},{"text":" ","type":"text"},{"text":"only a weak reference is held in the reverse direction from ","type":"text"},{"type":"codeVoice","code":"object"},{"type":"text","text":" "},{"text":"to the proxy object, but when there are other references held to","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"object"},{"type":"text","text":", a strong reference is held. The "},{"code":"notify","type":"codeVoice"},{"type":"text","text":" callback is called"},{"text":" ","type":"text"},{"text":"when the reference from ","type":"text"},{"code":"object","type":"codeVoice"},{"type":"text","text":" to the proxy object should be"},{"type":"text","text":" "},{"text":"“toggled” from strong to weak (","type":"text"},{"code":"is_last_ref","type":"codeVoice"},{"type":"text","text":" true) or weak to strong"},{"type":"text","text":" "},{"type":"text","text":"("},{"code":"is_last_ref","type":"codeVoice"},{"type":"text","text":" false)."}]},{"type":"paragraph","inlineContent":[{"text":"Since a (normal) reference must be held to the object before","type":"text"},{"text":" ","type":"text"},{"text":"calling ","type":"text"},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"type":"text","text":", the initial state of the reverse"},{"type":"text","text":" "},{"text":"link is always strong.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Multiple toggle references may be added to the same gobject,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"however if there are multiple toggle references to an object, none"},{"type":"text","text":" "},{"type":"text","text":"of them will ever be notified until all but one are removed.  For"},{"text":" ","type":"text"},{"text":"this reason, you should only ever use a toggle reference if there","type":"text"},{"text":" ","type":"text"},{"text":"is important state in the proxy object.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that if you unref the object on another thread, then "},{"code":"notify","type":"codeVoice"},{"type":"text","text":" might"},{"type":"text","text":" "},{"type":"text","text":"still be invoked after "},{"type":"codeVoice","code":"g_object_remove_toggle_ref()"},{"text":", and the object argument","type":"text"},{"text":" ","type":"text"},{"text":"might be a dangling pointer. If the object is destroyed on other threads,","type":"text"},{"type":"text","text":" "},{"text":"you must take care of that yourself.","type":"text"}]},{"inlineContent":[{"type":"text","text":"A "},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"text":" must be released with ","type":"text"},{"type":"codeVoice","code":"g_object_remove_toggle_ref()"},{"text":".","type":"text"}],"type":"paragraph"}]}],"metadata":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"addToggleRef"},{"text":"(","kind":"text"},{"text":"notify","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"GToggleNotify","kind":"typeIdentifier","preciseIdentifier":"c:gobject.h@T@GToggleNotify"},{"text":"?, ","kind":"text"},{"text":"data","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"text":"?)","kind":"text"}],"externalID":"s:10GLibObject0B8ProtocolPAAE12addToggleRef6notify4datayySvSg_SpySo8_GObjectVGSgs5Int32VtXCSg_AGtF::SYNTHESIZED::s:10GLibObject13TypeModuleRefV","roleHeading":"Instance Method","extendedModule":"GLibObject","role":"symbol","modules":[{"name":"GLibObject"}],"symbolKind":"method","title":"addToggleRef(notify:data:)"},"kind":"symbol","sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/typemoduleref\/addtoggleref(notify:data:)"]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/addToggleRef(notify:data:)","interfaceLanguage":"swift"},"references":{"doc://GLibObject/documentation/GLibObject/TypeModuleRef/ObjectProtocol-Implementations":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/ObjectProtocol-Implementations","type":"topic","url":"\/documentation\/glibobject\/typemoduleref\/objectprotocol-implementations","role":"collectionGroup","abstract":[],"title":"ObjectProtocol Implementations","kind":"article"},"doc://GLibObject/documentation/GLibObject":{"role":"collection","type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","abstract":[],"title":"GLibObject","kind":"symbol","url":"\/documentation\/glibobject"},"doc://GLibObject/documentation/GLibObject/TypeModuleRef/addToggleRef(notify:data:)":{"abstract":[{"type":"text","text":"Increases the reference count of the object by one and sets a"},{"type":"text","text":" "},{"text":"callback to be called when all other references to the object are","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"dropped, or when this is already the last reference to the object"},{"text":" ","type":"text"},{"type":"text","text":"and another reference is established."}],"kind":"symbol","role":"symbol","url":"\/documentation\/glibobject\/typemoduleref\/addtoggleref(notify:data:)","title":"addToggleRef(notify:data:)","type":"topic","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"addToggleRef","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"notify"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"GToggleNotify","preciseIdentifier":"c:gobject.h@T@GToggleNotify"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"data"},{"text":": ","kind":"text"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"kind":"text","text":"?)"}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/addToggleRef(notify:data:)"},"doc://GLibObject/documentation/GLibObject/TypeModuleRef":{"type":"topic","abstract":[{"code":"GTypeModule","type":"codeVoice"},{"type":"text","text":" provides a simple implementation of the "},{"type":"codeVoice","code":"GTypePlugin"},{"text":" ","type":"text"},{"type":"text","text":"interface."}],"url":"\/documentation\/glibobject\/typemoduleref","kind":"symbol","title":"TypeModuleRef","navigatorTitle":[{"kind":"identifier","text":"TypeModuleRef"}],"role":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"TypeModuleRef","kind":"identifier"}]}}}