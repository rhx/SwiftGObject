lly changed. When it is emitted is determined by the"},{"text":" ","type":"text"},{"text":"derived GObject class. If the implementor did not create the property with","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"explicitNotify"},{"type":"text","text":", then any call to "},{"code":"g_object_set_property()","type":"codeVoice"},{"type":"text","text":" results"},{"text":" ","type":"text"},{"type":"text","text":"in "},{"type":"codeVoice","code":"notify"},{"type":"text","text":" being emitted, even if the new value is the same as the old."},{"type":"text","text":" "},{"text":"If they did pass ","type":"text"},{"code":"explicitNotify","type":"codeVoice"},{"text":", then this signal is emitted only","type":"text"},{"text":" ","type":"text"},{"text":"when they explicitly call ","type":"text"},{"type":"codeVoice","code":"g_object_notify()"},{"type":"text","text":" or "},{"type":"codeVoice","code":"g_object_notify_by_pspec()"},{"type":"text","text":","},{"type":"text","text":" "},{"text":"and common practice is to do that only when the value has actually changed.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This signal is typically used to obtain change notification for a"},{"type":"text","text":" "},{"text":"single property, by specifying the property name as a detail in the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_signal_connect()"},{"text":" call, like this:","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"],"syntax":"C","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is important to note that you must use"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"#class@GObject.ParamSpec#parameter-names"},{"type":"text","text":" as"},{"text":" ","type":"text"},{"type":"text","text":"detail strings for the notify signal."}]},{"content":[{"inlineContent":[{"text":"This represents the underlying ","type":"text"},{"type":"codeVoice","code":"notify"},{"type":"text","text":" signal"}],"type":"paragraph"}],"type":"aside","name":"Note","style":"note"}],"kind":"content"}],"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/onNotify(flags:handler:)","interfaceLanguage":"swift"},"references":{"doc://GLibObject/documentation/GLibObject/TypeModuleRef/onNotify(flags:handler:)":{"role":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/onNotify(flags:handler:)","abstract":[{"text":"The notify signal is emitted on an object when one of its properties has","type":"text"},{"type":"text","text":" "},{"text":"its value set through ","type":"text"},{"code":"g_object_set_property()","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"g_object_set()"},{"text":", et al.","type":"text"}],"type":"topic","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"onNotify","kind":"identifier"},{"text":"(","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"text":", ","kind":"text"},{"text":"handler","kind":"externalParam"},{"text":": (","kind":"text"},{"preciseIdentifier":"s:10GLibObject0B3RefV","text":"ObjectRef","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ParamSpecRefV","text":"ParamSpecRef"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:s4Voida","text":"Void","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"title":"onNotify(flags:handler:)","url":"\/documentation\/glibobject\/typemoduleref\/onn