{"kind":"symbol","metadata":{"extendedModule":"GLibObject","role":"symbol","modules":[{"name":"GLibObject"}],"roleHeading":"Instance Method","externalID":"s:10GLibObject17TypeClassProtocolPAAE10addPrivate11privateSizeySi_tF::SYNTHESIZED::s:10GLibObject9TypeClassC","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"addPrivate"},{"text":"(","kind":"text"},{"text":"privateSize","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":")","kind":"text"}],"title":"addPrivate(privateSize:)","symbolKind":"method","platforms":[]},"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeClass","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeClass\/TypeClassProtocol-Implementations"]]},"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeClass\/addPrivate(privateSize:)","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Registers a private structure for an instantiatable type."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"addPrivate","kind":"identifier"},{"kind":"text","text":"("},{"text":"privateSize","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":")"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"inlineContent":[{"type":"text","text":"When an object is allocated, the private structures for"},{"text":" ","type":"text"},{"type":"text","text":"the type and all of its parent types are allocated"},{"type":"text","text":" "},{"text":"sequentially in the same memory block as the public","type":"text"},{"type":"text","text":" "},{"type":"text","text":"structures, and are zero-filled."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Note that the accumulated size of the private structures of"},{"text":" ","type":"text"},{"type":"text","text":"a type and all its parent types cannot exceed 64 KiB."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This function should be called in the type’s "},{"type":"codeVoice","code":"class_init()"},{"text":" function.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The private structure can be retrieved using the"},{"type":"text","text":" "},{"type":"codeVoice","code":"G_TYPE_INSTANCE_GET_PRIVATE()"},{"type":"text","text":" macro."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following example shows attaching a private structure"},{"text":" ","type":"text"},{"text":"MyObjectPrivate to an object MyObject defined in the standard","type":"text"},{"type":"text","text":" "},{"text":"GObject fashion in the type’s ","type":"text"},{"type":"codeVoice","code":"class_init()"},{"text":" function.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Note the use of a structure member “priv” to avoid the overhead"},{"type":"text","text":" "},{"text":"of repeatedly calling ","type":"text"},{"type":"codeVoice","code":"MY_OBJECT_GET_PRIVATE()"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"code":["typedef struct _MyObject        MyObject;","typedef struct _MyObjectPrivate MyObjectPrivate;","","struct _MyObject {"," GObject parent;",""," MyObjectPrivate *priv;","};","","struct _MyObjectPrivate {","  int some_field;","};","","static void","my_object_class_init (MyObjectClass *klass)","{","  g_type_class_add_private (klass, sizeof (MyObjectPrivate));","}","","static void","my_object_init (MyObject *my_object)","{","  my_object->priv = G_TYPE_INSTANCE_GET_PRIVATE (my_object,","                                                 MY_TYPE_OBJECT,","                                                 MyObjectPrivate);","  \/\/ my_object->priv->some_field will be automatically initialised to 0","}","","static int","my_object_get_some_field (MyObject *my_object)","{","  MyObjectPrivate *priv;","","  g_return_val_if_fail (MY_IS_OBJECT (my_object), 0);","","  priv = my_object->priv;","","  return priv->some_field;","}"],"type":"codeListing","syntax":"C"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"add_private is deprecated:","type":"text"}]},{"type":"text","text":" "},{"text":"Use the G_ADD_PRIVATE() macro with the ","type":"text"},{"type":"codeVoice","code":"G_DEFINE_*"},{"type":"text","text":" "},{"text":"family of macros to add instance private data to a type","type":"text"}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/typeclass\/addprivate(privatesize:)"]}],"references":{"doc://GLibObject/documentation/GLibObject":{"role":"collection","type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","abstract":[],"title":"GLibObject","kind":"symbol","url":"\/documentation\/glibobject"},"doc://GLibObject/documentation/GLibObject/TypeClass":{"abstract":[{"type":"text","text":"An opaque structure used as the base of all classes."}],"url":"\/documentation\/glibobject\/typeclass","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"TypeClass","kind":"identifier"}],"navigatorTitle":[{"text":"TypeClass","kind":"identifier"}],"kind":"symbol","type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeClass","title":"TypeClass","role":"symbol"},"doc://GLibObject/documentation/GLibObject/TypeClass/addPrivate(privateSize:)":{"role":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeClass\/addPrivate(privateSize:)","deprecated":true,"abstract":[{"text":"Registers a private structure for an instantiatable type.","type":"text"}],"type":"topic","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"addPrivate"},{"kind":"text","text":"("},{"text":"privateSize","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"text":")","kind":"text"}],"title":"addPrivate(privateSize:)","url":"\/documentation\/glibobject\/typeclass\/addprivate(privatesize:)","kind":"symbol"},"doc://GLibObject/documentation/GLibObject/TypeClass/TypeClassProtocol-Implementations":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeClass\/TypeClassProtocol-Implementations","type":"topic","url":"\/documentation\/glibobject\/typeclass\/typeclassprotocol-implementations","role":"collectionGroup","abstract":[],"title":"TypeClassProtocol Implementations","kind":"article"}}}