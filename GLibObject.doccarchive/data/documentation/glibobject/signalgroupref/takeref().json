{"variants":[{"paths":["\/documentation\/glibobject\/signalgroupref\/takeref()"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"If "},{"type":"codeVoice","code":"object"},{"type":"text","text":" is floating, sink it.  Otherwise, do nothing."}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/SignalGroupRef","doc:\/\/GLibObject\/documentation\/GLibObject\/SignalGroupRef\/ObjectProtocol-Implementations"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"takeRef","kind":"identifier"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","text":"ObjectRef","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef","preciseIdentifier":"s:10GLibObject0B3RefV"},{"kind":"text","text":"!"}]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In other words, this function will convert a floating reference (if"},{"type":"text","text":" "},{"type":"text","text":"present) into a full reference."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Typically you want to use "},{"code":"g_object_ref_sink()","type":"codeVoice"},{"type":"text","text":" in order to"},{"text":" ","type":"text"},{"text":"automatically do the correct thing with respect to floating or","type":"text"},{"type":"text","text":" "},{"text":"non-floating references, but there is one specific scenario where","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this function is helpful."}]},{"inlineContent":[{"text":"The situation where this function is helpful is when creating an API","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"that allows the user to provide a callback function that returns a"},{"type":"text","text":" "},{"text":"GObject. We certainly want to allow the user the flexibility to","type":"text"},{"text":" ","type":"text"},{"text":"return a non-floating reference from this callback (for the case","type":"text"},{"type":"text","text":" "},{"text":"where the object that is being returned already exists).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"At the same time, the API style of some popular GObject-based","type":"text"},{"type":"text","text":" "},{"text":"libraries (such as Gtk) make it likely that for newly-created GObject","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"instances, the user can be saved some typing if they are allowed to"},{"type":"text","text":" "},{"type":"text","text":"return a floating reference."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Using this function on the return value of the user’s callback allows"},{"type":"text","text":" "},{"type":"text","text":"the user to do whichever is more convenient for them. The caller will"},{"type":"text","text":" "},{"text":"always receives exactly one full reference to the value: either the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"one that was returned in the first place, or a floating reference"},{"text":" ","type":"text"},{"type":"text","text":"that has been converted to a full reference."}]},{"type":"paragraph","inlineContent":[{"text":"This function has an odd interaction when combined with","type":"text"},{"text":" ","type":"text"},{"code":"g_object_ref_sink()","type":"codeVoice"},{"text":" running at the same time in another thread on","type":"text"},{"type":"text","text":" "},{"text":"the same ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","type":"reference"},{"text":" instance. If ","type":"text"},{"code":"g_object_ref_sink()","type":"codeVoice"},{"type":"text","text":" runs first then"},{"type":"text","text":" "},{"text":"the result will be that the floating reference is converted to a hard","type":"text"},{"type":"text","text":" "},{"text":"reference. If ","type":"text"},{"code":"g_object_take_ref()","type":"codeVoice"},{"type":"text","text":" runs first then the result will be"},{"type":"text","text":" "},{"text":"that the floating reference is converted to a hard reference and an","type":"text"},{"text":" ","type":"text"},{"text":"additional reference on top of that one is added. It is best to avoid","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this situation."}]}]}],"metadata":{"role":"symbol","externalID":"s:10GLibObject0B8ProtocolPAAE7takeRefAA0bE0VSgyF::SYNTHESIZED::s:10GLibObject14SignalGroupRefV","extendedModule":"GLibObject","modules":[{"name":"GLibObject"}],"symbolKind":"method","roleHeading":"Instance Method","title":"takeRef()","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"takeRef"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","text":"ObjectRef","preciseIdentifier":"s:10GLibObject0B3RefV"},{"text":"!","kind":"text"}]},"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/SignalGroupRef\/takeRef()","interfaceLanguage":"swift"},"references":{"doc://GLibObject/documentation/GLibObject":{"role":"collection","type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","abstract":[],"title":"GLibObject","kind":"symbol","url":"\/documentation\/glibobject"},"doc://GLibObject/documentation/GLibObject/SignalGroupRef":{"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"SignalGroupRef"}],"title":"SignalGroupRef","type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/SignalGroupRef","role":"symbol","url":"\/documentation\/glibobject\/signalgroupref","navigatorTitle":[{"text":"SignalGroupRef","kind":"identifier"}],"kind":"symbol","abstract":[{"type":"codeVoice","code":"GSignalGroup"},{"text":" manages a collection of signals on a ","type":"text"},{"type":"codeVoice","code":"GObject"},{"type":"text","text":"."}]},"doc://GLibObject/documentation/GLibObject/SignalGroupRef/takeRef()":{"abstract":[{"type":"text","text":"If "},{"type":"codeVoice","code":"object"},{"type":"text","text":" is floating, sink it.  Otherwise, do nothing."}],"kind":"symbol","title":"takeRef()","type":"topic","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"takeRef","kind":"identifier"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","text":"ObjectRef","preciseIdentifier":"s:10GLibObject0B3RefV"},{"text":"!","kind":"text"}],"role":"symbol","url":"\/documentation\/glibobject\/signalgroupref\/takeref()","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/SignalGroupRef\/takeRef()"},"doc://GLibObject/documentation/GLibObject/SignalGroupRef/ObjectProtocol-Implementations":{"abstract":[],"url":"\/documentation\/glibobject\/signalgroupref\/objectprotocol-implementations","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/SignalGroupRef\/ObjectProtocol-Implementations","role":"collectionGroup","kind":"article","type":"topic","title":"ObjectProtocol Implementations"},"doc://GLibObject/documentation/GLibObject/Object":{"title":"Object","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Object","kind":"identifier"}],"navigatorTitle":[{"text":"Object","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/glibobject\/object","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","type":"topic","abstract":[{"type":"text","text":"The base object type."}],"role":"symbol"},"doc://GLibObject/documentation/GLibObject/ObjectRef":{"type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ObjectRef","kind":"identifier"}],"url":"\/documentation\/glibobject\/objectref","kind":"symbol","navigatorTitle":[{"text":"ObjectRef","kind":"identifier"}],"abstract":[{"type":"text","text":"The base object type."}],"role":"symbol","title":"ObjectRef"}}}