{"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/signalgroupref\/takeref()"]}],"metadata":{"title":"takeRef()","roleHeading":"Instance Method","externalID":"s:10GLibObject0B8ProtocolPAAE7takeRefAA0bE0VSgyF::SYNTHESIZED::s:10GLibObject14SignalGroupRefV","symbolKind":"method","extendedModule":"GLibObject","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"takeRef"},{"kind":"text","text":"() -> "},{"text":"ObjectRef","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject0B3RefV"},{"text":"!","kind":"text"}],"role":"symbol","modules":[{"name":"GLibObject"}]},"abstract":[{"type":"text","text":"If "},{"type":"codeVoice","code":"object"},{"type":"text","text":" is floating, sink it.  Otherwise, do nothing."}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/SignalGroupRef","doc:\/\/GLibObject\/documentation\/GLibObject\/SignalGroupRef\/ObjectProtocol-Implementations"]]},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"takeRef","kind":"identifier"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef","text":"ObjectRef","preciseIdentifier":"s:10GLibObject0B3RefV"},{"kind":"text","text":"!"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"In other words, this function will convert a floating reference (if"},{"text":" ","type":"text"},{"type":"text","text":"present) into a full reference."}]},{"type":"paragraph","inlineContent":[{"text":"Typically you want to use ","type":"text"},{"code":"g_object_ref_sink()","type":"codeVoice"},{"text":" in order to","type":"text"},{"type":"text","text":" "},{"text":"automatically do the correct thing with respect to floating or","type":"text"},{"text":" ","type":"text"},{"text":"non-floating references, but there is one specific scenario where","type":"text"},{"type":"text","text":" "},{"type":"text","text":"this function is helpful."}]},{"type":"paragraph","inlineContent":[{"text":"The situation where this function is helpful is when creating an API","type":"text"},{"type":"text","text":" "},{"type":"text","text":"that allows the user to provide a callback function that returns a"},{"type":"text","text":" "},{"text":"GObject. We certainly want to allow the user the flexibility to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"return a non-floating reference from this callback (for the case"},{"type":"text","text":" "},{"type":"text","text":"where the object that is being returned already exists)."}]},{"inlineContent":[{"text":"At the same time, the API style of some popular GObject-based","type":"text"},{"type":"text","text":" "},{"type":"text","text":"libraries (such as Gtk) make it likely that for newly-created GObject"},{"type":"text","text":" "},{"type":"text","text":"instances, the user can be saved some typing if they are allowed to"},{"type":"text","text":" "},{"type":"text","text":"return a floating reference."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Using this function on the return value of the user’s callback allows","type":"text"},{"type":"text","text":" "},{"text":"the user to do whichever is more convenient for them. The caller will","type":"text"},{"type":"text","text":" "},{"type":"text","text":"always receives exactly one full reference to the value: either the"},{"text":" ","type":"text"},{"type":"text","text":"one that was returned in the first place, or a floating reference"},{"text":" ","type":"text"},{"type":"text","text":"that has been converted to a full reference."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function has an odd interaction when combined with"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_object_ref_sink()"},{"type":"text","text":" running at the same time in another thread on"},{"type":"text","text":" "},{"type":"text","text":"the same "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","isActive":true,"type":"reference"},{"text":" instance. If ","type":"text"},{"type":"codeVoice","code":"g_object_ref_sink()"},{"type":"text","text":" runs first then"},{"type":"text","text":" "},{"type":"text","text":"the result will be that the floating reference is converted to a hard"},{"text":" ","type":"text"},{"text":"reference. If ","type":"text"},{"code":"g_object_take_ref()","type":"codeVoice"},{"type":"text","text":" runs first then the result will be"},{"type":"text","text":" "},{"text":"that the floating reference is converted to a hard reference and an","type":"text"},{"type":"text","text":" "},{"text":"additional reference on top of that one is added. It is best to avoid","type":"text"},{"type":"text","text":" "},{"text":"this situation.","type":"text"}]}],"kind":"content"}],"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/SignalGroupRef\/takeRef()","interfaceLanguage":"swift"},"sections":[],"references":{"doc://GLibObject/documentation/GLibObject/SignalGroupRef/takeRef()":{"title":"takeRef()","abstract":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"object"},{"text":" is floating, sink it.  Otherwise, do nothing.","type":"text"}],"role":"symbol","kind":"symbol","url":"\/documentation\/glibobject\/signalgroupref\/takeref()","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/SignalGroupRef\/takeRef()","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"takeRef"},{"text":"() -> ","kind":"text"},{"text":"ObjectRef","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject0B3RefV"},{"kind":"text","text":"!"}],"type":"topic"},"doc://GLibObject/documentation/GLibObject/ObjectRef":{"type":"topic","kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef","abstract":[{"text":"The base object type.","type":"text"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"ObjectRef","kind":"identifier"}],"url":"\/documentation\/glibobject\/objectref","title":"ObjectRef","navigatorTitle":[{"text":"ObjectRef","kind":"identifier"}],"role":"symbol"},"doc://GLibObject/documentation/GLibObject":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","url":"\/documentation\/glibobject","abstract":[],"role":"collection","kind":"symbol","title":"GLibObject","type":"topic"},"doc://GLibObject/documentation/GLibObject/Object":{"url":"\/documentation\/glibobject\/object","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","kind":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"Object","kind":"identifier"}],"type":"topic","title":"Object","navigatorTitle":[{"text":"Object","kind":"identifier"}],"abstract":[{"type":"text","text":"The base object type."}],"role":"symbol"},"doc://GLibObject/documentation/GLibObject/SignalGroupRef/ObjectProtocol-Implementations":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/SignalGroupRef\/ObjectProtocol-Implementations","role":"collectionGroup","kind":"article","title":"ObjectProtocol Implementations","abstract":[],"type":"topic","url":"\/documentation\/glibobject\/signalgroupref\/objectprotocol-implementations"},"doc://GLibObject/documentation/GLibObject/SignalGroupRef":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/SignalGroupRef","role":"symbol","kind":"symbol","title":"SignalGroupRef","abstract":[{"code":"GSignalGroup","type":"codeVoice"},{"type":"text","text":" manages a collection of signals on a "},{"type":"codeVoice","code":"GObject"},{"text":".","type":"text"}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"SignalGroupRef"}],"fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"SignalGroupRef","kind":"identifier"}],"url":"\/documentation\/glibobject\/signalgroupref"}}}