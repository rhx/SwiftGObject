,{"type":"codeVoice","code":"explicitNotify"},{"type":"text","text":", then any call to "},{"type":"codeVoice","code":"g_object_set_property()"},{"text":" results","type":"text"},{"text":" ","type":"text"},{"text":"in ","type":"text"},{"code":"notify","type":"codeVoice"},{"type":"text","text":" being emitted, even if the new value is the same as the old."},{"text":" ","type":"text"},{"type":"text","text":"If they did pass "},{"type":"codeVoice","code":"explicitNotify"},{"type":"text","text":", then this signal is emitted only"},{"text":" ","type":"text"},{"type":"text","text":"when they explicitly call "},{"type":"codeVoice","code":"g_object_notify()"},{"text":" or ","type":"text"},{"code":"g_object_notify_by_pspec()","type":"codeVoice"},{"text":",","type":"text"},{"type":"text","text":" "},{"text":"and common practice is to do that only when the value has actually changed.","type":"text"}]},{"inlineContent":[{"type":"text","text":"This signal is typically used to obtain change notification for a"},{"type":"text","text":" "},{"text":"single property, by specifying the property name as a detail in the","type":"text"},{"text":" ","type":"text"},{"code":"g_signal_connect()","type":"codeVoice"},{"text":" call, like this:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"syntax":"C","type":"codeListing","code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"]},{"type":"paragraph","inlineContent":[{"text":"It is important to note that you must use","type":"text"},{"text":" ","type":"text"},{"identifier":"#class@GObject.ParamSpec#parameter-names","type":"reference","isActive":true},{"type":"text","text":" as"},{"type":"text","text":" "},{"text":"detail strings for the notify signal.","type":"text"}]},{"style":"note","name":"Note","content":[{"inlineContent":[{"text":"This represent