{"topicSections":[{"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin\/init(_:)-3cm5a","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin\/init(_:)-62sev","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin\/init(_:)-62wpb","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin\/init(_:)-8ummq","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin\/init(_:)-92sfd","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin\/init(cPointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin\/init(gconstpointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin\/init(gpointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin\/init(opaquePointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin\/init(raw:)-3wrt5","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin\/init(raw:)-47yum","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin\/init(retaining:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin\/init(retainingCPointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin\/init(retainingOpaquePointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin\/init(retainingRaw:)-1688d","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin\/init(retainingRaw:)-7ym33"],"generated":true,"anchor":"Initializers","title":"Initializers"},{"generated":true,"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin\/ptr"],"anchor":"Instance-Properties","title":"Instance Properties"},{"anchor":"Default-Implementations","title":"Default Implementations","generated":true,"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin\/TypePluginProtocol-Implementations"]}],"relationshipsSections":[{"identifiers":["doc:\/\/GLibObject\/4GLib14PointerWrapperP","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol"],"title":"Conforms To","kind":"relationships","type":"conformsTo"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject"]]},"metadata":{"symbolKind":"class","roleHeading":"Class","role":"symbol","title":"TypePlugin","externalID":"s:10GLibObject10TypePluginC","modules":[{"name":"GLibObject"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"TypePlugin"}],"navigatorTitle":[{"text":"TypePlugin","kind":"identifier"}]},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TypePlugin","kind":"identifier"}]}]},{"content":[{"anchor":"overview","text":"Overview","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"The GObject type system supports dynamic loading of types."},{"type":"text","text":" "},{"type":"text","text":"It goes as follows:"}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The type is initially introduced (usually upon loading the module","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the first time, or by your main application that knows what modules"},{"type":"text","text":" "},{"text":"introduces what types), like this:","type":"text"}]},{"code":["new_type_id = g_type_register_dynamic (parent_type_id,","                                       \"TypeName\",","                                       new_type_plugin,","                                       type_flags);"],"syntax":"c","type":"codeListing"},{"inlineContent":[{"type":"text","text":"where "},{"code":"new_type_plugin","type":"codeVoice"},{"text":" is an implementation of the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"GTypePlugin"},{"type":"text","text":" interface."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"The type’s implementation is referenced, e.g. through"},{"type":"text","text":" "},{"text":"[func","type":"text"},{"type":"codeVoice","code":"GObject.TypeClass.ref"},{"text":"] or through [func","type":"text"},{"code":"GObject.type_create_instance","type":"codeVoice"},{"type":"text","text":"]"},{"type":"text","text":" "},{"type":"text","text":"(this is being called by [ctor"},{"code":"GObject.Object.new","type":"codeVoice"},{"type":"text","text":"]) or through one of the above"},{"type":"text","text":" "},{"type":"text","text":"done on a type derived from "},{"code":"new_type_id","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This causes the type system to load the type’s implementation by calling"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GObject.TypePlugin.use"},{"text":"] and [method","type":"text"},{"type":"codeVoice","code":"GObject.TypePlugin.complete_type_info"},{"text":"]","type":"text"},{"type":"text","text":" "},{"type":"text","text":"on "},{"type":"codeVoice","code":"new_type_plugin"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"At some point the type’s implementation isn’t required anymore, e.g. after"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"code":"GObject.TypeClass.unref","type":"codeVoice"},{"text":"] or [func","type":"text"},{"type":"codeVoice","code":"GObject.type_free_instance"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"text":"(called when the reference count of an instance drops to zero).","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"This causes the type system to throw away the information retrieved","type":"text"},{"type":"text","text":" "},{"text":"from [method","type":"text"},{"code":"GObject.TypePlugin.complete_type_info","type":"codeVoice"},{"text":"] and then it calls","type":"text"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"code":"GObject.TypePlugin.unuse","type":"codeVoice"},{"type":"text","text":"] on "},{"code":"new_type_plugin","type":"codeVoice"},{"type":"text","text":"."}]}]},{"content":[{"inlineContent":[{"text":"Things may repeat from the second step.","type":"text"}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"So basically, you need to implement a "},{"code":"GTypePlugin","type":"codeVoice"},{"type":"text","text":" type that"},{"type":"text","text":" "},{"type":"text","text":"carries a use_count, once use_count goes from zero to one, you need"},{"type":"text","text":" "},{"text":"to load the implementation to successfully handle the upcoming","type":"text"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"code":"GObject.TypePlugin.complete_type_info","type":"codeVoice"},{"text":"] call. Later, maybe after","type":"text"},{"type":"text","text":" "},{"type":"text","text":"succeeding use\/unuse calls, once use_count drops to zero, you can"},{"type":"text","text":" "},{"text":"unload the implementation again. The type system makes sure to call","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GObject.TypePlugin.use"},{"type":"text","text":"] and [method"},{"code":"GObject.TypePlugin.complete_type_info","type":"codeVoice"},{"text":"]","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"again when the type is needed again."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"[class","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule"},{"text":"] is an implementation of ","type":"text"},{"type":"codeVoice","code":"GTypePlugin"},{"text":" that","type":"text"},{"type":"text","text":" "},{"type":"text","text":"already implements most of this except for the actual module loading and"},{"text":" ","type":"text"},{"text":"unloading. It even handles multiple registered types per module.","type":"text"}]},{"inlineContent":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin","isActive":true},{"text":" type acts as an owner of an underlying ","type":"text"},{"code":"GTypePlugin","type":"codeVoice"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"text":"It provides the methods that can operate on this data type through ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol","isActive":true,"type":"reference"},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin","isActive":true,"type":"reference"},{"type":"text","text":" as a strong reference or owner of a "},{"type":"codeVoice","code":"GTypePlugin"},{"type":"text","text":" instance."}],"type":"paragraph"},{"name":"Note","style":"note","type":"aside","content":[{"inlineContent":[{"text":"Use ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef","type":"reference","isActive":true},{"type":"text","text":" (instead of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin"},{"text":") for a lightweight Swift reference to an underlying ","type":"text"},{"code":"GTypePlugin","type":"codeVoice"},{"type":"text","text":" instance."}],"type":"paragraph"}]}],"kind":"content"}],"abstract":[{"type":"text","text":"An interface that handles the lifecycle of dynamically loaded types."}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin"},"variants":[{"paths":["\/documentation\/glibobject\/typeplugin"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GLibObject/documentation/GLibObject/TypePlugin/init(cPointer:)":{"type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin\/init(cPoin