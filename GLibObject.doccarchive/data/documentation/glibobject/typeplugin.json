{"abstract":[{"type":"text","text":"An interface that handles the lifecycle of dynamically loaded types."}],"metadata":{"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"TypePlugin"}],"modules":[{"name":"GLibObject"}],"symbolKind":"class","role":"symbol","title":"TypePlugin","navigatorTitle":[{"kind":"identifier","text":"TypePlugin"}],"externalID":"s:10GLibObject10TypePluginC","roleHeading":"Class"},"sections":[],"relationshipsSections":[{"identifiers":["doc:\/\/GLibObject\/4GLib14PointerWrapperP","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol"],"kind":"relationships","type":"conformsTo","title":"Conforms To"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"TypePlugin","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"text":"Overview","anchor":"overview","type":"heading","level":2},{"inlineContent":[{"text":"The GObject type system supports dynamic loading of types.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It goes as follows:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The type is initially introduced (usually upon loading the module"},{"type":"text","text":" "},{"text":"the first time, or by your main application that knows what modules","type":"text"},{"text":" ","type":"text"},{"text":"introduces what types), like this:","type":"text"}]},{"syntax":"c","type":"codeListing","code":["new_type_id = g_type_register_dynamic (parent_type_id,","                                       \"TypeName\",","                                       new_type_plugin,","                                       type_flags);"]},{"type":"paragraph","inlineContent":[{"text":"where ","type":"text"},{"type":"codeVoice","code":"new_type_plugin"},{"text":" is an implementation of the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"GTypePlugin"},{"text":" interface.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"The type’s implementation is referenced, e.g. through","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[func"},{"code":"GObject.TypeClass.ref","type":"codeVoice"},{"type":"text","text":"] or through [func"},{"type":"codeVoice","code":"GObject.type_create_instance"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"text":"(this is being called by [ctor","type":"text"},{"type":"codeVoice","code":"GObject.Object.new"},{"type":"text","text":"]) or through one of the above"},{"type":"text","text":" "},{"type":"text","text":"done on a type derived from "},{"type":"codeVoice","code":"new_type_id"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"This causes the type system to load the type’s implementation by calling","type":"text"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GObject.TypePlugin.use"},{"type":"text","text":"] and [method"},{"type":"codeVoice","code":"GObject.TypePlugin.complete_type_info"},{"type":"text","text":"]"},{"type":"text","text":" "},{"type":"text","text":"on "},{"type":"codeVoice","code":"new_type_plugin"},{"text":".","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"At some point the type’s implementation isn’t required anymore, e.g. after","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"code":"GObject.TypeClass.unref","type":"codeVoice"},{"type":"text","text":"] or [func"},{"code":"GObject.type_free_instance","type":"codeVoice"},{"text":"]","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(called when the reference count of an instance drops to zero)."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"This causes the type system to throw away the information retrieved","type":"text"},{"type":"text","text":" "},{"text":"from [method","type":"text"},{"type":"codeVoice","code":"GObject.TypePlugin.complete_type_info"},{"text":"] and then it calls","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GObject.TypePlugin.unuse"},{"type":"text","text":"] on "},{"code":"new_type_plugin","type":"codeVoice"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Things may repeat from the second step."}]}]}],"type":"orderedList"},{"type":"paragraph","inlineContent":[{"text":"So basically, you need to implement a ","type":"text"},{"type":"codeVoice","code":"GTypePlugin"},{"text":" type that","type":"text"},{"type":"text","text":" "},{"text":"carries a use_count, once use_count goes from zero to one, you need","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to load the implementation to successfully handle the upcoming"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GObject.TypePlugin.complete_type_info"},{"type":"text","text":"] call. Later, maybe after"},{"type":"text","text":" "},{"type":"text","text":"succeeding use\/unuse calls, once use_count drops to zero, you can"},{"text":" ","type":"text"},{"type":"text","text":"unload the implementation again. The type system makes sure to call"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"code":"GObject.TypePlugin.use","type":"codeVoice"},{"text":"] and [method","type":"text"},{"type":"codeVoice","code":"GObject.TypePlugin.complete_type_info"},{"type":"text","text":"]"},{"type":"text","text":" "},{"text":"again when the type is needed again.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"[class","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule"},{"text":"] is an implementation of ","type":"text"},{"type":"codeVoice","code":"GTypePlugin"},{"text":" that","type":"text"},{"type":"text","text":" "},{"text":"already implements most of this except for the actual module loading and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"unloading. It even handles multiple registered types per module."}]},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin","type":"reference","isActive":true},{"text":" type acts as an owner of an underlying ","type":"text"},{"type":"codeVoice","code":"GTypePlugin"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"type":"text","text":"It provides the methods that can operate on this data type through "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol"},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"text":"Use ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin"},{"type":"text","text":" as a strong reference or owner of a "},{"type":"codeVoice","code":"GTypePlugin"},{"type":"text","text":" instance."}],"type":"paragraph"},{"style":"note","name":"Note","content":[{"inlineContent":[{"text":"Use ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef","isActive":true},{"type":"text","text":" (instead of "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin","isActive":true,"type":"reference"},{"text":") for a lightweight Swift reference to an underlying ","type":"text"},{"type":"codeVoice","code":"GTypePlugin"},{"type":"text","text":" instance."}],"type":"paragraph"}],"type":"aside"}],"kind":"content"}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/typeplugin"]}],"h