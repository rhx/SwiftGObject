{"sections":[],"metadata":{"roleHeading":"Structure","symbolKind":"struct","externalID":"s:10GLibObject13TypeModuleRefV","role":"symbol","navigatorTitle":[{"text":"TypeModuleRef","kind":"identifier"}],"title":"TypeModuleRef","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"TypeModuleRef","kind":"identifier"}],"modules":[{"name":"GLibObject"}]},"topicSections":[{"title":"Initializers","anchor":"Initializers","generated":true,"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/init(_:)-371zq","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/init(_:)-3z8qk","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/init(_:)-4b5zs","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/init(_:)-4vlqa","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/init(_:)-92kh5","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/init(cPointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/init(constPointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/init(gconstpointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/init(gpointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/init(mutating:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/init(opaquePointer:)"]},{"generated":true,"anchor":"Instance-Properties","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/ptr"],"title":"Instance Properties"},{"title":"Type Methods","anchor":"Type-Methods","generated":true,"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/unowned(_:)"]},{"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/ObjectProtocol-Implementations","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/PointerWrapper-Implementations","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/TypeModuleProtocol-Implementations","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/TypePluginProtocol-Implementations"],"generated":true,"title":"Default Implementations","anchor":"Default-Implementations"}],"variants":[{"paths":["\/documentation\/glibobject\/typemoduleref"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef"},"abstract":[{"type":"codeVoice","code":"GTypeModule"},{"type":"text","text":" provides a simple implementation of the "},{"code":"GTypePlugin","type":"codeVoice"},{"type":"text","text":" "},{"text":"interface.","type":"text"}],"relationshipsSections":[{"type":"conformsTo","title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/GLibObject\/4GLib14PointerWrapperP","doc:\/\/GLibObject\/documentation\/GLibObject\/GWeakCapturing","doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectProtocol","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleProtocol","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol"]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"TypeModuleRef","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"anchor":"overview","level":2,"text":"Overview","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The model of "},{"code":"GTypeModule","type":"codeVoice"},{"text":" is a dynamically loaded module which","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"implements some number of types and interface implementations."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When the module is loaded, it registers its types and interfaces"},{"text":" ","type":"text"},{"text":"using [method","type":"text"},{"type":"codeVoice","code":"GObject.TypeModule.register_type"},{"type":"text","text":"] and"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"code":"GObject.TypeModule.add_interface","type":"codeVoice"},{"type":"text","text":"]."},{"text":" ","type":"text"},{"type":"text","text":"As long as any instances of these types and interface implementations"},{"text":" ","type":"text"},{"type":"text","text":"are in use, the module is kept loaded. When the types and interfaces"},{"type":"text","text":" "},{"text":"are gone, the module may be unloaded. If the types and interfaces","type":"text"},{"text":" ","type":"text"},{"text":"become used again, the module will be reloaded. Note that the last","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"reference cannot be released from within the module code, since that"},{"type":"text","text":" "},{"text":"would lead to the caller’s code being unloaded before ","type":"text"},{"type":"codeVoice","code":"g_object_unref()"},{"text":" ","type":"text"},{"type":"text","text":"returns to it."}]},{"inlineContent":[{"text":"Keeping track of whether the module should be loaded or not is done by","type":"text"},{"type":"text","text":" "},{"text":"using a use count - it starts at zero, and whenever it is greater than","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"zero, the module is loaded. The use count is maintained internally by"},{"type":"text","text":" "},{"type":"text","text":"the type system, but also can be explicitly controlled by"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GObject.TypeModule.use"},{"text":"] and [method","type":"text"},{"type":"codeVoice","code":"GObject.TypeModule.unuse"},{"type":"text","text":"]."},{"type":"text","text":" "},{"type":"text","text":"Typically, when loading a module for the first type, "},{"type":"codeVoice","code":"g_type_module_use()"},{"type":"text","text":" "},{"type":"text","text":"will be used to load it so that it can initialize its types. At some later"},{"type":"text","text":" "},{"type":"text","text":"point, when the module no longer needs to be loaded except for the type"},{"type":"text","text":" "},{"type":"text","text":"implementations it contains, "},{"type":"codeVoice","code":"g_type_module_unuse()"},{"type":"text","text":" is called."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"GTypeModule"},{"text":" does not actually provide any implementation of module","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"loading and unloading. To create a particular module type you must"},{"type":"text","text":" "},{"type":"text","text":"derive from "},{"code":"GTypeModule","type":"codeVoice"},{"type":"text","text":" and implement the load and unload functions"},{"type":"text","text":" "},{"type":"text","text":"in "},{"code":"GTypeModuleClass","type":"codeVoice"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef","isActive":true,"type":"reference"},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"code":"GTypeModule","type":"codeVoice"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleProtocol","isActive":true,"type":"reference"},{"text":" conformance.","type":"text"},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef","type":"reference"},{"text":" only as an ","type":"text"},{"code":"unowned","type":"codeVoice"},{"text":" reference to an existing ","type":"text"},{"code":"GTypeModule","type":"codeVoice"},{"text":" instance.","type":"text"}],"type":"paragraph"},{"name":"Note","type":"aside","style":"note","content":[{"inlineContent":[{"text":"Use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule","type":"reference"},{"text":" (instead of ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef","type":"reference","isActive":true},{"type":"text","text":") if you want to use Automatic Reference Counting for memory management of the underlying "},{"type":"codeVoice","code":"GTypeModule"},{"text":" instance.","type":"text"}],"type":"paragraph"}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject"]]},"references":{"doc://GLibObject/documentation/GLibObject/TypeModuleRef/init(_:)-4vlqa":{"kind":"symbol","url":"\/documentation\/glibobject\/typemoduleref\/init(_:)-4vlqa","title":"init(_:)","type":"topic","abstract":[{"type":"text","text":"Conditional initialiser from an optional pointer to the underlying "},{"code":"C","type":"codeVoice"},{"text":" data type","type":"text"}],"fragments":[{"kind":"identifier","text":"init"},{"text":"!(","kind":"text"},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"GTypeModule"},{"kind":"text","text":">?)"}],"role":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/init(_:)-4vlqa"},"doc://GLibObject/documentation/GLibObject/TypeModuleRef/ptr":{"title":"ptr","abstract":[{"type":"text","text":"Untyped pointer to the underlying "},{"type":"codeVoice","code":"GTypeModule"},{"text":" instance.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"For type-safe access, use the generated, typed pointer "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleProtocol\/type_module_ptr-lh1o","type":"reference","isActive":true},{"text":" property instead.","type":"text"}],"role":"symbol","kind":"symbol","url":"\/documentation\/glibobject\/typemoduleref\/ptr","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/ptr","fragments