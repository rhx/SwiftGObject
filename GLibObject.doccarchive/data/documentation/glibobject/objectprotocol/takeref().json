{"kind":"symbol","metadata":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"takeRef"},{"kind":"text","text":"() -> "},{"text":"ObjectRef","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject0B3RefV"},{"kind":"text","text":"!"}],"roleHeading":"Instance Method","modules":[{"name":"GLibObject"}],"role":"symbol","symbolKind":"method","title":"takeRef()","externalID":"s:10GLibObject0B8ProtocolPAAE7takeRefAA0bE0VSgyF","extendedModule":"GLibObject"},"sections":[],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectProtocol"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectProtocol\/takeRef()"},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"takeRef","kind":"identifier"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","text":"ObjectRef","preciseIdentifier":"s:10GLibObject0B3RefV","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef"},{"kind":"text","text":"!"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In other words, this function will convert a floating reference (if"},{"type":"text","text":" "},{"type":"text","text":"present) into a full reference."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Typically you want to use "},{"type":"codeVoice","code":"g_object_ref_sink()"},{"type":"text","text":" in order to"},{"type":"text","text":" "},{"text":"automatically do the correct thing with respect to floating or","type":"text"},{"text":" ","type":"text"},{"text":"non-floating references, but there is one specific scenario where","type":"text"},{"type":"text","text":" "},{"type":"text","text":"this function is helpful."}]},{"inlineContent":[{"text":"The situation where this function is helpful is when creating an API","type":"text"},{"text":" ","type":"text"},{"text":"that allows the user to provide a callback function that returns a","type":"text"},{"type":"text","text":" "},{"text":"GObject. We certainly want to allow the user the flexibility to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"return a non-floating reference from this callback (for the case"},{"text":" ","type":"text"},{"type":"text","text":"where the object that is being returned already exists)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"At the same time, the API style of some popular GObject-based","type":"text"},{"type":"text","text":" "},{"type":"text","text":"libraries (such as Gtk) make it likely that for newly-created GObject"},{"type":"text","text":" "},{"text":"instances, the user can be saved some typing if they are allowed to","type":"text"},{"type":"text","text":" "},{"text":"return a floating reference.","type":"text"}]},{"inlineContent":[{"text":"Using this function on the return value of the user’s callback allows","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the user to do whichever is more convenient for them. The caller will"},{"text":" ","type":"text"},{"type":"text","text":"always receives exactly one full reference to the value: either the"},{"type":"text","text":" "},{"text":"one that was returned in the first place, or a floating reference","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"that has been converted to a full reference."}],"type":"paragraph"},{"inlineContent":[{"text":"This function has an odd interaction when combined with","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_object_ref_sink()"},{"text":" running at the same time in another thread on","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the same "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","isActive":true,"type":"reference"},{"type":"text","text":" instance. If "},{"code":"g_object_ref_sink()","type":"codeVoice"},{"type":"text","text":" runs first then"},{"type":"text","text":" "},{"text":"the result will be that the floating reference is converted to a hard","type":"text"},{"type":"text","text":" "},{"text":"reference. If ","type":"text"},{"code":"g_object_take_ref()","type":"codeVoice"},{"text":" runs first then the result will be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"that the floating reference is converted to a hard reference and an"},{"text":" ","type":"text"},{"type":"text","text":"additional reference on top of that one is added. It is best to avoid"},{"text":" ","type":"text"},{"text":"this situation.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"object"},{"type":"text","text":" is floating, sink it.  Otherwise, do nothing."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/objectprotocol\/takeref()"]}],"references":{"doc://GLibObject/documentation/GLibObject":{"role":"collection","type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","abstract":[],"title":"GLibObject","kind":"symbol","url":"\/documentation\/glibobject"},"doc://GLibObject/documentation/GLibObject/Object":{"title":"Object","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Object","kind":"identifier"}],"navigatorTitle":[{"text":"Object","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/glibobject\/object","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","type":"topic","abstract":[{"type":"text","text":"The base object type."}],"role":"symbol"},"doc://GLibObject/documentation/GLibObject/ObjectProtocol/takeRef()":{"abstract":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"object"},{"type":"text","text":" is floating, sink it.  Otherwise, do nothing."}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectProtocol\/takeRef()","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"takeRef"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:10GLibObject0B3RefV","text":"ObjectRef","kind":"typeIdentifier"},{"kind":"text","text":"!"}],"title":"takeRef()","url":"\/documentation\/glibobject\/objectprotocol\/takeref()","type":"topic","role":"symbol","kind":"symbol"},"doc://GLibObject/documentation/GLibObject/ObjectRef":{"type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ObjectRef","kind":"identifier"}],"url":"\/documentation\/glibobject\/objectref","kind":"symbol","navigatorTitle":[{"text":"ObjectRef","kind":"identifier"}],"abstract":[{"type":"text","text":"The base object type."}],"role":"symbol","title":"ObjectRef"},"doc://GLibObject/documentation/GLibObject/ObjectProtocol":{"title":"ObjectProtocol","type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectProtocol","role":"symbol","url":"\/documentation\/glibobject\/objectprotocol","kind":"symbol","abstract":[{"type":"text","text":"The base object type."}],"navigatorTitle":[{"text":"ObjectProtocol","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"ObjectProtocol","kind":"identifier"}]}}}