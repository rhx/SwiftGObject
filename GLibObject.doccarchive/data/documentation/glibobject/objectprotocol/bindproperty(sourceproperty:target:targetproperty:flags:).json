text":" is changed the "},{"type":"codeVoice","code":"targetProperty"},{"text":" is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"updated using the same value. For instance:"}]},{"inlineContent":[{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"syntax":"C","type":"codeListing","code":["  g_object_bind_property (action, \"active\", widget, \"sensitive\", 0);"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Will result in the “sensitive” property of the widget "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object"},{"type":"text","text":" instance to be"},{"text":" ","type":"text"},{"type":"text","text":"updated with the same value of the “active” property of the action "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","isActive":true},{"text":" ","type":"text"},{"type":"text","text":"instance."}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"flags","type":"codeVoice"},{"type":"text","text":" contains "},{"type":"codeVoice","code":"bidirectional"},{"text":" then the binding will be mutual:","type":"text"},{"type":"text","text":" "},{"type":"text","text":"if "},{"code":"targetProperty","type":"codeVoice"},{"type":"text","text":" on "},{"code":"target","type":"codeVoice"},{"type":"text","text":" changes then the "},{"code":"sourceProperty","type":"codeVoice"},{"text":" on ","type":"text"},{"code":"source","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"will be updated as well."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The binding will automatically be removed when either the "},{"code":"source","type":"codeVoice"},{"text":" or the","type":"text"},{"type":"text","text":" "},{"code":"target","type":"codeVoice"},{"type":"text","text":" instances are finalized. To remove the binding without affecting the"},{"type":"text","text":" "},{"type":"codeVoice","