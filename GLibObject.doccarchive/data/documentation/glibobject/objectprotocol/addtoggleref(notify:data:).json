{"sections":[],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectProtocol"]]},"metadata":{"externalID":"s:10GLibObject0B8ProtocolPAAE12addToggleRef6notify4datayySvSg_SpySo8_GObjectVGSgs5Int32VtXCSg_AGtF","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"addToggleRef"},{"kind":"text","text":"("},{"kind":"externalParam","text":"notify"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"GToggleNotify","preciseIdentifier":"c:gobject.h@T@GToggleNotify"},{"text":"?, ","kind":"text"},{"text":"data","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer"},{"kind":"text","text":"?)"}],"symbolKind":"method","modules":[{"name":"GLibObject"}],"role":"symbol","title":"addToggleRef(notify:data:)","extendedModule":"GLibObject","roleHeading":"Instance Method"},"kind":"symbol","identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectProtocol\/addToggleRef(notify:data:)","interfaceLanguage":"swift"},"abstract":[{"text":"Increases the reference count of the object by one and sets a","type":"text"},{"type":"text","text":" "},{"text":"callback to be called when all other references to the object are","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"dropped, or when this is already the last reference to the object"},{"text":" ","type":"text"},{"type":"text","text":"and another reference is established."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"addToggleRef","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"notify"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:gobject.h@T@GToggleNotify","text":"GToggleNotify"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"data"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"text":"? = nil)","kind":"text"}],"languages":["swift"]}]},{"content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This functionality is intended for binding "},{"type":"codeVoice","code":"object"},{"type":"text","text":" to a proxy"},{"text":" ","type":"text"},{"text":"object managed by another memory manager. This is done with two","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"paired references: the strong reference added by"},{"text":" ","type":"text"},{"code":"g_object_add_toggle_ref()","type":"codeVoice"},{"type":"text","text":" and a reverse reference to the proxy"},{"type":"text","text":" "},{"type":"text","text":"object which is either a strong reference or weak reference."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The setup is that when there are no other references to "},{"code":"object","type":"codeVoice"},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"text","text":"only a weak reference is held in the reverse direction from "},{"type":"codeVoice","code":"object"},{"text":" ","type":"text"},{"type":"text","text":"to the proxy object, but when there are other references held to"},{"text":" ","type":"text"},{"type":"codeVoice","code":"object"},{"type":"text","text":", a strong reference is held. The "},{"type":"codeVoice","code":"notify"},{"type":"text","text":" callback is called"},{"text":" ","type":"text"},{"text":"when the reference from ","type":"text"},{"code":"object","type":"codeVoice"},{"text":" to the proxy object should be","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"“toggled” from strong to weak ("},{"type":"codeVoice","code":"is_last_ref"},{"text":" true) or weak to strong","type":"text"},{"type":"text","text":" "},{"type":"text","text":"("},{"type":"codeVoice","code":"is_last_ref"},{"type":"text","text":" false)."}]},{"inlineContent":[{"type":"text","text":"Since a (normal) reference must be held to the object before"},{"type":"text","text":" "},{"text":"calling ","type":"text"},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"text":", the initial state of the reverse","type":"text"},{"text":" ","type":"text"},{"text":"link is always strong.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Multiple toggle references may be added to the same gobject,"},{"type":"text","text":" "},{"text":"however if there are multiple toggle references to an object, none","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of them will ever be notified until all but one are removed.  For"},{"text":" ","type":"text"},{"type":"text","text":"this reason, you should only ever use a toggle reference if there"},{"type":"text","text":" "},{"type":"text","text":"is important state in the proxy object."}]},{"type":"paragraph","inlineContent":[{"text":"Note that if you unref the object on another thread, then ","type":"text"},{"type":"codeVoice","code":"notify"},{"type":"text","text":" might"},{"type":"text","text":" "},{"type":"text","text":"still be invoked after "},{"code":"g_object_remove_toggle_ref()","type":"codeVoice"},{"text":", and the object argument","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"might be a dangling pointer. If the object is destroyed on other threads,"},{"type":"text","text":" "},{"text":"you must take care of that yourself.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"text":" must be released with ","type":"text"},{"type":"codeVoice","code":"g_object_remove_toggle_ref()"},{"type":"text","text":"."}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/glibobject\/objectprotocol\/addtoggleref(notify:data:)"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://GLibObject/documentation/GLibObject":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","url":"\/documentation\/glibobject","abstract":[],"role":"collection","kind":"symbol","title":"GLibObject","type":"topic"},"doc://GLibObject/documentation/GLibObject/ObjectProtocol":{"url":"\/documentation\/glibobject\/objectprotocol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectProtocol","title":"ObjectProtocol","role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"ObjectProtocol"}],"abstract":[{"text":"The base object type.","type":"text"}],"kind":"symbol","type":"topic","navigatorTitle":[{"text":"ObjectProtocol","kind":"identifier"}]},"doc://GLibObject/documentation/GLibObject/ObjectProtocol/addToggleRef(notify:data:)":{"kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectProtocol\/addToggleRef(notify:data:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"addToggleRef"},{"text":"(","kind":"text"},{"text":"notify","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gobject.h@T@GToggleNotify","text":"GToggleNotify","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"text":"data","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier","text":"gpointer"},{"kind":"text","text":"?)"}],"url":"\/documentation\/glibobject\/objectprotocol\/addtoggleref(notify:data:)","abstract":[{"type":"text","text":"Increases the reference count of the object by one and sets a"},{"text":" ","type":"text"},{"text":"callback to be called when all other references to the object are","type":"text"},{"type":"text","text":" "},{"type":"text","text":"dropped, or when this is already the last reference to the object"},{"text":" ","type":"text"},{"type":"text","text":"and another reference is established."}],"role":"symbol","type":"topic","title":"addToggleRef(notify:data:)"}}}