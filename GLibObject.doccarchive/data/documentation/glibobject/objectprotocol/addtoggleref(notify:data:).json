{"sections":[],"abstract":[{"text":"Increases the reference count of the object by one and sets a","type":"text"},{"text":" ","type":"text"},{"text":"callback to be called when all other references to the object are","type":"text"},{"type":"text","text":" "},{"text":"dropped, or when this is already the last reference to the object","type":"text"},{"text":" ","type":"text"},{"text":"and another reference is established.","type":"text"}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"addToggleRef"},{"kind":"text","text":"("},{"kind":"externalParam","text":"notify"},{"kind":"text","text":": "},{"preciseIdentifier":"c:gobject.h@T@GToggleNotify","text":"GToggleNotify","kind":"typeIdentifier"},{"kind":"text","text":"?, "},{"text":"data","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"kind":"text","text":"? = nil)"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"inlineContent":[{"text":"This functionality is intended for binding ","type":"text"},{"code":"object","type":"codeVoice"},{"text":" to a proxy","type":"text"},{"type":"text","text":" "},{"type":"text","text":"object managed by another memory manager. This is done with two"},{"type":"text","text":" "},{"text":"paired references: the strong reference added by","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"text":" and a reverse reference to the proxy","type":"text"},{"type":"text","text":" "},{"type":"text","text":"object which is either a strong reference or weak reference."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The setup is that when there are no other references to "},{"type":"codeVoice","code":"object"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"only a weak reference is held in the reverse direction from ","type":"text"},{"code":"object","type":"codeVoice"},{"text":" ","type":"text"},{"text":"to the proxy object, but when there are other references held to","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"object"},{"type":"text","text":", a strong reference is held. The "},{"code":"notify","type":"codeVoice"},{"type":"text","text":" callback is called"},{"type":"text","text":" "},{"text":"when the reference from ","type":"text"},{"type":"codeVoice","code":"object"},{"text":" to the proxy object should be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"“toggled” from strong to weak ("},{"type":"codeVoice","code":"is_last_ref"},{"type":"text","text":" true) or weak to strong"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"code":"is_last_ref","type":"codeVoice"},{"text":" false).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Since a (normal) reference must be held to the object before"},{"type":"text","text":" "},{"type":"text","text":"calling "},{"code":"g_object_add_toggle_ref()","type":"codeVoice"},{"text":", the initial state of the reverse","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"link is always strong."}]},{"inlineContent":[{"type":"text","text":"Multiple toggle references may be added to the same gobject,"},{"text":" ","type":"text"},{"type":"text","text":"however if there are multiple toggle references to an object, none"},{"text":" ","type":"text"},{"type":"text","text":"of them will ever be notified until all but one are removed.  For"},{"text":" ","type":"text"},{"text":"this reason, you should only ever use a toggle reference if there","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is important state in the proxy object."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that if you unref the object on another thread, then "},{"type":"codeVoice","code":"notify"},{"type":"text","text":" might"},{"type":"text","text":" "},{"type":"text","text":"still be invoked after "},{"type":"codeVoice","code":"g_object_remove_toggle_ref()"},{"type":"text","text":", and the object argument"},{"type":"text","text":" "},{"type":"text","text":"might be a dangling pointer. If the object is destroyed on other threads,"},{"text":" ","type":"text"},{"text":"you must take care of that yourself.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"text":" must be released with ","type":"text"},{"type":"codeVoice","code":"g_object_remove_toggle_ref()"},{"text":".","type":"text"}]}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectProtocol\/addToggleRef(notify:data:)"},"kind":"symbol","metadata":{"roleHeading":"Instance Method","externalID":"s:10GLibObject0B8ProtocolPAAE12addToggleRef6notify4datayySvSg_SpySo8_GObjectVGSgs5Int32VtXCSg_AGtF","modules":[{"name":"GLibObject"}],"symbolKind":"method","title":"addToggleRef(notify:data:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"addToggleRef"},{"kind":"text","text":"("},{"text":"notify","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gobject.h@T@GToggleNotify","text":"GToggleNotify","kind":"typeIdentifier"},{"kind":"text","text":"?, "},{"text":"data","kind":"externalParam"},{"kind":"text","text":": "},{"text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier"},{"text":"?)","kind":"text"}],"extendedModule":"GLibObject","role":"symbol"},"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/objectprotocol\/addtoggleref(notify:data:)"]}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectProtocol"]]},"references":{"doc://GLibObject/documentation/GLibObject":{"role":"collection","type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","abstract":[],"title":"GLibObject","kind":"symbol","url":"\/documentation\/glibobject"},"doc://GLibObject/documentation/GLibObject/ObjectProtocol/addToggleRef(notify:data:)":{"kind":"symbol","type":"topic","url":"\/documentation\/glibobject\/objectprotocol\/addtoggleref(notify:data:)","title":"addToggleRef(notify:data:)","abstract":[{"type":"text","text":"Increases the reference count of the object by one and sets a"},{"type":"text","text":" "},{"type":"text","text":"callback to be called when all other references to the object are"},{"type":"text","text":" "},{"text":"dropped, or when this is already the last reference to the object","type":"text"},{"text":" ","type":"text"},{"text":"and another reference is established.","type":"text"}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectProtocol\/addToggleRef(notify:data:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"addToggleRef","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"notify"},{"text":": ","kind":"text"},{"text":"GToggleNotify","kind":"typeIdentifier","preciseIdentifier":"c:gobject.h@T@GToggleNotify"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"data"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer"},{"text":"?)","kind":"text"}],"role":"symbol"},"doc://GLibObject/documentation/GLibObject/ObjectProtocol":{"title":"ObjectProtocol","type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectProtocol","role":"symbol","url":"\/documentation\/glibobject\/objectprotocol","kind":"symbol","abstract":[{"type":"text","text":"The base object type."}],"navigatorTitle":[{"text":"ObjectProtocol","k