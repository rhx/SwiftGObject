{"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/typeEnsure(type:)","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Ensures that the indicated "},{"code":"type","type":"codeVoice"},{"type":"text","text":" has been registered with the"},{"text":" ","type":"text"},{"type":"text","text":"type system, and its "},{"type":"codeVoice","code":"_class_init()"},{"text":" method has been run.","type":"text"}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"typeEnsure"},{"text":"(","kind":"text"},{"text":"type","kind":"externalParam"},{"kind":"text","text":": "},{"text":"GType","preciseIdentifier":"c:@T@GType","kind":"typeIdentifier"},{"kind":"text","text":")"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"In theory, simply calling the type’s "},{"type":"codeVoice","code":"_get_type()"},{"text":" method (or using","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the corresponding macro) is supposed take care of this. However,"},{"type":"text","text":" "},{"type":"codeVoice","code":"_get_type()"},{"type":"text","text":" methods are often marked "},{"type":"codeVoice","code":"G_GNUC_CONST"},{"type":"text","text":" for performance"},{"type":"text","text":" "},{"text":"reasons, even though this is technically incorrect (since","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"G_GNUC_CONST"},{"type":"text","text":" requires that the function not have side effects,"},{"type":"text","text":" "},{"text":"which ","type":"text"},{"code":"_get_type()","type":"codeVoice"},{"text":" methods do on the first call). As a result, if","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"you write a bare call to a "},{"type":"codeVoice","code":"_get_type()"},{"type":"text","text":" macro, it may get optimized"},{"text":" ","type":"text"},{"type":"text","text":"out by the compiler. Using "},{"type":"codeVoice","code":"g_type_ensure()"},{"text":" guarantees that the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"type’s "},{"type":"codeVoice","code":"_get_type()"},{"type":"text","text":" method is called."}]}],"kind":"content"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/glibobject\/typeensure(type:)"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"modules":[{"name":"GLibObject"}],"symbolKind":"func","roleHeading":"Function","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"typeEnsure","kind":"identifier"},{"text":"(","kind":"text"},{"text":"type","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@T@GType","kind":"typeIdentifier","text":"GType"},{"text":")","kind":"text"}],"title":"typeEnsure(type:)","externalID":"s:10GLibObject10typeEnsure0C0ySu_tF"},"sections":[],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject"]]},"references":{"doc://GLibObject/documentation/GLibObject/typeEnsure(type:)":{"url":"\/documentation\/glibobject\/typeensure(type:)","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/typeEnsure(type:)","title":"typeEnsure(type:)","abstract":[{"type":"text","text":"Ensures that the indicated "},{"code":"type","type":"codeVoice"},{"type":"text","text":" has been registered with the"},{"text":" ","type":"text"},{"type":"text","text":"type system, and its "},{"code":"_class_init()","type":"codeVoice"},{"type":"text","text":" method has been run."}],"type":"topic","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"typeEnsure","kind":"identifier"},{"kind":"text","text":"("},{"text":"type","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"GType","kind"