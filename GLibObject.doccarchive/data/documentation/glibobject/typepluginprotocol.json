{"abstract":[{"type":"text","text":"An interface that handles the lifecycle of dynamically loaded types."}],"relationshipsSections":[{"kind":"relationships","title":"Inherits From","identifiers":["doc:\/\/GLibObject\/4GLib14PointerWrapperP"],"type":"inheritsFrom"},{"type":"inheritedBy","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleProtocol"],"title":"Inherited By","kind":"relationships"},{"type":"conformingTypes","title":"Conforming Types","kind":"relationships","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef"]}],"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol","interfaceLanguage":"swift"},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/typepluginprotocol"]}],"topicSections":[{"anchor":"Instance-Properties","generated":true,"title":"Instance Properties","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol\/type_plugin_ptr-1f7zf"]},{"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol\/completeInterfaceInfo(instanceType:interfaceType:info:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol\/completeTypeInfo(gType:info:valueTable:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol\/typeAddInterfaceDynamic(instanceType:interfaceType:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol\/typeRegisterDynamic(parentType:typeName:flags:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol\/unuse()","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol\/use()"],"generated":true,"anchor":"Instance-Methods","title":"Instance Methods"}],"kind":"symbol","metadata":{"externalID":"s:10GLibObject18TypePluginProtocolP","roleHeading":"Protocol","modules":[{"name":"GLibObject"}],"role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"TypePluginProtocol","kind":"identifier"}],"title":"TypePluginProtocol","symbolKind":"protocol","navigatorTitle":[{"kind":"identifier","text":"TypePluginProtocol"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"TypePluginProtocol"},{"kind":"text","text":" : "},{"text":"PointerWrapper","kind":"typeIdentifier","preciseIdentifier":"s:4GLib14PointerWrapperP"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"overview","text":"Overview","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"The GObject type system supports dynamic loading of types."},{"type":"text","text":" "},{"text":"It goes as follows:","type":"text"}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The type is initially introduced (usually upon loading the module","type":"text"},{"text":" ","type":"text"},{"text":"the first time, or by your main application that knows what modules","type":"text"},{"text":" ","type":"text"},{"text":"introduces what types), like this:","type":"text"}]},{"syntax":"c","type":"codeListing","code":["new_type_id = g_type_register_dynamic (parent_type_id,","                                       \"TypeName\",","                                       new_type_plugin,","                                       type_flags);"]},{"type":"paragraph","inlineContent":[{"text":"where ","type":"text"},{"type":"codeVoice","code":"new_type_plugin"},{"text":" is an implementation of the","type":"text"},{"text":" ","type":"text"},{"code":"GTypePlugin","type":"codeVoice"},{"text":" interface.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The type’s implementation is referenced, e.g. through","type":"text"},{"text":" ","type":"text"},{"text":"[func","type":"text"},{"code":"GObject.TypeClass.ref","type":"codeVoice"},{"type":"text","text":"] or through [func"},{"type":"codeVoice","code":"GObject.type_create_instance"},{"text":"]","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(this is being called by [ctor"},{"type":"codeVoice","code":"GObject.Object.new"},{"type":"text","text":"]) or through one of the above"},{"text":" ","type":"text"},{"type":"text","text":"done on a type derived from "},{"type":"codeVoice","code":"new_type_id"},{"text":".","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"This causes the type system to load the type’s implementation by calling"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GObject.TypePlugin.use"},{"type":"text","text":"] and [method"},{"code":"GObject.TypePlugin.complete_type_info","type":"codeVoice"},{"type":"text","text":"]"},{"type":"text","text":" "},{"type":"text","text":"on "},{"type":"codeVoice","code":"new_type_plugin"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"At some point the type’s implementation isn’t required anymore, e.g. after","type":"text"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"code":"GObject.TypeClass.unref","type":"codeVoice"},{"text":"] or [func","type":"text"},{"code":"GObject.type_free_instance","type":"codeVoice"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"type":"text","text":"(called when the reference count of an instance drops to zero)."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"This causes the type system to throw away the information retrieved","type":"text"},{"type":"text","text":" "},{"type":"text","text":"from [method"},{"code":"GObject.TypePlugin.complete_type_info","type":"codeVoice"},{"type":"text","text":"] and then it calls"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"code":"GObject.TypePlugin.unuse","type":"codeVoice"},{"type":"text","text":"] on "},{"type":"codeVoice","code":"new_type_plugin"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Things may repeat from the second step."}]}]}]},{"type":"paragraph","inlineContent":[{"text":"So basically, you need to implement a ","type":"text"},{"type":"codeVoice","code":"GTypePlugin"},{"type":"text","text":" type that"},{"type":"text","text":" "},{"type":"text","text":"carries a use_count, once use_count goes from zero to one, you need"},{"type":"text","text":" "},{"text":"to load the implementation to successfully handle the upcoming","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"code":"GObject.TypePlugin.complete_type_info","type":"codeVoice"},{"text":"] call. Later, maybe after","type":"text"},{"type":"text","text":" "},{"text":"succeeding use\/unuse calls, once use_count drops to zero, you can","type":"text"},{"type":"text","text":" "},{"text":"unload the implementation again. The type system makes sure to call","type":"text"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GObject.TypePlugin.use"},{"text":"] and [method","type":"text"},{"code":"GObject.TypePlugin.complete_type_info","type":"codeVoice"},{"text":"]","type":"text"},{"type":"text","text":" "},{"text":"again when the type is needed again.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"[class","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule"},{"text":"] is an implementation of ","type":"text"},{"type":"codeVoice","code":"GTypePlugin"},{"type":"text","text":" that"},{"type":"text","text":" "},{"text":"already implements most of this except for the actual module loading and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"unloading. It even handles multiple registered types per module."}]},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol","type":"reference","isActive":true},{"text":" protocol exposes the methods and properties of an underlying ","type":"text"},{"code":"GTypePlugin","type":"codeVoice"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"The default implementation of these can be found in the protocol extension below."},{"type":"text","text":" "},{"type":"text","text":"For a concrete class that implements these methods and properties, see "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin"},{"text":".","type":"text"},{"type":"text","text":" "},{"text":"Alternatively, use ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef","isActive":true},{"text":" as a lighweight, ","type":"text"},{"type":"codeVoice","code":"unowned"},{"type":"text","text":" reference if you already have an instance you just want to use."}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://GLibObject/documentation/GLibObject/TypePluginProtocol/completeTypeInfo(gType:info:valueTable:)":{"abstract":[{"type":"text","text":"Calls the "},{"code":"complete_type_info","type":"codeVoice"},{"type":"text","text":" function from the "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginClass","type":"reference","isActive":true},{"text":" of ","type":"text"},{"type":"codeVoice","code":"plugin"},{"text":".","type":"text"},{"type":"text","text":" "},{"text":"There should be no need to use this function outside of the GObject","type":"text"},{"type":"text","text":" "},{"type":"text","text":"type system itself."}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin