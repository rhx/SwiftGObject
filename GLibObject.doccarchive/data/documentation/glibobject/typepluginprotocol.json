ure"},{"type":"text","text":" "},{"type":"text","text":"(e.g. abstract or not) of the type."}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol\/typeRegisterDynamic(parentType:typeName:flags:)","title":"typeRegisterDynamic(parentType:typeName:flags:)","kind":"symbol","url":"\/documentation\/glibobject\/typepluginprotocol\/typeregisterdynamic(parenttype:typename:flags:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"typeRegisterDynamic","kind":"identifier"},{"text":"(","kind":"text"},{"text":"parentType","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"GType","preciseIdentifier":"c:@T@GType"},{"text":", ","kind":"text"},{"text":"typeName","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"text":"TypeFlags","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject9TypeFlagsV"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"GType","preciseIdentifier":"c:@T@GType"}],"role":"symbol","type":"topic"},"doc://GLibObject/documentation/GLibObject/TypePluginClass":{"abstract":[{"type":"text","text":"The "},{"isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin","type":"reference"},{"type":"text","text":" interface is used by the type system in order to handle"},{"type":"text","text":" "},{"text":"the lifecycle of dynamically loaded types.","type":"text"}],"role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TypePluginClass","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginClass","url":"\/documentation\/glibobject\/typepluginclass","type":"topic","n