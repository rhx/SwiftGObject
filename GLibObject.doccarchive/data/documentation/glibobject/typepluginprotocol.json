ic"},{"kind":"text","text":"("},{"text":"parentType","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"GType","preciseIdentifier":"c:@T@GType"},{"text":", ","kind":"text"},{"text":"typeName","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"text":"TypeFlags","preciseIdentifier":"s:10GLibObject9TypeFlagsV","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"text":"GType","preciseIdentifier":"c:@T@GType","kind":"typeIdentifier"}],"abstract":[{"type":"text","text":"Registers "},{"code":"typeName","type":"codeVoice"},{"type":"text","text":" as the name of a new dynamic type derived from"},{"type":"text","text":" "},{"type":"codeVoice","code":"parentType"},{"type":"text","text":".  The type system uses the information contained in the"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin","isActive":true},{"text":" structure pointed to by ","type":"text"},{"code":"plugin","type":"codeVoice"},{"text":" to manage the type and its","type":"text"},{"type":"text","text":" "},{"type":"text","text":"instances (if not abstract).  The value of "},{"type":"codeVoice","code":"flags"},{"text":" determines the nature","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(e.g. abstract or not) of the type."}],"title":"typeRegisterDynamic(parentType:typeName:flags:)","kind":"symbol"},"doc://GLibObject/documentation/GLibObject/TypePlugin":{"type":"topic","url":"\/documentation\/glibobject\/typeplugin","kind":"symbol","role":"symbol","title":"TypePlugin","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"TypePlugin","kind":"identifier"}],"abstract":[{"type":"text",