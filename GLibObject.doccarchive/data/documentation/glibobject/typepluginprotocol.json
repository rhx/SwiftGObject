{"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"type":"text","text":"An interface that handles the lifecycle of dynamically loaded types."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol"},"variants":[{"paths":["\/documentation\/glibobject\/typepluginprotocol"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","sections":[],"metadata":{"role":"symbol","symbolKind":"protocol","externalID":"s:10GLibObject18TypePluginProtocolP","roleHeading":"Protocol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TypePluginProtocol"}],"navigatorTitle":[{"text":"TypePluginProtocol","kind":"identifier"}],"title":"TypePluginProtocol","modules":[{"name":"GLibObject"}]},"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject"]]},"topicSections":[{"title":"Instance Properties","generated":true,"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol\/type_plugin_ptr-1f7zf"],"anchor":"Instance-Properties"},{"generated":true,"title":"Instance Methods","anchor":"Instance-Methods","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol\/completeInterfaceInfo(instanceType:interfaceType:info:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol\/completeTypeInfo(gType:info:valueTable:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol\/typeAddInterfaceDynamic(instanceType:interfaceType:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol\/typeRegisterDynamic(parentType:typeName:flags:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol\/unuse()","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol\/use()"]}],"relationshipsSections":[{"identifiers":["doc:\/\/GLibObject\/4GLib14PointerWrapperP"],"kind":"relationships","title":"Inherits From","type":"inheritsFrom"},{"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleProtocol"],"type":"inheritedBy","title":"Inherited By","kind":"relationships"},{"kind":"relationships","title":"Conforming Types","type":"conformingTypes","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"TypePluginProtocol","kind":"identifier"},{"text":" : ","kind":"text"},{"kind":"typeIdentifier","text":"PointerWrapper","preciseIdentifier":"s:4GLib14PointerWrapperP"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Overview","anchor":"overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The GObject type system supports dynamic loading of types."},{"text":" ","type":"text"},{"type":"text","text":"It goes as follows:"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The type is initially introduced (usually upon loading the module","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the first time, or by your main application that knows what modules"},{"text":" ","type":"text"},{"type":"text","text":"introduces what types), like this:"}]},{"syntax":"c","type":"codeListing","code":["new_type_id = g_type_register_dynamic (parent_type_id,","                                       \"TypeName\",","                                       new_type_plugin,","                                       type_flags);"]},{"type":"paragraph","inlineContent":[{"text":"where ","type":"text"},{"type":"codeVoice","code":"new_type_plugin"},{"type":"text","text":" is an implementation of the"},{"type":"text","text":" "},{"type":"codeVoice","code":"GTypePlugin"},{"type":"text","text":" interface."}]}]},{"content":[{"inlineContent":[{"text":"The type’s implementation is referenced, e.g. through","type":"text"},{"text":" ","type":"text"},{"text":"[func","type":"text"},{"type":"codeVoice","code":"GObject.TypeClass.ref"},{"type":"text","text":"] or through [func"},{"code":"GObject.type_create_instance","type":"codeVoice"},{"text":"]","type":"text"},{"type":"text","text":" "},{"text":"(this is being called by [ctor","type":"text"},{"type":"codeVoice","code":"GObject.Object.new"},{"text":"]) or through one of the above","type":"text"},{"type":"text","text":" "},{"type":"text","text":"done on a type derived from "},{"type":"codeVoice","code":"new_type_id"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"This causes the type system to load the type’s implementation by calling","type":"text"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"code":"GObject.TypePlugin.use","type":"codeVoice"},{"text":"] and [method","type":"text"},{"type":"codeVoice","code":"GObject.TypePlugin.complete_type_info"},{"type":"text","text":"]"},{"type":"text","text":" "},{"type":"text","text":"on "},{"code":"new_type_plugin","type":"codeVoice"},{"text":".","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"At some point the type’s implementation isn’t required anymore, e.g. after"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"code":"GObject.TypeClass.unref","type":"codeVoice"},{"type":"text","text":"] or [func"},{"type":"codeVoice","code":"GObject.type_free_instance"},{"text":"]","type":"text"},{"type":"text","text":" "},{"text":"(called when the reference count of an instance drops to zero).","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"This causes the type system to throw away the information retrieved","type":"text"},{"type":"text","text":" "},{"text":"from [method","type":"text"},{"type":"codeVoice","code":"GObject.TypePlugin.complete_type_info"},{"text":"] and then it calls","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GObject.TypePlugin.unuse"},{"text":"] on ","type":"text"},{"type":"codeVoice","code":"new_type_plugin"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Things may repeat from the second step.","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"So basically, you need to implement a ","type":"text"},{"code":"GTypePlugin","type":"codeVoice"},{"text":" type that","type":"text"},{"text":" ","type":"text"},{"text":"carries a use_count, once use_count goes from zero to one, you need","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to load the implementation to successfully handle the upcoming"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"code":"GObject.TypePlugin.complete_type_info","type":"codeVoice"},{"type":"text","text":"] call. Later, maybe after"},{"type":"text","text":" "},{"type":"text","text":"succeeding use\/unuse calls, once use_count drops to zero, you can"},{"type":"text","text":" "},{"type":"text","text":"unload the implementation again. The type system makes sure to call"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"code":"GObject.TypePlugin.use","type":"codeVoice"},{"text":"] and [method","type":"text"},{"type":"codeVoice","code":"GObject.TypePlugin.complete_type_info"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"text":"again when the type is needed again.","type":"text"}]},{"inlineContent":[{"type":"text","text":"[class"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule","isActive":true,"type":"reference"},{"text":"] is an implementation of ","type":"text"},{"type":"codeVoice","code":"GTypePlugin"},{"type":"text","text":" that"},{"text":" ","type":"text"},{"type":"text","text":"already implements most of this except for the actual module loading and"},{"type":"text","text":" "},{"text":"unloading. It even handles multiple registered types per module.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol","type":"reference"},{"type":"text","text":" protocol exposes the methods and properties of an underlying "},{"type":"codeVoice","code":"GTypePlugin"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"The default implementation of these can be found in the protocol extension below."},{"type":"text","text":" "},{"text":"For a concrete class that implements these methods and properties, see ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin","isActive":true,"type":"reference"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Alternatively, use "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef","isActive":true},{"type":"text","text":" as a lighweight, "},{"code":"unowned","type":"codeVoice"},{"text":" reference if you already have an instance you just want to use.","type":"text"}],"type":"paragraph"}]}],"references":{"doc://GLibObject/documentation/GLibObject/TypeModuleProtocol":{"abstract":[{"code":"GTypeModule","type":"codeVoice"},{"type":"text","text":" provides a simple implementation of the "},{"type":"codeVoice","code":"GTypePlugin"},{"text":" ","type":"text"},{"text":"interface.","type":"text"}],"title":"TypeModuleProtocol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TypeModuleProtocol"}],"navigatorTitle":[{"kind":"identifier","text":"TypeModuleProtocol"}],"url":"\/documentation\/glibobject\/typemoduleprotocol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleProtocol","kind":"symbol","type":"topic","role":"symbol"},"doc://GLibObject/