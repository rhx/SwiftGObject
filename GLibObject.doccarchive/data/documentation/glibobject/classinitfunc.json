{"sections":[],"kind":"symbol","primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ClassInitFunc","kind":"identifier"},{"text":" = ","kind":"text"},{"text":"GClassInitFunc","kind":"typeIdentifier","preciseIdentifier":"c:gtype.h@T@GClassInitFunc"}]}],"kind":"declarations"},{"content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function should initialize all static class members."}]},{"inlineContent":[{"text":"The initialization process of a class involves:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Copying common members from the parent class over to the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"derived class structure."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Zero initialization of the remaining members not copied","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"over from the parent class."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Invocation of the "},{"type":"codeVoice","code":"GBaseInitFunc()"},{"text":" initializers of all parent","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"types and the class’ type."}]}]},{"content":[{"inlineContent":[{"text":"Invocation of the class’ ","type":"text"},{"code":"GClassInitFunc()","type":"codeVoice"},{"type":"text","text":" initializer."}],"type":"paragraph"}]}]},{"inlineContent":[{"text":"Since derived classes are partially initialized through a memory copy","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of the parent class, the general rule is that "},{"code":"GBaseInitFunc()","type":"codeVoice"},{"type":"text","text":" and"},{"type":"text","text":" "},{"code":"GBaseFinalizeFunc()","type":"codeVoice"},{"type":"text","text":" should take care of necessary reinitialization"},{"type":"text","text":" "},{"type":"text","text":"and release of those class members that were introduced by the type"},{"type":"text","text":" "},{"type":"text","text":"that specified these "},{"code":"GBaseInitFunc()``\/GBaseFinalizeFunc()","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"code":"GClassInitFunc()","type":"codeVoice"},{"text":" should only care about initializing static","type":"text"},{"text":" ","type":"text"},{"text":"class members, while dynamic class members (such as allocated strings","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"or reference counted resources) are better handled by a "},{"code":"GBaseInitFunc()","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"for this type, so proper initialization of the dynamic class members"},{"text":" ","type":"text"},{"type":"text","text":"is performed for class initialization of derived types as well."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An example may help to correspond the intend of the different class"},{"type":"text","text":" "},{"type":"text","text":"initializers:"}]},{"inlineContent":[{"text":"(C Language Example):","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["typedef struct {","  GObjectClass parent_class;","  gint         static_integer;","  gchar       *dynamic_string;","} TypeAClass;","static void","type_a_base_class_init (TypeAClass *class)","{","  class->dynamic_string = g_strdup (\"some string\");","}","static void","type_a_base_class_finalize (TypeAClass *class)","{","  g_free (class->dynamic_string);","}","static void","type_a_class_init (TypeAClass *class)","{","  class->static_integer = 42;","}","","typedef struct {","  TypeAClass   parent_class;","  gfloat       static_float;","  GString     *dynamic_gstring;","} TypeBClass;","static void","type_b_base_class_init (TypeBClass *class)","{","  class->dynamic_gstring = g_string_new (\"some other string\");","}","static void","type_b_base_class_finalize (TypeBClass *class)","{","  g_string_free (class->dynamic_gstring);","}","static void","type_b_class_init (TypeBClass *class)","{","  class->static_float = 3.14159265358979323846;","}"],"syntax":"C"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Initialization of TypeBClass will first cause initialization of"},{"text":" ","type":"text"},{"type":"text","text":"TypeAClass (derived classes reference their parent classes, see"},{"text":" ","type":"text"},{"code":"g_type_class_ref()","type":"codeVoice"},{"type":"text","text":" on this)."}]},{"inlineContent":[{"text":"Initialization of TypeAClass roughly involves zero-initializing its fields,","type":"text"},{"text":" ","type":"text"},{"text":"then calling its ","type":"text"},{"type":"codeVoice","code":"GBaseInitFunc()"},{"text":" ","type":"text"},{"code":"type_a_base_class_init()","type":"codeVoice"},{"type":"text","text":" to allocate"},{"type":"text","text":" "},{"text":"its dynamic members (dynamic_string), and finally calling its ","type":"text"},{"type":"codeVoice","code":"GClassInitFunc()"},{"type":"text","text":" "},{"type":"codeVoice","code":"type_a_class_init()"},{"type":"text","text":" to initialize its static members (static_integer)."},{"type":"text","text":" "},{"type":"text","text":"The first step in the initialization process of TypeBClass is then"},{"type":"text","text":" "},{"text":"a plain memory copy of the contents of TypeAClass into TypeBClass and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"zero-initialization of the remaining fields in TypeBClass."},{"type":"text","text":" "},{"type":"text","text":"The dynamic members of TypeAClass within TypeBClass now need"},{"text":" ","type":"text"},{"text":"reinitialization which is performed by calling ","type":"text"},{"type":"codeVoice","code":"type_a_base_class_init()"},{"type":"text","text":" "},{"text":"with an argument of TypeBClass.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"After that, the "},{"code":"GBaseInitFunc()","type":"codeVoice"},{"text":" of TypeBClass, ","type":"text"},{"code":"type_b_base_class_init()","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"is called to allocate the dynamic members of TypeBClass (dynamic_gstring),"},{"text":" ","type":"text"},{"type":"text","text":"and finally the "},{"type":"codeVoice","code":"GClassInitFunc()"},{"type":"text","text":" of TypeBClass, "},{"code":"type_b_class_init()","type":"codeVoice"},{"type":"text","text":","},{"text":" ","type":"text"},{"text":"is called to complete the initialization process with the static members","type":"text"},{"text":" ","type":"text"},{"text":"(static_float).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Corresponding finalization counter parts to the ","type":"text"},{"type":"codeVoice","code":"GBaseInitFunc()"},{"text":" functions","type":"text"},{"type":"text","text":" "},{"type":"text","text":"have to be provided to release allocated resources at class finalization"},{"text":" ","type":"text"},{"text":"time.","type":"text"}]}],"kind":"content"}],"abstract":[{"type":"text","text":"A callback function used by the type system to initialize the class"},{"type":"text","text":" "},{"type":"text","text":"of a specific type."}],"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"paths":["\/documentation\/glibobject\/classinitfunc"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"fragments":[{"kind":"keyword","text":"typealias"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ClassInitFunc"}],"navigatorTitle":[{"text":"ClassInitFunc","kind":"identifier"}],"modules":[{"name":"GLibObject"}],"roleHeading":"Type Alias","title":"ClassInitFunc","externalID":"s:10GLibObject13ClassInitFunca","symbolKind":"typealias","role":"symbol"},"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClassInitFunc","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject"]]},"references":{"doc://GLibObject/documentation/GLibObject":{"role":"collection","type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","abstract":[],"title":"GLibObject","kind":"symbol","url":"\/documentation\/glibobject"},"doc://GLibObject/documentation/GLibObject/ClassInitFunc":{"role":"symbol","url":"\/documentation\/glibobject\/classinitfunc","kind":"symbol","fragments":[{"kind":"keyword","text":"typealias"},{"text":" ","kind":"text"},{"text":"ClassInitFunc","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"ClassInitFunc"}],"abstract":[{"type":"text","text":"A callback function used by the type system to initialize the class"},{"text":" ","type":"text"},{"type":"text","text":"of a specific type."}],"type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClassInitFunc","title":"ClassInitFunc"}}}