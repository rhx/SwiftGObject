{"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClassInitFunc","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"A callback function used by the type system to initialize the class"},{"text":" ","type":"text"},{"type":"text","text":"of a specific type."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/classinitfunc"]}],"metadata":{"fragments":[{"kind":"keyword","text":"typealias"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ClassInitFunc"}],"symbolKind":"typealias","externalID":"s:10GLibObject13ClassInitFunca","navigatorTitle":[{"text":"ClassInitFunc","kind":"identifier"}],"modules":[{"name":"GLibObject"}],"roleHeading":"Type Alias","title":"ClassInitFunc","role":"symbol"},"sections":[],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ClassInitFunc"},{"kind":"text","text":" = "},{"text":"GClassInitFunc","kind":"typeIdentifier","preciseIdentifier":"c:gtype.h@T@GClassInitFunc"}]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"inlineContent":[{"type":"text","text":"This function should initialize all static class members."}],"type":"paragraph"},{"inlineContent":[{"text":"The initialization process of a class involves:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Copying common members from the parent class over to the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"derived class structure."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Zero initialization of the remaining members not copied","type":"text"},{"type":"text","text":" "},{"type":"text","text":"over from the parent class."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Invocation of the ","type":"text"},{"type":"codeVoice","code":"GBaseInitFunc()"},{"type":"text","text":" initializers of all parent"},{"type":"text","text":" "},{"type":"text","text":"types and the class’ type."}]}]},{"content":[{"inlineContent":[{"text":"Invocation of the class’ ","type":"text"},{"type":"codeVoice","code":"GClassInitFunc()"},{"text":" initializer.","type":"text"}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"Since derived classes are partially initialized through a memory copy"},{"type":"text","text":" "},{"text":"of the parent class, the general rule is that ","type":"text"},{"type":"codeVoice","code":"GBaseInitFunc()"},{"type":"text","text":" and"},{"type":"text","text":" "},{"code":"GBaseFinalizeFunc()","type":"codeVoice"},{"text":" should take care of necessary reinitialization","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and release of those class members that were introduced by the type"},{"type":"text","text":" "},{"text":"that specified these ","type":"text"},{"type":"codeVoice","code":"GBaseInitFunc()``\/GBaseFinalizeFunc()"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"GClassInitFunc()"},{"text":" should only care about initializing static","type":"text"},{"type":"text","text":" "},{"type":"text","text":"class members, while dynamic class members (such as allocated strings"},{"text":" ","type":"text"},{"type":"text","text":"or reference counted resources) are better handled by a "},{"code":"GBaseInitFunc()","type":"codeVoice"},{"text":" ","type":"text"},{"text":"for this type, so proper initialization of the dynamic class members","type":"text"},{"text":" ","type":"text"},{"text":"is performed for class initialization of derived types as well.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An example may help to correspond the intend of the different class"},{"type":"text","text":" "},{"text":"initializers:","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"(C Language Example):","type":"text"}]},{"syntax":"C","type":"codeListing","code":["typedef struct {","  GObjectClass parent_class;","  gint         static_integer;","  gchar       *dynamic_string;","} TypeAClass;","static void","type_a_base_class_init (TypeAClass *class)","{","  class->dynamic_string = g_strdup (\"some string\");","}","static void","type_a_base_class_finalize (TypeAClass *class)","{","  g_free (class->dynamic_string);","}","static void","type_a_class_init (TypeAClass *class)","{","  class->static_integer = 42;","}","","typedef struct {","  TypeAClass   parent_class;","  gfloat       static_float;","  GString     *dynamic_gstring;","} TypeBClass;","static void","type_b_base_class_init (TypeBClass *class)","{","  class->dynamic_gstring = g_string_new (\"some other string\");","}","static void","type_b_base_class_finalize (TypeBClass *class)","{","  g_string_free (class->dynamic_gstring);","}","static void","type_b_class_init (TypeBClass *class)","{","  class->static_float = 3.14159265358979323846;","}"]},{"inlineContent":[{"text":"Initialization of TypeBClass will first cause initialization of","type":"text"},{"text":" ","type":"text"},{"text":"TypeAClass (derived classes reference their parent classes, see","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_type_class_ref()"},{"type":"text","text":" on this)."}],"type":"paragraph"},{"inlineContent":[{"text":"Initialization of TypeAClass roughly involves zero-initializing its fields,","type":"text"},{"text":" ","type":"text"},{"text":"then calling its ","type":"text"},{"type":"codeVoice","code":"GBaseInitFunc()"},{"text":" ","type":"text"},{"code":"type_a_base_class_init()","type":"codeVoice"},{"type":"text","text":" to allocate"},{"type":"text","text":" "},{"type":"text","text":"its dynamic members (dynamic_string), and finally calling its "},{"code":"GClassInitFunc()","type":"codeVoice"},{"text":" ","type":"text"},{"type":"codeVoice","code":"type_a_class_init()"},{"text":" to initialize its static members (static_integer).","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The first step in the initialization process of TypeBClass is then"},{"type":"text","text":" "},{"type":"text","text":"a plain memory copy of the contents of TypeAClass into TypeBClass and"},{"type":"text","text":" "},{"type":"text","text":"zero-initialization of the remaining fields in TypeBClass."},{"text":" ","type":"text"},{"type":"text","text":"The dynamic members of TypeAClass within TypeBClass now need"},{"type":"text","text":" "},{"type":"text","text":"reinitialization which is performed by calling "},{"type":"codeVoice","code":"type_a_base_class_init()"},{"type":"text","text":" "},{"type":"text","text":"with an argument of TypeBClass."}],"type":"paragraph"},{"inlineContent":[{"text":"After that, the ","type":"text"},{"code":"GBaseInitFunc()","type":"codeVoice"},{"text":" of TypeBClass, ","type":"text"},{"code":"type_b_base_class_init()","type":"codeVoice"},{"text":" ","type":"text"},{"text":"is called to allocate the dynamic members of TypeBClass (dynamic_gstring),","type":"text"},{"type":"text","text":" "},{"text":"and finally the ","type":"text"},{"type":"codeVoice","code":"GClassInitFunc()"},{"type":"text","text":" of TypeBClass, "},{"type":"codeVoice","code":"type_b_class_init()"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"is called to complete the initialization process with the static members"},{"type":"text","text":" "},{"type":"text","text":"(static_float)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Corresponding finalization counter parts to the "},{"code":"GBaseInitFunc()","type":"codeVoice"},{"type":"text","text":" functions"},{"text":" ","type":"text"},{"text":"have to be provided to release allocated resources at class finalization","type":"text"},{"type":"text","text":" "},{"type":"text","text":"time."}]}]}],"references":{"doc://GLibObject/documentation/GLibObject":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","url":"\/documentation\/glibobject","abstract":[],"role":"collection","kind":"symbol","title":"GLibObject","type":"topic"},"doc://GLibObject/documentation/GLibObject/ClassInitFunc":{"title":"ClassInitFunc","type":"topic","role":"symbol","fragments":[{"text":"typealias","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"ClassInitFunc"}],"abstract":[{"type":"text","text":"A callback function used by the type system to initialize the class"},{"text":" ","type":"text"},{"text":"of a specific type.","type":"text"}],"url":"\/documentation\/glibobject\/classinitfunc","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClassInitFunc","navigatorTitle":[{"kind":"identifier","text":"ClassInitFunc"}],"kind":"symbol"}}}