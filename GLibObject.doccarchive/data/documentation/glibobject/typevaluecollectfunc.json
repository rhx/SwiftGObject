{"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"fragments":[{"text":"typealias","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"TypeValueCollectFunc"}],"modules":[{"name":"GLibObject"}],"roleHeading":"Type Alias","role":"symbol","title":"TypeValueCollectFunc","externalID":"s:10GLibObject20TypeValueCollectFunca","navigatorTitle":[{"kind":"identifier","text":"TypeValueCollectFunc"}],"symbolKind":"typealias"},"sections":[],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject"]]},"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeValueCollectFunc","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"typealias","kind":"keyword"},{"kind":"text","text":" "},{"text":"TypeValueCollectFunc","kind":"identifier"},{"text":" = ","kind":"text"},{"text":"GTypeValueCollectFunc","kind":"typeIdentifier","preciseIdentifier":"c:@T@GTypeValueCollectFunc"}],"languages":["swift"]}]},{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"This function should setup ","type":"text"},{"type":"codeVoice","code":"value"},{"text":" similar to ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeValueInitFunc","type":"reference","isActive":true},{"text":"; e.g.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for a string value that does not allow "},{"code":"NULL","type":"codeVoice"},{"text":" pointers, it needs to either","type":"text"},{"type":"text","text":" "},{"type":"text","text":"emit an error, or do an implicit conversion by storing an empty string."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"value"},{"type":"text","text":" passed in to this function has a zero-filled data array, so"},{"text":" ","type":"text"},{"type":"text","text":"just like for "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeValueInitFunc","type":"reference","isActive":true},{"text":" it is guaranteed to not contain any old","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"contents that might need freeing."}]},{"inlineContent":[{"type":"text","text":"The "},{"code":"nCollectValues","type":"codeVoice"},{"type":"text","text":" argument is the string length of the "},{"type":"codeVoice","code":"collect_format"},{"type":"text","text":" "},{"text":"field of ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeValueTable","type":"reference"},{"text":", and ","type":"text"},{"type":"codeVoice","code":"collect_values"},{"type":"text","text":" is an array of "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeCValue","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"with length of ","type":"text"},{"type":"codeVoice","code":"nCollectValues"},{"type":"text","text":", containing the collected values according"},{"type":"text","text":" "},{"type":"text","text":"to "},{"code":"collect_format","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"collectFlags"},{"type":"text","text":" argument provided as a hint by the caller. It may"},{"type":"text","text":" "},{"type":"text","text":"contain the flag "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/valueNocopyContents"},{"text":" indicating that the collected","type":"text"},{"type":"text","text":" "},{"text":"value contents may be considered ‘static’ for the duration of the ","type":"text"},{"type":"codeVoice","code":"value"},{"type":"text","text":" "},{"type":"text","text":"lifetime. Thus an extra copy of the contents stored in "},{"type":"codeVoice","code":"collectValues"},{"type":"text","text":" is"},{"text":" ","type":"text"},{"text":"not required for assignment to ","type":"text"},{"code":"value","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"For our above string example, we continue with:","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"(C Language Example):","type":"text"}]},{"code":["if (!collect_values[0].v_pointer)","  value->data[0].v_pointer = g_strdup (\"\");","else if (collect_flags & G_VALUE_NOCOPY_CONTENTS)","  {","    value->data[0].v_pointer = collect_values[0].v_pointer;","    \/\/ keep a flag for the value_free() implementation to not free this string","    value->data[1].v_uint = G_VALUE_NOCOPY_CONTENTS;","  }","else","  value->data[0].v_pointer = g_strdup (collect_values[0].v_pointer);","return NULL;"],"type":"codeListing","syntax":"C"},{"type":"paragraph","inlineContent":[{"text":"It should be noted, that it is generally a bad idea to follow the","type":"text"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/valueNocopyContents"},{"type":"text","text":" hint for reference counted types. Due to"},{"type":"text","text":" "},{"type":"text","text":"reentrancy requirements and reference count assertions performed"},{"text":" ","type":"text"},{"text":"by the signal emission code, reference counts should always be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"incremented for reference counted contents stored in the "},{"code":"value->data","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"array. To deviate from our string example for a moment, and taking"},{"type":"text","text":" "},{"type":"text","text":"a look at an exemplary implementation for "},{"type":"codeVoice","code":"GTypeValueTable.collect_value()"},{"text":" ","type":"text"},{"type":"text","text":"of "},{"type":"codeVoice","code":"GObject"},{"type":"text","text":":"}]},{"inlineContent":[{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"syntax":"C","code":["GObject *object = G_OBJECT (collect_values[0].v_pointer);","g_return_val_if_fail (object != NULL,","   g_strdup_printf (\"Object %p passed as invalid NULL pointer\", object));","\/\/ never honour G_VALUE_NOCOPY_CONTENTS for ref-counted types","value->data[0].v_pointer = g_object_ref (object);","return NULL;"],"type":"codeListing"},{"inlineContent":[{"text":"The reference count for valid objects is always incremented, regardless","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of "},{"code":"collect_flags","type":"codeVoice"},{"text":". For invalid objects, the example returns a newly","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"allocated string without altering "},{"type":"codeVoice","code":"value"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Upon success, "},{"code":"collect_value()","type":"codeVoice"},{"type":"text","text":" needs to return "},{"code":"NULL","type":"codeVoice"},{"type":"text","text":". If, however,"},{"type":"text","text":" "},{"text":"an error condition occurred, ","type":"text"},{"type":"codeVoice","code":"collect_value()"},{"text":" should return a newly","type":"text"},{"type":"text","text":" "},{"type":"text","text":"allocated string containing an error diagnostic."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The calling code makes no assumptions about the "},{"type":"codeVoice","code":"value"},{"type":"text","text":" contents being"},{"type":"text","text":" "},{"type":"text","text":"valid upon error returns, "},{"code":"value","type":"codeVoice"},{"text":" is simply thrown away without further","type":"text"},{"type":"text","text":" "},{"text":"freeing. As such, it is a good idea to not allocate ","type":"text"},{"code":"GValue","type":"codeVoice"},{"type":"text","text":" contents"},{"type":"text","text":" "},{"type":"text","text":"prior to returning an error; however, "},{"code":"collect_values()","type":"codeVoice"},{"type":"text","text":" is not obliged"},{"text":" ","type":"text"},{"type":"text","text":"to return a correctly setup "},{"type":"codeVoice","code":"value"},{"type":"text","text":" for error returns, simply because"},{"type":"text","text":" "},{"type":"text","text":"any non-"},{"type":"codeVoice","code":"NULL"},{"type":"text","text":" return is considered a fatal programming error, and"},{"text":" ","type":"text"},{"type":"text","text":"further program behaviour is undefined."}]}],"kind":"content"}],"kind":"symbol","variants":[{"paths":["\/documentation\/glibobject\/typevaluecollectfunc"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"This function is responsible for converting the values collected from"},{"text":" ","type":"text"},{"type":"text","text":"a variadic argument list into contents suitable for storage in a "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Value","isActive":true},{"type":"text","text":"."}],"references":{"doc://GLibObject/documentation/GLibObject/TypeValueCollectFunc":{"abstract":[{"type":"text","text":"This function is responsible for converting the values collected from"},{"type":"text","text":" "},{"text":"a variadic argument list into contents suitable for storage in a ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Value","isActive":true,"type":"reference"},{"text":".","type":"text"}],"type":"topic","url":"\/documentation\/glibobject\/typevaluecollectfunc","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeValueCollectFunc","fragments":[{"text":"typealias","kind":"keyword"},{"kind":"text","text":" "},{"text":"TypeValueCollectFunc","kind":"identifier"}],"navigatorTitle":[{"text":"TypeValueCollectFunc","kind":"identifier"}],"kind":"symbol","role":"symbol","title":"TypeValueCollectFunc"},"doc://GLibObject/documentation/GLibObject/valueNocopyContents":{"type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"text":"valueNocopyContents","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:s5Int32V","text":"Int32"}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/valueNocopyContents","abstract":[{"type":"text","text":"Flag to indicate that allocated data in a [struct"},{"isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Value","type":"reference"},{"text":"] shouldn’t be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"copied."}],"title":"valueNocopyContents","url":"\/documentation\/glibobject\/valuenocopycontents","role":"symbol"},"doc://GLibObject/documentation/GLibObject":{"role":"collection","type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","abstract":[],"title":"GLibObject","kind":"symbol","url":"\/documentation\/glibobject"},"doc://GLibObject/documentation/GLibObject/TypeCValue":{"role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"TypeCValue"}],"abstract":[{"text":"A union holding one collected value.","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"TypeCValue"}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeCValue","url":"\/documentation\/glibobject\/typecvalue","type":"topic","title":"TypeCValue","kind":"symbol"},"doc://GLibObject/documentation/GLibObject/TypeValueInitFunc":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeValueInitFunc","type":"topic","kind":"symbol","fragments":[{"text":"typealias","kind":"keyword"},{"kind":"text","text":" "},{"text":"TypeValueInitFunc","kind":"identifier"}],"url":"\/documentation\/glibobject\/typevalueinitfunc","abstract":[{"text":"Initializes the value contents by setting the fields of the ","type":"text"},{"type":"codeVoice","code":"value->data"},{"type":"text","text":" "},{"type":"text","text":"array."}],"title":"TypeValueInitFunc","role":"symbol","navigatorTitle":[{"text":"TypeValueInitFunc","kind":"identifier"}]},"doc://GLibObject/documentation/GLibObject/TypeValueTable":{"abstract":[],"kind":"symbol","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"TypeValueTable","kind":"identifier"}],"role":"symbol","navigatorTitle":[{"text":"TypeValueTable","kind":"identifier"}],"title":"TypeValueTable","url":"\/documentation\/glibobject\/typevaluetable","type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeValueTable"},"doc://GLibObject/documentation/GLibObject/Value":{"type":"topic","url":"\/documentation\/glibobject\/value","abstract":[{"text":"This class is the main Swift wrapper with memory management","type":"text"},{"type":"text","text":" "},{"text":"for underlying ","type":"text"},{"type":"codeVoice","code":"GValues"},{"type":"text","text":" (the opaque GLib structure used to"},{"type":"text","text":" "},{"type":"text","text":"hold different types of values."}],"title":"Value","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"Value"}],"role":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Value","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Value"}]}}}