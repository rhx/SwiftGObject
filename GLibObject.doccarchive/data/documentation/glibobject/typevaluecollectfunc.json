{"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject"]]},"sections":[],"metadata":{"role":"symbol","externalID":"s:10GLibObject20TypeValueCollectFunca","navigatorTitle":[{"text":"TypeValueCollectFunc","kind":"identifier"}],"modules":[{"name":"GLibObject"}],"title":"TypeValueCollectFunc","symbolKind":"typealias","fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"text":"TypeValueCollectFunc","kind":"identifier"}],"roleHeading":"Type Alias"},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/typevaluecollectfunc"]}],"abstract":[{"text":"This function is responsible for converting the values collected from","type":"text"},{"type":"text","text":" "},{"text":"a variadic argument list into contents suitable for storage in a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Value"},{"type":"text","text":"."}],"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"typealias","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"TypeValueCollectFunc"},{"text":" = ","kind":"text"},{"text":"GTypeValueCollectFunc","kind":"typeIdentifier","preciseIdentifier":"c:@T@GTypeValueCollectFunc"}]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"This function should setup ","type":"text"},{"type":"codeVoice","code":"value"},{"type":"text","text":" similar to "},{"isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeValueInitFunc","type":"reference"},{"type":"text","text":"; e.g."},{"type":"text","text":" "},{"type":"text","text":"for a string value that does not allow "},{"type":"codeVoice","code":"NULL"},{"text":" pointers, it needs to either","type":"text"},{"type":"text","text":" "},{"text":"emit an error, or do an implicit conversion by storing an empty string.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"value","type":"codeVoice"},{"type":"text","text":" passed in to this function has a zero-filled data array, so"},{"type":"text","text":" "},{"text":"just like for ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeValueInitFunc","isActive":true,"type":"reference"},{"text":" it is guaranteed to not contain any old","type":"text"},{"type":"text","text":" "},{"type":"text","text":"contents that might need freeing."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"code":"nCollectValues","type":"codeVoice"},{"type":"text","text":" argument is the string length of the "},{"type":"codeVoice","code":"collect_format"},{"type":"text","text":" "},{"type":"text","text":"field of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeValueTable"},{"type":"text","text":", and "},{"type":"codeVoice","code":"collect_values"},{"text":" is an array of ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeCValue","isActive":true},{"text":" ","type":"text"},{"text":"with length of ","type":"text"},{"type":"codeVoice","code":"nCollectValues"},{"type":"text","text":", containing the collected values according"},{"type":"text","text":" "},{"text":"to ","type":"text"},{"type":"codeVoice","code":"collect_format"},{"text":".","type":"text"}]},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"collectFlags"},{"type":"text","text":" argument provided as a hint by the caller. It may"},{"type":"text","text":" "},{"text":"contain the flag ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/valueNocopyContents","type":"reference","isActive":true},{"text":" indicating that the collected","type":"text"},{"type":"text","text":" "},{"text":"value contents may be considered ‘static’ for the duration of the ","type":"text"},{"type":"codeVoice","code":"value"},{"text":" ","type":"text"},{"text":"lifetime. Thus an extra copy of the contents stored in ","type":"text"},{"code":"collectValues","type":"codeVoice"},{"text":" is","type":"text"},{"type":"text","text":" "},{"text":"not required for assignment to ","type":"text"},{"type":"codeVoice","code":"value"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For our above string example, we continue with:"}]},{"inlineContent":[{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"type":"codeListing","syntax":"C","code":["if (!collect_values[0].v_pointer)","  value->data[0].v_pointer = g_strdup (\"\");","else if (collect_flags & G_VALUE_NOCOPY_CONTENTS)","  {","    value->data[0].v_pointer = collect_values[0].v_pointer;","    \/\/ keep a flag for the value_free() implementation to not free this string","    value->data[1].v_uint = G_VALUE_NOCOPY_CONTENTS;","  }","else","  value->data[0].v_pointer = g_strdup (collect_values[0].v_pointer);","return NULL;"]},{"inlineContent":[{"text":"It should be noted, that it is generally a bad idea to follow the","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/valueNocopyContents"},{"type":"text","text":" hint for reference counted types. Due to"},{"type":"text","text":" "},{"type":"text","text":"reentrancy requirements and reference count assertions performed"},{"type":"text","text":" "},{"type":"text","text":"by the signal emission code, reference counts should always be"},{"type":"text","text":" "},{"type":"text","text":"incremented for reference counted contents stored in the "},{"code":"value->data","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"array. To deviate from our string example for a moment, and taking"},{"text":" ","type":"text"},{"type":"text","text":"a look at an exemplary implementation for "},{"type":"codeVoice","code":"GTypeValueTable.collect_value()"},{"text":" ","type":"text"},{"text":"of ","type":"text"},{"code":"GObject","type":"codeVoice"},{"type":"text","text":":"}],"type":"paragraph"},{"inlineContent":[{"text":"(C Language Example):","type":"text"}],"type":"paragraph"},{"code":["GObject *object = G_OBJECT (collect_values[0].v_pointer);","g_return_val_if_fail (object != NULL,","   g_strdup_printf (\"Object %p passed as invalid NULL pointer\", object));","\/\/ never honour G_VALUE_NOCOPY_CONTENTS for ref-counted types","value->data[0].v_pointer = g_object_ref (object);","return NULL;"],"type":"codeListing","syntax":"C"},{"type":"paragraph","inlineContent":[{"text":"The reference count for valid objects is always incremented, regardless","type":"text"},{"type":"text","text":" "},{"text":"of ","type":"text"},{"code":"collect_flags","type":"codeVoice"},{"type":"text","text":". For invalid objects, the example returns a newly"},{"type":"text","text":" "},{"type":"text","text":"allocated string without altering "},{"type":"codeVoice","code":"value"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"Upon success, "},{"code":"collect_value()","type":"codeVoice"},{"type":"text","text":" needs to return "},{"type":"codeVoice","code":"NULL"},{"type":"text","text":". If, however,"},{"text":" ","type":"text"},{"type":"text","text":"an error condition occurred, "},{"type":"codeVoice","code":"collect_value()"},{"text":" should return a newly","type":"text"},{"type":"text","text":" "},{"type":"text","text":"allocated string containing an error diagnostic."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The calling code makes no assumptions about the "},{"type":"codeVoice","code":"value"},{"type":"text","text":" contents being"},{"type":"text","text":" "},{"text":"valid upon error returns, ","type":"text"},{"code":"value","type":"codeVoice"},{"text":" is simply thrown away without further","type":"text"},{"type":"text","text":" "},{"type":"text","text":"freeing. As such, it is a good idea to not allocate "},{"code":"GValue","type":"codeVoice"},{"text":" contents","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"prior to returning an error; however, "},{"type":"codeVoice","code":"collect_values()"},{"type":"text","text":" is not obliged"},{"type":"text","text":" "},{"type":"text","text":"to return a correctly setup "},{"type":"codeVoice","code":"value"},{"type":"text","text":" for error returns, simply because"},{"type":"text","text":" "},{"text":"any non-","type":"text"},{"type":"codeVoice","code":"NULL"},{"type":"text","text":" return is considered a fatal programming error, and"},{"type":"text","text":" "},{"text":"further program behaviour is undefined.","type":"text"}]}]}],"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeValueCollectFunc","interfaceLanguage":"swift"},"references":{"doc://GLibObject/documentation/GLibObject/valueNocopyContents":{"abstract":[{"text":"Flag to indicate that allocated data in a [struct","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Value","type":"reference"},{"type":"text","text":"] shouldn’t be"},{"type":"text","text":" "},{"text":"copied.","type":"text"}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/valueNocopyContents","url":"\/documentation\/glibobject\/valuenocopycontents","role":"symbol","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"text":"valueNocopyContents","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int32","kind":"typeIdentifier","preciseIdentifier":"s:s5Int32V"}],"title":"valueNocopyContents","type":"topic","kind":"symbol"},"doc://GLibObject/documentation/GLibObject":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","url":"\/documentation\/glibobject","abstract":[]