er":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeValueCollectFunc","navigatorTitle":[{"text":"TypeValueCollectFunc","kind":"identifier"}],"kind":"symbol"},"doc://GLibObject/documentation/GLibObject/TypeValueInitFunc":{"url":"\/documentation\/glibobject\/typevalueinitfunc","kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeValueInitFunc","type":"topic","abstract":[{"text":"Initializes the value contents by setting the fields of the ","type":"text"},{"type":"codeVoice","code":"value->data"},{"type":"text","text":" "},{"text":"array.","type":"text"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"TypeValueInitFunc"}],"title":"TypeValueInitFunc","fragments":[{"text":"typealias","kind":"keyword"},{"kind":"text","text":" "},{"text":"TypeValueInitFunc","kind":"identifier"}]},"doc://GLibObject/documentation/GLibObject/TypeValueTable":{"kind":"symbol","title":"TypeValueTable","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeValueTable","abstract":[],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"TypeValueTable"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TypeValueTable","kind":"identifier"}],"url":"\/documentation\/glibobject\/typevaluetable","type":"topic"}}}