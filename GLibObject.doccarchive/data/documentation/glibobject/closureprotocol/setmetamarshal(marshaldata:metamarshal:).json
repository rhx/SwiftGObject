{"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","sections":[],"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureProtocol\/setMetaMarshal(marshalData:metaMarshal:)","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/closureprotocol\/setmetamarshal(marshaldata:metamarshal:)"]}],"abstract":[{"type":"text","text":"Sets the meta marshaller of "},{"type":"codeVoice","code":"closure"},{"text":".","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"setMetaMarshal"},{"text":"(","kind":"text"},{"text":"marshalData","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"text":"? = nil, ","kind":"text"},{"text":"metaMarshal","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"GClosureMarshal","preciseIdentifier":"c:gclosure.h@T@GClosureMarshal"},{"text":")","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"text":"A meta marshaller wraps the ","type":"text"},{"type":"codeVoice","code":"closure"},{"text":"’s marshal and modifies the way","type":"text"},{"type":"text","text":" "},{"type":"text","text":"it is called in some fashion. The most common use of this facility"},{"type":"text","text":" "},{"text":"is for C callbacks.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The same marshallers (generated by "},{"type":"reference","identifier":"#glib-genmarshal","isActive":true},{"text":"),","type":"text"},{"text":" ","type":"text"},{"text":"are used everywhere, but the way that we get the callback function","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"differs. In most cases we want to use the "},{"type":"codeVoice","code":"closure"},{"type":"text","text":"’s callback, but in"},{"type":"text","text":" "},{"type":"text","text":"other cases we want to use some different technique to retrieve the"},{"text":" ","type":"text"},{"type":"text","text":"callback function."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"For example, class closures for signals (see","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_signal_type_cclosure_new()"},{"text":") retrieve the callback function from a","type":"text"},{"text":" ","type":"text"},{"text":"fixed offset in the class structure.  The meta marshaller retrieves","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the right callback and passes it to the marshaller as the"},{"type":"text","text":" "},{"type":"codeVoice","code":"marshalData"},{"type":"text","text":" argument."}]}]}],"metadata":{"role":"symbol","symbolKind":"method","extendedModule":"GLibObject","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"setMetaMarshal"},{"text":"(","kind":"text"},{"text":"marshalData","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"text":"?, ","kind":"text"},{"text":"metaMarshal","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:gclosure.h@T@GClosureMarshal","text":"GClosureMarshal"},{"kind":"text","text":")"}],"title":"setMetaMarshal(marshalData:metaMarshal:)","modules":[{"name":"GLibObject"}],"externalID":"s:10GLibObject15ClosureProtocolPAAE14setMetaMarshal11marshalData04metaG0ySvSg_ySpySo9_GClosureVGSg_SpySo7_GValueVGSgs6UInt32VSPyAMGSgA2GtXCtF","roleHeading":"Instance Method"},"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureProtocol"]]},"references":{"doc:/