{"schemaVersion":{"patch":0,"minor":3,"major":0},"sections":[],"metadata":{"symbolKind":"method","role":"symbol","roleHeading":"Instance Method","modules":[{"name":"GLibObject"}],"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"setMetaMarshal"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"marshalData"},{"kind":"text","text":": "},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"metaMarshal"},{"kind":"text","text":": "},{"preciseIdentifier":"c:gclosure.h@T@GClosureMarshal","kind":"typeIdentifier","text":"GClosureMarshal"},{"kind":"text","text":")"}],"title":"setMetaMarshal(marshalData:metaMarshal:)","extendedModule":"GLibObject","externalID":"s:10GLibObject15ClosureProtocolPAAE14setMetaMarshal11marshalData04metaG0ySvSg_ySpySo9_GClosureVGSg_SpySo7_GValueVGSgs6UInt32VSPyAMGSgA2GtXCtF"},"abstract":[{"type":"text","text":"Sets the meta marshaller of "},{"type":"codeVoice","code":"closure"},{"type":"text","text":"."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"setMetaMarshal","kind":"identifier"},{"kind":"text","text":"("},{"text":"marshalData","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"text":"? = nil, ","kind":"text"},{"kind":"externalParam","text":"metaMarshal"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"GClosureMarshal","preciseIdentifier":"c:gclosure.h@T@GClosureMarshal"},{"text":")","kind":"text"}]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A meta marshaller wraps the "},{"type":"codeVoice","code":"closure"},{"type":"text","text":"’s marshal and modifies the way"},{"type":"text","text":" "},{"type":"text","text":"it is called in some fashion. The most common use of this facility"},{"type":"text","text":" "},{"type":"text","text":"is for C callbacks."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The same marshallers (generated by "},{"type":"reference","isActive":true,"identifier":"#glib-genmarshal"},{"type":"text","text":"),"},{"text":" ","type":"text"},{"text":"are used everywhere, but the way that we get the callback function","type":"text"},{"text":" ","type":"text"},{"text":"differs. In most cases we want to use the ","type":"text"},{"type":"codeVoice","code":"closure"},{"type":"text","text":"’s callback, but in"},{"type":"text","text":" "},{"type":"text","text":"other cases we want to use some different technique to retrieve the"},{"text":" ","type":"text"},{"type":"text","text":"callback function."}]},{"type":"paragraph","inlineContent":[{"text":"For example, class closures for signals (see","type":"text"},{"text":" ","type":"text"},{"code":"g_signal_type_cclosure_new()","type":"codeVoice"},{"text":") retrieve the callback function from a","type":"text"},{"type":"text","text":" "},{"text":"fixed offset in the class structure.  The meta marshaller retrieves","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the right callback and passes it to the marshaller as the"},{"type":"text","text":" "},{"code":"marshalData","type":"codeVoice"},{"text":" argument.","type":"text"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/closureprotocol\/setmetamarshal(marshaldata:metamarshal:)"]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureProtocol"]]},"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureProtocol\/setMetaMarshal(marshalData:metaMarshal:)","interfaceLanguage":"swift"},"references":{"doc:/