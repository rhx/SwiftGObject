{"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"takeRef","kind":"identifier"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject0B3RefV","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef","text":"ObjectRef"},{"kind":"text","text":"!"}]}]},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In other words, this function will convert a floating reference (if"},{"type":"text","text":" "},{"type":"text","text":"present) into a full reference."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Typically you want to use "},{"type":"codeVoice","code":"g_object_ref_sink()"},{"type":"text","text":" in order to"},{"type":"text","text":" "},{"text":"automatically do the correct thing with respect to floating or","type":"text"},{"type":"text","text":" "},{"type":"text","text":"non-floating references, but there is one specific scenario where"},{"text":" ","type":"text"},{"text":"this function is helpful.","type":"text"}]},{"inlineContent":[{"text":"The situation where this function is helpful is when creating an API","type":"text"},{"type":"text","text":" "},{"type":"text","text":"that allows the user to provide a callback function that returns a"},{"type":"text","text":" "},{"type":"text","text":"GObject. We certainly want to allow the user the flexibility to"},{"type":"text","text":" "},{"text":"return a non-floating reference from this callback (for the case","type":"text"},{"text":" ","type":"text"},{"text":"where the object that is being returned already exists).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"At the same time, the API style of some popular GObject-based","type":"text"},{"type":"text","text":" "},{"type":"text","text":"libraries (such as Gtk) make it likely that for newly-created GObject"},{"text":" ","type":"text"},{"text":"instances, the user can be saved some typing if they are allowed to","type":"text"},{"type":"text","text":" "},{"text":"return a floating reference.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Using this function on the return value of the user’s callback allows","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the user to do whichever is more convenient for them. The caller will"},{"type":"text","text":" "},{"text":"always receives exactly one full reference to the value: either the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"one that was returned in the first place, or a floating reference"},{"type":"text","text":" "},{"type":"text","text":"that has been converted to a full reference."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function has an odd interaction when combined with"},{"text":" ","type":"text"},{"code":"g_object_ref_sink()","type":"codeVoice"},{"type":"text","text":" running at the same time in another thread on"},{"type":"text","text":" "},{"text":"the same ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object"},{"text":" instance. If ","type":"text"},{"type":"codeVoice","code":"g_object_ref_sink()"},{"type":"text","text":" runs first then"},{"text":" ","type":"text"},{"text":"the result will be that the floating reference is converted to a hard","type":"text"},{"type":"text","text":" "},{"type":"text","text":"reference. If "},{"type":"codeVoice","code":"g_object_take_ref()"},{"type":"text","text":" runs first then the result will be"},{"type":"text","text":" "},{"type":"text","text":"that the floating reference is converted to a hard reference and an"},{"type":"text","text":" "},{"type":"text","text":"additional reference on top of that one is added. It is best to avoid"},{"type":"text","text":" "},{"type":"text","text":"this situation."}]}],"kind":"content"}],"abstract":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"object"},{"type":"text","text":" is floating, sink it.  Otherwise, do nothing."}],"metadata":{"roleHeading":"Instance Method","symbolKind":"method","modules":[{"name":"GLibObject"}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"takeRef","kind":"identifier"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","text":"ObjectRef","preciseIdentifier":"s:10GLibObject0B3RefV"},{"kind":"text","text":"!"}],"extendedModule":"GLibObject","externalID":"s:10GLibObject0B8ProtocolPAAE7takeRefAA0bE0VSgyF::SYNTHESIZED::s:10GLibObject10BindingRefV","title":"takeRef()","role":"symbol"},"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/ObjectProtocol-Implementations"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/bindingref\/takeref()"]}],"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/takeRef()","interfaceLanguage":"swift"},"references":{"doc://GLibObject/documentation/GLibObject/BindingRef":{"title":"BindingRef","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"BindingRef","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef","abstract":[{"type":"codeVoice","code":"GObject"},{"type":"text","text":" instance (or source) and another property on another "},{"type":"codeVoice","code":"GObject"},{"text":" ","type":"text"},{"text":"instance (or target).","type":"text"}],"navigatorTitle":[{"text":"BindingRef","kind":"identifier"}],"url":"\/documentation\/glibobject\/bindingref","role":"symbol","type":"topic"},"doc://GLibObject/documentation/GLibObject/BindingRef/ObjectProtocol-Implementations":{"role":"collectionGroup","url":"\/documentation\/glibobject\/bindingref\/objectprotocol-implementations","abstract":[],"title":"ObjectProtocol Implementations","kind":"article","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/ObjectProtocol-Implementations","type":"topic"},"doc://GLibObject/documentation/GLibObject/ObjectRef":{"type":"topic","kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef","abstract":[{"text":"The base object type.","type":"text"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"ObjectRef","kind":"identifier"}],"url":"\/documentation\/glibobject\/objectref","title":"ObjectRef","navigatorTitle":[{"text":"ObjectRef","kind":"identifier"}],"role":"symbol"},"doc://GLibObject/documentation/GLibObject/Object":{"url":"\/documentation\/glibobject\/object","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","kind":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"Object","kind":"identifier"}],"type":"topic","title":"Object","navigatorTitle":[{"text":"Object","kind":"identifier"}],"abstract":[{"type":"text","text":"The base object type."}],"role":"symbol"},"doc://GLibObject/documentation/GLibObject/BindingRef/takeRef()":{"abstract":[{"type":"text","text":"If "},{"type":"codeVoice","code":"object"},{"type":"text","text":" is floating, sink it.  Otherwise, do nothing."}],"url":"\/documentation\/glibobject\/bindingref\/takeref()","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"takeRef","kind":"identifier"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:10GLibObject0B3RefV","kind":"typeIdentifier","text":"ObjectRef"},{"kind":"text","text":"!"}],"title":"takeRef()","kind":"symbol","type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/takeRef()"},"doc://GLibObject/documentation/GLibObject":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","url":"\/documentation\/glibobject","abstract":[],"role":"collection","kind":"symbol","title":"GLibObject","type":"topic"}}}