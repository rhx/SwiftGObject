{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/addToggleRef(notify:data:)"},"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/ObjectProtocol-Implementations"]]},"metadata":{"roleHeading":"Instance Method","symbolKind":"method","modules":[{"name":"GLibObject"}],"title":"addToggleRef(notify:data:)","externalID":"s:10GLibObject0B8ProtocolPAAE12addToggleRef6notify4datayySvSg_SpySo8_GObjectVGSgs5Int32VtXCSg_AGtF::SYNTHESIZED::s:10GLibObject10BindingRefV","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"addToggleRef"},{"text":"(","kind":"text"},{"text":"notify","kind":"externalParam"},{"kind":"text","text":": "},{"text":"GToggleNotify","kind":"typeIdentifier","preciseIdentifier":"c:gobject.h@T@GToggleNotify"},{"text":"?, ","kind":"text"},{"text":"data","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer"},{"text":"?)","kind":"text"}],"extendedModule":"GLibObject","role":"symbol"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/bindingref\/addtoggleref(notify:data:)"]}],"abstract":[{"text":"Increases the reference count of the object by one and sets a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"callback to be called when all other references to the object are"},{"text":" ","type":"text"},{"type":"text","text":"dropped, or when this is already the last reference to the object"},{"type":"text","text":" "},{"type":"text","text":"and another reference is established."}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"addToggleRef","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"notify"},{"kind":"text","text":": "},{"preciseIdentifier":"c:gobject.h@T@GToggleNotify","text":"GToggleNotify","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"data"},{"text":": ","kind":"text"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"kind":"text","text":"? = nil)"}]}]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This functionality is intended for binding "},{"type":"codeVoice","code":"object"},{"type":"text","text":" to a proxy"},{"type":"text","text":" "},{"type":"text","text":"object managed by another memory manager. This is done with two"},{"type":"text","text":" "},{"type":"text","text":"paired references: the strong reference added by"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"text":" and a reverse reference to the proxy","type":"text"},{"type":"text","text":" "},{"type":"text","text":"object which is either a strong reference or weak reference."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The setup is that when there are no other references to "},{"code":"object","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"only a weak reference is held in the reverse direction from ","type":"text"},{"code":"object","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"to the proxy object, but when there are other references held to"},{"text":" ","type":"text"},{"type":"codeVoice","code":"object"},{"type":"text","text":", a strong reference is held. The "},{"code":"notify","type":"codeVoice"},{"type":"text","text":" callback is called"},{"type":"text","text":" "},{"type":"text","text":"when the reference from "},{"code":"object","type":"codeVoice"},{"type":"text","text":" to the proxy object should be"},{"type":"text","text":" "},{"type":"text","text":"“toggled” from strong to weak ("},{"code":"is_last_ref","type":"codeVoice"},{"type":"text","text":" true) or weak to strong"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"type":"codeVoice","code":"is_last_ref"},{"text":" false).","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Since a (normal) reference must be held to the object before"},{"type":"text","text":" "},{"text":"calling ","type":"text"},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"text":", the initial state of the reverse","type":"text"},{"text":" ","type":"text"},{"text":"link is always strong.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Multiple toggle references may be added to the same gobject,"},{"type":"text","text":" "},{"text":"however if there are multiple toggle references to an object, none","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of them will ever be notified until all but one are removed.  For"},{"type":"text","text":" "},{"text":"this reason, you should only ever use a toggle reference if there","type":"text"},{"type":"text","text":" "},{"text":"is important state in the proxy object.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that if you unref the object on another thread, then "},{"code":"notify","type":"codeVoice"},{"text":" might","type":"text"},{"type":"text","text":" "},{"type":"text","text":"still be invoked after "},{"code":"g_object_remove_toggle_ref()","type":"codeVoice"},{"type":"text","text":", and the object argument"},{"text":" ","type":"text"},{"text":"might be a dangling pointer. If the object is destroyed on other threads,","type":"text"},{"type":"text","text":" "},{"text":"you must take care of that yourself.","type":"text"}]},{"inlineContent":[{"text":"A ","type":"text"},{"code":"g_object_add_toggle_ref()","type":"codeVoice"},{"text":" must be released with ","type":"text"},{"code":"g_object_remove_toggle_ref()","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]}],"kind":"symbol","references":{"doc://GLibObject/documentation/GLibObject":{"role":"collection","type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","abstract":[],"title":"GLibObject","kind":"symbol","url":"\/documentation\/glibobject"},"doc://GLibObject/documentation/GLibObject/BindingRef":{"title":"BindingRef","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"BindingRef"}],"role":"symbol","url":"\/documentation\/glibobject\/bindingref","navigatorTitle":[{"text":"BindingRef","kind":"identifier"}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef","type":"topic","abstract":[{"type":"codeVoice","code":"GObject"},{"text":" instance (or source) and another property on another ","type":"text"},{"type":"codeVoice","code":"GObject"},{"type":"text","text":" "},{"type":"text","text":"instance (or target)."}]},"doc://GLibObject/documentation/GLibObject/BindingRef/addToggleRef(notify:data:)":{"abstract":[{"type":"text","text":"Increases the reference count of the object by one and sets a"},{"type":"text","text":" "},{"type":"text","text":"callback to be called when all other references to the object are"},{"text":" ","type":"text"},{"text":"dropped, or when this is already the last reference to the object","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and another reference is established."}],"type":"topic","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"addToggleRef","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"notify"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gobject.h@T@GToggleNotify","text":"GToggleNotify","kind":"typeIdentifier"},{"kind":"text","text":"?, "},{"text":"data","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"kind":"text","text":"?)"}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/addToggleRef(notify:data:)","role":"symbol","title":"addToggleRef(notify:data:)","kind":"symbol","url":"\/documentation\/glibobject\/bindingref\/addtoggleref(notify:data:)"},"doc://GLibObject/documentation/GLibObject/BindingRef/ObjectProtocol-Implementations":{"title":"ObjectProtocol Implementations","abstract":[],"kind":"article","url":"\/documentation\/glibobject\/bindingref\/objectprotocol-implementations","type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/ObjectProtocol-Implementations","role":"collectionGroup"}}}