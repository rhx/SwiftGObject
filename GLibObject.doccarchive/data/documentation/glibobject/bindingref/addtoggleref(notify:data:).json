{"sections":[],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"addToggleRef"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"notify"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gobject.h@T@GToggleNotify","kind":"typeIdentifier","text":"GToggleNotify"},{"kind":"text","text":"?, "},{"text":"data","kind":"externalParam"},{"kind":"text","text":": "},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"kind":"text","text":"? = nil)"}]}],"kind":"declarations"},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This functionality is intended for binding "},{"code":"object","type":"codeVoice"},{"type":"text","text":" to a proxy"},{"type":"text","text":" "},{"type":"text","text":"object managed by another memory manager. This is done with two"},{"type":"text","text":" "},{"text":"paired references: the strong reference added by","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"text":" and a reverse reference to the proxy","type":"text"},{"type":"text","text":" "},{"text":"object which is either a strong reference or weak reference.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The setup is that when there are no other references to "},{"type":"codeVoice","code":"object"},{"text":",","type":"text"},{"type":"text","text":" "},{"type":"text","text":"only a weak reference is held in the reverse direction from "},{"type":"codeVoice","code":"object"},{"type":"text","text":" "},{"type":"text","text":"to the proxy object, but when there are other references held to"},{"text":" ","type":"text"},{"type":"codeVoice","code":"object"},{"text":", a strong reference is held. The ","type":"text"},{"code":"notify","type":"codeVoice"},{"text":" callback is called","type":"text"},{"type":"text","text":" "},{"type":"text","text":"when the reference from "},{"type":"codeVoice","code":"object"},{"type":"text","text":" to the proxy object should be"},{"type":"text","text":" "},{"text":"“toggled” from strong to weak (","type":"text"},{"type":"codeVoice","code":"is_last_ref"},{"type":"text","text":" true) or weak to strong"},{"text":" ","type":"text"},{"type":"text","text":"("},{"type":"codeVoice","code":"is_last_ref"},{"type":"text","text":" false)."}]},{"inlineContent":[{"type":"text","text":"Since a (normal) reference must be held to the object before"},{"text":" ","type":"text"},{"type":"text","text":"calling "},{"code":"g_object_add_toggle_ref()","type":"codeVoice"},{"type":"text","text":", the initial state of the reverse"},{"type":"text","text":" "},{"type":"text","text":"link is always strong."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Multiple toggle references may be added to the same gobject,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"however if there are multiple toggle references to an object, none"},{"text":" ","type":"text"},{"text":"of them will ever be notified until all but one are removed.  For","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this reason, you should only ever use a toggle reference if there"},{"type":"text","text":" "},{"type":"text","text":"is important state in the proxy object."}]},{"type":"paragraph","inlineContent":[{"text":"Note that if you unref the object on another thread, then ","type":"text"},{"type":"codeVoice","code":"notify"},{"type":"text","text":" might"},{"type":"text","text":" "},{"type":"text","text":"still be invoked after "},{"type":"codeVoice","code":"g_object_remove_toggle_ref()"},{"text":", and the object argument","type":"text"},{"type":"text","text":" "},{"type":"text","text":"might be a dangling pointer. If the object is destroyed on other threads,"},{"type":"text","text":" "},{"text":"you must take care of that yourself.","type":"text"}]},{"inlineContent":[{"text":"A ","type":"text"},{"code":"g_object_add_toggle_ref()","type":"codeVoice"},{"type":"text","text":" must be released with "},{"type":"codeVoice","code":"g_object_remove_toggle_ref()"},{"type":"text","text":"."}],"type":"paragraph"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/glibobject\/bindingref\/addtoggleref(notify:data:)"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/addToggleRef(notify:data:)"},"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/ObjectProtocol-Implementations"]]},"abstract":[{"type":"text","text":"Increases the reference count of the object by one and sets a"},{"type":"text","text":" "},{"type":"text","text":"callback to be called when all other references to the object are"},{"type":"text","text":" "},{"type":"text","text":"dropped, or when this is already the last reference to the object"},{"type":"text","text":" "},{"type":"text","text":"and another reference is established."}],"metadata":{"modules":[{"name":"GLibObject"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"addToggleRef"},{"kind":"text","text":"("},{"kind":"externalParam","text":"notify"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"GToggleNotify","preciseIdentifier":"c:gobject.h@T@GToggleNotify"},{"kind":"text","text":"?, "},{"text":"data","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"text":"?)","kind":"text"}],"role":"symbol","extendedModule":"GLibObject","externalID":"s:10GLibObject0B8ProtocolPAAE12addToggleRef6notify4datayySvSg_SpySo8_GObjectVGSgs5Int32VtXCSg_AGtF::SYNTHESIZED::s:10GLibObject10BindingRefV","title":"addToggleRef(notify:data:)","symbolKind":"method","roleHeading":"Instance Method"},"references":{"doc://GLibObject/documentation/GLibObject/BindingRef/addToggleRef(notify:data:)":{"type":"topic","title":"addToggleRef(notify:data:)","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/addToggleRef(notify:data:)","kind":"symbol","role":"symbol","url":"\/documentation\/glibobject\/bindingref\/addtoggleref(notify:data:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"addToggleRef","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"notify"},{"kind":"text","text":": "},{"preciseIdentifier":"c:gobject.h@T@GToggleNotify","text":"GToggleNotify","kind":"typeIdentifier"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"data"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"kind":"text","text":"?)"}],"abstract":[{"type":"text","text":"Increases the reference count of the object by one and sets a"},{"text":" ","type":"text"},{"type":"text","text":"callback to be called when all other references to the object are"},{"text":" ","type":"text"},{"type":"text","text":"dropped, or when this is already the last reference to the object"},{"type":"text","text":" "},{"text":"and another reference is established.","type":"text"}]},"doc://GLibObject/documentation/GLibObject/BindingRef/ObjectProtocol-Implementations":{"role":"collectionGroup","url":"\/documentation\/glibobject\/bindingref\/objectprotocol-implementations","abstract":[],"title":"ObjectProtocol Implementations","kind":"article","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/ObjectProtocol-Implementations","type":"topic"},"doc://GLibObject/documentation/GLibObject":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","url":"\/documentation\/glibobject","abstract":[],"role":"collection","kind":"symbol","title":"GLibObject","type":"topic"},"doc://GLibObject/documentation/GLibObject/BindingRef":{"title":"BindingRef","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"BindingRef","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef","abstract":[{"type":"codeVoice","code":"GObject"},{"type":"text","text":" instance (or source) and another property on another "},{"type":"codeVoice","code":"GObject"},{"text":" ","type":"text"},{"text":"instance (or target).","type":"text"}],"navigatorTitle":[{"text":"BindingRef","kind":"identifier"}],"url":"\/documentation\/glibobject\/bindingref","role":"symbol","type":"topic"}}}