\/glibobject\/weakrefref"]}],"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRefRef","interfaceLanguage":"swift"},"metadata":{"role":"symbol","symbolKind":"struct","navigatorTitle":[{"text":"WeakRefRef","kind":"identifier"}],"roleHeading":"Structure","modules":[{"name":"GLibObject"}],"externalID":"s:10GLibObject07WeakRefD0V","title":"WeakRefRef","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"WeakRefRef","kind":"identifier"}]},"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"WeakRefRef"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"text":"Overview","level":2,"type":"heading","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"type":"codeVoice","code":"GWeakRef"},{"type":"text","text":" can either be empty (i.e. point to "},{"code":"nil","type":"codeVoice"},{"type":"text","text":"), or point to an"},{"text":" ","type":"text"},{"text":"object for as long as at least one “strong” reference to that object","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"exists. Before the object’s "},{"type":"codeVoice","code":"GObjectClass.dispose"},{"type":"text","text":" method is called,"},{"text":" ","type":"text"},{"text":"every ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRef","isActive":true},{"type":"text","text":" associated with becomes empty (i.e. points to "},{"type":"codeVoice","code":"nil"},{"text":").","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Like ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Value","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRef","isActive":true},{"text":" can be statically allocated, stack- or","type":"text"},{"type":"text","text":" "},{"type":"text","text":"heap-allocated, or embedded in larger structures."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Unlike "},{"type":"codeVoice","code":"g_object_weak_ref()"},{"text":" and ","type":"text"},{"code":"g_object_add_weak_pointer()","type":"codeVoice"},{"text":", this weak","type":"text"},{"type":"text","text":" "},{"type":"text","text":"reference is thread-safe: converting a weak pointer to a reference is"},{"type":"text","text":" "},{"type":"text","text":"atomic with respect to invalidation of weak pointers to destroyed"},{"text":" ","type":"text"},{"text":"objects.","type":"text"}]},{"inlineContent":[{"text":"If the object’s ","type":"text"},{"code":"GObjectClass.dispose","type":"codeVoice"},{"type":"text","text":" method results in additional"},{"text":" ","type":"text"},{"text":"references to the object being held (‘re-referencing’), any ","type":"text"},{"type":"codeVoice","code":"GWeakRefs"},{"type":"text","text":" taken"},{"type":"text","text":" "},{"type":"text","text":"before it was disposed will continue to point to "},{"type":"codeVoice","code":"nil"},{"text":".  Any ","type":"text"},{"code":"GWeakRefs","type":"codeVoice"},{"text":" taken","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"during disposal and after re-referencing, or after disposal has returned due"},{"type":"text","text":" "},{"type":"text","text":"to the re-referencing, will continue to point to the object until its refcount"},{"text":" ","type":"text"},{"text":"goes back to zero, at which point they too will be invalidated.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is invalid to take a "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRef","type":"reference","isActive":true},{"type":"text","text":" on an object during "},{"type":"codeVoice","code":"GObjectClass.dispose"},{"text":" ","type":"text"},{"text":"without first having or creating a strong reference to the object.","type":"text"}]},{"inlineContent":[{"type":"text","text":"The "},{"isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRefRef","type":"reference"},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GWeakRef"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRefProtocol","isActive":true},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRefRef"},{"type":"text","text":" only as an "},{"type":"codeVoice","code":"unowned"},{"text":" reference to an existing ","type":"text"},{"type":"codeVoice","code":"GWeakRef"},{"type":"text","text":" instance."}],"type":"paragraph"},{"type":"aside","name":"Note","content":[{"inlineContent":[{"text":"Use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRef","type":"reference"},{"type":"text","text":" (instead of "},{"isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRefRef","type":"reference"},{"text":") if you want to use Automatic Reference Counting for memory management of the underlying ","type":"text"},{"code":"GWeakRef","type":"codeVoice"},{"type":"text","text":" instance."}],"type":"paragraph"}],"style":"note"}],"kind":"content"}],"references":{"doc://GLibObject/documentation/GLibObject/WeakRefRef/init(opaquePointer:)":{"kind":"symbol","title":"init(opaquePointer:)","abstract":[{"type":"text","text":"Unsafe untyped initialiser."},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"Do not use u