{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object\/addToggleRef(notify:data:)"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/Object","doc:\/\/GLibObject\/documentation\/GLibObject\/Object\/ObjectProtocol-Implementations"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/object\/addtoggleref(notify:data:)"]}],"abstract":[{"type":"text","text":"Increases the reference count of the object by one and sets a"},{"type":"text","text":" "},{"type":"text","text":"callback to be called when all other references to the object are"},{"type":"text","text":" "},{"text":"dropped, or when this is already the last reference to the object","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and another reference is established."}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"addToggleRef"},{"kind":"text","text":"("},{"text":"notify","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"GToggleNotify","kind":"typeIdentifier","preciseIdentifier":"c:gobject.h@T@GToggleNotify"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"data"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer"},{"text":"? = nil)","kind":"text"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"This functionality is intended for binding ","type":"text"},{"code":"object","type":"codeVoice"},{"text":" to a proxy","type":"text"},{"text":" ","type":"text"},{"text":"object managed by another memory manager. This is done with two","type":"text"},{"type":"text","text":" "},{"type":"text","text":"paired references: the strong reference added by"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"type":"text","text":" and a reverse reference to the proxy"},{"text":" ","type":"text"},{"type":"text","text":"object which is either a strong reference or weak reference."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The setup is that when there are no other references to "},{"code":"object","type":"codeVoice"},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"text","text":"only a weak reference is held in the reverse direction from "},{"type":"codeVoice","code":"object"},{"type":"text","text":" "},{"text":"to the proxy object, but when there are other references held to","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"object"},{"text":", a strong reference is held. The ","type":"text"},{"type":"codeVoice","code":"notify"},{"type":"text","text":" callback is called"},{"type":"text","text":" "},{"text":"when the reference from ","type":"text"},{"type":"codeVoice","code":"object"},{"text":" to the proxy object should be","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"“toggled” from strong to weak ("},{"type":"codeVoice","code":"is_last_ref"},{"type":"text","text":" true) or weak to strong"},{"text":" ","type":"text"},{"type":"text","text":"("},{"type":"codeVoice","code":"is_last_ref"},{"type":"text","text":" false)."}]},{"type":"paragraph","inlineContent":[{"text":"Since a (normal) reference must be held to the object before","type":"text"},{"type":"text","text":" "},{"text":"calling ","type":"text"},{"code":"g_object_add_toggle_ref()","type":"codeVoice"},{"type":"text","text":", the initial state of the reverse"},{"type":"text","text":" "},{"type":"text","text":"link is always strong."}]},{"inlineContent":[{"text":"Multiple toggle references may be added to the same gobject,","type":"text"},{"type":"text","text":" "},{"text":"however if there are multiple toggle references to an object, none","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of them will ever be notified until all but one are removed.  For"},{"text":" ","type":"text"},{"type":"text","text":"this reason, you should only ever use a toggle reference if there"},{"type":"text","text":" "},{"type":"text","text":"is important state in the proxy object."}],"type":"paragraph"},{"inlineContent":[{"text":"Note that if you unref the object on another thread, then ","type":"text"},{"type":"codeVoice","code":"notify"},{"text":" might","type":"text"},{"type":"text","text":" "},{"type":"text","text":"still be invoked after "},{"type":"codeVoice","code":"g_object_remove_toggle_ref()"},{"text":", and the object argument","type":"text"},{"type":"text","text":" "},{"text":"might be a dangling pointer. If the object is destroyed on other threads,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"you must take care of that yourself."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A "},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"text":" must be released with ","type":"text"},{"type":"codeVoice","code":"g_object_remove_toggle_ref()"},{"text":".","type":"text"}],"type":"paragraph"}]}],"metadata":{"externalID":"s:10GLibObject0B8ProtocolPAAE12addToggleRef6notify4datayySvSg_SpySo8_GObjectVGSgs5Int32VtXCSg_AGtF::SYNTHESIZED::s:10GLibObject0B0C","modules":[{"name":"GLibObject"}],"role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"addToggleRef","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"notify"},{"text":": ","kind":"text"},{"text":"GToggleNotify","preciseIdentifier":"c:gobject.h@T@GToggleNotify","kind":"typeIdentifier"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"data"},{"kind":"text","text":": "},{"text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier"},{"text":"?)","kind":"text"}],"title":"addToggleRef(notify:data:)","extendedModule":"GLibObject","roleHeading":"Instance Method","symbolKind":"method"},"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"references":{"doc://GLibObject/documentation/GLibObject":{"role":"collection","type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","abstract":[],"title":"GLibObject","kind":"symbol","url":"\/documentation\/glibobject"},"doc://GLibObject/documentation/GLibObject/Object/addToggleRef(notify:data:)":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object\/addToggleRef(notify:data:)","url":"\/documentation\/glibobject\/object\/addtoggleref(notify:data:)","title":"addToggleRef(notify:data:)","abstract":[{"text":"Increases the reference count of the object by one and sets a","type":"text"},{"type":"text","text":" "},{"text":"callback to be called when all other references to the object are","type":"text"},{"text":" ","type":"text"},{"text":"dropped, or when this is already the last reference to the object","type":"text"},{"text":" ","type":"text"},{"text":"and another reference is established.","type":"text"}],"type":"topic","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"addToggleRef"},{"kind":"text","text":"("},{"text":"notify","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"GToggleNotify","preciseIdentifier":"c:gobject.h@T@GToggleNotify"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"data"},{"kind":"text","text":": "},{"text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier"},{"text":"?)","kind":"text"}],"kind":"symbol"},"doc://GLibObject/documentation/GLibObject/Object":{"title":"Object","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Object","kind":"identifier"}],"navigatorTitle":[{"text":"Object","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/glibobject\/object","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","type":"topic","abstract":[{"type":"text","text":"The base object type."}],"role":"symbol"},"doc://GLibObject/documentation/GLibObject/Object/ObjectProtocol-Implementations":{"type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object\/ObjectProtocol-Implementations","title":"ObjectProtocol Implementations","url":"\/documentation\/glibobject\/object\/objectprotocol-implementations","abstract":[],"kind":"article","role":"collectionGroup"}}}