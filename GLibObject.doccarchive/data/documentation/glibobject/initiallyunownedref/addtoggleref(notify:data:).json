{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef\/addToggleRef(notify:data:)"},"abstract":[{"text":"Increases the reference count of the object by one and sets a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"callback to be called when all other references to the object are"},{"text":" ","type":"text"},{"type":"text","text":"dropped, or when this is already the last reference to the object"},{"type":"text","text":" "},{"type":"text","text":"and another reference is established."}],"variants":[{"paths":["\/documentation\/glibobject\/initiallyunownedref\/addtoggleref(notify:data:)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","metadata":{"title":"addToggleRef(notify:data:)","symbolKind":"method","roleHeading":"Instance Method","modules":[{"name":"GLibObject"}],"role":"symbol","externalID":"s:10GLibObject0B8ProtocolPAAE12addToggleRef6notify4datayySvSg_SpySo8_GObjectVGSgs5Int32VtXCSg_AGtF::SYNTHESIZED::s:10GLibObject19InitiallyUnownedRefV","extendedModule":"GLibObject","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"addToggleRef"},{"text":"(","kind":"text"},{"text":"notify","kind":"externalParam"},{"kind":"text","text":": "},{"text":"GToggleNotify","kind":"typeIdentifier","preciseIdentifier":"c:gobject.h@T@GToggleNotify"},{"kind":"text","text":"?, "},{"text":"data","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer"},{"kind":"text","text":"?)"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"addToggleRef","kind":"identifier"},{"text":"(","kind":"text"},{"text":"notify","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"GToggleNotify","preciseIdentifier":"c:gobject.h@T@GToggleNotify"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"data"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer"},{"kind":"text","text":"? = nil)"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"This functionality is intended for binding ","type":"text"},{"code":"object","type":"codeVoice"},{"type":"text","text":" to a proxy"},{"type":"text","text":" "},{"type":"text","text":"object managed by another memory manager. This is done with two"},{"text":" ","type":"text"},{"type":"text","text":"paired references: the strong reference added by"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"text":" and a reverse reference to the proxy","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"object which is either a strong reference or weak reference."}]},{"inlineContent":[{"text":"The setup is that when there are no other references to ","type":"text"},{"type":"codeVoice","code":"object"},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"text","text":"only a weak reference is held in the reverse direction from "},{"type":"codeVoice","code":"object"},{"text":" ","type":"text"},{"text":"to the proxy object, but when there are other references held to","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"object"},{"type":"text","text":", a strong reference is held. The "},{"type":"codeVoice","code":"notify"},{"text":" callback is called","type":"text"},{"type":"text","text":" "},{"text":"when the reference from ","type":"text"},{"type":"codeVoice","code":"object"},{"type":"text","text":" to the proxy object should be"},{"type":"text","text":" "},{"text":"“toggled” from strong to weak (","type":"text"},{"type":"codeVoice","code":"is_last_ref"},{"text":" true) or weak to strong","type":"text"},{"type":"text","text":" "},{"type":"text","text":"("},{"code":"is_last_ref","type":"codeVoice"},{"text":" false).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Since a (normal) reference must be held to the object before"},{"text":" ","type":"text"},{"type":"text","text":"calling "},{"code":"g_object_add_toggle_ref()","type":"codeVoice"},{"text":", the initial state of the reverse","type":"text"},{"type":"text","text":" "},{"type":"text","text":"link is always strong."}]},{"type":"paragraph","inlineContent":[{"text":"Multiple toggle references may be added to the same gobject,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"however if there are multiple toggle references to an object, none"},{"text":" ","type":"text"},{"text":"of them will ever be notified until all but one are removed.  For","type":"text"},{"type":"text","text":" "},{"text":"this reason, you should only ever use a toggle reference if there","type":"text"},{"type":"text","text":" "},{"text":"is important state in the proxy object.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Note that if you unref the object on another thread, then ","type":"text"},{"code":"notify","type":"codeVoice"},{"text":" might","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"still be invoked after "},{"type":"codeVoice","code":"g_object_remove_toggle_ref()"},{"type":"text","text":", and the object argument"},{"type":"text","text":" "},{"type":"text","text":"might be a dangling pointer. If the object is destroyed on other threads,"},{"type":"text","text":" "},{"type":"text","text":"you must take care of that yourself."}]},{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"code":"g_object_add_toggle_ref()","type":"codeVoice"},{"type":"text","text":" must be released with "},{"code":"g_object_remove_toggle_ref()","type":"codeVoice"},{"text":".","type":"text"}]}]}],"sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef","doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef\/ObjectProtocol-Implementations"]]},"references":{"doc://GLibObject/documentation/GLibObject/InitiallyUnownedRef":{"title":"InitiallyUnownedRef","type":"topic","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"InitiallyUnownedRef","kind":"identifier"}],"abstract":[{"type":"text","text":"A type for objects that have an initially floating reference."}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef","url":"\/documentation\/glibobject\/initiallyunownedref","navigatorTitle":[{"kind":"identifier","text":"InitiallyUnownedRef"}],"kind":"symbol"},"doc://GLibObject/documentation/GLibObject/InitiallyUnownedRef/ObjectProtocol-Implementations":{"title":"ObjectProtocol Implementations","type":"topic","role":"collectionGroup","abstract":[],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef\/ObjectProtocol-Implementations","url":"\/documentation\/glibobject\/initiallyunownedref\/objectprotocol-implementations","kind":"article"},"doc://GLibObject/documentation/GLibObject/InitiallyUnownedRef/addToggleRef(notify:data:)":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"addToggleRef"},{"text":"(","kind":"text"},{"text":"notify","kind":"externalParam"},{"kind":"text","text":": "},{"text":"GToggleNotify","preciseIdentifier":"c:gobject.h@T@GToggleNotify","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"text":"data","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer"},{"text":"?)","kind":"text"}],"url":"\/documentation\/glibobject\/initiallyunownedref\/addtoggleref(notify:data:)","role":"symbol","kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef\/addToggleRef(notify:data:)","abstract":[{"type":"text","text":"Increases the reference count of the object by one and sets a"},{"type":"text","text":" "},{"text":"callback to be called when all other references to the object are","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"dropped, or when this is already the last reference to the object"},{"type":"text","text":" "},{"text":"and another reference is established.","type":"text"}],"type":"topic","title":"addToggleRef(notify:data:)"},"doc://GLibObject/documentation/GLibObject":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","url":"\/documentation\/glibobject","abstract":[],"role":"collection","kind":"symbol","title":"GLibObject","type":"topic"}}}