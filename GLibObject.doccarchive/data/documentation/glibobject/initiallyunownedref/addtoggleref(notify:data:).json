{"metadata":{"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"addToggleRef"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"notify"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gobject.h@T@GToggleNotify","text":"GToggleNotify","kind":"typeIdentifier"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"data"},{"text":": ","kind":"text"},{"text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier"},{"text":"?)","kind":"text"}],"externalID":"s:10GLibObject0B8ProtocolPAAE12addToggleRef6notify4datayySvSg_SpySo8_GObjectVGSgs5Int32VtXCSg_AGtF::SYNTHESIZED::s:10GLibObject19InitiallyUnownedRefV","modules":[{"name":"GLibObject"}],"title":"addToggleRef(notify:data:)","symbolKind":"method","extendedModule":"GLibObject","roleHeading":"Instance Method","role":"symbol"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/initiallyunownedref\/addtoggleref(notify:data:)"]}],"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef\/addToggleRef(notify:data:)","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"addToggleRef","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"notify"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"GToggleNotify","preciseIdentifier":"c:gobject.h@T@GToggleNotify"},{"text":"?, ","kind":"text"},{"text":"data","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"kind":"text","text":"? = nil)"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"This functionality is intended for binding "},{"type":"codeVoice","code":"object"},{"text":" to a proxy","type":"text"},{"text":" ","type":"text"},{"text":"object managed by another memory manager. This is done with two","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"paired references: the strong reference added by"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"type":"text","text":" and a reverse reference to the proxy"},{"type":"text","text":" "},{"type":"text","text":"object which is either a strong reference or weak reference."}]},{"inlineContent":[{"text":"The setup is that when there are no other references to ","type":"text"},{"type":"codeVoice","code":"object"},{"type":"text","text":","},{"type":"text","text":" "},{"text":"only a weak reference is held in the reverse direction from ","type":"text"},{"code":"object","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"to the proxy object, but when there are other references held to"},{"text":" ","type":"text"},{"type":"codeVoice","code":"object"},{"text":", a strong reference is held. The ","type":"text"},{"code":"notify","type":"codeVoice"},{"text":" callback is called","type":"text"},{"type":"text","text":" "},{"type":"text","text":"when the reference from "},{"type":"codeVoice","code":"object"},{"type":"text","text":" to the proxy object should be"},{"type":"text","text":" "},{"type":"text","text":"“toggled” from strong to weak ("},{"code":"is_last_ref","type":"codeVoice"},{"type":"text","text":" true) or weak to strong"},{"type":"text","text":" "},{"type":"text","text":"("},{"type":"codeVoice","code":"is_last_ref"},{"type":"text","text":" false)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Since a (normal) reference must be held to the object before","type":"text"},{"type":"text","text":" "},{"text":"calling ","type":"text"},{"code":"g_object_add_toggle_ref()","type":"codeVoice"},{"type":"text","text":", the initial state of the reverse"},{"text":" ","type":"text"},{"type":"text","text":"link is always strong."}]},{"type":"paragraph","inlineContent":[{"text":"Multiple toggle references may be added to the same gobject,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"however if there are multiple toggle references to an object, none"},{"type":"text","text":" "},{"type":"text","text":"of them will ever be notified until all but one are removed.  For"},{"text":" ","type":"text"},{"type":"text","text":"this reason, you should only ever use a toggle reference if there"},{"type":"text","text":" "},{"type":"text","text":"is important state in the proxy object."}]},{"inlineContent":[{"type":"text","text":"Note that if you unref the object on another thread, then "},{"type":"codeVoice","code":"notify"},{"type":"text","text":" might"},{"type":"text","text":" "},{"text":"still be invoked after ","type":"text"},{"type":"codeVoice","code":"g_object_remove_toggle_ref()"},{"type":"text","text":", and the object argument"},{"type":"text","text":" "},{"text":"might be a dangling pointer. If the object is destroyed on other threads,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"you must take care of that yourself."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A "},{"code":"g_object_add_toggle_ref()","type":"codeVoice"},{"text":" must be released with ","type":"text"},{"type":"codeVoice","code":"g_object_remove_toggle_ref()"},{"type":"text","text":"."}],"type":"paragraph"}]}],"abstract":[{"text":"Increases the reference count of the object by one and sets a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"callback to be called when all other references to the object are"},{"text":" ","type":"text"},{"text":"dropped, or when this is already the last reference to the object","type":"text"},{"type":"text","text":" "},{"text":"and another reference is established.","type":"text"}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef","doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef\/ObjectProtocol-Implementations"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"references":{"doc://GLibObject/documentation/GLibObject/InitiallyUnownedRef/ObjectProtocol-Implementations":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef\/ObjectProtocol-Implementations","title":"ObjectProtocol Implementations","url":"\/documentation\/glibobject\/initiallyunownedref\/objectprotocol-implementations","type":"topic","abstract":[],"role":"collectionGroup","kind":"article"},"doc://GLibObject/documentation/GLibObject/InitiallyUnownedRef/addToggleRef(notify:data:)":{"url":"\/documentation\/glibobject\/initiallyunownedref\/addtoggleref(notify:data:)","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef\/addToggleRef(notify:data:)","type":"topic","abstract":[{"text":"Increases the reference count of the object by one and sets a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"callback to be called when all other references to the object are"},{"type":"text","text":" "},{"text":"dropped, or when this is already the last reference to the object","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and another reference is established."}],"kind":"symbol","title":"addToggleRef(notify:data:)","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"addToggleRef","kind":"identifier"},{"text":"(","kind":"text"},{"text":"notify","kind":"externalParam"},{"kind":"text","text":": "},{"text":"GToggleNotify","preciseIdentifier":"c:gobject.h@T@GToggleNotify","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"data"},{"kind":"text","text":": "},{"preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier","text":"gpointer"},{"kind":"text","text":"?)"}]},"doc://GLibObject/documentation/GLibObject/InitiallyUnownedRef":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef","title":"InitiallyUnownedRef","url":"\/documentation\/glibobject\/initiallyunownedref","navigatorTitle":[{"kind":"identifier","text":"InitiallyUnownedRef"}],"type":"topic","abstract":[{"text":"A type for objects that have an initially floating reference.","type":"text"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"InitiallyUnownedRef","kind":"identifier"}],"role":"symbol","kind":"symbol"},"doc://GLibObject/documentation/GLibObject":{"role":"collection","type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","abstract":[],"title":"GLibObject","kind":"symbol","url":"\/documentation\/glibobject"}}}