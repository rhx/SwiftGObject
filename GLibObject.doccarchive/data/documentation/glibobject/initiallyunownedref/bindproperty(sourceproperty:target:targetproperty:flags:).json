,{"text":" ","type":"text"},{"type":"text","text":"updated using the same value. For instance:"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"syntax":"C","code":["  g_object_bind_property (action, \"active\", widget, \"sensitive\", 0);"],"type":"codeListing"},{"inlineContent":[{"text":"Will result in the “sensitive” property of the widget ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object"},{"type":"text","text":" instance to be"},{"text":" ","type":"text"},{"text":"updated with the same value of the “active” property of the action ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","isActive":true},{"text":" ","type":"text"},{"type":"text","text":"instance."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"flags"},{"type":"text","text":" contains "},{"code":"bidirectional","type":"codeVoice"},{"type":"text","text":" then the binding will be mutual:"},{"type":"text","text":" "},{"type":"text","text":"if "},{"code":"targetProperty","type":"codeVoice"},{"type":"text","text":" on "},{"type":"codeVoice","code":"target"},{"type":"text","text":" changes then the "},{"type":"codeVoice","code":"sourceProperty"},{"type":"text","text":" on "},{"type":"codeVoice","code":"source"},{"type":"text","text":" "},{"text":"will be updated as well.","type":"text"}]},{"inlineContent":[{"text":"The binding will automatically be removed when either the ","type":"text"},{"code":"source","type":"codeVoice"},{"text":" or the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"target"},{"type":"text","text":" instances are finalized. To remove the binding without affecting the"},{"type":"text","text":" "},{"type":"codeVoice","code":"source"},{"text":" and the ","type":"text"},{"type":"codeVoice","code":"target"},{"text":" you can just call ",