":"text","text":" "},{"type":"text","text":"emit the signal if no one is attached anyway, thus saving the cost"},{"type":"text","text":" "},{"type":"text","text":"of building the arguments."}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/initiallyunownedref\/signalhashandlerpending(signalid:detail:maybeblocked:)"]}],"references":{"doc://GLibObject/documentation/GLibObject":{"role":"collection","type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","abstract":[],"title":"GLibObject","kind":"symbol","url":"\/documentation\/glibobject"},"doc://GLibObject/documentation/GLibObject/InitiallyUnownedRef":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef","title":"InitiallyUnownedRef","url":"\/documentation\/glibobject\/initiallyunownedref","navigatorTitle":[{"kind":"identifier","text":"InitiallyUnownedRef"}],"type":"topic","abstract":[{"text":"A type for objects that have an initially floating reference.","type":"text"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"InitiallyUnownedRef","kind":"identifier"}],"role":"symbol","kind":"symbol"},"doc://GLibObject/documentation/GLibObject/InitiallyUnownedRef/ObjectProtocol-Implementations":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef\/ObjectProtocol-Implementations","title":"ObjectProtocol Implementations","url":"\/documentation\/glibobject\/initiallyunownedref\/objectprotocol-implementations","type":"topic","abstract":[],"role":"collectionGroup","kind":"article"},"doc://GLibObject/documentation/GLibObject/InitiallyUnownedRef/signalHasHandlerPending(signalID:detail:mayBeBlocked:)":{"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"signalHasHandlerPending","kind":"identifier"},{"kind":"text","text":"("},{"text":"signalID","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","te