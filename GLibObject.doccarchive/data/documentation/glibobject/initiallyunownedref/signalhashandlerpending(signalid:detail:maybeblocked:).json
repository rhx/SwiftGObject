n the arguments to the"},{"text":" ","type":"text"},{"type":"text","text":"signal are difficult to compute. A class implementor may opt to not"},{"text":" ","type":"text"},{"type":"text","text":"emit the signal if no one is attached anyway, thus saving the cost"},{"type":"text","text":" "},{"type":"text","text":"of building the arguments."}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef","doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef\/ObjectProtocol-Implementations"]]},"kind":"symbol","abstract":[{"type":"text","text":"Returns whether there are any handlers connected to "},{"type":"codeVoice","code":"instance"},{"type":"text","text":" for the"},{"text":" ","type":"text"},{"text":"given signal id and detail.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/initiallyunownedref\/signalhashandlerpending(signalid:detail:maybeblocked:)"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"roleHeading":"Instance Method","title":"signalHasHandlerPending(signalID:detail:mayBeBlocked:)","role":"symbol","extendedModule":"GLibObject","modules":[{"name":"GLibObject"}],"externalID":"s:10GLibObject0B8ProtocolPAAE23signalHasHandlerPending0D2ID6detail12mayBeBlockedSbSi_s6UInt32VSbtF::SYNTHESIZED::s:10GLibObject19InitiallyUnownedRefV","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"signalHasHandlerPending"},{"kind":"text","text":"("},{"kind":"externalParam","text":"signalID"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"detail","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GQuark","text":"GQuark"},{"text":", ","kind":"text"},{"text":"mayBeBlocked","kind":"externalPa