{"kind":"symbol","abstract":[{"type":"text","text":"Returns whether there are any handlers connected to "},{"code":"instance","type":"codeVoice"},{"type":"text","text":" for the"},{"text":" ","type":"text"},{"type":"text","text":"given signal id and detail."}],"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef\/signalHasHandlerPending(signalID:detail:mayBeBlocked:)","interfaceLanguage":"swift"},"metadata":{"role":"symbol","title":"signalHasHandlerPending(signalID:detail:mayBeBlocked:)","externalID":"s:10GLibObject0B8ProtocolPAAE23signalHasHandlerPending0D2ID6detail12mayBeBlockedSbSi_s6UInt32VSbtF::SYNTHESIZED::s:10GLibObject19InitiallyUnownedRefV","symbolKind":"method","modules":[{"name":"GLibObject"}],"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"signalHasHandlerPending","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"signalID"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"detail","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@GQuark","text":"GQuark","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"mayBeBlocked"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"roleHeading":"Instance Method","extendedModule":"GLibObject"},"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef","doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef\/ObjectProtocol-Implementations"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"signa