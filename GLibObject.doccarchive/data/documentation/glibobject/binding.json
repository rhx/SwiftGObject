{"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/Binding","interfaceLanguage":"swift"},"metadata":{"modules":[{"name":"GLibObject"}],"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Binding","kind":"identifier"}],"externalID":"s:10GLibObject7BindingC","title":"Binding","roleHeading":"Class","symbolKind":"class","role":"symbol","navigatorTitle":[{"text":"Binding","kind":"identifier"}]},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Binding","kind":"identifier"}]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Overview","type":"heading","anchor":"overview","level":2},{"type":"paragraph","inlineContent":[{"text":"Whenever the source property changes, the same value is applied to the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"target property; for instance, the following binding:"}]},{"code":["  g_object_bind_property (object1, \"property-a\",","                          object2, \"property-b\",","                          G_BINDING_DEFAULT);"],"type":"codeListing","syntax":"c"},{"type":"paragraph","inlineContent":[{"type":"text","text":"will cause the property named “property-b” of "},{"type":"codeVoice","code":"object2"},{"text":" to be updated","type":"text"},{"type":"text","text":" "},{"text":"every time [method","type":"text"},{"code":"GObject.set","type":"codeVoice"},{"text":"] or the specific accessor changes the value of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the property “property-a” of "},{"code":"object1","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is possible to create a bidirectional binding between two properties"},{"text":" ","type":"text"},{"text":"of two ","type":"text"},{"code":"GObject","type":"codeVoice"},{"text":" instances, so that if either property changes, the","type":"text"},{"text":" ","type":"text"},{"text":"other is updated as well, for instance:","type":"text"}]},{"syntax":"c","code":["  g_object_bind_property (object1, \"property-a\",","                          object2, \"property-b\",","                          G_BINDING_BIDIRECTIONAL);"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"will keep the two properties in sync.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is also possible to set a custom transformation function (in both"},{"type":"text","text":" "},{"text":"directions, in case of a bidirectional binding) to apply a custom","type":"text"},{"type":"text","text":" "},{"type":"text","text":"transformation from the source value to the target value before"},{"type":"text","text":" "},{"text":"applying it; for instance, the following binding:","type":"text"}]},{"type":"codeListing","syntax":"c","code":["  g_object_bind_property_full (adjustment1, \"value\",","                               adjustment2, \"value\",","                               G_BINDING_BIDIRECTIONAL,","                               celsius_to_fahrenheit,","                               fahrenheit_to_celsius,","                               NULL, NULL);"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"will keep the “value” property of the two adjustments in sync; the"},{"type":"text","text":" "},{"code":"celsius_to_fahrenheit","type":"codeVoice"},{"type":"text","text":" function will be called whenever the “value”"},{"text":" ","type":"text"},{"text":"property of ","type":"text"},{"type":"codeVoice","code":"adjustment1"},{"text":" changes and will transform the current value","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of the property before applying it to the “value” property of "},{"type":"codeVoice","code":"adjustment2"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Vice versa, the "},{"type":"codeVoice","code":"fahrenheit_to_celsius"},{"text":" function will be called whenever","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the “value” property of "},{"code":"adjustment2","type":"codeVoice"},{"type":"text","text":" changes, and will transform the"},{"type":"text","text":" "},{"type":"text","text":"current value of the property before applying it to the “value” property"},{"type":"text","text":" "},{"text":"of ","type":"text"},{"code":"adjustment1","type":"codeVoice"},{"type":"text","text":"."}]},{"inlineContent":[{"text":"Note that ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Binding"},{"text":" does not resolve cycles by itself; a cycle like","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["  object1:propertyA -> object2:propertyB","  object2:propertyB -> object3:propertyC","  object3:propertyC -> object1:propertyA"],"syntax":null},{"type":"paragraph","inlineContent":[{"type":"text","text":"might lead to an infinite loop. The loop, in this particular case,"},{"type":"text","text":" "},{"text":"can be avoided if the objects emit the ","type":"text"},{"type":"codeVoice","code":"GObject"},{"text":"notify","type":"text"},{"code":" signal only if the value has effectively been changed. A binding is implemented using the `GObject`notify","type":"codeVoice"},{"type":"text","text":" signal, so it is susceptible to all the"},{"type":"text","text":" "},{"text":"various ways of blocking a signal emission, like [func","type":"text"},{"type":"codeVoice","code":"GObject.signal_stop_emission"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"text":"or [func","type":"text"},{"type":"codeVoice","code":"GObject.signal_handler_block"},{"text":"].","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A binding will be severed, and the resources it allocates freed, whenever"},{"type":"text","text":" "},{"type":"text","text":"either one of the "},{"code":"GObject","type":"codeVoice"},{"text":" instances it refers to are finalized, or when","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Binding","isActive":true},{"type":"text","text":" instance loses its last reference."}]},{"inlineContent":[{"type":"text","text":"Bindings for languages with garbage collection can use"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GObject.Binding.unbind"},{"type":"text","text":"] to explicitly release a binding between the source"},{"type":"text","text":" "},{"text":"and target properties, instead of relying on the last reference on the","type":"text"},{"type":"text","text":" "},{"text":"binding, source, and target instances to drop.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Binding","isActive":true},{"type":"text","text":" type acts as a reference-counted owner of an underlying "},{"type":"codeVoice","code":"GBinding"},{"text":" instance.","type":"text"},{"text":" ","type":"text"},{"text":"It provides the methods that can operate on this data type through ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol"},{"text":" conformance.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Binding"},{"text":" as a strong reference or owner of a ","type":"text"},{"code":"GBinding","type":"codeVoice"},{"type":"text","text":" instance."}],"type":"paragraph"},{"name":"Note","style":"note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"Use "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef","type":"reference","isActive":true},{"type":"text","text":" (instead of "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Binding","type":"reference","isActive":true},{"type":"text","text":") for a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GBinding"},{"type":"text","text":" instance."}],"type":"paragraph"}]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"codeVoice","code":"GObject"},{"type":"text","text":" instance (or source) and another property on another "},{"type":"codeVoice","code":"GObject"},{"type":"text","text":" "},{"text":"instance (or target).","type":"text"}],"sections":[],"topicSections":[{"anchor":"Initializers","generated":true,"title":"Initializers","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/init(_:)-2gjer","doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/init(_:)-6ihlv","doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/init(_:)-9ejwo","doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/init(_:)-c2ks","doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/init(binding:)","doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/init(cPointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/init(gconstpointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/init(gpointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/init(opaquePointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/init(raw:)-6d9mu","doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/init(raw:)-8xm6p","doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/init(retaining:)","doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/init(retainingCPointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/init(retainingOpaquePointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/init(retainingRaw:)-6qwvy","doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/init(retainingRaw:)-9vwpp"]},{"generated":true,"title":"D