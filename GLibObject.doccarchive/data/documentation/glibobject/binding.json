{"metadata":{"role":"symbol","symbolKind":"class","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Binding"}],"navigatorTitle":[{"kind":"identifier","text":"Binding"}],"title":"Binding","externalID":"s:10GLibObject7BindingC","roleHeading":"Class","modules":[{"name":"GLibObject"}]},"relationshipsSections":[{"type":"inheritsFrom","title":"Inherits From","kind":"relationships","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/Object"]},{"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol","doc:\/\/GLibObject\/4GLib14PointerWrapperP","doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectProtocol"],"type":"conformsTo","title":"Conforms To","kind":"relationships"}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Binding","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Overview","level":2,"type":"heading","anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"Whenever the source property changes, the same value is applied to the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"target property; for instance, the following binding:"}]},{"type":"codeListing","code":["  g_object_bind_property (object1, \"property-a\",","                          object2, \"property-b\",","                          G_BINDING_DEFAULT);"],"syntax":"c"},{"inlineContent":[{"type":"text","text":"will cause the property named “property-b” of "},{"type":"codeVoice","code":"object2"},{"type":"text","text":" to be updated"},{"text":" ","type":"text"},{"type":"text","text":"every time [method"},{"code":"GObject.set","type":"codeVoice"},{"type":"text","text":"] or the specific accessor changes the value of"},{"text":" ","type":"text"},{"type":"text","text":"the property “property-a” of "},{"code":"object1","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"It is possible to create a bidirectional binding between two properties","type":"text"},{"type":"text","text":" "},{"text":"of two ","type":"text"},{"type":"codeVoice","code":"GObject"},{"type":"text","text":" instances, so that if either property changes, the"},{"text":" ","type":"text"},{"text":"other is updated as well, for instance:","type":"text"}],"type":"paragraph"},{"syntax":"c","type":"codeListing","code":["  g_object_bind_property (object1, \"property-a\",","                          object2, \"property-b\",","                          G_BINDING_BIDIRECTIONAL);"]},{"type":"paragraph","inlineContent":[{"text":"will keep the two properties in sync.","type":"text"}]},{"inlineContent":[{"type":"text","text":"It is also possible to set a custom transformation function (in both"},{"text":" ","type":"text"},{"type":"text","text":"directions, in case of a bidirectional binding) to apply a custom"},{"text":" ","type":"text"},{"type":"text","text":"transformation from the source value to the target value before"},{"type":"text","text":" "},{"text":"applying it; for instance, the following binding:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"c","code":["  g_object_bind_property_full (adjustment1, \"value\",","                               adjustment2, \"value\",","                               G_BINDING_BIDIRECTIONAL,","                               celsius_to_fahrenheit,","                               fahrenheit_to_celsius,","                               NULL, NULL);"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"will keep the “value” property of the two adjustments in sync; the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"celsius_to_fahrenheit"},{"type":"text","text":" function will be called whenever the “value”"},{"type":"text","text":" "},{"type":"text","text":"property of "},{"type":"codeVoice","code":"adjustment1"},{"text":" changes and will transform the current value","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of the property before applying it to the “value” property of "},{"type":"codeVoice","code":"adjustment2"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"Vice versa, the "},{"code":"fahrenheit_to_celsius","type":"codeVoice"},{"type":"text","text":" function will be called whenever"},{"type":"text","text":" "},{"text":"the “value” property of ","type":"text"},{"code":"adjustment2","type":"codeVoice"},{"type":"text","text":" changes, and will transform the"},{"type":"text","text":" "},{"text":"current value of the property before applying it to the “value” property","type":"text"},{"type":"text","text":" "},{"text":"of ","type":"text"},{"type":"codeVoice","code":"adjustment1"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Binding"},{"text":" does not resolve cycles by itself; a cycle like","type":"text"}]},{"code":["  object1:propertyA -> object2:propertyB","  object2:propertyB -> object3:propertyC","  object3:propertyC -> object1:propertyA"],"syntax":null,"type":"codeListing"},{"inlineContent":[{"type":"text","text":"might lead to an infinite loop. The loop, in this particular case,"},{"text":" ","type":"text"},{"text":"can be avoided if the objects emit the ","type":"text"},{"type":"codeVoice","code":"GObject"},{"type":"text","text":"notify"},{"type":"codeVoice","code":" signal only if the value has effectively been changed. A binding is implemented using the `GObject`notify"},{"text":" signal, so it is susceptible to all the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"various ways of blocking a signal emission, like [func"},{"type":"codeVoice","code":"GObject.signal_stop_emission"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"type":"text","text":"or [func"},{"type":"codeVoice","code":"GObject.signal_handler_block"},{"text":"].","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"A binding will be severed, and the resources it allocates freed, whenever","type":"text"},{"text":" ","type":"text"},{"text":"either one of the ","type":"text"},{"type":"codeVoice","code":"GObject"},{"type":"text","text":" instances it refers to are finalized, or when"},{"text":" ","type":"text"},{"type":"text","text":"the "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Binding","isActive":true},{"type":"text","text":" instance loses its last reference."}]},{"inlineContent":[{"text":"Bindings for languages with garbage collection can use","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"code":"GObject.Binding.unbind","type":"codeVoice"},{"type":"text","text":"] to explicitly release a binding between the source"},{"type":"text","text":" "},{"type":"text","text":"and target properties, instead of relying on the last reference on the"},{"type":"text","text":" "},{"text":"binding, source, and target instances to drop.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Binding","type":"reference"},{"type":"text","text":" type acts as a reference-counted owner of an underlying "},{"code":"GBinding","type":"codeVoice"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"It provides the methods that can operate on this data type through "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol","isActive":true},{"text":" conformance.","type":"text"},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Binding"},{"text":" as a strong reference or owner of a ","type":"text"},{"type":"codeVoice","code":"GBinding"},{"type":"text","text":" instance."}]},{"style":"note","name":"Note","content":[{"inlineContent":[{"type":"text","text":"Use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef"},{"text":" (instead of ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Binding","type":"reference"},{"text":") for a lightweight Swift reference to an underlying ","type":"text"},{"code":"GBinding","type":"codeVoice"},{"type":"text","text":" instance."}],"type":"paragraph"}],"type":"aside"}]}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject"]]},"variants":[{"paths":["\/documentation\/glibobject\/binding"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"code":"GObject","type":"codeVoice"},{"text":" instance (or source) and another property on another ","type":"text"},{"type":"codeVoice","code":"GObject"},{"text":" ","type":"text"},{"type":"text","text":"instance (or target)."}],"kind":"symbol","sections":[],"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/Binding","interfaceLanguage":"swift"},"topicSections":[{"generated":true,"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/init(_:)-2gjer","doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/init(_:)-6ihlv","doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/init(_:)-9ejwo","doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/init(_:)-c2ks","doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/init(binding:)","doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/init(cPointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/init(gconstpointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/init(gpointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/init(opaquePointer:)","doc:\/\/GLibObject\