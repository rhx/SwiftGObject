{"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"symbolKind":"protocol","roleHeading":"Protocol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"BindingProtocol","kind":"identifier"}],"role":"symbol","title":"BindingProtocol","modules":[{"name":"GLibObject"}],"externalID":"s:10GLibObject15BindingProtocolP","navigatorTitle":[{"text":"BindingProtocol","kind":"identifier"}]},"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"text":"BindingProtocol","kind":"identifier"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:10GLibObject0B8ProtocolP","text":"ObjectProtocol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectProtocol","kind":"typeIdentifier"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Overview","type":"heading","anchor":"overview","level":2},{"type":"paragraph","inlineContent":[{"text":"Whenever the source property changes, the same value is applied to the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"target property; for instance, the following binding:"}]},{"syntax":"c","type":"codeListing","code":["  g_object_bind_property (object1, \"property-a\",","                          object2, \"property-b\",","                          G_BINDING_DEFAULT);"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"will cause the property named “property-b” of "},{"type":"codeVoice","code":"object2"},{"text":" to be updated","type":"text"},{"text":" ","type":"text"},{"text":"every time [method","type":"text"},{"type":"codeVoice","code":"GObject.set"},{"text":"] or the specific accessor changes the value of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the property “property-a” of "},{"code":"object1","type":"codeVoice"},{"type":"text","text":"."}]},{"inlineContent":[{"text":"It is possible to create a bidirectional binding between two properties","type":"text"},{"text":" ","type":"text"},{"text":"of two ","type":"text"},{"code":"GObject","type":"codeVoice"},{"type":"text","text":" instances, so that if either property changes, the"},{"type":"text","text":" "},{"text":"other is updated as well, for instance:","type":"text"}],"type":"paragraph"},{"syntax":"c","code":["  g_object_bind_property (object1, \"property-a\",","                          object2, \"property-b\",","                          G_BINDING_BIDIRECTIONAL);"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"will keep the two properties in sync.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is also possible to set a custom transformation function (in both"},{"type":"text","text":" "},{"text":"directions, in case of a bidirectional binding) to apply a custom","type":"text"},{"type":"text","text":" "},{"text":"transformation from the source value to the target value before","type":"text"},{"type":"text","text":" "},{"type":"text","text":"applying it; for instance, the following binding:"}]},{"syntax":"c","type":"codeListing","code":["  g_object_bind_property_full (adjustment1, \"value\",","                               adjustment2, \"value\",","                               G_BINDING_BIDIRECTIONAL,","                               celsius_to_fahrenheit,","                               fahrenheit_to_celsius,","                               NULL, NULL);"]},{"inlineContent":[{"text":"will keep the “value” property of the two adjustments in sync; the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"celsius_to_fahrenheit"},{"type":"text","text":" function will be called whenever the “value”"},{"text":" ","type":"text"},{"text":"property of ","type":"text"},{"code":"adjustment1","type":"codeVoice"},{"type":"text","text":" changes and will transform the current value"},{"text":" ","type":"text"},{"type":"text","text":"of the property before applying it to the “value” property of "},{"code":"adjustment2","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Vice versa, the ","type":"text"},{"type":"codeVoice","code":"fahrenheit_to_celsius"},{"text":" function will be called whenever","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the “value” property of "},{"code":"adjustment2","type":"codeVoice"},{"text":" changes, and will transform the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"current value of the property before applying it to the “value” property"},{"type":"text","text":" "},{"type":"text","text":"of "},{"type":"codeVoice","code":"adjustment1"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Note that ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Binding","isActive":true},{"type":"text","text":" does not resolve cycles by itself; a cycle like"}]},{"type":"codeListing","code":["  object1:propertyA -> object2:propertyB","  object2:propertyB -> object3:propertyC","  object3:propertyC -> object1:propertyA"],"syntax":null},{"type":"paragraph","inlineContent":[{"text":"might lead to an infinite loop. The loop, in this particular case,","type":"text"},{"text":" ","type":"text"},{"text":"can be avoided if the objects emit the ","type":"text"},{"type":"codeVoice","code":"GObject"},{"type":"text","text":"notify"},{"type":"codeVoice","code":" signal only if the value has effectively been changed. A binding is implemented using the `GObject`notify"},{"type":"text","text":" signal, so it is susceptible to all the"},{"type":"text","text":" "},{"type":"text","text":"various ways of blocking a signal emission, like [func"},{"type":"codeVoice","code":"GObject.signal_stop_emission"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"type":"text","text":"or [func"},{"type":"codeVoice","code":"GObject.signal_handler_block"},{"type":"text","text":"]."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A binding will be severed, and the resources it allocates freed, whenever"},{"type":"text","text":" "},{"type":"text","text":"either one of the "},{"type":"codeVoice","code":"GObject"},{"type":"text","text":" instances it refers to are finalized, or when"},{"type":"text","text":" "},{"type":"text","text":"the "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Binding","isActive":true},{"type":"text","text":" instance loses its last reference."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Bindings for languages with garbage collection can use"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GObject.Binding.unbind"},{"type":"text","text":"] to explicitly release a binding between the source"},{"type":"text","text":" "},{"text":"and target properties, instead of relying on the last reference on the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"binding, source, and target instances to drop."}]},{"inlineContent":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol","isActive":true},{"type":"text","text":" protocol exposes the methods and properties of an underlying "},{"code":"GBinding","type":"codeVoice"},{"text":" instance.","type":"text"},{"type":"text","text":" "},{"text":"The default implementation of these can be found in the protocol extension below.","type":"text"},{"type":"text","text":" "},{"text":"For a concrete class that implements these methods and properties, see ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Binding","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Alternatively, use "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef","isActive":true},{"text":" as a lighweight, ","type":"text"},{"code":"unowned","type":"codeVoice"},{"text":" reference if you already have an instance you just want to use.","type":"text"}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject"]]},"topicSections":[{"title":"Instance Properties","anchor":"Instance-Properties","generated":true,"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol\/binding_ptr-9m3c1","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol\/flags","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol\/source","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol\/sourceProperty","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol\/target","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol\/targetProperty"]},{"anchor":"Instance-Methods","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol\/bind(property:to:_:flags:transformFrom:transformTo:)","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol\/dupSource()","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol\/dupTarget()","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol\/get(property:)","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol\/getFlags()","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol\/getSource()","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol\/getSourceProperty()","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol\/getTarget()","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol\/getTargetProperty()","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol\/set(property:value:)","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol\/unbind()"],"title":"Instance Methods","generated":true}],"abstract":[{"code":"GObject","type":"cod