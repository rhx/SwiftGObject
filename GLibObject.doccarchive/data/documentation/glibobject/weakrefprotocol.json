{"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject"]]},"metadata":{"navigatorTitle":[{"text":"WeakRefProtocol","kind":"identifier"}],"modules":[{"name":"GLibObject"}],"externalID":"s:10GLibObject15WeakRefProtocolP","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"WeakRefProtocol"}],"role":"symbol","title":"WeakRefProtocol","symbolKind":"protocol","roleHeading":"Protocol"},"relationshipsSections":[{"type":"inheritsFrom","kind":"relationships","identifiers":["doc:\/\/GLibObject\/4GLib14PointerWrapperP"],"title":"Inherits From"},{"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRef","doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRefRef"],"kind":"relationships","type":"conformingTypes","title":"Conforming Types"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"WeakRefProtocol","kind":"identifier"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib14PointerWrapperP","text":"PointerWrapper"}]}]},{"content":[{"text":"Overview","type":"heading","level":2,"anchor":"overview"},{"inlineContent":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"GWeakRef"},{"text":" can either be empty (i.e. point to ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":"), or point to an"},{"type":"text","text":" "},{"type":"text","text":"object for as long as at least one “strong” reference to that object"},{"type":"text","text":" "},{"text":"exists. Before the object’s ","type":"text"},{"code":"GObjectClass.dispose","type":"codeVoice"},{"type":"text","text":" method is called,"},{"text":" ","type":"text"},{"text":"every ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRef"},{"text":" associated with becomes empty (i.e. points to ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":")."}],"type":"paragraph"},{"inlineContent":[{"text":"Like ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Value","type":"reference"},{"text":", ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRef"},{"type":"text","text":" can be statically allocated, stack- or"},{"text":" ","type":"text"},{"type":"text","text":"heap-allocated, or embedded in larger structures."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Unlike "},{"code":"g_object_weak_ref()","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"g_object_add_weak_pointer()"},{"text":", this weak","type":"text"},{"type":"text","text":" "},{"type":"text","text":"reference is thread-safe: converting a weak pointer to a reference is"},{"text":" ","type":"text"},{"type":"text","text":"atomic with respect to invalidation of weak pointers to destroyed"},{"type":"text","text":" "},{"type":"text","text":"objects."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the object’s "},{"code":"GObjectClass.dispose","type":"codeVoice"},{"text":" method results in additional","type":"text"},{"text":" ","type":"text"},{"text":"references to the object being held (‘re-referencing’), any ","type":"text"},{"code":"GWeakRefs","type":"codeVoice"},{"type":"text","text":" taken"},{"text":" ","type":"text"},{"text":"before it was disposed will continue to point to ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":".  Any "},{"code":"GWeakRefs","type":"codeVoice"},{"type":"text","text":" taken"},{"type":"text","text":" "},{"text":"during disposal and after re-referencing, or after disposal has returned due","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to the re-referencing, will continue to point to the object until its refcount"},{"type":"text","text":" "},{"type":"text","text":"goes back to zero, at which point they too will be invalidated."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is invalid to take a "},{"isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRef","type":"reference"},{"type":"text","text":" on an object during "},{"code":"GObjectClass.dispose","type":"codeVoice"},{"type":"text","text":" "},{"text":"without first having or creating a strong reference to the object.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRefProtocol","isActive":true},{"text":" protocol exposes the methods and properties of an underlying ","type":"text"},{"code":"GWeakRef","type":"codeVoice"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"The default implementation of these can be found in the protocol extension below."},{"text":" ","type":"text"},{"type":"text","text":"For a concrete class that implements these methods and properties, see "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRef"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Alternatively, use "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRefRef","type":"reference","isActive":true},{"type":"text","text":" as a lighweight, "},{"code":"unowned","type":"codeVoice"},{"text":" reference if you already have an instance you just want to use.","type":"text"}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/glibobject\/weakrefprotocol"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"A structure containing a weak reference to a "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","isActive":true,"type":"re