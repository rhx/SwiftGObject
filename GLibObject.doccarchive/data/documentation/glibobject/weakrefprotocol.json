{"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"WeakRefProtocol"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","text":"PointerWrapper","preciseIdentifier":"s:4GLib14PointerWrapperP"}]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"code":"GWeakRef","type":"codeVoice"},{"type":"text","text":" can either be empty (i.e. point to "},{"code":"nil","type":"codeVoice"},{"type":"text","text":"), or point to an"},{"text":" ","type":"text"},{"type":"text","text":"object for as long as at least one “strong” reference to that object"},{"type":"text","text":" "},{"type":"text","text":"exists. Before the object’s "},{"code":"GObjectClass.dispose","type":"codeVoice"},{"text":" method is called,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"every "},{"isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRef","type":"reference"},{"text":" associated with becomes empty (i.e. points to ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":")."}]},{"inlineContent":[{"type":"text","text":"Like "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Value"},{"text":", ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRef","isActive":true,"type":"reference"},{"text":" can be statically allocated, stack- or","type":"text"},{"type":"text","text":" "},{"text":"heap-allocated, or embedded in larger structures.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Unlike ","type":"text"},{"type":"codeVoice","code":"g_object_weak_ref()"},{"type":"text","text":" and "},{"type":"codeVoice","code":"g_object_add_weak_pointer()"},{"type":"text","text":", this weak"},{"text":" ","type":"text"},{"type":"text","text":"reference is thread-safe: converting a weak pointer to a reference is"},{"text":" ","type":"text"},{"type":"text","text":"atomic with respect to invalidation of weak pointers to destroyed"},{"text":" ","type":"text"},{"type":"text","text":"objects."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If the object’s ","type":"text"},{"code":"GObjectClass.dispose","type":"codeVoice"},{"text":" method results in additional","type":"text"},{"text":" ","type":"text"},{"text":"references to the object being held (‘re-referencing’), any ","type":"text"},{"code":"GWeakRefs","type":"codeVoice"},{"type":"text","text":" taken"},{"type":"text","text":" "},{"text":"before it was disposed will continue to point to ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":".  Any "},{"code":"GWeakRefs","type":"codeVoice"},{"type":"text","text":" taken"},{"text":" ","type":"text"},{"type":"text","text":"during disposal and after re-referencing, or after disposal has returned due"},{"type":"text","text":" "},{"type":"text","text":"to the re-referencing, will continue to point to the object until its refcount"},{"text":" ","type":"text"},{"type":"text","text":"goes back to zero, at which point they too will be invalidated."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is invalid to take a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRef"},{"type":"text","text":" on an object during "},{"type":"codeVoice","code":"GObjectClass.dispose"},{"text":" ","type":"text"},{"type":"text","text":"without first having or creating a strong reference to the object."}]},{"inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRefProtocol"},{"type":"text","text":" protocol exposes the methods and properties of an underlying "},{"type":"codeVoice","code":"GWeakRef"},{"text":" instance.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"The default implementation of these can be found in the protocol extension below."},{"text":" ","type":"text"},{"type":"text","text":"For a concrete class that implements these methods and properties, see "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRef","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Alternatively, use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRefRef"},{"type":"text","text":" as a lighweight, "},{"code":"unowned","type":"codeVoice"},{"type":"text","text":" reference if you already have an instance you just want to use."}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRefProtocol"},"metadata":{"navigatorTitle":[{"kind":"identifier","text":"WeakRefProtocol"}],"modules":[{"name":"GLibObject"}],"externalID":"s:10GLibObject15WeakRefProtocolP","roleHeading":"Protocol","role":"symbol","symbolKind":"protocol","title":"WeakRefProtocol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"WeakRefProtocol"}]},"topicSections":[{"anchor":"Instance-Methods","title":"Instance Methods","generated":true,"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRefProtocol\/clear()","doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRefProtocol\/get()","doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRefProtocol\/init_(object:)-4v5ku","doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRefProtocol\/init_(object:)-56kyl","doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRefProtocol\/set(object:)-3cppk","doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRefProtocol\/set(object:)-94gtr"]}],"relationshi