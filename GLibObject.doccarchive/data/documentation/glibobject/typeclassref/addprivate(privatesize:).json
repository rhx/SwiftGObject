{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeClassRef\/addPrivate(privateSize:)"},"metadata":{"extendedModule":"GLibObject","platforms":[],"symbolKind":"method","role":"symbol","title":"addPrivate(privateSize:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"addPrivate","kind":"identifier"},{"text":"(","kind":"text"},{"text":"privateSize","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"kind":"text","text":")"}],"roleHeading":"Instance Method","externalID":"s:10GLibObject17TypeClassProtocolPAAE10addPrivate11privateSizeySi_tF::SYNTHESIZED::s:10GLibObject12TypeClassRefV","modules":[{"name":"GLibObject"}]},"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeClassRef","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeClassRef\/TypeClassProtocol-Implementations"]]},"abstract":[{"text":"Registers a private structure for an instantiatable type.","type":"text"}],"sections":[],"variants":[{"paths":["\/documentation\/glibobject\/typeclassref\/addprivate(privatesize:)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","schemaVersion":{"patch":0,"minor":3,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"addPrivate"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"privateSize"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":")"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"When an object is allocated, the private structures for"},{"type":"text","text":" "},{"text":"the type and all of its parent types are allocated","type":"text"},{"type":"text","text":" "},{"text":"sequentially in the same memory block as the public","type":"text"},{"type":"text","text":" "},{"text":"structures, and are zero-filled.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Note that the accumulated size of the private structures of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a type and all its parent types cannot exceed 64 KiB."}]},{"inlineContent":[{"text":"This function should be called in the type’s ","type":"text"},{"code":"class_init()","type":"codeVoice"},{"text":" function.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The private structure can be retrieved using the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"G_TYPE_INSTANCE_GET_PRIVATE()"},{"type":"text","text":" macro."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following example shows attaching a private structure"},{"type":"text","text":" "},{"text":"MyObjectPrivate to an object MyObject defined in the standard","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"GObject fashion in the type’s "},{"code":"class_init()","type":"codeVoice"},{"type":"text","text":" function."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note the use of a structure member “priv” to avoid the overhead"},{"text":" ","type":"text"},{"text":"of repeatedly calling ","type":"text"},{"type":"codeVoice","code":"MY_OBJECT_GET_PRIVATE()"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"type":"codeListing","syntax":"C","code":["typedef struct _MyObject        MyObject;","typedef struct _MyObjectPrivate MyObjectPrivate;","","struct _MyObject {"," GObject parent;",""," MyObjectPrivate *priv;","};","","struct _MyObjectPrivate {","  int some_field;","};","","static void","my_object_class_init (MyObjectClass *klass)","{","  g_type_class_add_private (klass, sizeof (MyObjectPrivate));","}","","static void","my_object_init (MyObject *my_object)","{","  my_object->priv = G_TYPE_INSTANCE_GET_PRIVATE (my_object,","                                                 MY_TYPE_OBJECT,","                                                 MyObjectPrivate);","  \/\/ my_object->priv->some_field will be automatically initialised to 0","}","","static int","my_object_get_some_field (MyObject *my_object)","{","  MyObjectPrivate *priv;","","  g_return_val_if_fail (MY_IS_OBJECT (my_object), 0);","","  priv = my_object->priv;","","  return priv->some_field;","}"]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"add_private is deprecated:"}],"type":"strong"},{"type":"text","text":" "},{"type":"text","text":"Use the G_ADD_PRIVATE() macro with the "},{"code":"G_DEFINE_*","type":"codeVoice"},{"type":"text","text":" "},{"text":"family of macros to add instance private data to a type","type":"text"}]}]}],"references":{"doc://GLibObject/documentation/GLibObject/TypeClassRef":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeClassRef","type":"topic","url":"\/documentation\/glibobject\/typeclassref","role":"symbol","abstract":[{"type":"text","text":"An opaque structure used as the base of all classes."}],"navigatorTitle":[{"text":"TypeClassRef","kind":"identifier"}],"title":"TypeClassRef","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TypeClassRef"}],"kind":"symbol"},"doc://GLibObject/documentation/GLibObject":{"role":"collection","type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","abstract":[],"title":"GLibObject","kind":"symbol","url":"\/documentation\/glibobject"},"doc://GLibObject/documentation/GLibObject/TypeClassRef/addPrivate(privateSize:)":{"abstract":[{"type":"text","text":"Registers a private structure for an instantiatable type."}],"kind":"symbol","fragments":[{"text":"func","kind":"key