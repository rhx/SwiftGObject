{"kind":"symbol","sections":[],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeClassRef","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeClassRef\/TypeClassProtocol-Implementations"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/typeclassref\/addprivate(privatesize:)"]}],"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeClassRef\/addPrivate(privateSize:)","interfaceLanguage":"swift"},"metadata":{"roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"addPrivate","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"privateSize"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"kind":"text","text":")"}],"platforms":[],"title":"addPrivate(privateSize:)","modules":[{"name":"GLibObject"}],"extendedModule":"GLibObject","role":"symbol","symbolKind":"method","externalID":"s:10GLibObject17TypeClassProtocolPAAE10addPrivate11privateSizeySi_tF::SYNTHESIZED::s:10GLibObject12TypeClassRefV"},"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"addPrivate"},{"kind":"text","text":"("},{"kind":"externalParam","text":"privateSize"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":")","kind":"text"}],"platforms":["macOS"]}]},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When an object is allocated, the private structures for"},{"type":"text","text":" "},{"text":"the type and all of its parent types are allocated","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"sequentially in the same memory block as the public"},{"text":" ","type":"text"},{"text":"structures, and are zero-filled.","type":"text"}]},{"inlineContent":[{"text":"Note that the accumulated size of the private structures of","type":"text"},{"type":"text","text":" "},{"text":"a type and all its parent types cannot exceed 64 KiB.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This function should be called in the type’s "},{"code":"class_init()","type":"codeVoice"},{"type":"text","text":" function."},{"type":"text","text":" "},{"type":"text","text":"The private structure can be retrieved using the"},{"text":" ","type":"text"},{"code":"G_TYPE_INSTANCE_GET_PRIVATE()","type":"codeVoice"},{"text":" macro.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The following example shows attaching a private structure","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"MyObjectPrivate to an object MyObject defined in the standard"},{"text":" ","type":"text"},{"text":"GObject fashion in the type’s ","type":"text"},{"type":"codeVoice","code":"class_init()"},{"type":"text","text":" function."}]},{"inlineContent":[{"text":"Note the use of a structure member “priv” to avoid the overhead","type":"text"},{"text":" ","type":"text"},{"text":"of repeatedly calling ","type":"text"},{"code":"MY_OBJECT_GET_PRIVATE()","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"code":["typedef struct _MyObject        MyObject;","typedef struct _MyObjectPrivate MyObjectPrivate;","","struct _MyObject {"," GObject parent;",""," MyObjectPrivate *priv;","};","","struct _MyObjectPrivate {","  int some_field;","};","","static void","my_object_class_init (MyObjectClass *klass)","{","  g_type_class_add_private (klass, sizeof (MyObjectPrivate));","}","","static void","my_object_init (MyObject *my_object)","{","  my_object->priv = G_TYPE_INSTANCE_GET_PRIVATE (my_object,","                                                 MY_TYPE_OBJECT,","                                                 MyObjectPrivate);","  \/\/ my_object->priv->some_field will be automatically initialised to 0","}","","static int","my_object_get_some_field (MyObject *my_object)","{","  MyObjectPrivate *priv;","","  g_return_val_if_fail (MY_IS_OBJECT (my_object), 0);","","  priv = my_object->priv;","","  return priv->some_field;","}"],"syntax":"C","type":"codeListing"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"add_private is deprecated:"}]},{"text":" ","type":"text"},{"type":"text","text":"Use the G_ADD_PRIVATE() macro with the "},{"type":"codeVoice","code":"G_DEFINE_*"},{"text":" ","type":"text"},{"type":"text","text":"family of macros to add instance private data to a type"}],"type":"paragraph"}],"kind":"content"}],"abstract":[{"type":"text","text":"Registers a private structure for an instantiatable type."}],"references":{"doc://GLibObject/documentation/GLibObject/TypeClassRef":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeClassRef","role":"symbol","kind":"symbol","navigatorTitle":[{"text":"TypeClassRef","kind":"identifier"}],"type":"topic","abstract":[{"text":"An opaque structure used as the base of all classes.","type":"text"}],"url":"\/documentation\/glibobject\/typeclassref","title":"TypeClassRef","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"TypeClassRef","kind":"identifier"}]},"doc://GLibObject/documentation/GLibObject/TypeClassRef/addPrivate(privateSize:)":{"type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeClassRef\/addPrivate(privateSize:)","abstract":[{"text":"Registers a private structure for an instantiatable type.","type":"text"}],"url":"\/documentation\/glibobject\/typeclassref\/addprivate(privatesize:)","title":"addPrivate(privateSize:)","kind":"symbol","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"addPrivate"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"privateSize"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"kind":"text","text":")"}],"deprecated":true},"doc://GLibObject/documentation/GLibObject":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","url":"\/documentation\/glibobject","abstract":[],"role":"collection","kind":"symbol","title":"GLibObject","type":"topic"},"doc://GLibObject/documentation/GLibObject/TypeClassRef/TypeClassProtocol-Implementations":{"title":"TypeClassProtocol Implementations","type":"topic","role":"collectionGroup","abstract":[],"url":"\/documentation\/glibobject\/typeclassref\/typeclassprotocol-implementations","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeClassRef\/TypeClassProtocol-Implementations","kind":"article"}}}