{"kind":"symbol","sections":[],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/Closure","doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/ClosureProtocol-Implementations"]]},"variants":[{"paths":["\/documentation\/glibobject\/closure\/setmetamarshal(marshaldata:metamarshal:)"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"modules":[{"name":"GLibObject"}],"title":"setMetaMarshal(marshalData:metaMarshal:)","symbolKind":"method","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"setMetaMarshal"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"marshalData"},{"text":": ","kind":"text"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"kind":"text","text":"?, "},{"text":"metaMarshal","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"GClosureMarshal","preciseIdentifier":"c:gclosure.h@T@GClosureMarshal","kind":"typeIdentifier"},{"kind":"text","text":")"}],"role":"symbol","externalID":"s:10GLibObject15ClosureProtocolPAAE14setMetaMarshal11marshalData04metaG0ySvSg_ySpySo9_GClosureVGSg_SpySo7_GValueVGSgs6UInt32VSPyAMGSgA2GtXCtF::SYNTHESIZED::s:10GLibObject7ClosureC","extendedModule":"GLibObject"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/setMetaMarshal(marshalData:metaMarshal:)"},"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"setMetaMarshal","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"marshalData"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer"},{"kind":"text","text":"? = nil, "},{"kind":"externalParam","text":"metaMarshal"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"GClosureMarshal","preciseIdentifier":"c:gclosure.h@T@GClosureMarshal"},{"text":")","kind":"text"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"A meta marshaller wraps the ","type":"text"},{"code":"closure","type":"codeVoice"},{"text":"’s marshal and modifies the way","type":"text"},{"type":"text","text":" "},{"type":"text","text":"it is called in some fashion. The most common use of this facility"},{"type":"text","text":" "},{"type":"text","text":"is for C callbacks."}]},{"inlineContent":[{"type":"text","text":"The same marshallers (generated by "},{"isActive":true,"identifier":"#glib-genmarshal","type":"reference"},{"type":"text","text":"),"},{"text":" ","type":"text"},{"type":"text","text":"are used everywhere, but the way that we get the callback function"},{"type":"text","text":" "},{"text":"differs. In most cases we want to use the ","type":"text"},{"type":"codeVoice","code":"closure"},{"type":"text","text":"’s callback, but in"},{"type":"text","text":" "},{"text":"other cases we want to use some different technique to retrieve the","type":"text"},{"text":" ","type":"text"},{"text":"callback function.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For example, class closures for signals (see"},{"type":"text","text":" "},{"code":"g_signal_type_cclosure_new()","type":"codeVoice"},{"type":"text","text":") retrieve the callback function from a"},{"type":"text","text":" "},{"text":"fixed offset in the class structure.  The meta marshaller retrieves","type":"text"},{"type":"text","text":" "},{"text":"the right callback and passes it to the marshaller as the","type":"text"},{"type":"text","text":" "},{"code":"marshalData","type":"codeVoice"},{"text":" argument.","type":"text"}],"type":"paragraph"}]}],"abstract":[{"type":"text","text":"Sets the meta marshaller of "},{"code":"closure","type":"codeVoice"},{"type":"text","text":"."}],"references":{"#glib-genmarshal":{"titleInlineContent":[{"text":"glib-genmarshal","type":"text"}],"url":"#glib-genmarshal","type":"link","title":"glib-genmarshal","identifier":"#glib-genmarshal"},"doc://GLibObject/documentation/GLibObject/Closure/ClosureProtocol-Implementations":{"abstract":[],"role":"collectionGroup","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/ClosureProtocol-Implementations","type":"topic","title":"ClosureProtocol Implementations","url":"\/documentation\/glibobject\/closure\/closureprotocol-implementations","kind":"article"},"doc://GLibObject/documentation/GLibObject/Closure/setMetaMarshal(marshalData:metaMarshal:)":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"setMetaMarshal","kind":"identifier"},{"text":"(","kind":"text"},{"text":"marshalData","kind":"externalParam"},{"kind":"text","text":": "},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"text":"?, ","kind":"text"},{"text":"metaMarshal","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"GClosureMarshal","kind":"typeIdentifier","preciseIdentifier":"c:gclosure.h@T@GClosureMarshal"},{"text":")","kind":"text"}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/setMetaMarshal(marshalData:metaMarshal:)","role":"symbol","type":"topic","url":"\/documentation\/glibobject\/closure\/setmetamarshal(marshaldata:metamarshal:)","kind":"symbol","abstract":[{"type":"text","text":"Sets the meta marshaller of "},{"type":"codeVoice","code":"closure"},{"type":"text","text":"."}],"title":"setMetaMarshal(marshalData:metaMarshal:)"},"doc://GLibObject/documentation/GLibObject":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","url":"\/documentation\/glibobject","abstract":[],"role":"collection","kind":"symbol","title":"GLibObject","type":"topic"},"doc://GLibObject/documentation/GLibObject/Closure":{"abstract":[{"text":"A ","type":"text"},{"code":"GClosure","type":"codeVoice"},{"text":" represents a callback supplied by the programmer.","type":"text"}],"title":"Closure","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Closure","type":"topic","kind":"symbol","navigatorTitle":[{"text":"Closure","kind":"identifier"}],"role":"symbol","url":"\/documentation\/glibobject\/closure","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"Closure"}]}}}