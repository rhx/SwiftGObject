{"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedSignalName\/notify","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"title":"InitiallyUnownedSignalName.notify","modules":[{"name":"GLibObject"}],"symbolKind":"case","roleHeading":"Case","fragments":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"notify"}],"role":"symbol","externalID":"s:10GLibObject26InitiallyUnownedSignalNameO6notifyyA2CmF"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedSignalName"]]},"abstract":[{"type":"text","text":"The notify signal is emitted on an object when one of its properties has"},{"type":"text","text":" "},{"text":"its value set through ","type":"text"},{"code":"g_object_set_property()","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"g_object_set()"},{"type":"text","text":", et al."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/initiallyunownedsignalname\/notify"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"notify"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Note that getting this signal doesn’t itself guarantee that the value of","type":"text"},{"text":" ","type":"text"},{"text":"the property has actually changed. When it is emitted is determined by the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"derived GObject class. If the implementor did not create the property with"},{"type":"text","text":" "},{"code":"explicitNotify","type":"codeVoice"},{"type":"text","text":", then any call to "},{"code":"g_object_set_property()","type":"codeVoice"},{"type":"text","text":" results"},{"type":"text","text":" "},{"type":"text","text":"in "},{"type":"codeVoice","code":"notify"},{"type":"text","text":" being emitted, even if the new value is the same as the old."},{"type":"text","text":" "},{"type":"text","text":"If they did pass "},{"code":"explicitNotify","type":"codeVoice"},{"text":", then this signal is emitted only","type":"text"},{"text":" ","type":"text"},{"text":"when they explicitly call ","type":"text"},{"type":"codeVoice","code":"g_object_notify()"},{"type":"text","text":" or "},{"type":"codeVoice","code":"g_object_notify_by_pspec()"},{"text":",","type":"text"},{"type":"text","text":" "},{"text":"and common practice is to do that only when the value has actually changed.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This signal is typically used to obtain change notification for a"},{"type":"text","text":" "},{"text":"single property, by specifying the property name as a detail in the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_signal_connect()"},{"type":"text","text":" call, like this:"}]},{"inlineContent":[{"text":"(C Language Example):","type":"text"}],"type":"paragraph"},{"code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"],"syntax":"C","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is important to note that you must use"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"#class@GObject.ParamSpec#parameter-names"},{"text":" as","type":"text"},{"type":"text","text":" "},{"type":"text","text":"detail strings for the notify signal."}]}]}],"sections":[],"references":{"doc://GLibObject/documentation/GLibObject/InitiallyUnownedSignalName":{"type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Initial