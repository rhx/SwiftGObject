{"primaryContentSections":[{"declarations":[{"tokens":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"notify"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Note that getting this signal doesn’t itself guarantee that the value of"},{"type":"text","text":" "},{"text":"the property has actually changed. When it is emitted is determined by the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"derived GObject class. If the implementor did not create the property with"},{"text":" ","type":"text"},{"type":"codeVoice","code":"explicitNotify"},{"type":"text","text":", then any call to "},{"type":"codeVoice","code":"g_object_set_property()"},{"type":"text","text":" results"},{"type":"text","text":" "},{"type":"text","text":"in "},{"type":"codeVoice","code":"notify"},{"type":"text","text":" being emitted, even if the new value is the same as the old."},{"type":"text","text":" "},{"type":"text","text":"If they did pass "},{"type":"codeVoice","code":"explicitNotify"},{"type":"text","text":", then this signal is emitted only"},{"type":"text","text":" "},{"type":"text","text":"when they explicitly call "},{"code":"g_object_notify()","type":"codeVoice"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"g_object_notify_by_pspec()"},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"text","text":"and common practice is to do that only when the value has actually changed."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This signal is typically used to obtain change notification for a"},{"text":" ","type":"text"},{"type":"text","text":"single property, by specifying the property name as a detail in the"},{"type":"text","text":" "},{"code":"g_signal_connect()","type":"codeVoice"},{"type":"text","text":" call, like this:"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"],"type":"codeListing","syntax":"C"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is important to note that you must use"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"#class@GObject.ParamSpec#parameter-names"},{"type":"text","text":" as"},{"type":"text","text":" "},{"text":"detail strings for the notify signal.","type":"text"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/typemodulesignalname\/notify"]}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleSignalName"]]},"kind":"symbol","abstract":[{"text":"The notify signal is emitted on an object when one of its properties has","type":"text"},{"type":"text","text":" "},{"type":"text","text":"its value set through "},{"type":"codeVoice","code":"g_object_set_property()"},{"type":"text","text":", "},{"type":"codeVoice","code":"g_object_set()"},{"type":"text","text":", et al."}],"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleSignalName\/notify","interfaceLanguage":"swift"},"metadata":{"symbolKind":"case","fragments":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"text":"notify","kind":"identifier"}],"role":"symbol","modules":[{"name":"GLibObject"}],"externalID":"s:10GLibObject20TypeModuleSignalNameO6notifyyA2CmF","roleHeading":"Case","title":"TypeModuleSignalName.notify"},"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://GLibObject/documentation/GLibObject/TypeModuleSignalName":{"abstract":[],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleSignalName","role":"symbol","url":"\/documentation\/glibobject\/typemodulesignalname","title":"TypeModuleSignalName","kind":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"enum"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TypeModuleSignalName"}],"navigatorTitle":[{"text":"TypeModuleSignalName","kind":"identifier"}]},"#class@GObject.ParamSpec#parameter-names":{"url":"#class@GObject.ParamSpec#parameter-names","title":"canonical parameter names","identifier":"#class@GObject.ParamSpec#parameter-names","titleInlineContent":[{"type":"text","text":"canonical parameter names"}],"type":"link"},"doc://GLibObject/documentation/GLibObject":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","url":"\/documentation\/glibobject","abstract":[],"role":"collection","kind":"symbol","title":"GLibObject","type":"topic"},"doc://GLibObject/documentation/GLibObject/TypeModuleSignalName/notify":{"role":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleSignalName\/notify","type":"topic","abstract":[{"type":"text","text":"The notify signal is emitted on an object when one of its properties has"},{"type":"text","text":" "},{"type":"text","text":"its value set through "},{"type":"codeVoice","code":"g_object_set_property()"},{"text":", ","type":"text"},{"code":"g_object_set()","type":"codeVoice"},{"type":"text","text":", et al."}],"title":"TypeModuleSignalName.notify","url":"\/documentation\/glibobject\/typemodulesignalname\/notify","kind":"symbol","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"notify"}]}}}