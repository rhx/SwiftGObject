},{"text":" ","type":"text"},{"text":"structures, and are zero-filled.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that the accumulated size of the private structures of"},{"text":" ","type":"text"},{"type":"text","text":"a type and all its parent types cannot exceed 64 KiB."}]},{"type":"paragraph","inlineContent":[{"text":"This function should be called in the type’s ","type":"text"},{"type":"codeVoice","code":"class_init()"},{"text":" function.","type":"text"},{"text":" ","type":"text"},{"text":"The private structure can be retrieved using the","type":"text"},{"type":"text","text":" "},{"code":"G_TYPE_INSTANCE_GET_PRIVATE()","type":"codeVoice"},{"text":" macro.","type":"text"}]},{"inlineContent":[{"text":"The following example shows attaching a private structure","type":"text"},{"text":" ","type":"text"},{"text":"MyObjectPrivate to an object MyObject defined in the standard","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"GObject fashion in the type’s "},{"type":"codeVoice","code":"class_init()"},{"type":"text","text":" function."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note the use of a structure member “priv” to avoid the overhead"},{"text":" ","type":"text"},{"type":"text","text":"of repeatedly calling "},{"code":"MY_OBJECT_GET_PRIVATE()","type":"codeVoice"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"syntax":"C","type":"codeListing","code":["typedef struct _MyObject        MyObject;","typedef struct _MyObjectPrivate MyObjectPrivate;","","struct _MyObject {"," GObject parent;",""," MyObjectPrivate *priv;","};","","struct _MyObjectPrivate {","  int some_field;","};","","static void","my_object_class_init (MyObjectClass *klass)","{","  g_type_class_add_private (klass, sizeof (MyObjectPrivate));","}","","static void","my_object_init (MyObject *my_object)","{","  my_object->priv = G_TYPE_INSTANCE_