{"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/typepluginref"]}],"relationshipsSections":[{"kind":"relationships","type":"conformsTo","identifiers":["doc:\/\/GLibObject\/4GLib14PointerWrapperP","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol"],"title":"Conforms To"}],"topicSections":[{"generated":true,"anchor":"Initializers","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(_:)-2mf3j","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(_:)-47vjm","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(_:)-5hv9g","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(_:)-75qw1","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(_:)-9532m","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(cPointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(constPointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(gconstpointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(gpointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(mutating:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(opaquePointer:)"],"title":"Initializers"},{"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/ptr"],"anchor":"Instance-Properties","generated":true,"title":"Instance Properties"},{"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/PointerWrapper-Implementations","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/TypePluginProtocol-Implementations"],"title":"Default Implementations","generated":true,"anchor":"Default-Implementations"}],"kind":"symbol","sections":[],"metadata":{"externalID":"s:10GLibObject13TypePluginRefV","role":"symbol","symbolKind":"struct","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"TypePluginRef"}],"navigatorTitle":[{"text":"TypePluginRef","kind":"identifier"}],"roleHeading":"Structure","title":"TypePluginRef","modules":[{"name":"GLibObject"}]},"abstract":[{"text":"An interface that handles the lifecycle of dynamically loaded types.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TypePluginRef"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"anchor":"overview","text":"Overview","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"The GObject type system supports dynamic loading of types."},{"type":"text","text":" "},{"text":"It goes as follows:","type":"text"}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"The type is initially introduced (usually upon loading the module"},{"text":" ","type":"text"},{"type":"text","text":"the first time, or by your main application that knows what modules"},{"text":" ","type":"text"},{"text":"introduces what types), like this:","type":"text"}],"type":"paragraph"},{"syntax":"c","code":["new_type_id = g_type_register_dynamic (parent_type_id,","                                       \"TypeName\",","                                       new_type_plugin,","                                       type_flags);"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"where ","type":"text"},{"type":"codeVoice","code":"new_type_plugin"},{"type":"text","text":" is an implementation of the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"GTypePlugin"},{"type":"text","text":" interface."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The type’s implementation is referenced, e.g. through","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[func"},{"code":"GObject.TypeClass.ref","type":"codeVoice"},{"text":"] or through [func","type":"text"},{"code":"GObject.type_create_instance","type":"codeVoice"},{"text":"]","type":"text"},{"type":"text","text":" "},{"text":"(this is being called by [ctor","type":"text"},{"type":"codeVoice","code":"GObject.Object.new"},{"type":"text","text":"]) or through one of the above"},{"text":" ","type":"text"},{"text":"done on a type derived from ","type":"text"},{"type":"codeVoice","code":"new_type_id"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This causes the type system to load the type’s implementation by calling"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"code":"GObject.TypePlugin.use","type":"codeVoice"},{"text":"] and [method","type":"text"},{"type":"codeVoice","code":"GObject.TypePlugin.complete_type_info"},{"type":"text","text":"]"},{"type":"text","text":" "},{"text":"on ","type":"text"},{"code":"new_type_plugin","type":"codeVoice"},{"text":".","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"At some point the type’s implementation isn’t required anymore, e.g. after"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GObject.TypeClass.unref"},{"type":"text","text":"] or [func"},{"code":"GObject.type_free_instance","type":"codeVoice"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"type":"text","text":"(called when the reference count of an instance drops to zero)."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This causes the type system to throw away the information retrieved"},{"type":"text","text":" "},{"text":"from [method","type":"text"},{"code":"GObject.TypePlugin.complete_type_info","type":"codeVoice"},{"text":"] and then it calls","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GObject.TypePlugin.unuse"},{"text":"] on ","type":"text"},{"code":"new_type_plugin","type":"codeVoice"},{"text":".","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Things may repeat from the second step."}],"type":"paragraph"}]}]},{"inlineContent":[{"text":"So basically, you need to implement a ","type":"text"},{"code":"GTypePlugin","type":"codeVoice"},{"text":" type that","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"carries a use_count, once use_count goes from zero to one, you need"},{"type":"text","text":" "},{"type":"text","text":"to load the implementation to successfully handle the upcoming"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GObject.TypePlugin.complete_type_info"},{"text":"] call. Later, maybe after","type":"text"},{"type":"text","text":" "},{"type":"text","text":"succeeding use\/unuse calls, once use_count drops to zero, you can"},{"text":" ","type":"text"},{"text":"unload the implementation again. The type system makes sure to call","type":"text"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GObject.TypePlugin.use"},{"type":"text","text":"] and [method"},{"code":"GObject.TypePlugin.complete_type_info","type":"codeVoice"},{"text":"]","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"again when the type is needed again."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"[class"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule","isActive":true,"type":"reference"},{"type":"text","text":"] is an implementation of "},{"code":"GTypePlugin","type":"codeVoice"},{"text":" that","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"already implements most of this except for the actual module loading and"},{"type":"text","text":" "},{"type":"text","text":"unloading. It even handles multiple registered types per module."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef","isActive":true},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"code":"GTypePlugin","type":"codeVoice"},{"text":" instance.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol","type":"reference"},{"type":"text","text":" conformance."},{"text":" ","type":"text"},{"type":"text","text":"Use "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef","type":"reference","isActive":true},{"type":"text","text":" only as an "},{"type":"codeVoice","code":"unowned"},{"text":" reference to an existing ","type":"text"},{"type":"codeVoice","code":"GTypePlugin"},{"type":"text","text":" instance."}]},{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin","type":"reference"},{"type":"text","text":" (instead of "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef","type":"reference","isActive":true},{"text":") if you want to use Automatic Reference Counting for memory management of the underlying ","type":"text"},{"type":"codeVoice","code":"GTypePlugin"},{"type":"text","text":" instance."}]}]}],"kind":"content"}],"references":{"doc://GLibObject/documentation/GLibObject/TypePluginRef/init(_:)-75qw1":{"url":"\/documentation\/glibobject\/typepluginref\/init(_:)-75qw1","role":"symbol","abstract":[{"type":"text","text":"Designated initialiser from the underlying "},{"type":"codeVoice","code":"C"},{"type":"text","text":" data type"}],"fra