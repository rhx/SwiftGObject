{"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/typepluginref"]}],"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef","interfaceLanguage":"swift"},"kind":"symbol","metadata":{"role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TypePluginRef"}],"modules":[{"name":"GLibObject"}],"title":"TypePluginRef","externalID":"s:10GLibObject13TypePluginRefV","navigatorTitle":[{"kind":"identifier","text":"TypePluginRef"}],"roleHeading":"Structure","symbolKind":"struct"},"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject"]]},"sections":[],"abstract":[{"type":"text","text":"An interface that handles the lifecycle of dynamically loaded types."}],"topicSections":[{"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(_:)-2mf3j","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(_:)-47vjm","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(_:)-5hv9g","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(_:)-75qw1","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(_:)-9532m","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(cPointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(constPointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(gconstpointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(gpointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(mutating:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(opaquePointer:)"],"anchor":"Initializers","generated":true,"title":"Initializers"},{"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/ptr"],"generated":true,"title":"Instance Properties","anchor":"Instance-Properties"},{"title":"Default Implementations","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/PointerWrapper-Implementations","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/TypePluginProtocol-Implementations"],"anchor":"Default-Implementations","generated":true}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TypePluginRef"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"overview","text":"Overview","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The GObject type system supports dynamic loading of types.","type":"text"},{"type":"text","text":" "},{"text":"It goes as follows:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The type is initially introduced (usually upon loading the module","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the first time, or by your main application that knows what modules"},{"type":"text","text":" "},{"type":"text","text":"introduces what types), like this:"}]},{"type":"codeListing","syntax":"c","code":["new_type_id = g_type_register_dynamic (parent_type_id,","                                       \"TypeName\",","                                       new_type_plugin,","                                       type_flags);"]},{"type":"paragraph","inlineContent":[{"text":"where ","type":"text"},{"type":"codeVoice","code":"new_type_plugin"},{"text":" is an implementation of the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"GTypePlugin"},{"text":" interface.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The type’s implementation is referenced, e.g. through"},{"text":" ","type":"text"},{"text":"[func","type":"text"},{"type":"codeVoice","code":"GObject.TypeClass.ref"},{"text":"] or through [func","type":"text"},{"code":"GObject.type_create_instance","type":"codeVoice"},{"type":"text","text":"]"},{"type":"text","text":" "},{"text":"(this is being called by [ctor","type":"text"},{"type":"codeVoice","code":"GObject.Object.new"},{"text":"]) or through one of the above","type":"text"},{"type":"text","text":" "},{"text":"done on a type derived from ","type":"text"},{"code":"new_type_id","type":"codeVoice"},{"type":"text","text":"."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"This causes the type system to load the type’s implementation by calling"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GObject.TypePlugin.use"},{"text":"] and [method","type":"text"},{"code":"GObject.TypePlugin.complete_type_info","type":"codeVoice"},{"text":"]","type":"text"},{"type":"text","text":" "},{"type":"text","text":"on "},{"code":"new_type_plugin","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"At some point the type’s implementation isn’t required anymore, e.g. after"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"code":"GObject.TypeClass.unref","type":"codeVoice"},{"type":"text","text":"] or [func"},{"code":"GObject.type_free_instance","type":"codeVoice"},{"type":"text","text":"]"},{"type":"text","text":" "},{"text":"(called when the reference count of an instance drops to zero).","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"This causes the type system to throw away the information retrieved","type":"text"},{"text":" ","type":"text"},{"text":"from [method","type":"text"},{"type":"codeVoice","code":"GObject.TypePlugin.complete_type_info"},{"type":"text","text":"] and then it calls"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GObject.TypePlugin.unuse"},{"type":"text","text":"] on "},{"type":"codeVoice","code":"new_type_plugin"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Things may repeat from the second step."}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"So basically, you need to implement a "},{"type":"codeVoice","code":"GTypePlugin"},{"type":"text","text":" type that"},{"type":"text","text":" "},{"text":"carries a use_count, once use_count goes from zero to one, you need","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to load the implementation to successfully handle the upcoming"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GObject.TypePlugin.complete_type_info"},{"text":"] call. Later, maybe after","type":"text"},{"type":"text","text":" "},{"type":"text","text":"succeeding use\/unuse calls, once use_count drops to zero, you can"},{"type":"text","text":" "},{"text":"unload the implementation again. The type system makes sure to call","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GObject.TypePlugin.use"},{"text":"] and [method","type":"text"},{"type":"codeVoice","code":"GObject.TypePlugin.complete_type_info"},{"text":"]","type":"text"},{"type":"text","text":" "},{"type":"text","text":"again when the type is needed again."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"[class"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule","isActive":true,"type":"reference"},{"text":"] is an implementation of ","type":"text"},{"type":"codeVoice","code":"GTypePlugin"},{"type":"text","text":" that"},{"type":"text","text":" "},{"type":"text","text":"already implements most of this except for the actual module loading and"},{"type":"text","text":" "},{"text":"unloading. It even handles multiple registered types per module.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef","isActive":true},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GTypePlugin"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol","isActive":true},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef","isActive":true},{"type":"text","text":" only as an "},{"code":"unowned","type":"codeVoice"},{"type":"text","text":" reference to an existing "},{"type":"codeVoice","code":"GTypePlugin"},{"text":" instance.","type":"text"}]},{"style":"note","type":"aside","content":[{"inlineContent":[{"text":"Use ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin","isActive":true},{"type":"text","text":" (instead of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef"},{"text":") if you want to use Automatic Reference Counting for memory management of the underlying ","type":"text"},{"type":"codeVoice","code":"GTypePlugin"},{"text":" instance.","type":"text"}],"type":"paragraph"}],"name":"Note"}]}],"relationshipsSections":[{"kind":"relationships","type":"conformsTo","identifiers":["doc:\/\/GLibObject\/4GLib14PointerWrapperP","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol"],"title":"Conforms To"}],"references":{"doc://GLibObject/documentation/GLibObject/TypePluginProtocol":{"navigatorTitle":[{"text":"TypePluginProtocol","kind":"identifier"}],"type":"topic","kind":"symbol","title":"TypePluginProtocol","abstract":[{"text":"An interface that handles the lifecycle of dynamically loaded types.","type":"text"}],"url":"\/do