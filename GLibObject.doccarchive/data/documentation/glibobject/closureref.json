{"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject"]]},"abstract":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"GClosure"},{"text":" represents a callback supplied by the programmer.","type":"text"}],"schemaVersion":{"patch":0,"minor":3,"major":0},"relationshipsSections":[{"title":"Conforms To","type":"conformsTo","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureProtocol","doc:\/\/GLibObject\/4GLib14PointerWrapperP"],"kind":"relationships"}],"topicSections":[{"generated":true,"anchor":"Initializers","title":"Initializers","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/init(_:)-259dx","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/init(_:)-34tv","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/init(_:)-98ud2","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/init(_:)-9tw13","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/init(_:)-9z2mi","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/init(cPointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/init(constPointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/init(gconstpointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/init(gpointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/init(mutating:)","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/init(object:object:)","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/init(opaquePointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/init(simple:data:)"]},{"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/ptr"],"anchor":"Instance-Properties","title":"Instance Properties","generated":true},{"generated":true,"title":"Type Methods","anchor":"Type-Methods","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/new(object:object:)","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/new(simple:data:)"]},{"title":"Default Implementations","generated":true,"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/ClosureProtocol-Implementations","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/PointerWrapper-Implementations"],"anchor":"Default-Implementations"}],"metadata":{"role":"symbol","symbolKind":"struct","externalID":"s:10GLibObject10ClosureRefV","roleHeading":"Structure","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"ClosureRef","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"ClosureRef"}],"title":"ClosureRef","modules":[{"name":"GLibObject"}]},"sections":[],"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/closureref"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ClosureRef"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"anchor":"overview","type":"heading","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"text":"It will generally comprise a function of some kind and a marshaller","type":"text"},{"type":"text","text":" "},{"text":"used to call it. It is the responsibility of the marshaller to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"convert the arguments for the invocation from "},{"identifier":"#struct@Value","type":"reference","isActive":true},{"type":"text","text":" into"},{"type":"text","text":" "},{"text":"a suitable form, perform the callback on the converted arguments,","type":"text"},{"type":"text","text":" "},{"text":"and transform the return value back into a [struct","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Value","isActive":true,"type":"reference"},{"type":"text","text":"]."}]},{"inlineContent":[{"type":"text","text":"In the case of C programs, a closure usually just holds a pointer"},{"type":"text","text":" "},{"type":"text","text":"to a function and maybe a data argument, and the marshaller"},{"type":"text","text":" "},{"text":"converts between [struct","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Value","isActive":true,"type":"reference"},{"type":"text","text":"] and native C types. The GObject"},{"text":" ","type":"text"},{"text":"library provides the [struct","type":"text"},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/CClosure","isActive":true},{"type":"text","text":"] type for this purpose. Bindings for"},{"type":"text","text":" "},{"type":"text","text":"other languages need marshallers which convert between "},{"overridingTitle":"GValues","overridingTitleInlineContent":[{"type":"text","text":"GValues"}],"identifier":"#struct@Value","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"and suitable representations in the runtime of the language in"},{"text":" ","type":"text"},{"type":"text","text":"order to use functions written in that language as callbacks. Use"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"Closure.set_marshal"},{"text":"] to set the marshaller on such a custom","type":"text"},{"text":" ","type":"text"},{"text":"closure implementation.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Within GObject, closures play an important role in the"},{"type":"text","text":" "},{"text":"implementation of signals. When a signal is registered, the","type":"text"},{"type":"text","text":" "},{"code":"c_marshaller","type":"codeVoice"},{"type":"text","text":" argument to [func"},{"type":"codeVoice","code":"signal_new"},{"type":"text","text":"] specifies the default C"},{"type":"text","text":" "},{"text":"marshaller for any closure which is connected to this","type":"text"},{"text":" ","type":"text"},{"text":"signal. GObject provides a number of C marshallers for this","type":"text"},{"type":"text","text":" "},{"type":"text","text":"purpose, see the "},{"type":"codeVoice","code":"g_cclosure_marshal_*()"},{"text":" functions. Additional C","type":"text"},{"type":"text","text":" "},{"text":"marshallers can be generated with the ","type":"text"},{"identifier":"#glib-genmarshal","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"utility.  Closures can be explicitly connected to signals with"},{"text":" ","type":"text"},{"type":"text","text":"[func"},{"code":"signal_connect_closure","type":"codeVoice"},{"type":"text","text":"], but it usually more convenient to let"},{"text":" ","type":"text"},{"type":"text","text":"GObject create a closure automatically by using one of the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_signal_connect_*()"},{"text":" functions which take a callback function\/user","type":"text"},{"text":" ","type":"text"},{"text":"data pair.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Using closures has a number of important advantages over a simple","type":"text"},{"type":"text","text":" "},{"type":"text","text":"callback function\/data pointer combination:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Closures allow the callee to get the types of the callback parameters,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"which means that language bindings don’t have to write individual glue"},{"type":"text","text":" "},{"type":"text","text":"for each callback type."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"The reference counting of [struct"},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Closure","isActive":true},{"type":"text","text":"] makes it easy to handle reentrancy"},{"type":"text","text":" "},{"type":"text","text":"right; if a callback is removed while it is being invoked, the closure"},{"type":"text","text":" "},{"text":"and its parameters won’t be freed until the invocation finishes.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"[method"},{"type":"codeVoice","code":"Closure.invalidate"},{"text":"] and invalidation notifiers allow callbacks to be","type":"text"},{"text":" ","type":"text"},{"text":"automatically removed when the objects they point to go away.","type":"text"}]}]}]},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef","isActive":true,"type":"reference"},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GClosure"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureProtocol"},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"text":"Use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef"},{"text":" only as an ","type":"text"},{"code":"unowned","type":"codeVoice"},{"type":"text","text":" reference to an existing "},{"type":"codeVoice","code":"GClosure"},{"type":"text","text":" instance."}],"type":"paragraph"},{"name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Closure"},{"type":"text","text":" (instead of "},{"isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef","type":"reference"},{"type":"text","text":") if you want to use Automatic Reference Counting for memory management of the underlying "},{"type":"codeVoice","code":"GClosure"},{"text":" instance.","type":"text"}]}],"type":"aside","style":"note"}]}],"references":{"doc://GLibObject/documentation/GLibObject/ClosureRef/init(_:)-9z2mi":{"abstract":[{"type":"text","text":"Conditional initialiser from an optional, non-mutable pointer to the underlying "},{"type":"codeVoice","code":"C"},{"type":"text","text":" data type"}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/init(_:)-9z2mi","url":"\/documentation\/glibobject\/closureref\/init(_:)-9z2mi","role":"symbol","fragments":[{"text":"init","kind":"identifier"},{"text":"!(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"GClosure"},{"kind":"text","text":">?)"}],"title":"init(_:)","type":"topic","kind":"symbol"},"doc://GLibObject/documentation/GLibObject/ClosureRef/init(constPointer:)":{"fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"T"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"constPointer"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"T","kind":"typeIdentifier"},{"kind":"text","text":">)"}],"type":"topic","title":"init(constPointer:)","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/init(constPointer:)","abstract":[{"type":"text","text":"Unsafe typed initialiser."},{"text":" ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"Do not use unless you know the underlying data type the pointer points to conforms to "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureProtocol"},{"text":".","type":"text"}]}],"role":"symbol","kind":"symbol","url":"\/documentation\/glibobject\/closureref\/init(constpointer:)"},"#struct@Value":{"titleInlineConte