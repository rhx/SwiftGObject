{"metadata":{"externalID":"s:10GLibObject10ClosureRefV","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ClosureRef","kind":"identifier"}],"title":"ClosureRef","roleHeading":"Structure","symbolKind":"struct","modules":[{"name":"GLibObject"}],"navigatorTitle":[{"text":"ClosureRef","kind":"identifier"}],"role":"symbol"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject"]]},"abstract":[{"text":"A ","type":"text"},{"code":"GClosure","type":"codeVoice"},{"text":" represents a callback supplied by the programmer.","type":"text"}],"topicSections":[{"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/init(_:)-259dx","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/init(_:)-34tv","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/init(_:)-98ud2","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/init(_:)-9tw13","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/init(_:)-9z2mi","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/init(cPointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/init(constPointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/init(gconstpointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/init(gpointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/init(mutating:)","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/init(object:object:)","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/init(opaquePointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/init(simple:data:)"],"anchor":"Initializers","title":"Initializers","generated":true},{"generated":true,"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/ptr"],"anchor":"Instance-Properties","title":"Instance Properties"},{"title":"Type Methods","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/new(object:object:)","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/new(simple:data:)"],"generated":true,"anchor":"Type-Methods"},{"generated":true,"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/ClosureProtocol-Implementations","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/PointerWrapper-Implementations"],"anchor":"Default-Implementations","title":"Default Implementations"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"ClosureRef","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Overview","anchor":"overview","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"It will generally comprise a function of some kind and a marshaller"},{"type":"text","text":" "},{"type":"text","text":"used to call it. It is the responsibility of the marshaller to"},{"type":"text","text":" "},{"type":"text","text":"convert the arguments for the invocation from "},{"code":"GValues","type":"codeVoice"},{"text":" into","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"a suitable form, perform the callback on the converted arguments,"},{"text":" ","type":"text"},{"type":"text","text":"and transform the return value back into a "},{"isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Value","type":"reference"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In the case of C programs, a closure usually just holds a pointer"},{"type":"text","text":" "},{"text":"to a function and maybe a data argument, and the marshaller","type":"text"},{"type":"text","text":" "},{"type":"text","text":"converts between "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Value","type":"reference","isActive":true},{"text":" and native C types. The GObject","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"library provides the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/CClosure"},{"type":"text","text":" type for this purpose. Bindings for"},{"text":" ","type":"text"},{"text":"other languages need marshallers which convert between ","type":"text"},{"type":"codeVoice","code":"GValues"},{"text":" ","type":"text"},{"type":"text","text":"and suitable representations in the runtime of the language in"},{"text":" ","type":"text"},{"type":"text","text":"order to use functions written in that language as callbacks. Use"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_closure_set_marshal()"},{"type":"text","text":" to set the marshaller on such a custom"},{"text":" ","type":"text"},{"text":"closure implementation.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Within GObject, closures play an important role in the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"implementation of signals. When a signal is registered, the"},{"type":"text","text":" "},{"code":"c_marshaller","type":"codeVoice"},{"text":" argument to ","type":"text"},{"code":"g_signal_new()","type":"codeVoice"},{"type":"text","text":" specifies the default C"},{"text":" ","type":"text"},{"type":"text","text":"marshaller for any closure which is connected to this"},{"type":"text","text":" "},{"text":"signal. GObject provides a number of C marshallers for this","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"purpose, see the g_cclosure_marshal_"},{"type":"emphasis","inlineContent":[{"type":"text","text":"() functions. Additional C"},{"type":"text","text":" "},{"type":"text","text":"marshallers can be generated with the "},{"identifier":"#glib-genmarshal","type":"reference","isActive":true},{"text":" ","type":"text"},{"type":"text","text":"utility.  Closures can be explicitly connected to signals with"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_signal_connect_closure()"},{"type":"text","text":", but it usually more convenient to let"},{"text":" ","type":"text"},{"type":"text","text":"GObject create a closure automatically by using one of the"},{"text":" ","type":"text"},{"text":"g_signal_connect_","type":"text"}]},{"type":"text","text":"() functions which take a callback function\/user"},{"text":" ","type":"text"},{"type":"text","text":"data pair."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Using closures has a number of important advantages over a simple","type":"text"},{"text":" ","type":"text"},{"text":"callback function\/data pointer combination:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Closures allow the callee to get the types of the callback parameters,","type":"text"},{"type":"text","text":" "},{"text":"which means that language bindings don’t have to write individual glue","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for each callback type."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The reference counting of ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Closure"},{"type":"text","text":" makes it easy to handle reentrancy"},{"text":" ","type":"text"},{"type":"text","text":"right; if a callback is removed while it is being invoked, the closure"},{"text":" ","type":"text"},{"type":"text","text":"and its parameters won’t be freed until the invocation finishes."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"g_closure_invalidate()","type":"codeVoice"},{"text":" and invalidation notifiers allow callbacks to be","type":"text"},{"text":" ","type":"text"},{"text":"automatically removed when the objects they point to go away.","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef","isActive":true},{"t