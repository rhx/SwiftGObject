{"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","sections":[],"abstract":[{"type":"text","text":"Takes over the initial ownership of a closure."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"sink","kind":"identifier"},{"kind":"text","text":"()"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"text":"Each closure is initially created in a “floating” state, which means","type":"text"},{"type":"text","text":" "},{"type":"text","text":"that the initial reference count is not owned by any caller."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This function checks to see if the object is still floating, and if so,"},{"type":"text","text":" "},{"text":"unsets the floating state and decreases the reference count. If the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"closure is not floating, "},{"type":"codeVoice","code":"g_closure_sink()"},{"text":" does nothing.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The reason for the existence of the floating state is to prevent"},{"type":"text","text":" "},{"type":"text","text":"cumbersome code sequences like:"}],"type":"paragraph"},{"inlineContent":[{"text":"(C Language Example):","type":"text"}],"type":"paragraph"},{"code":["closure = g_cclosure_new (cb_func, cb_data);","g_source_set_closure (source, closure);","g_closure_unref (closure); \/\/ GObject doesn't really need this"],"syntax":"C","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Because "},{"type":"codeVoice","code":"g_source_set_closure()"},{"type":"text","text":" (and similar functions) take ownership of the"},{"type":"text","text":" "},{"type":"text","text":"initial reference count, if it is unowned, we instead can write:"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"syntax":"C","type":"codeListing","code":["g_source_set_closure (source, g_cclosure_new (cb_func, cb_data));"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Generally, this function is used together with "},{"type":"codeVoice","code":"g_closure_ref()"},{"text":". An example","type":"text"},{"type":"text","text":" "},{"text":"of storing a closure for later notification looks like:","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"code":["static GClosure *notify_closure = NULL;","void","foo_notify_set_closure (GClosure *closure)","{","  if (notify_closure)","    g_closure_unref (notify_closure);","  notify_closure = closure;","  if (notify_closure)","    {","      g_closure_ref (notify_closure);","      g_closure_sink (notify_closure);","    }","}"],"type":"codeListing","syntax":"C"},{"type":"paragraph","inlineContent":[{"text":"Because ","type":"text"},{"type":"codeVoice","code":"g_closure_sink()"},{"text":" may decrement the reference count of a closure","type":"text"},{"text":" ","type":"text"},{"text":"(if it hasn’t been called on ","type":"text"},{"type":"codeVoice","code":"closure"},{"type":"text","text":" yet) just like "},{"code":"g_closure_unref()","type":"codeVoice"},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_closure_ref()"},{"text":" should be called prior to this function.","type":"text"}]}]}],"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/sink()","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/ClosureProtocol-Implementations"]]},"variants":[{"paths":["\/documentation\/glibobject\/closureref\/sink()"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"sink"},{"text":"()","kind":"text"}],"title":"sink()","extendedModule":"GLibObject","role":"symbol","modules":[{"name":"GLibObject"}],"roleHeading":"Instance Method","externalID":"s:10GLibObject15ClosureProtocolPAAE4sinkyyF::SYNTHESIZED::s:10GLibObject10ClosureRefV","symbolKind":"method"},"references":{"doc://GLibObject/documentation/GLibObject/ClosureRef/sink()":{"url":"\/documentation\/glibobject\/closureref\/sink()","abstract":[{"type":"text","text":"Takes over the initial ownership of a closure."}],"title":"sink()","type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/sink()","role":"symbol","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"sink","kind":"identifier"},{"kind":"text","text":"()"}]},"doc://GLibObject/documentation/GLibObject/ClosureRef/ClosureProtocol-Implementations":{"kind":"article","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/ClosureProtocol-Implementations","url":"\/documentation\/glibobject\/closureref\/closureprotocol-implementations","type":"topic","abstract":[],"title":"ClosureProtocol Implementations","role":"collectionGroup"},"doc://GLibObject/documentation/GLibObject/ClosureRef":{"kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef","url":"\/documentation\/glibobject\/closureref","type":"topic","navigatorTitle":[{"kind":"identifier","text":"ClosureRef"}],"fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"ClosureRef"}],"abstract":[{"type":"text","text":"A "},{"type":"codeVoice","code":"GClosure"},{"type":"text","text":" represents a callback supplied by the programmer."}],"title":"ClosureRef","role":"symbol"},"doc://GLibObject/documentation/GLibObject":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject","url":"\/documentation\/glibobject","abstract":[],"role":"collection","kind":"symbol","title":"GLibObject","type":"topic"}}}