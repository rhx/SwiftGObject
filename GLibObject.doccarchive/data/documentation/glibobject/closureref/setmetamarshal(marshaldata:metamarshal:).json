{"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"setMetaMarshal"},{"kind":"text","text":"("},{"kind":"externalParam","text":"marshalData"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"kind":"text","text":"? = nil, "},{"kind":"externalParam","text":"metaMarshal"},{"kind":"text","text":": "},{"preciseIdentifier":"c:gclosure.h@T@GClosureMarshal","text":"GClosureMarshal","kind":"typeIdentifier"},{"text":")","kind":"text"}]}],"kind":"declarations"},{"content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A meta marshaller wraps the "},{"type":"codeVoice","code":"closure"},{"text":"’s marshal and modifies the way","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"it is called in some fashion. The most common use of this facility"},{"type":"text","text":" "},{"text":"is for C callbacks.","type":"text"}]},{"inlineContent":[{"text":"The same marshallers (generated by ","type":"text"},{"isActive":true,"type":"reference","identifier":"#glib-genmarshal"},{"type":"text","text":"),"},{"text":" ","type":"text"},{"text":"are used everywhere, but the way that we get the callback function","type":"text"},{"type":"text","text":" "},{"type":"text","text":"differs. In most cases we want to use the "},{"code":"closure","type":"codeVoice"},{"text":"’s callback, but in","type":"text"},{"text":" ","type":"text"},{"text":"other cases we want to use some different technique to retrieve the","type":"text"},{"type":"text","text":" "},{"text":"callback function.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"For example, class closures for signals (see","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_signal_type_cclosure_new()"},{"type":"text","text":") retrieve the callback function from a"},{"type":"text","text":" "},{"text":"fixed offset in the class structure.  The meta marshaller retrieves","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the right callback and passes it to the marshaller as the"},{"type":"text","text":" "},{"type":"codeVoice","code":"marshalData"},{"type":"text","text":" argument."}],"type":"paragraph"}],"kind":"content"}],"metadata":{"extendedModule":"GLibObject","role":"symbol","modules":[{"name":"GLibObject"}],"roleHeading":"Instance Method","externalID":"s:10GLibObject15ClosureProtocolPAAE14setMetaMarshal11marshalData04metaG0ySvSg_ySpySo9_GClosureVGSg_SpySo7_GValueVGSgs6UInt32VSPyAMGSgA2GtXCtF::SYNTHESIZED::s:10GLibObject10ClosureRefV","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"setMetaMarshal"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"marshalData"},{"kind":"text","text":": "},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"text":"?, ","kind":"text"},{"text":"metaMarshal","kind":"externalParam"},{"kind":"text","text":": "},{"text":"GClosureMarshal","preciseIdentifier":"c:gclosure.h@T@GClosureMarshal","kind":"typeIdentifier"},{"text":")","kind":"text"}],"title":"setMetaMarshal(marshalData:metaMarshal:)","symbolKind":"method"},"abstract":[{"text":"Sets the meta marshaller of ","type":"text"},{"type":"codeVoice","code":"closure"},{"text":".","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/ClosureProtocol-Implementations"]]},"variants":[{"paths":["\/documentation\/glibobject\/closureref\/setmetamarshal(marshaldata:metamarshal:)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"do