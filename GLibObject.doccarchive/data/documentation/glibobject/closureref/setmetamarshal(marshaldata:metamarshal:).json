{"metadata":{"extendedModule":"GLibObject","roleHeading":"Instance Method","externalID":"s:10GLibObject15ClosureProtocolPAAE14setMetaMarshal11marshalData04metaG0ySvSg_ySpySo9_GClosureVGSg_SpySo7_GValueVGSgs6UInt32VSPyAMGSgA2GtXCtF::SYNTHESIZED::s:10GLibObject10ClosureRefV","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"setMetaMarshal","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"marshalData"},{"kind":"text","text":": "},{"text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"metaMarshal"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:gclosure.h@T@GClosureMarshal","text":"GClosureMarshal"},{"kind":"text","text":")"}],"modules":[{"name":"GLibObject"}],"role":"symbol","title":"setMetaMarshal(marshalData:metaMarshal:)"},"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"Sets the meta marshaller of "},{"type":"codeVoice","code":"closure"},{"text":".","type":"text"}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"setMetaMarshal"},{"text":"(","kind":"text"},{"text":"marshalData","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier"},{"text":"? = nil, ","kind":"text"},{"kind":"externalParam","text":"metaMarshal"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"GClosureMarshal","preciseIdentifier":"c:gclosure.h@T@GClosureMarshal"},{"text":")","kind":"text"}]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A meta marshaller wraps the "},{"type":"codeVoice","code":"closure"},{"type":"text","text":"’s marshal and modifies the way"},{"text":" ","type":"text"},{"text":"it is called in some fashion. The most common use of this facility","type":"text"},{"text":" ","type":"text"},{"text":"is for C callbacks.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The same marshallers (generated by "},{"type":"reference","identifier":"#glib-genmarshal","isActive":true},{"type":"text","text":"),"},{"type":"text","text":" "},{"type":"text","text":"are used everywhere, but the way that we get the callback function"},{"text":" ","type":"text"},{"type":"text","text":"differs. In most cases we want to use the "},{"type":"codeVoice","code":"closure"},{"type":"text","text":"’s callback, but in"},{"type":"text","text":" "},{"type":"text","text":"other cases we want to use some different technique to retrieve the"},{"text":" ","type":"text"},{"text":"callback function.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"For example, class closures for signals (see","type":"text"},{"text":" ","type":"text"},{"code":"g_signal_type_cclosure_new()","type":"codeVoice"},{"type":"text","text":") retrieve the callback function from a"},{"text":" ","type":"text"},{"type":"text","text":"fixed offset in the class structure.  The meta marshaller retrieves"},{"type":"text","text":" "},{"type":"text","text":"the right callback and passes it to the marshaller as the"},{"type":"text","text":" "},{"type":"codeVoice","code":"marshalData"},{"text":" argument.","type":"text"}]}]}],"kind":"symbol","variants":[{"paths":["\/documentation\/glibobject\/closureref\/setmetamarshal(marshaldata:metamarshal:)"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/ClosureProtocol-Implementations"]]},"identifier":{"url":"doc:\/\/GLibObject\/documentat